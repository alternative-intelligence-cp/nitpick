    h4 = h4 + e;  h5 = h5 + f;  h6 = h6 + g;  h7 = h7 + hh;

    // Verify: SHA-256("abc") = ba7816bf8f01cfea414140de5dae2ec73b338c2ba3e1ca9e7aa1f9a8b99d1e74
    uint32:pass1 = 1u32;
    if (h0 != 0xba7816bfu32) { pass1 = 0u32; }
