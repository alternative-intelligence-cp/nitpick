    ];

    idx = 16u32;
    while (idx < 64u32) {
        ww2  = W1[(idx - 2u32)  => int64];
        ww7  = W1[(idx - 7u32)  => int64];
        ww15 = W1[(idx - 15u32) => int64];
        ww16 = W1[(idx - 16u32) => int64];
        rot17 = ((ww2 >> 17u32) & M17) | (ww2 << 15u32);
        rot19 = ((ww2 >> 19u32) & M19) | (ww2 << 13u32);
        s1 = rot17 ^ rot19 ^ ((ww2 >> 10u32) & M10);
