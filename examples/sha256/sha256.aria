    if (h3 != 0x5dae2ec7u32) { pass1 = 0u32; }
    if (h4 != 0x3b338c2bu32) { pass1 = 0u32; }
    if (h5 != 0xa3e1ca9eu32) { pass1 = 0u32; }
    if (h6 != 0x7aa1f9a8u32) { pass1 = 0u32; }
