// Aria shared library example
// Compile: ariac mathlib.aria --shared -o libmathlib.so

func:add = int32(int32:a, int32:b) {
    pass(a + b);
};

func:subtract = int32(int32:a, int32:b) {
    pass(a - b);
};

func:multiply = int32(int32:x, int32:y) {
    pass(x * y);
};

func:square = int32(int32:n) {
    pass(n * n);
};

func:is_even = bool(int32:n) {
    pass(n % 2 == 0);
};
