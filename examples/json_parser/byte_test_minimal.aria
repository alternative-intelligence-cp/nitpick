use "../../stdlib/string_convert.aria".*;
use "../../stdlib/print_utils.aria".*;
extern func:aria_string_byte_at = int64(string:s, int64:i);
func:failsafe = NIL(int32:code) { pass(NIL); };
func:main = int32() {
    drop(printlnString("start"));
    string:s = "hello";
    drop(printlnString("got string"));
    int64:b = aria_string_byte_at(s, 0i64);
    drop(printlnString("got byte"));
    drop(printlnInt64(b));
    pass(0i32);
};
