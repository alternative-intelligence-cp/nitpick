/// A 2D point structure
struct Point {
    /// X coordinate
    x: flt64,
    /// Y coordinate
    y: flt64,
}

/// Calculate the distance between two points
/// @param p1 First point
/// @param p2 Second point
/// @return The Euclidean distance between the points
/// @example
/// ```aria
/// let p1 = Point { x: 0.0, y: 0.0 };
/// let p2 = Point { x: 3.0, y: 4.0 };
/// let dist = distance(p1, p2);  // returns 5.0
/// ```
fn distance(p1: Point, p2: Point) -> flt64 {
    let dx = p2.x - p1.x;
    let dy = p2.y - p1.y;
    sqrt(dx * dx + dy * dy)
}

/// Mathematical constants
const PI: flt64 = 3.141592653589793;
const E: flt64 = 2.718281828459045;
