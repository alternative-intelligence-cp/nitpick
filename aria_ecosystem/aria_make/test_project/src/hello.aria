// hello.aria - Simple standalone binary
// Tests: basic ariac binary compilation through aria_make

func:failsafe = NIL(int32:code) { pass(NIL); };

func:main = int32() {
    // Compute something so the binary isn't trivially empty
    int64:x = 6i64;
    int64:y = 7i64;
    int64:z = x * y;  // 42
    if (z == 42i64) { pass(0i32); }
    pass(1i32);
};
