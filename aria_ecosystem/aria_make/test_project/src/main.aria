// main.aria - Binary that links against the utils Aria library
// Tests: library dep resolution, extern linkage, ariac -L/-l flags
//
// utils functions are declared as extern — aria_make passes
// -L.aria_make/build -lutils automatically based on deps = ["utils"].

extern func:add      = int64(int64:a, int64:b);
extern func:subtract = int64(int64:a, int64:b);
extern func:multiply = int64(int64:a, int64:b);

func:failsafe = NIL(int32:code) { pass(NIL); };

func:main = int32() {
    // add(10, 20) = 30
    int64:sum  = add(10i64, 20i64);
    // subtract(100, 70) = 30
    int64:diff = subtract(100i64, 70i64);
    // multiply(3, 10) = 30
    int64:prod = multiply(3i64, 10i64);

    // All three results must be equal; exit 0 on success
    if (sum == diff) {
        if (diff == prod) {
            pass(0i32);
        }
    }
    pass(1i32);
};
