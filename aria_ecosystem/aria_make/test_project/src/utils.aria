// utils.aria - Utility functions library

func:failsafe = void(int32:err_code) {
    // Error handling
};

pub func:add = int64(int64:a, int64:b) {
    return a + b;
};

pub func:subtract = int64(int64:a, int64:b) {
    return a - b;
};

pub func:multiply = int64(int64:a, int64:b) {
    return a * b;
};
