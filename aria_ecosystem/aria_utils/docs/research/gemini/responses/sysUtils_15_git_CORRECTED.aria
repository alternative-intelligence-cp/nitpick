// File: tools/vcs/git_types.aria
// ============================================================================
// libgit2 FFI Type Definitions
// ============================================================================

// Opaque handles (pointer-only, no direct field access)
extern "libgit2" struct git_repository;
extern "libgit2" struct git_revwalk;
extern "libgit2" struct git_commit;

// Concrete struct for OID (20-byte SHA-1)
extern "libgit2" struct:git_oid = {
    array<u8>  // 20 bytes:id;
};

// Time structure
extern "libgit2" struct:git_time = {
    int64:time;
    int32   // Timezone offset in minutes:offset;
};

// Signature (author/committer)
extern "libgit2" struct:git_signature = {
    wild byte:name;
    wild byte:email;
    git_time      // Embedded time struct:when;
};

// Error structure
extern "libgit2" struct:git_error = {
    wild byte:message;
    int32:klass;
};

// ============================================================================
// Module: tools/vcs/git_ffi.aria
// ============================================================================
// libgit2 FFI Function Declarations
// ============================================================================

// Library initialization
extern "libgit2" func:git_libgit2_init = int32(void);
extern "libgit2" func:git_libgit2_shutdown = int32(void);

// Error handling
extern "libgit2" func:git_error_last = wild git_error(void);

// Repository management
extern "libgit2" func:git_repository_open = int32(
    wild git_repository:out,
    wild byte:path
);
extern "libgit2" func:git_repository_free = void(wild git_repository:repo);

// Revision walker
extern "libgit2" func:git_revwalk_new = int32(
    wild git_revwalk:out,
    wild git_repository:repo
);
extern "libgit2" func:git_revwalk_push_head = int32(wild git_revwalk:walk);
extern "libgit2" func:git_revwalk_sorting = void(wild git_revwalk:walk, u32:sort_mode);
extern "libgit2" func:git_revwalk_next = int32(
    wild git_oid:out,
    wild git_revwalk:walk
);
extern "libgit2" func:git_revwalk_free = void(wild git_revwalk:walk);

// Commit object access
extern "libgit2" func:git_commit_lookup = int32(
    wild git_commit:commit,
    wild git_repository:repo,
    wild git_oid:id
);
extern "libgit2" func:git_commit_message = wild byte(wild git_commit:commit);
extern "libgit2" func:git_commit_author = wild git_signature(wild git_commit:commit);
extern "libgit2" func:git_commit_committer = wild git_signature(wild git_commit:commit);
extern "libgit2" func:git_commit_time = int64(wild git_commit:commit);
extern "libgit2" func:git_commit_parentcount = u32(wild git_commit:commit);
extern "libgit2" func:git_commit_parent_id = wild git_oid(wild git_commit:commit, u32:n);
extern "libgit2" func:git_commit_free = void(wild git_commit:commit);

// OID utilities
extern "libgit2" func:git_oid_tostr = wild byte(wild byte:out, u64:size, wild git_oid:oid);

// ============================================================================
// Module: tools/vcs/git_wrapper.aria
// ============================================================================
// Safe Wrappers for libgit2 FFI
// ============================================================================

// use std.io;
// use std.string;

// Convert libgit2 error code to Result
func:check_git_error = result<void>(int32:code) {
    if (code < 0) {
        wild git_error:err = git_error_last();
        
        if (err != wild_null) {
            // Convert C string to Aria string
            string:msg = std.string.from_c_str(err.message) ? "Unknown error";
            
            result<void>:err_result;
            err_result.is_error = true;
            err_result.error = msg;
            pass(err_result);
        };
        
        result<void>:err_result;
        err_result.is_error = true;
        err_result.error = "Unknown libgit2 error";
        pass(err_result);
    };
    
    result<void>:success;
    success.is_error = false;
    pass(success);
};

// Convert git_oid to hex string
func:oid_to_string = string(wild git_oid:oid) {
    // OID is 20 bytes, hex representation is 40 chars + null
    array<byte>:buffer = array<byte>.new_with_size(41);
    
    wild byte:buf_ptr = buffer.as_wild_ptr();
    git_oid_tostr(buf_ptr, 41, oid);
    
    string:hex_str = std.string.from_c_str(buf_ptr) ? "0000000000000000000000000000000000000000";
    pass(hex_str);
};

// ============================================================================
// Module: tools/vcs/commit_data.aria
// ============================================================================
// Aria-Native Commit Representation
// ============================================================================

struct:CommitData = {
    string:oid;
    array<string>:parent_oids;
    string:author_name;
    string:author_email;
    tbb64:timestamp;
    string:message;
    tbb16    // TBB-safe parent count:parent_count;
};

// Extract commit data from libgit2 handle
func:extract_commit_data = result<CommitData>(
    wild git_commit:commit,
    wild git_oid:oid
) {
    CommitData:data;
    
    // Extract OID
    data.oid = oid_to_string(oid);
    
    // Extract message
    wild byte:msg_ptr = git_commit_message(commit);
    if (msg_ptr == wild_null) {
        result<CommitData>:err_result;
        err_result.is_error = true;
        err_result.error = "Failed to get commit message";
        pass(err_result);
    };
    data.message = std.string.from_c_str(msg_ptr) ? "";
    
    // Extract author
    wild git_signature:author = git_commit_author(commit);
    if (author == wild_null) {
        result<CommitData>:err_result;
        err_result.is_error = true;
        err_result.error = "Failed to get author";
        pass(err_result);
    };
    
    data.author_name = std.string.from_c_str(author.name) ? "";
    data.author_email = std.string.from_c_str(author.email) ? "";
    
    // Extract timestamp (TBB-safe)
    int64:timestamp = git_commit_time(commit);
    data.timestamp = tbb64.from_int(timestamp) ? ERR;
    
    // Extract parent count
    u32:parent_count = git_commit_parentcount(commit);
    data.parent_count = tbb16.from_int(parent_count) ? ERR;
    
    // Check for TBB errors
    if (tbb64.is_err(data.timestamp) || tbb16.is_err(data.parent_count)) {
        result<CommitData>:err_result;
        err_result.is_error = true;
        err_result.error = "Commit data exceeds protocol limits";
        pass(err_result);
    };
    
    // Extract parent OIDs
    data.parent_oids = array<string>.new();
    
    u32:i = 0;
    while (i < parent_count) {
        wild git_oid:parent_oid = git_commit_parent_id(commit, i);
        
        if (parent_oid != wild_null) {
            string:parent_hex = oid_to_string(parent_oid);
            data.parent_oids.push(parent_hex);
        };
        
        i = i + 1;
    };
    
    result<CommitData>:success;
    success.is_error = false;
    success.value = data;
    pass(success);
};

// ============================================================================
// Module: tools/vcs/serializer.aria
// ============================================================================
// AGIT-GRAPH-V1 Binary Protocol Serializer
// ============================================================================

// Protocol constants
const AGIT_MAGIC:u32 = 0x41474954;  // "AGIT"
const PACKET_TYPE_COMMIT:u8 = 0x01;
const PACKET_TYPE_EDGE:u8 = 0x02;
const PACKET_TYPE_REF:u8 = 0x03;

// Serialize commit to stddato (TLV format)
func:serialize_commit = result<void>(CommitData:commit) {
    // Calculate lengths (TBB-safe)
    tbb16:author_len = tbb16.from_int((commit.author_name.length() ? 0)) ? ERR;
    tbb16:msg_len = tbb16.from_int((commit.message.length() ? 0)) ? ERR;
    
    // Check for TBB errors
    if (tbb16.is_err(author_len) || tbb16.is_err(msg_len)) {
        result<void>:err_result;
        err_result.is_error = true;
        err_result.error = "String length overflow";
        pass(err_result);
    };
    
    // Calculate total payload size
    int32:oid_size = 40;  // Hex string of SHA-1
    int32:parent_size = (commit.parent_oids.length() ? 0) * 40;
    int32:author_size = tbb16.to_int(author_len) ? 0;
    int32:msg_size = tbb16.to_int(msg_len) ? 0;
    
    int32:payload_size = 8 +  // timestamp (tbb64)
                         2 +  // parent_count (tbb16)
                         2 +  // author_len (tbb16)
                         2 +  // msg_len (tbb16)
                         oid_size +
                         parent_size +
                         author_size +
                         msg_size;
    
    tbb64:payload_len = tbb64.from_int(payload_size) ? ERR;
    
    if (tbb64.is_err(payload_len)) {
        result<void>:err_result;
        err_result.is_error = true;
        err_result.error = "Payload size overflow";
        pass(err_result);
    };
    
    // Write header
    std.io.stddato.write_u32(AGIT_MAGIC);
    std.io.stddato.write_u8(PACKET_TYPE_COMMIT);
    std.io.stddato.write_u8(0);  // Reserved
    std.io.stddato.write_u16(0); // Padding for alignment
    std.io.stddato.write_tbb64(payload_len);
    
    // Write payload
    std.io.stddato.write_tbb64(commit.timestamp);
    std.io.stddato.write_tbb16(commit.parent_count);
    std.io.stddato.write_tbb16(author_len);
    std.io.stddato.write_tbb16(msg_len);
    
    // Write OID (40 hex chars)
    std.io.stddato.write_string(commit.oid);
    
    // Write parent OIDs
    int32:i = 0;
    while (i < commit.parent_oids.length()) {
        std.io.stddato.write_string(commit.parent_oids.at(i));
        i = i + 1;
    };
    
    // Write author
    std.io.stddato.write_string(commit.author_name);
    
    // Write message
    std.io.stddato.write_string(commit.message);
    
    result<void>:success;
    success.is_error = false;
    pass(success);
};

// Deserialize commit from stddati
func:deserialize_commit = result<CommitData>(void) {
    // Read header
    result<u32>:magic_result = std.io.stddati.read_u32();
    
    if (magic_result.is_error) {
        result<CommitData>:err_result;
        err_result.is_error = true;
        err_result.error = "Failed to read magic";
        pass(err_result);
    };
    
    u32:magic = magic_result.value;
    
    if (magic != AGIT_MAGIC) {
        result<CommitData>:err_result;
        err_result.is_error = true;
        err_result.error = "Invalid AGIT magic";
        pass(err_result);
    };
    
    // Read packet type
    result<u8>:type_result = std.io.stddati.read_u8();
    
    if (type_result.is_error) {
        result<CommitData>:err_result;
        err_result.is_error = true;
        err_result.error = "Failed to read packet type";
        pass(err_result);
    };
    
    // Skip reserved and padding
    std.io.stddati.skip(3);
    
    // Read payload length
    result<tbb64>:payload_len_result = std.io.stddati.read_tbb64();
    
    if (payload_len_result.is_error) {
        result<CommitData>:err_result;
        err_result.is_error = true;
        err_result.error = "Failed to read payload length";
        pass(err_result);
    };
    
    tbb64:payload_len = payload_len_result.value;
    
    if (tbb64.is_err(payload_len)) {
        result<CommitData>:err_result;
        err_result.is_error = true;
        err_result.error = "TBB error in payload length";
        pass(err_result);
    };
    
    // Read commit data
    CommitData:commit;
    
    // Read timestamp
    result<tbb64>:ts_result = std.io.stddati.read_tbb64();
    if (!ts_result.is_error) {
        commit.timestamp = ts_result.value;
    };
    
    // Read counts
    result<tbb16>:parent_count_result = std.io.stddati.read_tbb16();
    if (!parent_count_result.is_error) {
        commit.parent_count = parent_count_result.value;
    };
    
    result<tbb16>:author_len_result = std.io.stddati.read_tbb16();
    result<tbb16>:msg_len_result = std.io.stddati.read_tbb16();
    
    // Read OID
    result<string>:oid_result = std.io.stddati.read_string(40);
    if (!oid_result.is_error) {
        commit.oid = oid_result.value;
    };
    
    // Read parent OIDs
    commit.parent_oids = array<string>.new();
    int32:parent_count = tbb16.to_int(commit.parent_count) ? 0;
    
    int32:i = 0;
    while (i < parent_count) {
        result<string>:parent_result = std.io.stddati.read_string(40);
        if (!parent_result.is_error) {
            commit.parent_oids.push(parent_result.value);
        };
        i = i + 1;
    };
    
    // Read author
    if (!author_len_result.is_error) {
        int32:author_len = tbb16.to_int(author_len_result.value);
        result<string>:author_result = std.io.stddati.read_string(author_len);
        if (!author_result.is_error) {
            commit.author_name = author_result.value;
        };
    };
    
    // Read message
    if (!msg_len_result.is_error) {
        int32:msg_len = tbb16.to_int(msg_len_result.value);
        result<string>:msg_result = std.io.stddati.read_string(msg_len);
        if (!msg_result.is_error) {
            commit.message = msg_result.value;
        };
    };
    
    result<CommitData>:success;
    success.is_error = false;
    success.value = commit;
    pass(success);
};

// ============================================================================
// Module: tools/vcs/telemetry.aria
// ============================================================================
// stddbg Telemetry Logging
// ============================================================================

// Log commit visit event
func:log_commit_visit = void(string:oid, int64:latency_ns) {
    std.io.stddbg.write("{\"timestamp\":");
    std.io.stddbg.write(std.string.from_int(std.time.unix_timestamp()));
    std.io.stddbg.write(",\"level\":\"DEBUG\",\"component\":\"revwalk\"");
    std.io.stddbg.write(",\"event\":\"commit_visit\",\"data\":{");
    std.io.stddbg.write("\"oid\":\"");
    std.io.stddbg.write(oid);
    std.io.stddbg.write("\",\"lookup_latency_ns\":");
    std.io.stddbg.write(std.string.from_int(latency_ns));
    std.io.stddbg.write("}}\n");
    
    std.io.stddbg.flush();
};

// Log performance metrics
func:log_metric = void(string:metric_name, int64:value) {
    std.io.stddbg.write("{\"level\":\"INFO\",\"component\":\"metrics\"");
    std.io.stddbg.write(",\"metric\":\"");
    std.io.stddbg.write(metric_name);
    std.io.stddbg.write("\",\"value\":");
    std.io.stddbg.write(std.string.from_int(value));
    std.io.stddbg.write("}\n");
};

// ============================================================================
// Module: tools/vcs/ui_renderer.aria
// ============================================================================
// UI Rendering (stdout with ANSI)
// ============================================================================

// ANSI color codes
const ANSI_RESET:string = "\x1b[0m";
const ANSI_YELLOW:string = "\x1b[33m";
const ANSI_CYAN:string = "\x1b[36m";
const ANSI_GREEN:string = "\x1b[32m";
const ANSI_GRAY:string = "\x1b[90m";

// Render commit to stdout
func:render_commit = void(CommitData:commit) {
    // OID (yellow)
    std.io.stdout.write(ANSI_YELLOW);
    std.io.stdout.write("commit ");
    std.io.stdout.write(commit.oid);
    std.io.stdout.write(ANSI_RESET);
    std.io.stdout.write("\n");
    
    // Author (cyan)
    std.io.stdout.write(ANSI_CYAN);
    std.io.stdout.write("Author: ");
    std.io.stdout.write(commit.author_name);
    std.io.stdout.write(" <");
    std.io.stdout.write(commit.author_email);
    std.io.stdout.write(">");
    std.io.stdout.write(ANSI_RESET);
    std.io.stdout.write("\n");
    
    // Date (green)
    std.io.stdout.write(ANSI_GREEN);
    std.io.stdout.write("Date: ");
    int64:timestamp = tbb64.to_int(commit.timestamp) ? 0;
    std.io.stdout.write(std.time.format_timestamp(timestamp) ? "Unknown date");
    std.io.stdout.write(ANSI_RESET);
    std.io.stdout.write("\n\n");
    
    // Message (indented)
    std.io.stdout.write("    ");
    std.io.stdout.write(commit.message);
    std.io.stdout.write("\n\n");
};

// ============================================================================
// Module: tools/vcs/commands.aria
// ============================================================================
// Command Implementations
// ============================================================================

// agit log command
func:git_log = int32(void) {
    // Initialize libgit2
    int32:init_result = git_libgit2_init();
    
    defer {
        git_libgit2_shutdown();
    };
    
    // Open repository
    wild git_repository:repo = wild_null;
    
    // Convert "." to C string
    wild byte:path = std.string.to_c_str(".");
    
    int32:open_result = git_repository_open(repo, path);
    
    result<void>:check_result = check_git_error(open_result);
    
    if (check_result.is_error) {
        std.io.stderr.write("Error: Failed to open repository: ");
        std.io.stderr.write(check_result.error);
        std.io.stderr.write("\n");
        pass(1);
    };
    
    defer {
        git_repository_free(repo);
    };
    
    // Create revision walker
    wild git_revwalk:walker = wild_null;
    
    int32:walker_result = git_revwalk_new(walker, repo);
    
    check_result = check_git_error(walker_result);
    
    if (check_result.is_error) {
        std.io.stderr.write("Error: Failed to create walker\n");
        pass(1);
    };
    
    defer {
        git_revwalk_free(walker);
    };
    
    // Configure walker
    git_revwalk_sorting(walker, 1);  // GIT_SORT_TOPOLOGICAL
    
    int32:push_result = git_revwalk_push_head(walker);
    
    check_result = check_git_error(push_result);
    
    if (check_result.is_error) {
        std.io.stderr.write("Error: Failed to push HEAD\n");
        pass(1);
    };
    
    // Process commits
    int64:commit_count = 0;
    
    while (true) {
        // Allocate OID on stack
        git_oid:oid;
        
        int64:start_time = std.time.nanos_since_epoch() ? 0;
        
        int32:next_result = git_revwalk_next(oid, walker);
        
        if (next_result != 0) {
            break;  // GIT_ITEROVER or error
        };
        
        // Lookup commit
        wild git_commit:commit = wild_null;
        
        int32:lookup_result = git_commit_lookup(commit, repo, oid);
        
        if (lookup_result < 0) {
            continue;  // Skip invalid commits
        };
        
        defer {
            git_commit_free(commit);
        };
        
        int64:end_time = std.time.nanos_since_epoch() ? 0;
        int64:latency = end_time - start_time;
        
        // Extract commit data
        result<CommitData>:data_result = extract_commit_data(commit, oid);
        
        if (data_result.is_error) {
            continue;
        };
        
        CommitData:commit_data = data_result.value;
        
        // Log telemetry (FD 3)
        log_commit_visit(commit_data.oid, latency);
        
        // Serialize to stddato (FD 5)
        result<void>:serialize_result = serialize_commit(commit_data);
        
        if (serialize_result.is_error) {
            std.io.stderr.write("Warning: Serialization failed\n");
        };
        
        // Render to stdout (FD 1)
        render_commit(commit_data);
        
        commit_count = commit_count + 1;
    };
    
    // Log final metrics
    log_metric("total_commits", commit_count);
    
    pass(0);
};

// ============================================================================
// Main Entry Point
// ============================================================================

func:main = int32(array<string>:args) {
    if (args.length() < 2) {
        std.io.stderr.write("Usage: agit <command>\n");
        std.io.stderr.write("Commands: log\n");
        pass(1);
    };
    
    string:command = args.at(1) ? "";
    
    if (command == "log") {
        pass(git_log());
    } else {
        std.io.stderr.write("Unknown command: ");
        std.io.stderr.write(command);
        std.io.stderr.write("\n");
        pass(1);
    };
};

// ============================================================================
// END OF CORRECTED AGIT IMPLEMENTATION
