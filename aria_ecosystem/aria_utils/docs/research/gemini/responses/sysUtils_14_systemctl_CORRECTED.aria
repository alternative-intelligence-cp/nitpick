// File: tools/service/service_unit.aria
// ============================================================================
// Service Unit Data Structures
// ============================================================================

// use std.io;
// use std.string;

// Service state enums (mapped from systemd strings)
enum:UnitActiveState = {
    ACTIVE = 0,
    INACTIVE = 1,
    ACTIVATING = 2,
    DEACTIVATING = 3,
    FAILED = 4,
    MAINTENANCE = 5,
    RELOADING = 6,
    UNKNOWN = 255
};

enum:UnitLoadState = {
    LOADED = 0,
    NOT_FOUND = 1,
    ERROR = 2,
    MASKED = 3,
    BAD_SETTING = 4,
    UNKNOWN = 255
};

enum:UnitSubState = {
    RUNNING = 0,
    EXITED = 1,
    DEAD = 2,
    LISTENING = 3,
    WAITING = 4,
    START_PRE = 5,
    START = 6,
    STOP = 7,
    UNKNOWN = 255
};

// ServiceUnit struct - canonical service representation
struct:ServiceUnit = {
    string:name;
    string:description;
    UnitLoadState:load_state;
    UnitActiveState:active_state;
    UnitSubState:sub_state;
    tbb64:main_pid;
    tbb64:active_enter_timestamp;
    tbb64:inactive_enter_timestamp;
    string:fragment_path;
};

// ============================================================================
// Module: tools/service/state_mapper.aria
// ============================================================================
// String-to-Enum Mapping (D-Bus state validation)
// ============================================================================

// Map systemd active state string to enum
func:map_active_state = UnitActiveState(string:state_str) {
    if (state_str == "active") {
        pass(UnitActiveState.ACTIVE);
    } else if (state_str == "inactive") {
        pass(UnitActiveState.INACTIVE);
    } else if (state_str == "activating") {
        pass(UnitActiveState.ACTIVATING);
    } else if (state_str == "deactivating") {
        pass(UnitActiveState.DEACTIVATING);
    } else if (state_str == "failed") {
        pass(UnitActiveState.FAILED);
    } else if (state_str == "maintenance") {
        pass(UnitActiveState.MAINTENANCE);
    } else if (state_str == "reloading") {
        pass(UnitActiveState.RELOADING);
    } else {
        // Unknown state - log warning to stddbg
        std.io.stddbg.write("{\"level\":\"WARN\",\"component\":\"state_mapper\",");
        std.io.stddbg.write("\"event\":\"unknown_active_state\",\"raw_state\":\"");
        std.io.stddbg.write(state_str);
        std.io.stddbg.write("\"}\n");
        
        pass(UnitActiveState.UNKNOWN);
    }
};

// Map systemd load state string to enum
func:map_load_state = UnitLoadState(string:state_str) {
    if (state_str == "loaded") {
        pass(UnitLoadState.LOADED);
    } else if (state_str == "not-found") {
        pass(UnitLoadState.NOT_FOUND);
    } else if (state_str == "error") {
        pass(UnitLoadState.ERROR);
    } else if (state_str == "masked") {
        pass(UnitLoadState.MASKED);
    } else if (state_str == "bad-setting") {
        pass(UnitLoadState.BAD_SETTING);
    } else {
        // Unknown state - log warning
        std.io.stddbg.write("{\"level\":\"WARN\",\"component\":\"state_mapper\",");
        std.io.stddbg.write("\"event\":\"unknown_load_state\",\"raw_state\":\"");
        std.io.stddbg.write(state_str);
        std.io.stddbg.write("\"}\n");
        
        pass(UnitLoadState.UNKNOWN);
    }
};

// Map systemd sub-state string to enum
func:map_sub_state = UnitSubState(string:state_str) {
    if (state_str == "running") {
        pass(UnitSubState.RUNNING);
    } else if (state_str == "exited") {
        pass(UnitSubState.EXITED);
    } else if (state_str == "dead") {
        pass(UnitSubState.DEAD);
    } else if (state_str == "listening") {
        pass(UnitSubState.LISTENING);
    } else if (state_str == "waiting") {
        pass(UnitSubState.WAITING);
    } else if (state_str == "start-pre") {
        pass(UnitSubState.START_PRE);
    } else if (state_str == "start") {
        pass(UnitSubState.START);
    } else if (state_str == "stop") {
        pass(UnitSubState.STOP);
    } else {
        pass(UnitSubState.UNKNOWN);
    }
};

// ============================================================================
// Module: tools/service/dbus_client.aria (FFI Layer)
// ============================================================================
// D-Bus Integration with libsystemd
// ============================================================================

// FFI declarations for libsystemd
extern "libsystemd" {
    // Opaque types (wild pointers)
    struct sd_bus;
    struct sd_bus_message;
    
    // Connect to system bus
    func:sd_bus_open_system = int32(wild sd_bus:bus);
    
    // Call D-Bus method
    func:sd_bus_call_method = int32(
        wild sd_bus:bus,
        wild byte:destination,
        wild byte:path,
        wild byte:interface,
        wild byte:member,
        wild sd_bus_message:error,
        wild sd_bus_message:reply,
        wild byte:types
    );
    
    // Message reading
    func:sd_bus_message_read_basic = int32(wild sd_bus_message:m, byte:type_char, wild void:p);
    func:sd_bus_message_enter_container = int32(wild sd_bus_message:m, byte:type_char, wild byte:contents);
    func:sd_bus_message_exit_container = int32(wild sd_bus_message:m);
    
    // Cleanup
    func:sd_bus_flush_close_unref = wild sd_bus(wild sd_bus:bus);
    func:sd_bus_message_unref = wild sd_bus_message(wild sd_bus_message:m);
};

// Bus connection handle (module-level state)
struct:DBusConnection = {
    wild sd_bus:bus;
    bool:is_connected;
};

// Connect to system bus
func:connect_system_bus = result<DBusConnection>(void) {
    DBusConnection:conn;
    conn.is_connected = false;
    
    int32:ret = sd_bus_open_system(conn.bus);
    
    if (ret < 0) {
        // Log failure to stddbg
        std.io.stddbg.write("{\"level\":\"FATAL\",\"component\":\"dbus_client\",");
        std.io.stddbg.write("\"event\":\"bus_connection_failed\",\"errno\":");
        std.io.stddbg.write(std.string.from_int(ret));
        std.io.stddbg.write("}\n");
        
        result<DBusConnection>:err_result;
        err_result.is_error = true;
        err_result.error = "Failed to connect to system bus";
        pass(err_result);
    }
    
    conn.is_connected = true;
    
    result<DBusConnection>:success;
    success.is_error = false;
    success.value = conn;
    pass(success);
};

// Call ListUnits method
func:call_list_units = result<wild sd_bus_message>(DBusConnection:conn) {
    wild sd_bus_message:error = wild_null;
    wild sd_bus_message:reply = wild_null;
    
    int64:start_time = std.time.nanos_since_epoch() ? 0;
    
    int32:ret = sd_bus_call_method(
        conn.bus,
        "org.freedesktop.systemd1",
        "/org/freedesktop/systemd1",
        "org.freedesktop.systemd1.Manager",
        "ListUnits",
        error,
        reply,
        ""  // No input parameters
    );
    
    int64:end_time = std.time.nanos_since_epoch() ? 0;
    int64:latency_us = (end_time - start_time) / 1000;
    
    // Log telemetry to stddbg
    std.io.stddbg.write("{\"level\":\"DEBUG\",\"component\":\"dbus_client\",");
    std.io.stddbg.write("\"event\":\"method_call\",\"method\":\"ListUnits\",");
    std.io.stddbg.write("\"latency_us\":");
    std.io.stddbg.write(std.string.from_int(latency_us));
    std.io.stddbg.write("}\n");
    
    if (ret < 0) {
        result<wild sd_bus_message>:err_result;
        err_result.is_error = true;
        err_result.error = "ListUnits call failed";
        pass(err_result);
    }
    
    result<wild sd_bus_message>:success;
    success.is_error = false;
    success.value = reply;
    pass(success);
};

// Close bus connection
func:disconnect = void(DBusConnection:conn) {
    if (conn.is_connected) {
        sd_bus_flush_close_unref(conn.bus);
    }
};

// ============================================================================
// Module: tools/service/serializer.aria
// ============================================================================
// TLV Serialization Protocol (stddato stream)
// ============================================================================

// Magic number for asystemctl stream: "ASYS"
const TLV_MAGIC:u32 = 0x41535953;

// Serialize ServiceUnit to JSON
func:serialize_to_json = string(ServiceUnit:unit) {
    string:json = "{";
    
    // Name
    json = json + "\"name\":\"" + unit.name + "\",";
    
    // Description
    json = json + "\"description\":\"" + unit.description + "\",";
    
    // Load state
    json = json + "\"load_state\":" + std.string.from_int(unit.load_state) + ",";
    
    // Active state
    json = json + "\"active_state\":" + std.string.from_int(unit.active_state) + ",";
    
    // Sub state
    json = json + "\"sub_state\":" + std.string.from_int(unit.sub_state) + ",";
    
    // Main PID (TBB-safe)
    json = json + "\"main_pid\":" + std.string.from_tbb64(unit.main_pid) + ",";
    
    // Fragment path
    json = json + "\"fragment_path\":\"" + unit.fragment_path + "\"";
    
    json = json + "}";
    
    pass(json);
};

// Write TLV frame to stddato
func:write_tlv_frame = void(ServiceUnit:unit) {
    // Serialize metadata
    string:meta_json = serialize_to_json(unit);
    tbb64:meta_len = tbb64.from_int(meta_json.length()) ? ERR;
    tbb64:data_len = tbb64.from_int(0) ? ERR;  // No binary payload for list
    
    // Check for TBB errors
    if (tbb64.is_err(meta_len)) {
        std.io.stddbg.write("{\"level\":\"ERROR\",\"event\":\"serialization_overflow\"}\n");
        pass();
    }
    
    // Write header
    std.io.stddato.write_u32(TLV_MAGIC);
    std.io.stddato.write_tbb64(meta_len);
    std.io.stddato.write_tbb64(data_len);
    
    // Write metadata
    std.io.stddato.write_string(meta_json);
};

// Read TLV frame from stddati
func:read_tlv_frame = result<ServiceUnit>(void) {
    // Read header
    result<u32>:magic_result = std.io.stddati.read_u32();
    
    if (magic_result.is_error) {
        result<ServiceUnit>:err_result;
        err_result.is_error = true;
        err_result.error = "EOF or read error";
        pass(err_result);
    }
    
    u32:magic = magic_result.value;
    
    if (magic != TLV_MAGIC) {
        std.io.stderr.write("Invalid stream magic. Expected ASYS.\n");
        
        result<ServiceUnit>:err_result;
        err_result.is_error = true;
        err_result.error = "Invalid magic number";
        pass(err_result);
    }
    
    // Read lengths
    result<tbb64>:meta_len_result = std.io.stddati.read_tbb64();
    result<tbb64>:data_len_result = std.io.stddati.read_tbb64();
    
    if (meta_len_result.is_error || data_len_result.is_error) {
        result<ServiceUnit>:err_result;
        err_result.is_error = true;
        err_result.error = "Failed to read frame lengths";
        pass(err_result);
    }
    
    tbb64:meta_len = meta_len_result.value;
    tbb64:data_len = data_len_result.value;
    
    // Check for TBB errors
    if (tbb64.is_err(meta_len) || tbb64.is_err(data_len)) {
        result<ServiceUnit>:err_result;
        err_result.is_error = true;
        err_result.error = "TBB error in frame lengths";
        pass(err_result);
    }
    
    // Read metadata
    int32:meta_len_int = tbb64.to_int(meta_len) ? 0;
    result<string>:json_result = std.io.stddati.read_string(meta_len_int);
    
    if (json_result.is_error) {
        result<ServiceUnit>:err_result;
        err_result.is_error = true;
        err_result.error = "Failed to read metadata";
        pass(err_result);
    }
    
    string:json = json_result.value;
    
    // Skip data payload (we only need metadata)
    int32:data_len_int = tbb64.to_int(data_len) ? 0;
    if (data_len_int > 0) {
        std.io.stddati.skip(data_len_int);
    }
    
    // Deserialize JSON (simplified - would use proper JSON parser)
    ServiceUnit:unit = deserialize_from_json(json);
    
    result<ServiceUnit>:success;
    success.is_error = false;
    success.value = unit;
    pass(success);
};

// Deserialize ServiceUnit from JSON (placeholder)
func:deserialize_from_json = ServiceUnit(string:json) {
    ServiceUnit:unit;
    
    // TODO: Implement proper JSON parsing
    // For now, placeholder implementation
    unit.name = "placeholder";
    unit.description = "";
    unit.load_state = UnitLoadState.LOADED;
    unit.active_state = UnitActiveState.ACTIVE;
    unit.sub_state = UnitSubState.RUNNING;
    unit.main_pid = tbb64.from_int(0);
    unit.active_enter_timestamp = tbb64.from_int(0);
    unit.inactive_enter_timestamp = tbb64.from_int(0);
    unit.fragment_path = "";
    
    pass(unit);
};

// ============================================================================
// Module: tools/service/ui_renderer.aria
// ============================================================================
// UI Rendering (stdout with ANSI colors)
// ============================================================================

// ANSI color codes
const ANSI_RESET:string = "\033[0m";
const ANSI_RED:string = "\033[31m";
const ANSI_GREEN:string = "\033[32m";
const ANSI_YELLOW:string = "\033[33m";
const ANSI_BLUE:string = "\033[34m";
const ANSI_GRAY:string = "\033[90m";

// Color active state
func:color_state = string(UnitActiveState:state) {
    if (state == UnitActiveState.ACTIVE) {
        pass(ANSI_GREEN + "active" + ANSI_RESET);
    } else if (state == UnitActiveState.FAILED) {
        pass(ANSI_RED + "failed" + ANSI_RESET);
    } else if (state == UnitActiveState.ACTIVATING) {
        pass(ANSI_YELLOW + "activating" + ANSI_RESET);
    } else if (state == UnitActiveState.INACTIVE) {
        pass(ANSI_GRAY + "inactive" + ANSI_RESET);
    } else {
        pass("unknown");
    }
};

// Format table header
func:format_header = string(void) {
    string:header = "UNIT                            LOAD      ACTIVE    SUB       DESCRIPTION\n";
    pass(header);
};

// Format table row
func:format_row = string(ServiceUnit:unit) {
    string:row = "";
    
    // Unit name (truncated to 30 chars)
    string:name = unit.name;
    if (name.length() > 30) {
        name = name.substring(0, 27) + "...";
    }
    row = row + std.string.pad_right(name, 32);
    
    // Load state
    string:load_state_str = std.string.from_int(unit.load_state) ? "0";
    row = row + std.string.pad_right(load_state_str, 10);
    
    // Active state (colored)
    string:active_str = color_state(unit.active_state);
    row = row + std.string.pad_right(active_str, 10 + 9);  // +9 for ANSI codes
    
    // Sub state
    string:sub_state_str = std.string.from_int(unit.sub_state) ? "0";
    row = row + std.string.pad_right(sub_state_str, 10);
    
    // Description (truncated)
    string:desc = unit.description;
    if (desc.length() > 40) {
        desc = desc.substring(0, 37) + "...";
    }
    row = row + desc;
    
    row = row + "\n";
    pass(row);
};

// ============================================================================
// Module: tools/service/fd_shim.aria (FFI - C++ Implementation)
// ============================================================================
// FD 3 Collision Resolution (Socket Activation)
// ============================================================================

// FFI to C++ shim layer
extern "aria_runtime" {
    // Detect and resolve FD 3 conflict with systemd socket activation
    func:ensure_aria_streams = void(void);
};

// Call shim during initialization
func:resolve_fd_collision = void(void) {
    // This calls into C++ runtime to:
    // 1. Check LISTEN_FDS environment variable
    // 2. If FD 3 is a socket, dup2() it to a safe FD (>= 1024)
    // 3. Open /dev/null or log file to FD 3 for stddbg
    ensure_aria_streams();
};

// ============================================================================
// Module: tools/service/commands.aria
// ============================================================================
// Command Implementations
// ============================================================================

// List all units
func:list_units = int32(string:filter_arg) {
    // Connect to D-Bus
    result<DBusConnection>:conn_result = connect_system_bus();
    
    if (conn_result.is_error) {
        std.io.stderr.write("Error: ");
        std.io.stderr.write(conn_result.error);
        std.io.stderr.write("\n");
        pass(1);
    }
    
    DBusConnection:conn = conn_result.value;
    
    // Call ListUnits
    result<wild sd_bus_message>:msg_result = call_list_units(conn);
    
    if (msg_result.is_error) {
        disconnect(conn);
        std.io.stderr.write("Error: ");
        std.io.stderr.write(msg_result.error);
        std.io.stderr.write("\n");
        pass(1);
    }
    
    wild sd_bus_message:msg = msg_result.value;
    
    // Write UI header to stdout
    std.io.stdout.write(format_header());
    
    // TODO: Iterate through D-Bus message array
    // For each unit:
    //   1. Parse D-Bus tuple (ssssssouso)
    //   2. Map strings to enums
    //   3. Create ServiceUnit struct
    //   4. Write formatted row to stdout
    //   5. Write TLV frame to stddato
    //   6. Log events to stddbg
    
    // Placeholder: Create sample unit for demonstration
    ServiceUnit:sample;
    sample.name = "sshd.service";
    sample.description = "OpenSSH server daemon";
    sample.load_state = UnitLoadState.LOADED;
    sample.active_state = UnitActiveState.ACTIVE;
    sample.sub_state = UnitSubState.RUNNING;
    sample.main_pid = tbb64.from_int(1234);
    sample.active_enter_timestamp = tbb64.from_int(0);
    sample.inactive_enter_timestamp = tbb64.from_int(0);
    sample.fragment_path = "/lib/systemd/system/ssh.service";
    
    // Render to stdout
    std.io.stdout.write(format_row(sample));
    
    // Serialize to stddato
    write_tlv_frame(sample);
    
    // Cleanup
    sd_bus_message_unref(msg);
    disconnect(conn);
    
    pass(0);
};

// Restart units (consume from stddati pipe)
func:restart_units = int32(string:targets) {
    if (targets.length() == 0) {
        // Read from stddati pipe
        while (true) {
            result<ServiceUnit>:unit_result = read_tlv_frame();
            
            if (unit_result.is_error) {
                break;  // EOF or error
            }
            
            ServiceUnit:unit = unit_result.value;
            
            std.io.stdout.write("Restarting ");
            std.io.stdout.write(unit.name);
            std.io.stdout.write("...\n");
            
            // TODO: Call D-Bus RestartUnit method
        }
    } else {
        // Direct target restart
        std.io.stdout.write("Restarting ");
        std.io.stdout.write(targets);
        std.io.stdout.write("...\n");
        
        // TODO: Parse targets and call RestartUnit
    }
    
    pass(0);
};

// ============================================================================
// Main Entry Point
// ============================================================================

func:main = int32(array<string>:args) {
    // 1. Resolve FD 3 collision (systemd socket activation)
    resolve_fd_collision();
    
    // 2. Parse arguments
    if (args.length() < 2) {
        std.io.stderr.write("Usage: asystemctl <command> [args]\n");
        std.io.stderr.write("Commands: list, restart\n");
        pass(1);
    }
    
    string:command = args.at(1) ? "";
    
    // 3. Dispatch command
    if (command == "list") {
        string:filter = "";
        if (args.length() >= 3) {
            filter = args.at(2);
        }
        
        pass(list_units(filter));
    } else if (command == "restart") {
        string:targets = "";
        if (args.length() >= 3) {
            targets = args.at(2);
        }
        
        pass(restart_units(targets));
    } else {
        std.io.stderr.write("Unknown command: ");
        std.io.stderr.write(command);
        std.io.stderr.write("\n");
        pass(1);
    }
};

