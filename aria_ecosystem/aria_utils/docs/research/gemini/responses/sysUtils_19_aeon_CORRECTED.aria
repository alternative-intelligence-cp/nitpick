// ============================================================================
// ARIA CONFIGURATION LANGUAGE (ACL) IMPLEMENTATION (Syntax-Corrected)
// ============================================================================
// Based on: sysUtils_19_aeon.txt
// Corrected: December 23, 2025
// Status: Ready for implementation
// ============================================================================

// File: frontend/config/config_node.aria
// ============================================================================
// Configuration AST Node Definitions
// ============================================================================

enum:NodeType = {
    OBJECT = 0,
    ARRAY = 1,
    STRING = 2,
    INTEGER = 3,
    FLOAT = 4,
    BOOL = 5,
    NULL_VALUE = 6,
    TBB_ERR = 7
};

struct:SourceInfo = {
    string:filename;
    int32:line;
    int32:column;
};

// Base configuration node
struct:ConfigNode = {
    NodeType:node_type;
    SourceInfo:location;
};

// Object node (key-value pairs)
struct:ConfigObject = {
    ConfigNode:base;
    array<KeyValuePair>:members;
    map<string, int32>:lookup;
};

struct:KeyValuePair = {
    string:key;
    ConfigNode:value;
    SourceInfo:key_location;
};

// Array node
struct:ConfigArray = {
    ConfigNode:base;
    array<ConfigNode>:elements;
};

// Literal value nodes
struct:ConfigString = {
    ConfigNode:base;
    string:value;
};

struct:ConfigInteger = {
    ConfigNode:base;
    int64:value;
    bool:is_tbb_err;  // Track if this is a TBB ERR sentinel
};

struct:ConfigFloat = {
    ConfigNode:base;
    flt64:value;
};

struct:ConfigBool = {
    ConfigNode:base;
    bool:value;
};

struct:ConfigNull = {
    ConfigNode:base;
};

// ============================================================================
// Module: frontend/config/lexer.aria
// ============================================================================
// Configuration Lexer (extends AriaLexer)
// ============================================================================

// use std.io;
// use std.string;

enum:TokenType = {
    // Structural
    LEFT_BRACE = 0,      // {
    RIGHT_BRACE = 1,     // }
    LEFT_BRACKET = 2,    // [
    RIGHT_BRACKET = 3,   // ]
    COLON = 4,           // :
    COMMA = 5,           // ,
    
    // Literals
    IDENTIFIER = 10,
    STRING = 11,
    INTEGER = 12,
    FLOAT = 13,
    TRUE = 14,
    FALSE = 15,
    NULL_TOK = 16,
    
    // Special
    TEMPLATE_STRING = 20,
    VARIABLE_REF = 21,   // &{...}
    
    // Control
    EOF = 255
};

struct:Token = {
    TokenType:tok_type;
    string:lexeme;
    SourceInfo:location;
    int64:int_value;
    flt64:float_value;
};

struct:ConfigLexer = {
    string:source;
    int32:current;
    int32:line;
    int32:column;
    string:filename;
};

// Initialize lexer
func:new_lexer = result<ConfigLexer>(string:source, string:filename) {
    ConfigLexer:lex;
    lex.source = source;
    lex.current = 0;
    lex.line = 1;
    lex.column = 1;
    lex.filename = filename;
    pass(result_ok(lex));
};

// Peek current character without advancing
func:peek = result<byte>(ConfigLexer:lex) {
    if (lex.current >= lex.source.length()) {
        pass(result_ok(0));  // EOF
    }
    pass(result_ok(lex.source.char_at(lex.current) ? 0));
};

// Advance to next character
func:advance = byte(ConfigLexer:lex) {
    if (lex.current >= lex.source.length()) {
        pass(0);
    }
    
    byte:ch = lex.source.char_at(lex.current) ? 0;
    lex.current = lex.current + 1;
    
    if (ch == 10) {  // '\n'
        lex.line = lex.line + 1;
        lex.column = 1;
    } else {
        lex.column = lex.column + 1;
    }
    
    pass(ch);
};

// Skip whitespace
func:skip_whitespace = void(ConfigLexer:lex) {
    while (true) {
        byte:ch = peek(lex);
        
        if (ch == 32 || ch == 9 || ch == 10 || ch == 13) {  // ' ', '\t', '\n', '\r'
            advance(lex);
        } else if (ch == 47) {
            // Check for comments
            if (lex.current + 1 < lex.source.length()) {
                byte:next = lex.source.char_at(lex.current + 1) ? 0;
                
                if (next == 47) {
                    // Single-line comment
                    while (peek(lex) != 10 && peek(lex) != 0) {  // '\n'
                        advance(lex);
                    }
                } else if (next == 42) {
                    // Multi-line comment (with nesting support)
                    advance(lex);  // consume '/'
                    advance(lex);  // consume '*'
                    
                    int32:depth = 1;
                    while (depth > 0 && peek(lex) != 0) {
                        byte:c = advance(lex);
                        
                        if (c == 47 && peek(lex) == 42) {
                            advance(lex);
                            depth = depth + 1;
                        } else if (c == 42 && peek(lex) == 47) {
                            advance(lex);
                            depth = depth - 1;
                        }
                    }
                } else {
                    break;  // Not a comment
                }
            } else {
                break;
            }
        } else {
            break;
        }
    }
};

// Scan identifier
func:scan_identifier = Token(ConfigLexer:lex) {
    SourceInfo:loc;
    loc.filename = lex.filename;
    loc.line = lex.line;
    loc.column = lex.column;
    
    string:lexeme = "";
    
    while (true) {
        byte:ch = peek(lex);
        
        if ((ch >= 97 && ch <= 122) || 
            (ch >= 65 && ch <= 90) || 
            (ch >= 48 && ch <= 57) || 
            ch == 95) {
            lexeme = lexeme + string.from_char(ch);
            advance(lex);
        } else {
            break;
        }
    }
    
    Token:tok;
    tok.lexeme = lexeme;
    tok.location = loc;
    
    // Check for keywords
    if (lexeme == "true") {
        tok.tok_type = TokenType.TRUE;
    } else if (lexeme == "false") {
        tok.tok_type = TokenType.FALSE;
    } else if (lexeme == "null") {
        tok.tok_type = TokenType.NULL_TOK;
    } else {
        tok.tok_type = TokenType.IDENTIFIER;
    }
    
    pass(tok);
};

// Scan string literal
func:scan_string = Token(ConfigLexer:lex) {
    SourceInfo:loc;
    loc.filename = lex.filename;
    loc.line = lex.line;
    loc.column = lex.column;
    
    advance(lex);  // consume opening quote
    
    string:value = "";
    
    while (true) {
        byte:ch = peek(lex);
        
        if (ch == 0 || ch == 10) {  // '\n'
            // Unterminated string - error
            break;
        } else if (ch == 34) {
            advance(lex);  // consume closing quote
            break;
        } else if (ch == 92) {
            advance(lex);
            byte:escaped = advance(lex);
            
            // Handle escape sequences
            if (escaped == 110) {
                value = value + "\n";
            } else if (escaped == 116) {
                value = value + "\t";
            } else if (escaped == 114) {
                value = value + "\r";
            } else if (escaped == 92) {
                value = value + "\\";
            } else if (escaped == 34) {
                value = value + "\"";
            } else {
                value = value + string.from_char(escaped);
            }
        } else {
            value = value + string.from_char(ch);
            advance(lex);
        }
    }
    
    Token:tok;
    tok.tok_type = TokenType.STRING;
    tok.lexeme = value;
    tok.location = loc;
    pass(tok);
};

// Scan number (integer or float)
func:scan_number = Token(ConfigLexer:lex) {
    SourceInfo:loc;
    loc.filename = lex.filename;
    loc.line = lex.line;
    loc.column = lex.column;
    
    string:lexeme = "";
    bool:is_float = false;
    
    // Handle negative sign
    if (peek(lex) == 45) {
        lexeme = lexeme + string.from_char(advance(lex));
    }
    
    // Check for hex prefix (0x)
    if (peek(lex) == 48) {
        byte:next_ch = 0;
        if (lex.current + 1 < lex.source.length()) {
            next_ch = lex.source.char_at(lex.current + 1);
        }
        
        if (next_ch == 120 || next_ch == 88) {
            // Hexadecimal
            lexeme = lexeme + string.from_char(advance(lex));  // '0'
            lexeme = lexeme + string.from_char(advance(lex));  // 'x'
            
            while (true) {
                byte:ch = peek(lex);
                if ((ch >= 48 && ch <= 57) || 
                    (ch >= 97 && ch <= 102) || 
                    (ch >= 65 && ch <= 70)) {
                    lexeme = lexeme + string.from_char(advance(lex));
                } else {
                    break;
                }
            }
            
            Token:tok;
            tok.tok_type = TokenType.INTEGER;
            tok.lexeme = lexeme;
            tok.location = loc;
            tok.int_value = std.convert.hex_to_int64(lexeme.substring(2));
            pass(tok);
        }
    }
    
    // Decimal number
    while (true) {
        byte:ch = peek(lex);
        
        if (ch >= 48 && ch <= 57) {
            lexeme = lexeme + string.from_char(advance(lex));
        } else if (ch == 46 && !is_float) {
            is_float = true;
            lexeme = lexeme + string.from_char(advance(lex));
        } else if ((ch == 101 || ch == 69) && !is_float) {
            is_float = true;
            lexeme = lexeme + string.from_char(advance(lex));
            
            // Handle exponent sign
            if (peek(lex) == '+' || peek(lex) == 45) {
                lexeme = lexeme + string.from_char(advance(lex));
            }
        } else {
            break;
        }
    }
    
    Token:tok;
    tok.lexeme = lexeme;
    tok.location = loc;
    
    if (is_float) {
        tok.tok_type = TokenType.FLOAT;
        tok.float_value = std.convert.to_float(lexeme);
    } else {
        tok.tok_type = TokenType.INTEGER;
        tok.int_value = std.convert.to_int64(lexeme);
    }
    
    pass(tok);
};

// Main tokenization function
func:next_token = Token(ConfigLexer:lex) {
    skip_whitespace(lex);
    
    byte:ch = peek(lex);
    
    if (ch == 0) {
        Token:tok;
        tok.tok_type = TokenType.EOF;
        pass(tok);
    }
    
    SourceInfo:loc;
    loc.filename = lex.filename;
    loc.line = lex.line;
    loc.column = lex.column;
    
    // Single-character tokens
    if (ch == 123) {
        advance(lex);
        Token:tok;
        tok.tok_type = TokenType.LEFT_BRACE;
        tok.location = loc;
        pass(tok);
    } else if (ch == 125) {
        advance(lex);
        Token:tok;
        tok.tok_type = TokenType.RIGHT_BRACE;
        tok.location = loc;
        pass(tok);
    } else if (ch == 91) {
        advance(lex);
        Token:tok;
        tok.tok_type = TokenType.LEFT_BRACKET;
        tok.location = loc;
        pass(tok);
    } else if (ch == 93) {
        advance(lex);
        Token:tok;
        tok.tok_type = TokenType.RIGHT_BRACKET;
        tok.location = loc;
        pass(tok);
    } else if (ch == 58) {
        advance(lex);
        Token:tok;
        tok.tok_type = TokenType.COLON;
        tok.location = loc;
        pass(tok);
    } else if (ch == 44) {
        advance(lex);
        Token:tok;
        tok.tok_type = TokenType.COMMA;
        tok.location = loc;
        pass(tok);
    } else if (ch == 34) {
        pass(scan_string(lex));
    } else if (ch == 45 || (ch >= 48 && ch <= 57)) {
        pass(scan_number(lex));
    } else if ((ch >= 97 && ch <= 122) || 
               (ch >= 65 && ch <= 90) || 
               ch == 95) {
        pass(scan_identifier(lex));
    } else if (ch == '&') {
        // Variable reference &{...}
        // TODO: Implement template interpolation
        advance(lex);
        Token:tok;
        tok.tok_type = TokenType.VARIABLE_REF;
        tok.location = loc;
        pass(tok);
    }
    
    // Unknown character - error token
    advance(lex);
    Token:tok;
    tok.tok_type = TokenType.EOF;  // Use EOF as error
    tok.location = loc;
    pass(tok);
};

// ============================================================================
// Module: frontend/config/parser.aria
// ============================================================================
// Configuration Parser
// ============================================================================

struct:ConfigParser = {
    ConfigLexer:lexer;
    Token:current;
    Token:previous;
    bool:had_error;
    bool:panic_mode;
};

// Initialize parser
func:new_parser = ConfigParser(string:source, string:filename) {
    ConfigParser:parser;
    parser.lexer = new_lexer(source, filename);
    parser.had_error = false;
    parser.panic_mode = false;
    
    // Prime the pump
    parser.current = next_token(parser.lexer);
    
    pass(parser);
};

// Advance to next token
func:advance_parser = void(ConfigParser:parser) {
    parser.previous = parser.current;
    parser.current = next_token(parser.lexer);
};

// Check if current token matches expected type
func:check = bool(ConfigParser:parser, TokenType:expected) {
    pass(parser.current.tok_type == expected);
};

// Consume token if it matches, otherwise error
func:consume = bool(ConfigParser:parser, TokenType:expected, string:message) {
    if (check(parser, expected)) {
        advance_parser(parser);
        pass(true);
    }
    
    // Error
    parser.had_error = true;
    
    std.io.stderr.write(parser.current.location.filename);
    std.io.stderr.write(":");
    std.io.stderr.write(std.string.from_int(parser.current.location.line));
    std.io.stderr.write(":");
    std.io.stderr.write(std.string.from_int(parser.current.location.column));
    std.io.stderr.write(": Error: ");
    std.io.stderr.write(message);
    std.io.stderr.write("\n");
    
    pass(false);
};

// Parse object { key: value, ... }
func:parse_object = ConfigObject(ConfigParser:parser) {
    ConfigObject:obj;
    obj.base.node_type = NodeType.OBJECT;
    obj.base.location = parser.current.location;
    obj.members = array<KeyValuePair>.new();
    obj.lookup = map<string, int32>.new();
    
    consume(parser, TokenType.LEFT_BRACE, "Expected '{'");
    
    // Empty object
    if (check(parser, TokenType.RIGHT_BRACE)) {
        advance_parser(parser);
        pass(obj);
    }
    
    while (true) {
        // Parse key (identifier or string)
        string:key = "";
        SourceInfo:key_loc = parser.current.location;
        
        if (check(parser, TokenType.IDENTIFIER)) {
            key = parser.current.lexeme;
            advance_parser(parser);
        } else if (check(parser, TokenType.STRING)) {
            key = parser.current.lexeme;
            advance_parser(parser);
        } else {
            consume(parser, TokenType.IDENTIFIER, "Expected object key");
            break;
        }
        
        // Consume colon
        if (!consume(parser, TokenType.COLON, "Expected ':' after key")) {
            break;
        }
        
        // Parse value
        ConfigNode:value = parse_value(parser);
        
        // Add to members
        KeyValuePair:pair;
        pair.key = key;
        pair.value = value;
        pair.key_location = key_loc;
        
        int32:index = obj.members.length() ? 0;
        obj.members.push(pair);
        obj.lookup.insert(key, index);
        
        // Check for comma or end
        if (check(parser, TokenType.COMMA)) {
            advance_parser(parser);
            
            // Allow trailing comma
            if (check(parser, TokenType.RIGHT_BRACE)) {
                advance_parser(parser);
                break;
            }
        } else if (check(parser, TokenType.RIGHT_BRACE)) {
            advance_parser(parser);
            break;
        } else {
            consume(parser, TokenType.COMMA, "Expected ',' or '}' after value");
            break;
        }
    }
    
    pass(obj);
};

// Parse array [ value, ... ]
func:parse_array = ConfigArray(ConfigParser:parser) {
    ConfigArray:arr;
    arr.base.node_type = NodeType.ARRAY;
    arr.base.location = parser.current.location;
    arr.elements = array<ConfigNode>.new();
    
    consume(parser, TokenType.LEFT_BRACKET, "Expected '['");
    
    // Empty array
    if (check(parser, TokenType.RIGHT_BRACKET)) {
        advance_parser(parser);
        pass(arr);
    }
    
    while (true) {
        // Parse value
        ConfigNode:value = parse_value(parser);
        arr.elements.push(value);
        
        // Check for comma or end
        if (check(parser, TokenType.COMMA)) {
            advance_parser(parser);
            
            // Allow trailing comma
            if (check(parser, TokenType.RIGHT_BRACKET)) {
                advance_parser(parser);
                break;
            }
        } else if (check(parser, TokenType.RIGHT_BRACKET)) {
            advance_parser(parser);
            break;
        } else {
            consume(parser, TokenType.COMMA, "Expected ',' or ']' after value");
            break;
        }
    }
    
    pass(arr);
};

// Parse value (object, array, or literal)
func:parse_value = ConfigNode(ConfigParser:parser) {
    if (check(parser, TokenType.LEFT_BRACE)) {
        ConfigObject:obj = parse_object(parser);
        pass(obj.base);
    } else if (check(parser, TokenType.LEFT_BRACKET)) {
        ConfigArray:arr = parse_array(parser);
        pass(arr.base);
    } else if (check(parser, TokenType.STRING)) {
        ConfigString:str;
        str.base.node_type = NodeType.STRING;
        str.base.location = parser.current.location;
        str.value = parser.current.lexeme;
        advance_parser(parser);
        pass(str.base);
    } else if (check(parser, TokenType.INTEGER)) {
        ConfigInteger:num;
        num.base.node_type = NodeType.INTEGER;
        num.base.location = parser.current.location;
        num.value = parser.current.int_value;
        num.is_tbb_err = false;
        advance_parser(parser);
        pass(num.base);
    } else if (check(parser, TokenType.FLOAT)) {
        ConfigFloat:flt;
        flt.base.node_type = NodeType.FLOAT;
        flt.base.location = parser.current.location;
        flt.value = parser.current.float_value;
        advance_parser(parser);
        pass(flt.base);
    } else if (check(parser, TokenType.TRUE)) {
        ConfigBool:b;
        b.base.node_type = NodeType.BOOL;
        b.base.location = parser.current.location;
        b.value = true;
        advance_parser(parser);
        pass(b.base);
    } else if (check(parser, TokenType.FALSE)) {
        ConfigBool:b;
        b.base.node_type = NodeType.BOOL;
        b.base.location = parser.current.location;
        b.value = false;
        advance_parser(parser);
        pass(b.base);
    } else if (check(parser, TokenType.NULL_TOK)) {
        ConfigNull:n;
        n.base.node_type = NodeType.NULL_VALUE;
        n.base.location = parser.current.location;
        advance_parser(parser);
        pass(n.base);
    }
    
    // Error - return null node
    consume(parser, TokenType.STRING, "Expected value");
    ConfigNull:err;
    err.base.node_type = NodeType.NULL_VALUE;
    err.base.location = parser.current.location;
    pass(err.base);
};

// Parse top-level configuration (object or array)
func:parse = result<ConfigNode>(ConfigParser:parser) {
    ConfigNode:root = parse_value(parser);
    
    if (parser.had_error) {
        result<ConfigNode>:err_result;
        err_result.is_error = true;
        err_result.error = "Parse errors occurred";
        pass(err_result);
    }
    
    result<ConfigNode>:success;
    success.is_error = false;
    success.value = root;
    pass(success);
};

// ============================================================================
// Example Usage and Tests
// ============================================================================

// Example: Parse build.aria configuration
func:test_parse_config = void() {
    string:config_text = "{
        project: {
            name: \"AriaCore\",
            version: \"0.1.0\",
            aria_version: \">=0.0.7\"
        },
        variables: {
            src: \"src\",
            out: \"build\",
            flags: \"-O3 --enable-safety\"
        },
        targets: [
            {
                name: \"core_lib\",
                type: \"library\",
                output: \"build/libcore.a\"
            }
        ]
    }";
    
    ConfigParser:parser = new_parser(config_text, "build.aria");
    result<ConfigNode>:result = parse(parser);
    
    if (result.is_error) {
        std.io.stderr.write("Parse failed: ");
        std.io.stderr.write(result.error);
        std.io.stderr.write("\n");
    } else {
        std.io.stdout.write("Parse successful!\n");
    }
};

// ============================================================================
// END OF CORRECTED ACL IMPLEMENTATION
// ============================================================================
