// test_aria_sdl2.aria — Automated tests for aria-sdl2 bindings

extern func:println = int32(string:msg);

func:failsafe = NIL(int32:code) { pass(NIL); };

// ── shim externs (direct for test) ──────────────────────────────────

extern func:aria_sdl2_init              = int32(int32:flags);
extern func:aria_sdl2_quit              = void();
extern func:aria_sdl2_create_window     = int32(string:title, int32:x, int32:y,
                                                  int32:w, int32:h, int32:flags);
extern func:aria_sdl2_create_renderer   = int32(int32:flags);
extern func:aria_sdl2_set_render_draw_color = void(int32:r, int32:g, int32:b, int32:a);
extern func:aria_sdl2_render_clear      = void();
extern func:aria_sdl2_render_present    = void();
extern func:aria_sdl2_render_draw_point = void(int32:x, int32:y);
extern func:aria_sdl2_render_draw_line  = void(int32:x1, int32:y1, int32:x2, int32:y2);
extern func:aria_sdl2_render_draw_rect  = void(int32:x, int32:y, int32:w, int32:h);
extern func:aria_sdl2_render_fill_rect  = void(int32:x, int32:y, int32:w, int32:h);
extern func:aria_sdl2_poll_event        = int32();
extern func:aria_sdl2_event_type        = int32();
extern func:aria_sdl2_get_window_width  = int32();
extern func:aria_sdl2_get_window_height = int32();
extern func:aria_sdl2_get_ticks         = int32();
extern func:aria_sdl2_delay             = void(int32:ms);
extern func:aria_sdl2_get_error         = string();
extern func:aria_sdl2_get_mouse_state_x = int32();
extern func:aria_sdl2_get_mouse_state_y = int32();
extern func:aria_sdl2_get_mouse_state_buttons = int32();
extern func:aria_sdl2_set_window_title  = void(string:title);

func:main = int32() {
    int64:passed = 0i64;
    int64:failed = 0i64;

    // ── test 01: SDL_Init ───────────────────────────────────────────
    int32:init_result = aria_sdl2_init(32i32);
    if (init_result == 0i32) {
        passed = passed + 1i64;
        drop(println("[PASS] SDL_Init(SDL_INIT_VIDEO) succeeded"));
    }
    if (init_result != 0i32) {
        failed = failed + 1i64;
        drop(println("[FAIL] SDL_Init(SDL_INIT_VIDEO) failed"));
    }

    // ── test 02: create window ──────────────────────────────────────
    // SDL_WINDOWPOS_UNDEFINED = 0x1FFF0000 = 536805376
    int32:win_ok = aria_sdl2_create_window("Aria SDL2 Test",
        536805376i32, 536805376i32,
        800i32, 600i32, 4i32);
    if (win_ok == 1i32) {
        passed = passed + 1i64;
        drop(println("[PASS] SDL_CreateWindow succeeded"));
    }
    if (win_ok != 1i32) {
        failed = failed + 1i64;
        drop(println("[FAIL] SDL_CreateWindow failed"));
    }

    // ── test 03: window dimensions ──────────────────────────────────
    int32:ww = aria_sdl2_get_window_width();
    if (ww == 800i32) {
        passed = passed + 1i64;
        drop(println("[PASS] window width = 800"));
    }
    if (ww != 800i32) {
        failed = failed + 1i64;
        drop(println("[FAIL] window width != 800"));
    }

    // ── test 04: window height ──────────────────────────────────────
    int32:wh = aria_sdl2_get_window_height();
    if (wh == 600i32) {
        passed = passed + 1i64;
        drop(println("[PASS] window height = 600"));
    }
    if (wh != 600i32) {
        failed = failed + 1i64;
        drop(println("[FAIL] window height != 600"));
    }

    // ── test 05: create renderer ────────────────────────────────────
    // SDL_RENDERER_ACCELERATED = 2, SDL_RENDERER_SOFTWARE = 1
    int32:ren_ok = aria_sdl2_create_renderer(1i32);
    if (ren_ok == 1i32) {
        passed = passed + 1i64;
        drop(println("[PASS] SDL_CreateRenderer succeeded"));
    }
    if (ren_ok != 1i32) {
        failed = failed + 1i64;
        drop(println("[FAIL] SDL_CreateRenderer failed"));
    }

    // ── test 06: set draw color ─────────────────────────────────────
    aria_sdl2_set_render_draw_color(40i32, 40i32, 40i32, 255i32);
    passed = passed + 1i64;
    drop(println("[PASS] set draw color (no crash)"));

    // ── test 07: render clear ───────────────────────────────────────
    aria_sdl2_render_clear();
    passed = passed + 1i64;
    drop(println("[PASS] render clear (no crash)"));

    // ── test 08: draw point ─────────────────────────────────────────
    aria_sdl2_set_render_draw_color(255i32, 255i32, 255i32, 255i32);
    aria_sdl2_render_draw_point(100i32, 100i32);
    passed = passed + 1i64;
    drop(println("[PASS] draw point (no crash)"));

    // ── test 09: draw line ──────────────────────────────────────────
    aria_sdl2_render_draw_line(50i32, 50i32, 750i32, 550i32);
    passed = passed + 1i64;
    drop(println("[PASS] draw line (no crash)"));

    // ── test 10: draw rect ──────────────────────────────────────────
    aria_sdl2_set_render_draw_color(0i32, 255i32, 0i32, 255i32);
    aria_sdl2_render_draw_rect(100i32, 100i32, 200i32, 150i32);
    passed = passed + 1i64;
    drop(println("[PASS] draw rect (no crash)"));

    // ── test 11: fill rect ──────────────────────────────────────────
    aria_sdl2_set_render_draw_color(255i32, 0i32, 0i32, 255i32);
    aria_sdl2_render_fill_rect(350i32, 100i32, 200i32, 150i32);
    passed = passed + 1i64;
    drop(println("[PASS] fill rect (no crash)"));

    // ── test 12: render present ─────────────────────────────────────
    aria_sdl2_render_present();
    passed = passed + 1i64;
    drop(println("[PASS] render present (no crash)"));

    // ── test 13: get ticks ──────────────────────────────────────────
    int32:ticks = aria_sdl2_get_ticks();
    if (ticks > 0i32) {
        passed = passed + 1i64;
        drop(println("[PASS] get_ticks > 0"));
    }
    if (ticks < 1i32) {
        failed = failed + 1i64;
        drop(println("[FAIL] get_ticks <= 0"));
    }

    // ── test 14: poll event (returns 0 when no events) ──────────────
    // Drain any pending events first
    int32:has_ev = aria_sdl2_poll_event();
    passed = passed + 1i64;
    drop(println("[PASS] poll_event (no crash)"));

    // ── test 15: event type accessible ──────────────────────────────
    int32:et = aria_sdl2_event_type();
    passed = passed + 1i64;
    drop(println("[PASS] event_type accessible (no crash)"));

    // ── test 16: mouse state ────────────────────────────────────────
    int32:mx = aria_sdl2_get_mouse_state_x();
    int32:my = aria_sdl2_get_mouse_state_y();
    int32:mb = aria_sdl2_get_mouse_state_buttons();
    passed = passed + 1i64;
    drop(println("[PASS] mouse state (no crash)"));

    // ── test 17: set window title ───────────────────────────────────
    aria_sdl2_set_window_title("Aria SDL2 - Updated Title");
    passed = passed + 1i64;
    drop(println("[PASS] set window title (no crash)"));

    // ── test 18: delay ──────────────────────────────────────────────
    aria_sdl2_delay(10i32);
    passed = passed + 1i64;
    drop(println("[PASS] delay 10ms (no crash)"));

    // ── test 19: get error (should be empty string or null) ─────────
    string:err = aria_sdl2_get_error();
    passed = passed + 1i64;
    drop(println("[PASS] get_error (no crash)"));

    // ── cleanup ─────────────────────────────────────────────────────
    aria_sdl2_quit();

    // ── summary ─────────────────────────────────────────────────────
    drop(println(""));
    drop(println("=== aria-sdl2 test summary ==="));

    if (failed == 0i64) {
        drop(println("ALL TESTS PASSED"));
    }
    if (failed > 0i64) {
        drop(println("SOME TESTS FAILED"));
    }

    pass(0i32);
};
