// test_aria_http_get.aria — GET & HEAD against local test server (:8888)

func:failsafe = NIL(int32:code) { pass(NIL); };

extern func:aria_http_init              = int32();
extern func:aria_http_get               = int32(string:url);
extern func:aria_http_head              = int32(string:url);
extern func:aria_http_status            = int32();
extern func:aria_http_assert_int_eq     = void(int32:actual, int32:expected, string:msg);
extern func:aria_http_assert_body_contains = void(string:substring, string:msg);
extern func:aria_http_test_summary      = void();

func:main = int32() {
    int32:r = aria_http_init();
    aria_http_assert_int_eq(r, 1i32, "test 01: http_init");

    int32:g = aria_http_get("http://127.0.0.1:8888/health");
    aria_http_assert_int_eq(g, 1i32, "test 02: GET /health");

    int32:gs = aria_http_status();
    aria_http_assert_int_eq(gs, 200i32, "test 03: GET status=200");

    aria_http_assert_body_contains("healthy", "test 04: body contains healthy");

    int32:h = aria_http_head("http://127.0.0.1:8888/json");
    aria_http_assert_int_eq(h, 1i32, "test 05: HEAD /json");

    int32:hs = aria_http_status();
    aria_http_assert_int_eq(hs, 200i32, "test 06: HEAD status=200");

    int32:g2 = aria_http_get("http://127.0.0.1:8888/json");
    aria_http_assert_int_eq(g2, 1i32, "test 07: GET /json after HEAD");

    aria_http_assert_body_contains("aria-dev", "test 08: body contains aria-dev");

    aria_http_test_summary();
    pass(0i32);
};
