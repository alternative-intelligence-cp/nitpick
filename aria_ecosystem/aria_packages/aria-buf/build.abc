# build.abc — aria-buf package
#
# Targets:
#   aria-buf       — compiled library for downstream packages
#   test-aria-buf  — test binary; imports src via `use "../src/aria_buf.aria".*;`

[project]
name = "aria-buf"
version = "0.1.0"
compiler = "/home/randy/Workspace/REPOS/aria/build/ariac"

[target.aria-buf]
type = "library"
sources = ["src/aria_buf.aria"]
deps = []
flags = []

[target.test-aria-buf]
type = "binary"
sources = ["tests/test_aria_buf.aria"]
deps = []
flags = []
