// ── public API: CSS ─────────────────────────────────────────────────

pub func:gtk_load_css = NIL(string:css) {
    aria_gtk4_load_css(css);
    pass(NIL);
};

// ── public API: box layout ──────────────────────────────────────────

pub func:gtk_box_set_spacing = NIL(int32:spacing) {
    aria_gtk4_box_set_spacing(spacing);
    pass(NIL);
};

pub func:gtk_box_set_homogeneous = NIL(int32:homogeneous) {
    aria_gtk4_box_set_homogeneous(homogeneous);
    pass(NIL);
};
