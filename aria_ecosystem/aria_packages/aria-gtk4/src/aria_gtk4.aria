pub func:gtk_add_label = int32(string:text) {
    int32:r = aria_gtk4_add_label(text);
    pass(r);
};

pub func:gtk_label_set_text = NIL(int32:id, string:text) {
    aria_gtk4_label_set_text(id, text);
    pass(NIL);
};

pub func:gtk_add_button = int32(string:label) {
    int32:r = aria_gtk4_add_button(label);
    pass(r);
};

pub func:gtk_add_entry = int32(string:placeholder) {
    int32:r = aria_gtk4_add_entry(placeholder);
    pass(r);
};

pub func:gtk_entry_get_text = string(int32:id) {
    string:r = aria_gtk4_entry_get_text(id);
    pass(r);
};

pub func:gtk_add_separator = int32() {
    int32:r = aria_gtk4_add_separator();
    pass(r);
};

pub func:gtk_add_check_button = int32(string:label) {
    int32:r = aria_gtk4_add_check_button(label);
    pass(r);
};

pub func:gtk_check_get_active = int32(int32:id) {
    int32:r = aria_gtk4_check_button_get_active(id);
    pass(r);
