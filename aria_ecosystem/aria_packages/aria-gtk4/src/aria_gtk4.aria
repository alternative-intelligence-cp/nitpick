// ── public API: widget properties ───────────────────────────────────

pub func:gtk_widget_set_visible = NIL(int32:id, int32:visible) {
    aria_gtk4_widget_set_visible(id, visible);
    pass(NIL);
};

pub func:gtk_widget_set_sensitive = NIL(int32:id, int32:sensitive) {
    aria_gtk4_widget_set_sensitive(id, sensitive);
    pass(NIL);
};

pub func:gtk_widget_set_size = NIL(int32:id, int32:w, int32:h) {
    aria_gtk4_widget_set_size_request(id, w, h);
    pass(NIL);
};

pub func:gtk_widget_add_css_class = NIL(int32:id, string:css_class) {
    aria_gtk4_widget_add_css_class(id, css_class);
