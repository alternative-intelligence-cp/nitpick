pub func:rl_draw_triangle = NIL(flt32:x1, flt32:y1,
                                 flt32:x2, flt32:y2,
                                 flt32:x3, flt32:y3,
                                 int32:r, int32:g, int32:b, int32:a) {
    aria_rl_draw_triangle(x1, y1, x2, y2, x3, y3, r, g, b, a);
