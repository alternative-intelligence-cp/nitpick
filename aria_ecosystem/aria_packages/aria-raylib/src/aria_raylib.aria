pub func:rl_draw_rectangle_lines = NIL(int32:x, int32:y, int32:w, int32:h,
                                        int32:r, int32:g, int32:b, int32:a) {
    aria_rl_draw_rectangle_lines(x, y, w, h, r, g, b, a);
