};

// ── public API: text ────────────────────────────────────────────────

pub func:rl_draw_text = NIL(string:text, int32:x, int32:y,
                             int32:font_size,
                             int32:r, int32:g, int32:b, int32:a) {
    aria_rl_draw_text(text, x, y, font_size, r, g, b, a);
    pass(NIL);
};

pub func:rl_draw_fps = NIL(int32:x, int32:y) {
    aria_rl_draw_fps(x, y);
    pass(NIL);
};

pub func:rl_measure_text = int32(string:text, int32:font_size) {
    int32:r = aria_rl_measure_text(text, font_size);
    pass(r);
};

