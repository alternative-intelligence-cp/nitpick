# build.abc — aria-entangled package
#
# Targets:
#   aria-entangled       — compiled library for downstream packages
#   test-aria-entangled  — test binary

[project]
name = "aria-entangled"
version = "0.1.0"
compiler = "/home/randy/Workspace/REPOS/aria/build/ariac"

[target.aria-entangled]
type = "library"
sources = ["src/aria_entangled.aria"]
deps = []
flags = []

[target.test-aria-entangled]
type = "binary"
sources = ["tests/test_aria_entangled.aria"]
deps = []
flags = []
