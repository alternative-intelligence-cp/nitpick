# build.abc — aria-vec package
#
# Targets:
#   aria-vec       — compiled library for downstream packages
#   test-aria-vec  — test binary; imports src via `use "../src/aria_vec.aria".*;`

[project]
name = "aria-vec"
version = "0.1.0"
compiler = "/home/randy/Workspace/REPOS/aria/build/ariac"

[target.aria-vec]
type = "library"
sources = ["src/aria_vec.aria"]
deps = []
flags = []

[target.test-aria-vec]
type = "binary"
sources = ["tests/test_aria_vec.aria"]
deps = []
flags = []
