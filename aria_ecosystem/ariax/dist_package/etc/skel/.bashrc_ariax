# AriaX Six-Stream Bash Configuration
# This file provides helpers for working with the six-stream I/O model

# AriaX streams are already set by the shell:
# STDDBG=/dev/fd/3  - Debug output
# STDDATI=/dev/fd/4 - Data input
# STDDATO=/dev/fd/5 - Data output

# Convenience functions for six-stream I/O
dbg() {
    echo "[DEBUG] $*" >&3
}

data_out() {
    echo "$*" >&5
}

data_in() {
    cat <&4
}

# Example usage:
# dbg "Starting process..."
# data_out "Result: 42"
# result=$(data_in)

# Pretty prompt showing we're in AriaX
export PS1='\[\033[01;36m\]AriaX\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '

# Add AriaX tools to PATH
export PATH="/usr/local/bin:$PATH"

# Welcome message on first login
if [ ! -f ~/.ariax_welcome_shown ]; then
    cat << 'EOF'
╔══════════════════════════════════════════════════════════════╗
║                   Welcome to AriaX Linux                     ║
║          Alternative Intelligence Liberation Platform        ║
╠══════════════════════════════════════════════════════════════╣
║                                                              ║
║  You are running a six-stream I/O enabled system:           ║
║                                                              ║
║    FD 0: stdin   - Standard input                           ║
║    FD 1: stdout  - Standard output                          ║
║    FD 2: stderr  - Standard error                           ║
║    FD 3: stddbg  - Debug messages  ($STDDBG)                ║
║    FD 4: stddati - Data input      ($STDDATI)               ║
║    FD 5: stddato - Data output     ($STDDATO)               ║
║                                                              ║
║  Helper functions available:                                ║
║    dbg "message"     - Write to debug stream                ║
║    data_out "data"   - Write to data output stream          ║
║    result=$(data_in) - Read from data input stream          ║
║                                                              ║
║  AriaX tools installed:                                     ║
║    ariash    - Six-stream aware shell                       ║
║    aria_make - Build system with stream support             ║
║                                                              ║
║  Documentation: /usr/local/share/ariax/README.md            ║
║                                                              ║
╚══════════════════════════════════════════════════════════════╝
EOF
    touch ~/.ariax_welcome_shown
fi
