// expect-exit: 7

struct:Leaf = {
    int32:x;
};

struct:Box = {
    Leaf->:leaf;
    int32:tag;
};

func:failsafe = int32(tbb32:err) {
    exit 7;
};

func:main = int32() {
    stack Leaf:leaf = Leaf{x: 10};
    stack Box:box = Box{leaf: @leaf, tag: 1};
    stack Box->:pin = #box;
    pin->leaf->x = 44;
    exit 0;
};