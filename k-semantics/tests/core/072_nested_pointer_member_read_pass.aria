// expect-exit: 10

struct:Leaf = {
    int32:x;
};

struct:Box = {
    Leaf->:leaf;
    int32:tag;
};

func:failsafe = int32(tbb32:err) {
    exit 7;
};

func:main = int32() {
    stack Leaf:leaf = Leaf{x: 10};
    stack Box:box = Box{leaf: @leaf, tag: 1};
    stack Box->:ptr = @box;
    int32:got = ptr->leaf->x;
    exit got;
};