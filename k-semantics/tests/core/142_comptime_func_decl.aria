// expect-exit: 8
// v0.24.7 COMPTIME-014: comptime func: declarations register in
// <comptime-env> and remain callable like ordinary functions.
comptime func:dbl = int32(int32:n) { pass n + n; };
func:failsafe = int32(tbb32:err) { exit 1; };
func:main = int32() {
    int32:r = raw dbl(4);
    exit r;
};
