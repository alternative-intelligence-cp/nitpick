// Test map module functionality
func:main = int32() {
    // Create a map for int64 -> string
    wild void->:m = map_new(8, 8);  // sizeof(int64), sizeof(ptr)
    
    // Insert some key-value pairs
    int64:key1 = 42;
    string:val1 = "Hello";
    map_insert(m, @key1, @val1);
    
    int64:key2 = 100;
    string:val2 = "World";
    map_insert(m, @key2, @val2);
    
    // Check has
    if (map_has(m, @key1)) {
        print("Found key 42");
    }
    
    // Get values
    wild void->:result1 = map_get(m, @key1);
    if (result1 != NULL) {
        // Note: result is void*, need to cast
        print("Retrieved value for 42");
    }
    
    // Check length
    int64:len = map_length(m);
    print("Map has");
    print(len);
    print("entries");
    
    // Remove a key
    map_remove(m, @key1);
    
    int64:new_len = map_length(m);
    print("After remove, map has");
    print(new_len);
    print("entries");
};
