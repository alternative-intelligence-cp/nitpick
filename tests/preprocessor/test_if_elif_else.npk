/**
 * Test: %if / %elif / %else chains
 * Expected: COMPILES SUCCESSFULLY
 * Verifies: correct branch selected; %elif and %else work
 */

%assign LEVEL 2

%if LEVEL == 1
%define BRANCH_TAKEN 1i32
%elif LEVEL == 2
%define BRANCH_TAKEN 2i32
%else
%define BRANCH_TAKEN 0i32
%endif

func:main = int32() {
    int32:r = BRANCH_TAKEN;
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};
