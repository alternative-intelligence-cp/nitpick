/**
 * Test: %str() directive — inline stringify of arbitrary text
 * Expected: COMPILES SUCCESSFULLY
 * Verifies: %str(content) is replaced inline with "content" as a string literal
 */

func:main = int32() {
    println(%str(Hello from preprocessor));
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};
