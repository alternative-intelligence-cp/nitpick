// test_define_redefinition.npk
// v0.21.1: Redefining a macro with a different value emits a warning but
// compilation succeeds.
// Expected: COMPILES SUCCESSFULLY (warning in stderr about redefinition)

%define MY_CONST 20i32
%define MY_CONST 40i32

func:failsafe = int32(tbb32:err) {
    exit 1;
};

func:main = int32() {
    int32:v = MY_CONST;
    if (v != 40i32) { exit 1; }
    exit 0;
};
