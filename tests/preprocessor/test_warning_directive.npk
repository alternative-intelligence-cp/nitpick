/**
 * Test: %warning directive emits a build warning but compilation succeeds
 * Expected: COMPILES SUCCESSFULLY (exits 0); stderr contains the warning text
 */

%warning "This is an intentional build warning from the preprocessor"

func:main = int32() {
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};
