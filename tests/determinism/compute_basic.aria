/**
 * Determinism Test: Basic Computation
 * Tests that computation results are deterministic
 */

func:main = int32() {
    // Deterministic computation
    int64:a = 10;
    int64:b = 20;
    int64:c = (a + b);
    int64:d = (c * 2);
    int64:e = (d - 5);

    // Output should always be the same
    print(a);
    print(b);
    print(c);
    print(d);
    print(e);

    return 0;
};
