/**
 * Determinism Test: Nested Loops
 * Tests that nested loop results are deterministic
 */

func:main = int32() {
    int64:outer = 0;
    int64:outer_count = 3;

    while (outer < outer_count) {
        int64:inner = 0;
        int64:inner_count = 3;

        while (inner < inner_count) {
            int64:product = (outer * inner);
            print(product);
            inner = (inner + 1);
        }

        outer = (outer + 1);
    }

    return 0;
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
