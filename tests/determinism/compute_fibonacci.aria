/**
 * Determinism Test: Fibonacci Sequence
 * Tests deterministic recursive-style computation
 */

func:main = int32() {
    int64:a = 0;
    int64:b = 1;
    int64:i = 0;
    int64:count = 15;

    print(a);
    print(b);

    while (i < count) {
        int64:next = (a + b);
        print(next);
        a = b;
        b = next;
        i = (i + 1);
    }

    return 0;
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
