/**
 * Determinism Test: Fibonacci Sequence
 * Tests deterministic recursive-style computation
 */

func:main = int32() {
    int64:a = 0;
    int64:b = 1;
    int64:i = 0;
    int64:count = 15;

    while (i < count) {
        int64:next = (a + b);
        a = b;
        b = next;
        i = (i + 1);
    }

    exit(0);
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit(1);
};
