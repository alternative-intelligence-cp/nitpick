// Test file for trit Kleene logic operations
// Verifies GOTCHA #5 fix: AND/OR use runtime functions, not bitwise ops

func:test_trit_and = NIL() {
    trit:a = 1;
    trit:b = -1;
    trit:result = trit_and(a, b);  // Should call aria_trit_and (min semantics)
    // Expected: min(1, -1) = -1
    
    trit:c = 1;
    trit:d = 1;
    trit:result2 = trit_and(c, d);  // Should return 1
    // Expected: min(1, 1) = 1
};

func:test_trit_or = NIL() {
    trit:a = 1;
    trit:b = -1;
    trit:result = trit_or(a, b);  // Should call aria_trit_or (max semantics)
    // Expected: max(1, -1) = 1
    
    trit:c = -1;
    trit:d = -1;
    trit:result2 = trit_or(c, d);  // Should return -1
    // Expected: max(-1, -1) = -1
};

func:test_trit_arithmetic = NIL() {
    trit:a = 1;
    trit:b = 1;
    trit:sum = a + b;  // Should call aria_trit_add
    // Expected: ERR (overflow, 1 + 1 = 2)
    
    trit:c = 1;
    trit:d = -1;
    trit:diff = c - d;  // Should call aria_trit_sub
    // Expected: ERR (overflow, 1 - (-1) = 2)
};

func:main = int32() {
    drop test_trit_and();
    drop test_trit_or();
    drop test_trit_arithmetic();
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
