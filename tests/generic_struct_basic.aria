// Generic Struct Basic Test
// Tests basic generic struct instantiation and usage

// Generic Box struct that holds a single value of type T
struct<T>:Box = {
    *T:value;
};

// Generic Result struct with two type parameters
struct<T, E>:Result = {
    *T:value;
    *E:error;
    bool:is_ok;
};

func:main = int64() {
    // Instantiate Box with int64
    Box<int64>:intBox;
    
    // Instantiate Box with string
    Box<string>:strBox;
    
    // Instantiate Result with int64 and string
    Result<int64, string>:result;
    
    return 0;
};
