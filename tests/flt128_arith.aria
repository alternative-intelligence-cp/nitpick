// Test flt128 arithmetic
// Part of Phase 3.2: Extended Precision Floats

func:main = int32() {
    // Test flt128 arithmetic operations
    flt128:a = 1.5;
    flt128:b = 2.5;

    flt128:sum = a + b;
    flt128:diff = b - a;
    flt128:prod = a * 2.0;

    int32:zero = 0;
    pass(zero);
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit(1);
};
