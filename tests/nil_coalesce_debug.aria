// Minimal test for null coalescing assignment debugging

func:main = int32() {
    print("Testing null coalescing assignment");
    
    // Test 1: Simple optional with value
    int64?:opt = 42;
    int64:result1 = opt ?? 999;
    print(result1);  // Should print 42
    
    // Test 2: Direct value without optional
    int64:direct = 55;
    print(direct);  // Should print 55
    
    pass(0);
};
