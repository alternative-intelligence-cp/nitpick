// Basic spaceship operator test
// Spaceship operator (<=>) returns:
//   -1 if left < right
//    0 if left == right
//    1 if left > right

func:failsafe = int32(tbb32:err) {
    print("ERROR");
    exit(1);
};

func:test_spaceship = int64() {
    int64:x = 5;
    int64:y = 3;
    int64:z = 5;
    
    // Test: x <=> y should be 1 (since 5 > 3)
    int64:result1 = x <=> y;
    
    // Test: y <=> x should be -1 (since 3 < 5)
    int64:result2 = y <=> x;
    
    // Test: x <=> z should be 0 (since 5 == 5)
    int64:result3 = x <=> z;
    
    // Return sum: 1 + (-1) + 0 = 0
    pass(result1 + result2 + result3);
};

func:main = int32() {
    int64:r = raw(test_spaceship());
    exit(0);
};
