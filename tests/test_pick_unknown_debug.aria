// Test: Test each pick unknown scenario individually
// Phase 5.4: Diagnose which tests pass/fail

func:test1 = int32() {
    int32:x = unknown;
    
    pick(x) {
        (unknown) {
            pass 1i32;
        },
        (*) {
            pass 100i32;  // FAIL marker
        }
    }
};

func:test2 = int32() {
    int32:y = 42i32;
    
    pick(y) {
        (unknown) {
            pass 200i32;  // FAIL marker - shouldn't match unknown
        },
        (42i32) {
            pass 2i32;
        },
        (*) {
            pass 201i32;  // FAIL marker
        }
    }
};

func:test3 = int32() {
    int32:z = unknown;
    
    pick(z) {
        (unknown) {
            pass 3i32;
        },
        (*) {
            pass 300i32;  // FAIL marker
        }
    }
};

func:test4 = int32() {
    int32:w = unknown;
    
    pick(w) {
        (0i32) {
            pass 400i32;  // FAIL marker
        },
        (unknown) {
            pass 4i32;
        },
        (100i32) {
            pass 401i32;  // FAIL marker
        },
        (*) {
            pass 402i32;  // FAIL marker
        }
    }
};

func:main = int32() {
    // Run each test individually to see results
    int32:result1 = raw test1();
    int32:result2 = raw test2();
    int32:result3 = raw test3();
    int32:result4 = raw test4();
    
    // Return sum - should be 10 if all exit
    // Any value >= 100 indicates which test failed
    exit result1 + result2 + result3 + result4;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
