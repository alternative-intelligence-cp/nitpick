// Expected: COMPILER ERROR - accesses unimplemented dbug internal state
/**
 * DBUG Variable Watchpoint Test
 * 
 * Demonstrates the variable watching feature for tracking changes.
 * 
 * Key Concept:
 * - Watchpoints are NOT automatic (would need compiler hooks)
 * - You manually call dbug_watch_check_all() at strategic points
 * - Perfect for tracking loop counters, state changes, etc.
 */

use stdlib.dbug;

/**
 * Simulates a loop where we want to track a counter.
 */
func:test_basic_watch = NIL() {
    raw dbug_separator("watch");
    raw dbug_print("watch", "TEST: Basic variable watching");
    
    int64:counter = 0i64;
    
    // Register watch BEFORE the loop
    int64->:counter_ptr = @counter;
    dbug_watch_int64("watch", "counter", counter_ptr);
    
    // Loop that modifies counter
    while (counter < 5i64) {
        counter = counter + 1i64;
        
        // Check all watches (alerts when counter changes)
        dbug_watch_check_all();
    }
    
    // Clean up
    dbug_watch_remove(counter_ptr);
    
    raw dbug_separator("watch");
    pass;
};

/**
 * Simulates tracking multiple variables simultaneously.
 */
func:test_multiple_watches = NIL() {
    raw dbug_separator("watch");
    raw dbug_print("watch", "TEST: Multiple variable tracking");
    
    int64:x = 0i64;
    int64:y = 0i64;
    int64:sum = 0i64;
    
    // Watch all three variables
    dbug_watch_int64("watch", "x", @x);
    dbug_watch_int64("watch", "y", @y);
    dbug_watch_int64("watch", "sum", @sum);
    
    // Show what we're watching
    dbug_watch_list();
    
    // Modify variables
    x = 10i64;
    dbug_watch_check_all();  // Should see x changed
    
    y = 20i64;
    dbug_watch_check_all();  // Should see y changed
    
    sum = x + y;
    dbug_watch_check_all();  // Should see sum changed
    
    // Clean up all at once
    dbug_watch_clear_all();
    
    raw dbug_separator("watch");
    pass;
};

/**
 * Demonstrates conditional watching (only enabled groups alert).
 */
func:test_conditional_watch = NIL() {
    raw dbug_separator("watch");
    raw dbug_print("watch", "TEST: Conditional watching with groups");
    
    int64:important = 0i64;
    int64:verbose = 0i64;
    
    // Watch with different groups
    dbug_watch_int64("important", "important_var", @important);
    dbug_watch_int64("verbose", "verbose_var", @verbose);
    
    // Only enable "important" group
    raw dbug_enable("important");
    raw dbug_disable("verbose");
    
    drop println("\n--- Only 'important' group enabled ---");
    
    important = 42i64;
    verbose = 99i64;
    
    // Should only see alert for 'important'
    dbug_watch_check_all();
    
    drop println("\n--- Now enable 'verbose' too ---");
    raw dbug_enable("verbose");
    
    important = 123i64;
    verbose = 456i64;
    
    // Should see alerts for both
    dbug_watch_check_all();
    
    dbug_watch_clear_all();
    raw dbug_separator("watch");
    pass;
};

/**
 * Demonstrates watching in a complex scenario: state machine.
 */
func:test_state_machine_watch = NIL() {
    raw dbug_separator("state");
    raw dbug_print("state", "TEST: State machine variable tracking");
    
    // State machine states (simple enum simulation)
    int64:STATE_IDLE = 0i64;
    int64:STATE_CONNECTING = 1i64;
    int64:STATE_CONNECTED = 2i64;
    int64:STATE_ERROR = 9i64;
    
    int64:current_state = STATE_IDLE;
    int64:retry_count = 0i64;
    
    // Watch state transitions
    dbug_watch_int64("state", "current_state", @current_state);
    dbug_watch_int64("state", "retry_count", @retry_count);
    
    // Simulate state transitions
    drop println("\n1. Starting connection...");
    current_state = STATE_CONNECTING;
    dbug_watch_check_all();
    
    drop println("\n2. Connection failed, retrying...");
    current_state = STATE_ERROR;
    retry_count = retry_count + 1i64;
    dbug_watch_check_all();
    
    drop println("\n3. Retry attempt...");
    current_state = STATE_CONNECTING;
    dbug_watch_check_all();
    
    drop println("\n4. Successfully connected!");
    current_state = STATE_CONNECTED;
    dbug_watch_check_all();
    
    dbug_watch_clear_all();
    raw dbug_separator("state");
    pass;
};

/**
 * Demonstrates the manual checkpoint pattern.
 */
func:test_strategic_checkpoints = NIL() {
    raw dbug_separator("checkpoint");
    raw dbug_print("checkpoint", "TEST: Strategic checkpoint placement");
    
    int64:balance = 1000i64;
    dbug_watch_int64("checkpoint", "account_balance", @balance);
    
    drop println("\nInitial balance: 1000");
    
    // Checkpoint 1: After deposit
    drop println("\nDeposit: +500");
    balance = balance + 500i64;
    dbug_watch_check_all();  // Shows balance changed
    
    // Checkpoint 2: After withdrawal
    drop println("\nWithdrawal: -200");
    balance = balance - 200i64;
    dbug_watch_check_all();  // Shows balance changed
    
    // Checkpoint 3: After interest
    drop println("\nInterest: +13");
    balance = balance + 13i64;
    dbug_watch_check_all();  // Shows balance changed
    
    drop println("\nFinal balance check:");
    dbug_watch_check_all();  // No change (same as last check)
    
    dbug_watch_clear_all();
    raw dbug_separator("checkpoint");
    pass;
};

/**
 * Main test harness.
 */
func:main = int32() {
    drop println("=== DBUG Watchpoint System Test ===\n");
    
    // Enable watch and related groups
    raw dbug_enable("watch");
    raw dbug_enable("state");
    raw dbug_enable("checkpoint");
    
    drop println("=== Test 1: Basic Variable Watching ===");
    raw test_basic_watch();
    
    drop println("\n=== Test 2: Multiple Variables ===");
    raw test_multiple_watches();
    
    drop println("\n=== Test 3: Group-Based Filtering ===");
    raw test_conditional_watch();
    
    drop println("\n=== Test 4: State Machine Tracking ===");
    raw test_state_machine_watch();
    
    drop println("\n=== Test 5: Strategic Checkpoints ===");
    raw test_strategic_checkpoints();
    
    // Summary
    drop println("\n=== ALL WATCHPOINT TESTS COMPLETE ===\n");
    drop println("Key Takeaways:");
    drop println("  ✓ Watchpoints track variable changes via pointers");
    drop println("  ✓ dbug_watch_check_all() must be called manually");
    drop println("  ✓ Place checks at loop ends, after operations, etc.");
    drop println("  ✓ Group filtering controls which changes are visible");
    drop println("  ✓ Perfect for tracking counters, state, balances");
    drop println("");
    drop println("Limitation:");
    drop println("  ⚠ NOT automatic - you control when checks happen");
    drop println("  ⚠ Cannot detect changes between check calls");
    drop println("  ⚠ Currently only supports int64 variables");
    drop println("");
    drop println("Future: Add dbug_watch_int32, dbug_watch_float64, etc.");
    
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
