// Range-based for loop with type annotations

func:main = int32() {
    print("Testing type-annotated range-based for loops:");
    
    // With int64 type annotation (explicit)
    print("int64:i in 1..3:");
    for (int64:i in 1..3) {
        print(i);
    }
    
    // With int32 type annotation
    print("int32:j in 10...13:");
    for (int32:j in 10...13) {
        print(j);
    }
    
    pass(0);
};
