// HashMap Basic Test - Validate two-parameter generic HashMap works
// Tests: Define HashMap struct with <K,V> parameters

// HashMap with two type parameters
struct<K, V>:HashMap = {
    int64:capacity;
    int64:length;
    bool:initialized;
};

// HashEntry with two type parameters
struct<K, V>:HashEntry = {
    K:key;
    V:value;
    bool:occupied;
};

// Test main - just validate struct declarations compile
func:main = int32() {
    // Declare HashMap variables with different type parameter combinations
    HashMap<int64, int32>:scores;
    HashMap<string, int64>:users;
    HashMap<int32, bool>:flags;
    
    // Declare HashEntry variables
    HashEntry<int64, int32>:score_entry;
    HashEntry<string, int64>:user_entry;
    
    pass(0i32);
};


func:failsafe = NIL(int32:err_code) {
    // Error handling
};
