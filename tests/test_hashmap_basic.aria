// HashMap<K,V> Basic Test - Phase 1: Type System
// Testing that HashMap<K,V> type is recognized and fields are mutable

// FFI declarations for HashMap runtime
extern func:aria_map_new_simple = wild int8*(int64:key_size, int64:value_size);
extern func:aria_map_length = int64(wild int8*:map);
extern func:aria_map_free = void(wild int8*:map);

// Helper to create initialized HashMap
func:HashMap_int32_int64_new = HashMap<int32, int64>() {
    HashMap<int32, int64>:map;
    
    // Call runtime to create map (key_size=4, value_size=8)
    map.entries = aria_map_new_simple(4i64, 8i64);
    map.capacity = 16i64;
    map.length = 0i64;
    map.key_size = 4i64;
    map.value_size = 8i64;
    map.load_factor = 0.75f32;
    
    pass map;
};

func:main = int32() {
    // Test 1: Create HashMap<int32, int64>
    HashMap<int32, int64>:scores = raw HashMap_int32_int64_new();
    
    // Test 2: Mutate fields (tests our struct field mutation fix!)
    scores.length = 42i64;
    scores.capacity = 128i64;
    
    // Test 3: Verify field assignments persisted
    if (scores.length != 42i64) {
        pass 1i32;  // FAIL: length should be 42
    }
    
    if (scores.capacity != 128i64) {
        pass 2i32;  // FAIL: capacity should be 128
    }
    
    exit 0;  // SUCCESS!
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};
