/**
 * Inline Q3 test - define Q3 in same file
 */

struct<T>:Q3 = {
    T:a;
    T:b;
    trit:c;
};

pub func<T>:q3_create = Q3<T>(T:a, T:b, trit:c) {
    Q3<T>:q;
    q.a = a;
    q.b = b;
    q.c = c;
    pass(q);
};

func:failsafe = int32(int32:err_code) {
    pass(err_code);
};

func:main = int32() {
    Q3<int32>:q;
    q.a = 10;
    q.b = 20;
    q.c = 0;
    pass(0);
};
