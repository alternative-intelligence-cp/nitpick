func:main = int32() {
    // Test int2048
    int2048:a_2048 = 1000000000;
    int2048:b_2048 = 2000000000;
    int2048:sum_2048 = a_2048 + b_2048;
    int2048:expected_2048 = 3000000000;
    
    if (sum_2048 != expected_2048) {
        return 1;  // int2048 addition failed
    }
    
    int2048:diff_2048 = sum_2048 - b_2048;
    if (diff_2048 != a_2048) {
        return 2;  // int2048 subtraction failed
    }
    
    int2048:prod_2048 = a_2048 * 3;
    int2048:prod_exp_2048 = 3000000000;
    if (prod_2048 != prod_exp_2048) {
        return 3;  // int2048 multiplication failed
    }
    
    // Test int4096
    int4096:a_4096 = 1000000000;
    int4096:b_4096 = 2000000000;
    int4096:sum_4096 = a_4096 + b_4096;
    int4096:expected_4096 = 3000000000;
    
    if (sum_4096 != expected_4096) {
        return 4;  // int4096 addition failed
    }
    
    int4096:diff_4096 = sum_4096 - b_4096;
    if (diff_4096 != a_4096) {
        return 5;  // int4096 subtraction failed
    }
    
    int4096:prod_4096 = a_4096 * 3;
    int4096:prod_exp_4096 = 3000000000;
    if (prod_4096 != prod_exp_4096) {
        return 6;  // int4096 multiplication failed
    }
    
    // Test division
    int4096:div_test = sum_4096 / 3;
    if (div_test != a_4096) {
        return 7;  // int4096 division failed
    }
    
    // All tests passed!
    return 0;
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
