// Vec<T> Phase 2: Constructor and Methods Test
// Tests Vec::new() equivalent and basic operations

// Create a new Vec<int32>
func:vec_new_int32 = Vec<int32>() {
    Vec<int32>:v;
    v.data = NULL;
    v.length = 0;
    v.capacity = 0;
    v.element_size = 4; // sizeof(int32)
    v.type_id = 1;
    pass(v);
};

// Get Vec length
func:vec_len_int32 = int64(Vec<int32>@:vec) {
    pass(vec.length);
};

func:main = int32() {
    // Test Vec creation
    Vec<int32>:numbers = vec_new_int32();
    
    // Verify initial state
    int64:len = vec_len_int32(&numbers);
    if (len != 0) {
        pass(1); // Fail: initial length should be 0
    };
    
    pass(0); // Success
};

func:failsafe = int32(int32:err_code) {
    pass(err_code);
};
