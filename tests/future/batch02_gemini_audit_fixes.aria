// ARIA Batch 02 Gemini Audit - Safety Critical Bug Fix Verification
// Tests all 4 bugs identified by Gemini SIL-4 audit:
//   BUG-004: TBB narrowing wraparound (CRITICAL)
//   BUG-005: Trit/nit logic inversion (CRITICAL)
//   BUG-006: Trit/nit sentinel healing (CRITICAL)
//   BUG-007: Nit error swallowing (MEDIUM)

// ==============================================================================
// BUG-004: TBB Narrowing Wraparound (Force Limit Bypass)
// ==============================================================================
// Physical Consequence Prevented: Robot grip force 300 Nm appears as 44 Nm

func:test_bug004_tbb8_wraparound = void() {
    // Before fix: 300 would wrap to 44 (0x012C → 0x2C)
    // After fix: 300 should return ERR sentinel (-128)
    
    int32:test_val = 300;  // Use variable to test runtime validation
    tbb8:val_tbb8 = tbb8_from_int(test_val);
    
    // Should be ERR, not 44 - explicit error check
    if (tbb8_is_err(val_tbb8)) {
        drop(print("✓ BUG-004: TBB8 overflow returns ERR (not 44)"));
    } else {
        drop(print("✗ FAIL: TBB8 overflow wrapped to: "));
        drop(print(val_tbb8));
    }
};

func:test_bug004_tbb8_underflow = void() {
    // Test negative overflow
    int32:test_val = -300;  // Use variable to test runtime validation
    tbb8:val_tbb8 = tbb8_from_int(test_val);
    
    if (tbb8_is_err(val_tbb8)) {
        drop(print("✓ BUG-004: TBB8 underflow returns ERR"));
    } else {
        drop(print("✗ FAIL: TBB8 underflow value: "));
        drop(print(val_tbb8));
    }
};

func:test_bug004_tbb8_valid_positive = void() {
    // Test edge of valid range (should work)
    tbb8:val_tbb8 = tbb8_from_int(127);
    
    // Explicit conversion to compare numeric value
    if (tbb8_to_int(val_tbb8) == 127) {
        drop(print("✓ BUG-004: TBB8 max valid value passes"));
    } else {
        drop(print("✗ FAIL: TBB8 max valid corrupted: "));
        drop(print(val_tbb8));
    }
};

func:test_bug004_tbb8_valid_negative = void() {
    // Test negative edge of valid range
    tbb8:val_tbb8 = tbb8_from_int(-127);
    
    // Explicit conversion - NOT checking error, checking value
    if (tbb8_to_int(val_tbb8) == -127) {
        drop(print("✓ BUG-004: TBB8 min valid value passes"));
    } else {
        drop(print("✗ FAIL: TBB8 min valid corrupted: "));
        drop(print(val_tbb8));
    }
};

func:test_bug004_tbb16_wraparound = void() {
    // Test tbb16 overflow (35000 > 32767)
    int32:test_val = 35000;  // Use variable to test runtime validation
    tbb16:val_tbb16 = tbb16_from_int(test_val);
    
    // Explicit error check - don't compare with int32 literal
    if (tbb16_is_err(val_tbb16)) {
        drop(print("✓ BUG-004: TBB16 overflow returns ERR"));
    } else {
        drop(print("✗ FAIL: TBB16 overflow value: "));
        drop(print(val_tbb16));
    }
};

func:test_bug004_tbb32_wraparound = void() {
    // Test tbb32 overflow (would require int64 input in real code)
    // This tests that the mechanism exists
    tbb32:val_tbb32 = tbb32_from_int(2147483647);  // Max valid
    
    // Explicit conversion to compare value, not error state
    if (tbb32_to_int(val_tbb32) == 2147483647) {
        drop(print("✓ BUG-004: TBB32 max valid passes"));
    } else {
        drop(print("✗ FAIL: TBB32 max valid corrupted: "));
        drop(print(val_tbb32));
    }
};

// ==============================================================================
// BUG-005: Trit/Nit Logic Inversion (Security Bypass)
// ==============================================================================
// Physical Consequence Prevented: permission && validated = true when should be false

func:test_bug005_trit_and_logic = void() {
    // Before fix: True (1) AND False (-1) = 1 (bitwise 0x01 & 0xFF = 0x01)
    // After fix: Should be -1 (min(1, -1) = -1)
    
    trit:true_val = 1;
    trit:false_val = -1;
    trit:result = trit_and(true_val, false_val);
    
    if (result == -1) {
        drop(print("✓ BUG-005: Trit AND(true, false) = false"));
    } else {
        drop(print("✗ FAIL: Trit AND logic inverted, got: "));
        drop(print(result));
    }
};

func:test_bug005_trit_or_logic = void() {
    // Test OR logic: OR(false, true) = true
    trit:false_val = -1;
    trit:true_val = 1;
    trit:result = trit_or(false_val, true_val);
    
    if (result == 1) {
        drop(print("✓ BUG-005: Trit OR(false, true) = true"));
    } else {
        drop(print("✗ FAIL: Trit OR logic broken, got: "));
        drop(print(result));
    }
};

func:test_bug005_trit_and_both_false = void() {
    // AND(false, false) = false
    trit:false1 = -1;
    trit:false2 = -1;
    trit:result = trit_and(false1, false2);
    
    if (result == -1) {
        drop(print("✓ BUG-005: Trit AND(false, false) = false"));
    } else {
        drop(print("✗ FAIL: Trit AND both false, got: "));
        drop(print(result));
    }
};

func:test_bug005_trit_and_both_true = void() {
    // AND(true, true) = true
    trit:true1 = 1;
    trit:true2 = 1;
    trit:result = trit_and(true1, true2);
    
    if (result == 1) {
        drop(print("✓ BUG-005: Trit AND(true, true) = true"));
    } else {
        drop(print("✗ FAIL: Trit AND both true, got: "));
        drop(print(result));
    }
};

func:test_bug005_trit_unknown_and_true = void() {
    // AND(unknown, true) = unknown (Kleene logic)
    trit:unknown = 0;
    trit:true_val = 1;
    trit:result = trit_and(unknown, true_val);
    
    if (result == 0) {
        drop(print("✓ BUG-005: Trit AND(unknown, true) = unknown"));
    } else {
        drop(print("✗ FAIL: Trit three-valued logic broken, got: "));
        drop(print(result));
    }
};

func:test_bug005_nit_and_logic = void() {
    // Test nonary AND logic (uses same Kleene semantics)
    nit:val1 = 3;   // "more true"
    nit:val2 = -2;  // "more false"
    nit:result = nit_and(val1, val2);
    
    // min(3, -2) = -2
    if (result == -2) {
        drop(print("✓ BUG-005: Nit AND uses min (Kleene logic)"));
    } else {
        drop(print("✗ FAIL: Nit AND logic broken, got: "));
        drop(print(result));
    }
};

func:test_bug005_nit_or_logic = void() {
    // Test nonary OR logic
    nit:val1 = 2;
    nit:val2 = -3;
    nit:result = nit_or(val1, val2);
    
    // max(2, -3) = 2
    if (result == 2) {
        drop(print("✓ BUG-005: Nit OR uses max (Kleene logic)"));
    } else {
        drop(print("✗ FAIL: Nit OR logic broken, got: "));
        drop(print(result));
    }
};

// ==============================================================================
// BUG-006: Trit/Nit Sentinel Healing (Error Laundering)
// ==============================================================================
// Physical Consequence Prevented: Corrupted sensor reading appears valid

func:test_bug006_trit_err_propagation_add = void() {
    // Before fix: ERR (-128) + 1 = -127 (becomes "valid")
    // After fix: ERR + 1 = ERR (sticky error)
    
    trit:err_trit = -128;  // TRIT_ERR sentinel
    trit:one = 1;
    trit:result = err_trit + one;
    
    if (result == -128) {
        drop(print("✓ BUG-006: Trit ERR + 1 = ERR (sticky)"));
    } else {
        drop(print("✗ FAIL: Trit error healed to: "));
        drop(print(result));
    }
};

func:test_bug006_trit_err_propagation_mul = void() {
    // ERR * valid = ERR
    trit:err_trit = -128;
    trit:val = 1;
    trit:result = err_trit * val;
    
    if (result == -128) {
        drop(print("✓ BUG-006: Trit ERR * val = ERR"));
    } else {
        drop(print("✗ FAIL: Trit ERR multiplication healed to: "));
        drop(print(result));
    }
};

func:test_bug006_trit_err_propagation_and = void() {
    // ERR && true = ERR
    trit:err_trit = -128;
    trit:true_val = 1;
    trit:result = trit_and(err_trit, true_val);
    
    if (result == -128) {
        drop(print("✓ BUG-006: Trit ERR && true = ERR"));
    } else {
        drop(print("✗ FAIL: Trit ERR logic healed to: "));
        drop(print(result));
    }
};

func:test_bug006_nit_err_propagation = void() {
    // NIT_ERR + valid = NIT_ERR
    nit:err_nit = -128;
    nit:val = 2;
    nit:result = err_nit + val;
    
    if (result == -128) {
        drop(print("✓ BUG-006: Nit ERR + val = ERR (sticky)"));
    } else {
        drop(print("✗ FAIL: Nit error healed to: "));
        drop(print(result));
    }
};

// ==============================================================================
// BUG-007: Nit Error Swallowing (Silent Saturation)
// ==============================================================================
// Physical Consequence Prevented: Accumulated sensor values hit ceiling, appear valid

func:test_bug007_nit_add_overflow = void() {
    // Before fix: 3 + 2 = 4 (saturated)
    // After fix: 3 + 2 = ERR (overflow for nit range [-4, 4])
    
    nit:val1 = 3;
    nit:val2 = 2;
    nit:result = val1 + val2;
    
    if (result == -128) {  // NIT_ERR
        drop(print("✓ BUG-007: Nit overflow returns ERR (not saturated)"));
    } else {
        drop(print("✗ FAIL: Nit overflow saturated to: "));
        drop(print(result));
    }
};

func:test_bug007_nit_add_underflow = void() {
    // -3 + (-2) = -5, out of range [-4, 4]
    nit:val1 = -3;
    nit:val2 = -2;
    nit:result = val1 + val2;
    
    if (result == -128) {
        drop(print("✓ BUG-007: Nit underflow returns ERR"));
    } else {
        drop(print("✗ FAIL: Nit underflow saturated to: "));
        drop(print(result));
    }
};

func:test_bug007_nit_mul_overflow = void() {
    // 3 * 2 = 6, out of range
    nit:val1 = 3;
    nit:val2 = 2;
    nit:result = val1 * val2;
    
    if (result == -128) {
        drop(print("✓ BUG-007: Nit mul overflow returns ERR"));
    } else {
        drop(print("✗ FAIL: Nit mul overflow saturated to: "));
        drop(print(result));
    }
};

func:test_bug007_nit_valid_addition = void() {
    // Test edge case: 4 + 0 = 4 (should work)
    nit:max_nit = 4;
    nit:zero = 0;
    nit:result = max_nit + zero;
    
    if (result == 4) {
        drop(print("✓ BUG-007: Nit max + 0 = max (valid)"));
    } else {
        drop(print("✗ FAIL: Nit valid add corrupted to: "));
        drop(print(result));
    }
};

func:test_bug007_nit_edge_valid = void() {
    // 2 + 2 = 4 (exactly at edge, valid)
    nit:val1 = 2;
    nit:val2 = 2;
    nit:result = val1 + val2;
    
    if (result == 4) {
        drop(print("✓ BUG-007: Nit 2+2 = 4 (edge valid)"));
    } else {
        drop(print("✗ FAIL: Nit edge case value: "));
        drop(print(result));
    }
};

func:test_bug007_nit_just_over_edge = void() {
    // 2 + 3 = 5 (one past edge, overflow)
    nit:val1 = 2;
    nit:val2 = 3;
    nit:result = val1 + val2;
    
    if (result == -128) {
        drop(print("✓ BUG-007: Nit 2+3 = ERR (overflow)"));
    } else {
        drop(print("✗ FAIL: Nit just-over-edge value: "));
        drop(print(result));
    }
};

// ==============================================================================
// Integration Test: All Bugs Combined
// ==============================================================================

func:test_integration_safety_chain = void() {
    drop(print("=== Integration Test: Safety Barrier Chain ==="));
    
    // Scenario: Robot control with multiple safety checks
    // Declare all variables upfront to avoid scoping issues
    
    // 1. Force limit check (BUG-004)
    int32:measured_force = 300;  // Exceeds tbb8 range
    tbb8:force_tbb8 = tbb8_from_int(measured_force);
    
    // 2. Permission logic (BUG-005)
    trit:has_permission = 1;  // true
    trit:security_check = -1;  // false
    trit:access_granted = trit_and(has_permission, security_check);
    
    // 3. Sensor error propagation (BUG-006)
    trit:sensor_reading = -128;  // ERR from failed sensor
    trit:processed = sensor_reading + 1;  // Attempted error recovery
    
    // 4. Accumulator overflow (BUG-007)
    nit:accumulator = 3;
    nit:increment = 2;
    nit:new_value = accumulator + increment;
    
    // Validate results (no early returns)
    bool:all_pass = true;
    
    if (!tbb8_is_err(force_tbb8)) {
        drop(print("✗ INTEGRATION FAIL: Force wraparound not prevented"));
        all_pass = false;
    }
    
    trit:expected_access = -1;
    if (access_granted != expected_access) {
        drop(print("✗ INTEGRATION FAIL: Security bypass possible"));
        all_pass = false;
    }
    
    trit:expected_err = -128;
    if (processed != expected_err) {
        drop(print("✗ INTEGRATION FAIL: Sensor error laundered"));
        all_pass = false;
    }
    
    nit:expected_nit_err = -128;
    if (new_value != expected_nit_err) {
        drop(print("✗ INTEGRATION FAIL: Overflow saturation hiding error"));
        all_pass = false;
    }
    
    if (all_pass) {
        drop(print("✓ INTEGRATION: All 4 safety barriers functioning"));
        drop(print("   - Force limits enforced (BUG-004)"));
        drop(print("   - Logic inversion prevented (BUG-005)"));
        drop(print("   - Error propagation maintained (BUG-006)"));
        drop(print("   - Overflow detection working (BUG-007)"));
    }
};

