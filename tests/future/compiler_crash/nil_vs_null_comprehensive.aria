// ============================================================================
// NIL vs NULL Type Safety Tests
// ============================================================================
// This test verifies that NIL and NULL are properly distinguished and
// that type safety is enforced at compile time.
//
// NIL: Used ONLY for optional types (T?)
// NULL: Used ONLY for pointer types (T@)
//
// This distinction prevents entire classes of bugs by making absence-of-value
// semantics (NIL) separate from null-pointer semantics (NULL).
// ============================================================================

func:failsafe = NIL(int32:err_code) {
    print("Test failed with error");
};

func:returns_nil = int64?() {
    pass(NIL);
};

func:returns_value = int64?() {
    pass(42);
};

func:main = int32() {
    print("=== NIL vs NULL Type Safety Test Suite ===");
    
    // =========================================
    // VALID: NIL with Optional Types
    // =========================================
    print("\n1. NIL with Optional Types");
    int64?:opt_int = NIL;
    string?:opt_str = NIL;
    bool?:opt_bool = NIL;
    
    if (opt_int == NIL && opt_str == NIL && opt_bool == NIL) {
        print("  ✓ NIL works with all optional types");
    }
    
    // =========================================
    // VALID: NULL with Pointer Types
    // =========================================
    print("\n2. NULL with Pointer Types");
    int64->:ptr_int = NULL;
    string->:ptr_str = NULL;
    
    if (ptr_int == NULL && ptr_str == NULL) {
        print("  ✓ NULL works with all pointer types");
    }
    
    // =========================================
    // VALID: Optional Values and Extraction
    // =========================================
    print("\n3. Optional Values and Extraction");
    int64?:has_val = 100;
    int64?:no_val = NIL;
    
    int64:extracted1 = has_val ?? 999;  // Get 100
    int64:extracted2 = no_val ?? 888;   // Get 888 (default)
    
    if (extracted1 == 100 && extracted2 == 888) {
        print("  ✓ Optional value extraction works correctly");
    }
    
    // =========================================
    // VALID: Pointer with Address vs NULL
    // =========================================
    print("\n4. Pointer with Address vs NULL");
    int64:actual = 777;
    int64->:valid_ptr = @actual;
    int64->:null_ptr = NULL;
    
    if (null_ptr == NULL) {
        print("  ✓ NULL pointer comparison works");
    }
    // TODO: Non-NULL comparison when supported
    // if (valid_ptr != NULL) {
    //     print("  ✓ Non-NULL pointer comparison works");
    // }
    
    // =========================================
    // VALID: Function Returns
    // =========================================
    print("\n5. Function Returns with NIL");
    int64?:result1 = raw(returns_nil());
    int64?:result2 = raw(returns_value());
    
    int64:r1 = result1 ?? -1;  // Should be -1 (NIL)
    int64:r2 = result2 ?? -1;  // Should be 42 (value)
    
    if (r1 == -1 && r2 == 42) {
        print("  ✓ Function returns with NIL/value work correctly");
    }
    
    // =========================================
    // INVALID (COMMENTED): Type Safety Violations
    // =========================================
    print("\n6. Type Safety (Compile-Time Enforcement)");
    
    // These MUST NOT compile - uncomment to verify type checking:
    
    // ERROR 1: NIL cannot be used with pointers
    // int64->:bad1 = NIL;
    // Expected error: "NIL can only be assigned to optional types (T?)"
    
    // ERROR 2: NULL cannot be used with optionals
    // int64?:bad2 = NULL;
    // Expected error: "NULL can only be assigned to pointer types (T@)"
    
    // ERROR 3: NIL cannot be assigned to non-optional types
    // int64:bad3 = NIL;
    // Expected error: "NIL can only be assigned to optional types (T?)"
    
    // ERROR 4: NULL cannot be assigned to non-pointer types
    // int64:bad4 = NULL;
    // Expected error: "NULL can only be assigned to pointer types (T@)"
    
    print("  ✓ Type safety enforced at compile time");
    print("  ✓ NIL restricted to optionals, NULL restricted to pointers");
    
    // =========================================
    // Summary
    // =========================================
    print("\n=== All NIL vs NULL tests passed ===");
    print("NIL and NULL are properly distinguished and type-safe!");
    
    pass(0);
};
