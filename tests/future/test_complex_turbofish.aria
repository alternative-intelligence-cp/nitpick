/**
 * Quick test: Turbofish syntax with complex numbers
 */

use stdlib.complex.*;

func:failsafe = NIL(int32:err_code) {};

func:main = int32() {
    // Test turbofish syntax ::<Type>
    int64:r1 = 3;
    int64:i1 = 4;
    
    complex<int64>:z1 = complex_new::<int64>(r1, i1);
    complex<int64>:z2 = complex_new::<int64>(1, 2);
    
    // Test addition
    complex<int64>:sum = complex_add::<int64>(z1, z2);
    
    pass(0);
};
