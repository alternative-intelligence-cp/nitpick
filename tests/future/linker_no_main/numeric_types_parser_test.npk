// Test: Parser recognition and type system integration for new numeric types
// Purpose: Verify that all new type keywords are recognized by parser and type system

// ============================================================================
// Frac Types (Exact Rational Arithmetic)
// ============================================================================

func:test_frac8 = tbb32() {
    frac8:half = {0, 1, 2};  // 0 + 1/2
    pass 0;
};

func:test_frac16 = tbb32() {
    frac16:third = {0, 1, 3};  // 0 + 1/3
    pass 0;
};

func:test_frac32 = tbb32() {
    frac32:quarter = {0, 1, 4};  // 0 + 1/4
    pass 0;
};

func:test_frac64 = tbb32() {
    frac64:fifth = {0, 1, 5};  // 0 + 1/5
    pass 0;
};

// ============================================================================
// TFP Types (Twisted Floating Point)
// ============================================================================

func:test_tfp32 = tbb32() {
    tfp32:pi_approx = {1, 14159};  // Approximate π as deterministic float
    pass 0;
};

func:test_tfp64 = tbb32() {
    tfp64:e_approx = {1, 71828182845904};  // Approximate e
    pass 0;
};

// ============================================================================
// Vec9 Type (9D Toroidal Vector)
// ============================================================================

func:test_vec9 = tbb32() {
    vec9:position;  // Declare vec9 type (runtime init omitted)
    pass 0;
};

// ============================================================================
// TMatrix Type (Sentinel-Aware Matrix)
// ============================================================================

func:test_tmatrix = tbb32() {
    tmatrix:identity;  // Declare tmatrix type (runtime init omitted)
    pass 0;
};

// ============================================================================
// TTensor Type (9D Toroidal Tensor)
// ============================================================================

func:test_ttensor = tbb32() {
    ttensor:cube;  // Declare ttensor type (runtime init omitted)
    pass 0;
};

// ============================================================================
// Type Mixing Test
// ============================================================================

func:test_type_mixing = tbb32() {
    // Verify all types can coexist in same function
    frac32:f = {1, 1, 2};      // 1.5 as exact rational
    tfp32:t = {0, 15000};       // 1.5 as deterministic float
    vec9:v;                      // 9D vector (runtime init omitted)
    tmatrix:m;                   // tmatrix (runtime init omitted)
    ttensor:t9d;                 // ttensor (runtime init omitted)
    
    pass 0;
};

// ============================================================================
// Array Declaration Test
// ============================================================================

func:test_arrays = tbb32() {
    frac32[10]:fractions;      // Array of fractions
    tfp64[5]:floats;           // Array of deterministic floats
    vec9[3]:vectors;           // Array of 9D vectors
    
    pass 0;
};

// Entry point
func:main = int32() {
    // These tests just verify compilation works
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
