// Simple float SIMD test

func:failsafe = NIL(int32:err_code) { pass(NIL); };
func:test_float_simd = float32(simd<float32, 4>:vec) {
    float32:result = simd_sum(vec);
    pass(result);
};

// Simple int SIMD test
func:test_int_simd = int32(simd<int32, 4>:vec) {
    int32:result = simd_sum(vec);
    pass(result);
};
