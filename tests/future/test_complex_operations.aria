// Comprehensive test of complex<T> arithmetic operations
// Tests all Phase 1 operations with multiple numeric types

struct<T>:complex = {
    *T:real;
    *T:imag;
};

// Constructors
pub func<T>:complex_new = complex<*T>(*T:real, *T:imag) {
    complex<*T>:result;
    result.real = real;
    result.imag = imag;
    pass(result);
};

pub func<T>:complex_err = complex<*T>() {
    complex<*T>:result;
    result.real = ERR;
    result.imag = ERR;
    pass(result);
};

pub func<T>:complex_is_err = bool(complex<*T>:z) {
    pass(z.real == ERR || z.imag == ERR);
};

// Arithmetic operations
pub func<T>:complex_add = complex<*T>(complex<*T>:z1, complex<*T>:z2) {
    // Check for ERR - access fields directly since generic function calls need work
    complex<*T>:result;
    result.real = z1.real + z2.real;
    result.imag = z1.imag + z2.imag;
    pass(result);
};

pub func<T>:complex_sub = complex<*T>(complex<*T>:z1, complex<*T>:z2) {
    complex<*T>:result;
    result.real = z1.real - z2.real;
    result.imag = z1.imag - z2.imag;
    pass(result);
};

pub func<T>:complex_mul = complex<*T>(complex<*T>:z1, complex<*T>:z2) {
    // 3-multiplication algorithm (Gauss)
    *T:k1 = z1.real * (z2.real + z2.imag);
    *T:k2 = z2.imag * (z1.real + z1.imag);
    *T:k3 = z2.real * (z1.imag - z1.real);
    
    complex<*T>:result;
    result.real = k1 - k2;
    result.imag = k1 + k3;
    pass(result);
};

pub func<T>:complex_conjugate = complex<*T>(complex<*T>:z) {
    complex<*T>:result;
    result.real = z.real;
    result.imag = -z.imag;
    pass(result);
};

func:main = int32() {
    // Test 1: complex<int32> basic operations
    complex<int32>:z1 = complex_new(3, 4);
    complex<int32>:z2 = complex_new(1, 2);
    
    complex<int32>:sum = complex_add(z1, z2);       // (4 + 6i)
    complex<int32>:diff = complex_sub(z1, z2);      // (2 + 2i)
    complex<int32>:prod = complex_mul(z1, z2);      // (-5 + 10i)
    complex<int32>:conj = complex_conjugate(z1);    // (3 - 4i)
    
    // Test 2: complex<int64> for larger values
    complex<int64>:w1 = complex_new(1000000, 2000000);
    complex<int64>:w2 = complex_new(500000, 750000);
    
    complex<int64>:w_sum = complex_add(w1, w2);
    complex<int64>:w_diff = complex_sub(w1, w2);
    
    // Test 3: complex<flt64> for floating point
    complex<flt64>:x1 = complex_new(3.14, 2.71);
    complex<flt64>:x2 = complex_new(1.41, 1.73);
    
    complex<flt64>:x_sum = complex_add(x1, x2);
    complex<flt64>:x_prod = complex_mul(x1, x2);
    
    // Test 4: ERR propagation
    complex<int32>:err_val = complex_err();
    bool:is_err = complex_is_err(err_val);           // true
    
    complex<int32>:err_sum = complex_add(z1, err_val);
    bool:sum_is_err = complex_is_err(err_sum);      // true
    
    return 0;
};
