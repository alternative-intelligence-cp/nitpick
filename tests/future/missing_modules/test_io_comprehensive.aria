/// I/O Test - Integer Printing

use std.io;

func:main = int32() {
    // Test integer printing functions
    print_char(61i32);  // '='
    print_newline();
    
    print_int32(42i32);
    print_newline();
    
    print_int32(-123i32);
    print_newline();
    
    print_int32(0i32);
    print_newline();
    
    print_int64(1234567890i64);
    print_newline();
    
    print_int64(-9876543210i64);
    print_newline();
    
    // Edge cases
    print_int32(2147483647i32);  // Max int32
    print_newline();
    
    print_int32(-2147483648i32);  // Min int32
    print_newline();
    
    print_int64(9223372036854775807i64);  // Max int64
    print_newline();
    
    pass(0i32);
};
