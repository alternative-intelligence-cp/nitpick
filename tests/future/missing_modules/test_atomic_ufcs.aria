// Test UFCS method syntax with atomic operations
use "stdlib/atomic/int32.aria".*;

func:main = int32() {
    int32:counter = 0;
    
    // Test UFCS method syntax: counter.atomic_store(42, order)
    // Should desugar to: atomic_int32_store(counter, 42, MEMORY_ORDER_SEQ_CST())
    counter = counter.atomic_store(42, MEMORY_ORDER_SEQ_CST());
    
    // Test UFCS method syntax: counter.atomic_load(order)
    // Should desugar to: atomic_int32_load(counter, MEMORY_ORDER_SEQ_CST())
    int32:value = counter.atomic_load(MEMORY_ORDER_SEQ_CST());
    
    // Test UFCS method syntax: value.atomic_add(10, order)
    value = value.atomic_add(10, MEMORY_ORDER_RELAXED());
    
    pass value;
};
