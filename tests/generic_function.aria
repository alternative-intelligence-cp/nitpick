// Generic function test: identity<T> instantiated for multiple types
// Verifies generic dispatch for int32 and flt64

func<T>:identity = *T(*T:value) {
    pass value;
};

func:main = int32() {
    // identity<int32>
    int32:a = 42i32;
    int32:ra = identity(a) ? -1i32;
    if (ra != 42i32) { pass 1i32; }

    // identity<int32> with different value
    int32:b = 100i32;
    int32:rb = identity(b) ? -1i32;
    if (rb != 100i32) { pass 2i32; }

    // identity<flt64>
    flt64:f = 3.14;
    flt64:rf = identity(f) ? -1.0;
    if (rf != 3.14) { pass 3i32; }

    // identity<int64>
    int64:n = 999i64;
    int64:rn = identity(n) ? -1i64;
    if (rn != 999i64) { pass 4i32; }

    exit 0;
};
func:failsafe = int32(tbb32:err) { exit 1; };
