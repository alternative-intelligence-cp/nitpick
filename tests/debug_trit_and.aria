// Debug test for trit_and
func:main = int32() {
    print("=== Trit AND Debug ===");
    
    trit:true_val = 1;
    trit:false_val = -1;
    
    print("Before trit_and call");
    trit:result = trit_and(true_val, false_val);
    print("After trit_and call");
    
    // Test with literal comparison
    if (result == -1) {
        print("✓ Result is -1 (correct)");
    } else if (result == 1) {
        print("✗ Result is 1 (wrong)");
    } else if (result == 0) {
        print("✗ Result is 0 (wrong)");
    } else {
        print("✗ Result is something else");
    }
    
    return 0;
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
