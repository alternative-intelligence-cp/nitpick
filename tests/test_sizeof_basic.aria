// Test: @sizeof operator — basic type sizes
// Verifies compile-time type size resolution for primitive types

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    // Primitive integer sizes
    int64:s_i8  = @sizeof(int8);
    int64:s_i16 = @sizeof(int16);
    int64:s_i32 = @sizeof(int32);
    int64:s_i64 = @sizeof(int64);

    // Floating point sizes
    int64:s_f32 = @sizeof(flt32);
    int64:s_f64 = @sizeof(flt64);

    // Boolean and tbb
    int64:s_bool = @sizeof(bool);
    int64:s_tbb  = @sizeof(tbb32);

    exit 0;
};
