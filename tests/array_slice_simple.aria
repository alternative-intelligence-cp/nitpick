// Simple array slicing test
// NOTE: Arrays have a pre-existing bug - this test will work once arrays are fixed

func:main = int64() {
    print("Simple slice test:");
    
    // Create array with known values
    int64[]:nums = [10, 20, 30, 40, 50];
    
    // Print original array
    print("Original:");
    print(nums[0]);  // Should be 10
    print(nums[1]);  // Should be 20
    print(nums[2]);  // Should be 30
    print(nums[3]);  // Should be 40
    print(nums[4]);  // Should be 50
    
    // Try a simple inclusive slice
    print("Slice [1..3] (should be 20, 30, 40):");
    int64[]:slice = nums[1..3];
    print(slice[0]);  // Should be 20
    print(slice[1]);  // Should be 30
    print(slice[2]);  // Should be 40
    
    // Try an exclusive slice
    print("Slice [0...2] (should be 10, 20):");
    int64[]:slice2 = nums[0...2];
    print(slice2[0]);  // Should be 10
    print(slice2[1]);  // Should be 20
    
    pass(0);
};
