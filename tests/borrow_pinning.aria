func:test_pin_lifetime = int32() {
    // Test 4: Pin released when reference goes out of scope
    int32:x = 10;
    
    {
        wild int32->:pin = #x;
    }  // pin goes out of scope, x is unpinned
    
    x = 20;  // OK: no longer pinned
    int32:zero = 0;
    pass zero;
};

