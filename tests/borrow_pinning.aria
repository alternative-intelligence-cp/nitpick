    // Test 5: Pin cannot outlive host
    // This should FAIL at compile time
    wild int32->:pin;
    
    {
        int32:inner = 100;
        pin = #inner;  // ERROR: pin outlives inner
    }
    
    int32:one = 1;
    pass(one);
};
*/

func:test_borrow_pinned_immutable = int32() {
    // Test 6: Can borrow pinned variable immutably
    int32:x = 10;
    wild int32->:pin = #x;
    $$i int32:ref = x;  // Should be OK - immutable borrow of pinned var
    
    int32:zero = 0;
    pass zero;
};

