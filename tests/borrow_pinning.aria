// Pinning Tests - # operator for stable GC pointers

func:test_basic_pinning = int32() {
    // Test 1: Basic pinning with # operator
    int32:gc_var = 42;            // GC-allocated variable
    wild int32->:pinned = #gc_var;      // Pin it to get stable pointer
    
    // Use the pinned value
    int32:result = gc_var;        // Access original value
    
    int32:zero = 0;
    pass zero;
};

