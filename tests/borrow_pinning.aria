    // This should FAIL at compile time
    int32:x = 10;
    wild int32->:pin = #x;
    $$m int32:mut_ref = x;  // ERROR: Cannot mutably borrow pinned variable
    
    int32:one = 1;
    pass(one);
};
*/

func:main = int32() {
    // Run tests that should succeed
    int32:result1 = raw test_basic_pinning();
    int32:result4 = raw test_pin_lifetime();
    int32:result6 = raw test_borrow_pinned_immutable();
    
    // Tests 2, 3, 5, 7 should fail at compile time
    // Uncomment one at a time to test error reporting:
    // int32:result2 = test_pinned_assignment();
    // int32:result3 = test_double_pinning();
    // int32:result5 = test_pin_invalid_lifetime();
    // int32:result7 = test_borrow_pinned_mutable();
    
    int32:zero = 0;
    exit zero;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
