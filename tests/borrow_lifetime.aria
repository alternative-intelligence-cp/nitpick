// Lifetime Tests - Appendage Theory: Depth(Host) <= Depth(Reference)

func:test_valid_lifetime = int32() {
    // Test 1: Reference at same depth as host - should be OK
    int32:outer = 42;
    int32$:ref = !$outer;
    int32:zero = 0;
    pass zero;
};

