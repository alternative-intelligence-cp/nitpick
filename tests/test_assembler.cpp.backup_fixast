// =============================================================================
// Integration Tests - Actual Execution
// =============================================================================

TEST_CASE(assembler_generate_return_constant) {
    // Generate function that returns constant: int64_t func() { return 123; }
    Assembler* asm_ctx = aria_asm_create();
    
    aria_asm_mov_r64_imm64(asm_ctx, REG_RAX, 123);
    aria_asm_ret(asm_ctx);
    
    // Finalize to executable memory
    WildXGuard guard = aria_asm_finalize(asm_ctx);
    ASSERT_NE(guard.ptr, nullptr, "Code should be finalized");
    ASSERT_EQ((int)guard.state, (int)WILDX_STATE_EXECUTABLE, "Memory should be executable");
    
    // Execute using helper
    int64_t result = aria_asm_execute(&guard);
    ASSERT_EQ(result, 123, "Function should return 123");
    
    // Cleanup
    aria_free_exec(&guard);
    aria_asm_destroy(asm_ctx);
}

TEST_CASE(assembler_add_function) {
    // Generate function: int64_t add(int64_t a, int64_t b) { return a + b; }
    // System V AMD64 ABI: arg1=RDI, arg2=RSI, return=RAX
    Assembler* asm_ctx = aria_asm_create();
    
    // Move first arg to return register
    aria_asm_mov_r64_r64(asm_ctx, REG_RAX, REG_RDI);
    
    // Add second arg
    aria_asm_add_r64_r64(asm_ctx, REG_RAX, REG_RSI);
    
    // Return
    aria_asm_ret(asm_ctx);
    
    // Finalize
    WildXGuard guard = aria_asm_finalize(asm_ctx);
    ASSERT_NE(guard.ptr, nullptr, "Code should be finalized");
    
    // Execute with two args
    int64_t result = aria_asm_execute_i64_i64(&guard, 10, 32);
    ASSERT_EQ(result, 42, "10 + 32 should equal 42");
    
    // Cleanup
    aria_free_exec(&guard);
    aria_asm_destroy(asm_ctx);
}

TEST_CASE(assembler_subtract_function) {
    // Generate function: int64_t sub(int64_t a, int64_t b) { return a - b; }
    Assembler* asm_ctx = aria_asm_create();
    
    aria_asm_mov_r64_r64(asm_ctx, REG_RAX, REG_RDI);  // RAX = arg1
    aria_asm_sub_r64_r64(asm_ctx, REG_RAX, REG_RSI);  // RAX -= arg2
    aria_asm_ret(asm_ctx);
    
    WildXGuard guard = aria_asm_finalize(asm_ctx);
    
    int64_t result = aria_asm_execute_i64_i64(&guard, 100, 58);
    ASSERT_EQ(result, 42, "100 - 58 should equal 42");
    
    aria_free_exec(&guard);
    aria_asm_destroy(asm_ctx);
}

TEST_CASE(assembler_jump_forward) {
    // Test forward jump:
    // mov rax, 1
    // jmp skip
    // mov rax, 999  (shouldn't execute)
    // skip:
    // mov rax, 2
    // ret
    
    Assembler* asm_ctx = aria_asm_create();
    
    int skip_label = aria_asm_new_label(asm_ctx);
    
    aria_asm_mov_r64_imm64(asm_ctx, REG_RAX, 1);
    aria_asm_jmp(asm_ctx, skip_label);
    aria_asm_mov_r64_imm64(asm_ctx, REG_RAX, 999);  // Should be skipped
    
    aria_asm_bind_label(asm_ctx, skip_label);
    aria_asm_mov_r64_imm64(asm_ctx, REG_RAX, 2);
    aria_asm_ret(asm_ctx);
    
    WildXGuard guard = aria_asm_finalize(asm_ctx);
    
    int64_t result = aria_asm_execute(&guard);
    ASSERT_EQ(result, 2, "Jump should skip to 2, not execute 999");
    
    aria_free_exec(&guard);
    aria_asm_destroy(asm_ctx);
}

TEST_CASE(assembler_conditional_jump) {
    // Generate function using conditional jump
    // Compare args and jump based on equality
    Assembler* asm_ctx = aria_asm_create();
    
    int return_a = aria_asm_new_label(asm_ctx);
    
    // Compare RDI (a) and RSI (b)
    aria_asm_cmp_r64_r64(asm_ctx, REG_RDI, REG_RSI);
    
    // If a != b, jump to return_a
    aria_asm_jne(asm_ctx, return_a);
    
    // Otherwise return b (they're equal)
    aria_asm_mov_r64_r64(asm_ctx, REG_RAX, REG_RSI);
    aria_asm_ret(asm_ctx);
    
    // return_a:
    aria_asm_bind_label(asm_ctx, return_a);
    aria_asm_mov_r64_r64(asm_ctx, REG_RAX, REG_RDI);
    aria_asm_ret(asm_ctx);
    
    WildXGuard guard = aria_asm_finalize(asm_ctx);
    
    // Test with different values
    int64_t r1 = aria_asm_execute_i64_i64(&guard, 100, 100);  // Equal, returns RSI
    int64_t r2 = aria_asm_execute_i64_i64(&guard, 50, 25);    // Not equal, returns RDI
    
    ASSERT_EQ(r1, 100, "Equal values should return RSI (100)");
    ASSERT_EQ(r2, 50, "Unequal values should return RDI (50)");
    
    aria_free_exec(&guard);
    aria_asm_destroy(asm_ctx);
}
