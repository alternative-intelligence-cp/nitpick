/**
 * Runtime Assembler (JIT) Tests
 * 
 * Tests for the Aria runtime assembler which provides
 * x86-64 JIT compilation with W⊕X security.
 */

#include "test_helpers.h"
#include "runtime/assembler.h"

// =============================================================================
// Assembler Core Tests
// =============================================================================

TEST_CASE(assembler_create_destroy) {
    Assembler* asm_ctx = aria_asm_create();
    ASSERT_NE(asm_ctx, nullptr, "Assembler should be created");
    ASSERT_NE(asm_ctx->buffer, nullptr, "Buffer should be initialized");
    ASSERT_EQ(asm_ctx->buffer->size, 0, "Buffer should be empty");
    ASSERT_EQ(asm_ctx->label_count, 0, "No labels initially");
    ASSERT_FALSE(aria_asm_has_error(asm_ctx), "No errors initially");
    
    aria_asm_destroy(asm_ctx);
}

TEST_CASE(assembler_label_basic) {
    Assembler* asm_ctx = aria_asm_create();
    
    int label_id = aria_asm_new_label(asm_ctx);
    ASSERT_EQ(label_id, 0, "First label should have ID 0");
    ASSERT_FALSE(aria_asm_has_error(asm_ctx), "No error creating label");
    
    // Label should not be bound initially
    ASSERT_FALSE(aria_asm_label_is_bound(&asm_ctx->labels[label_id]), "Label should not be bound");
    
    // Bind label
    aria_asm_bind_label(asm_ctx, label_id);
    ASSERT_TRUE(aria_asm_label_is_bound(&asm_ctx->labels[label_id]), "Label should be bound");
    ASSERT_EQ(asm_ctx->labels[label_id].position, 0, "Label bound at position 0");
    
    aria_asm_destroy(asm_ctx);
}

