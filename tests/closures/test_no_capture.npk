// v0.20.4 — Closure capture: lambda with no captures compiles fine
// Tests a pure lambda (no outer scope references) — no capturedVars expected.

func:failsafe = int32(tbb32:err) {
    exit 1;
};

func:main = int32() {
    (int32)(int32, int32):multiply = int32(int32:x, int32:y) { pass x * y; };
    int32:result = multiply(4i32, 5i32) ? -1i32;
    if (result != 20i32) {
        exit 1;
    }
    exit 0;
};
