// Print sum value via exit code  
func:main = int64() {
    tbb8:x = 5;
    tbb8:one = 3;
    tbb8:sum = x + one;  
    
    // TBB is stored as i8, will extend to i64 for exit
    // If sum is 8, overflow detection is NOT working  
    // If sum is ERR (-128), overflow detection IS working (but shouldn't overflow this case)
    pass(sum);
};