use "lockfree.aria".*;
use "thread.aria".*;
use "atomic.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    println("=== Lock-Free Data Structure Tests ===");
    
    // Test 1: LFQueue basic push/pop
    int64:q = raw LFQueue.create(64i64);
    raw LFQueue.push(q, 10i64);
    raw LFQueue.push(q, 20i64);
    raw LFQueue.push(q, 30i64);
    
    int64:v1 = raw LFQueue.pop(q);
    int64:v2 = raw LFQueue.pop(q);
    int64:v3 = raw LFQueue.pop(q);
    
    if (v1 == 10) {
        if (v2 == 20) {
            if (v3 == 30) { println(" [PASS] LFQueue FIFO order"); }
        }
    }
    if (v1 != 10) { println(" [FAIL] LFQueue wrong values"); }
    
    raw LFQueue.destroy(q);
    
    // Test 2: LFQueue MPMC with threads
    int64:q2 = raw LFQueue.create(1024i64);
    AtomicInt32:done_count = raw AtomicInt32.create(0i32);
    
    extern func:aria_shim_lfqueue_push = int32(int64:handle, int64:value);
    extern func:aria_shim_atomic_int32_fetch_add = int32(int64:handle, int32:value, int32:order);
    
    // Producer — pushes values 1..10
    (int64)(int64):producer = int64(int64:queue_h) {
        for(int32:i = 1i32; i < 11i32; i += 1i32) {
            int64:val = @cast<int64>(i);
            aria_shim_lfqueue_push(queue_h, val);
        }
        pass 0i64;
    };
    
    // Spawn 2 producers
    int64:p1 = raw Thread.spawn(producer, q2);
    int64:p2 = raw Thread.spawn(producer, q2);
    raw Thread.join(p1);
    raw Thread.join(p2);
    
    // Should have 20 items
    int64:sz = raw LFQueue.size(q2);
    if (sz == 20) { println(" [PASS] LFQueue MPMC producers (20 items)"); }
    if (sz != 20) { println(" [FAIL] LFQueue MPMC wrong size"); }
    
    // Pop all and sum
    int64:sum = 0;
    for(int32:j = 0i32; j < 20i32; j += 1i32) {
        int64:val = raw LFQueue.pop(q2);
        sum = sum + val;
    }
    // Each producer sends 1+2+...+10 = 55, two producers = 110
    if (sum == 110) { println(" [PASS] LFQueue MPMC sum correct (110)"); }
    if (sum != 110) { println(" [FAIL] LFQueue MPMC wrong sum"); }
    
    raw LFQueue.destroy(q2);
    raw AtomicInt32.destroy(done_count);
    
    // Test 3: LFStack basic push/pop (LIFO)
    int64:stk = raw LFStack.create();
    raw LFStack.push(stk, 100i64);
    raw LFStack.push(stk, 200i64);
    raw LFStack.push(stk, 300i64);
    
    int64:s1 = raw LFStack.pop(stk);
    int64:s2 = raw LFStack.pop(stk);
    int64:s3 = raw LFStack.pop(stk);
    
    // LIFO: should be 300, 200, 100
    if (s1 == 300) {
        if (s2 == 200) {
            if (s3 == 100) { println(" [PASS] LFStack LIFO order"); }
        }
    }
    if (s1 != 300) { println(" [FAIL] LFStack wrong values"); }
    
    raw LFStack.destroy(stk);
    
    // Test 4: LFStack concurrent push
    int64:stk2 = raw LFStack.create();
    extern func:aria_shim_lfstack_push = int32(int64:handle, int64:value);
    
    (int64)(int64):stack_pusher = int64(int64:stack_h) {
        for(int32:i = 0i32; i < 50i32; i += 1i32) {
            aria_shim_lfstack_push(stack_h, 1i64);
        }
        pass 0i64;
    };
    
    int64:t1 = raw Thread.spawn(stack_pusher, stk2);
    int64:t2 = raw Thread.spawn(stack_pusher, stk2);
    raw Thread.join(t1);
    raw Thread.join(t2);
    
    int64:stk_sz = raw LFStack.size(stk2);
    if (stk_sz == 100) { println(" [PASS] LFStack concurrent push (100 items)"); }
    if (stk_sz != 100) { println(" [FAIL] LFStack concurrent wrong size"); }
    
    raw LFStack.destroy(stk2);
    
    // Test 5: RingBuf SPSC
    int64:rb = raw RingBuf.create(16i64);
    
    raw RingBuf.push(rb, 1i64);
    raw RingBuf.push(rb, 2i64);
    raw RingBuf.push(rb, 3i64);
    
    int64:cap = raw RingBuf.capacity(rb);
    if (cap == 16) { println(" [PASS] RingBuf capacity"); }
    if (cap != 16) { println(" [FAIL] RingBuf wrong capacity"); }
    
    int64:r1 = raw RingBuf.pop(rb);
    int64:r2 = raw RingBuf.pop(rb);
    int64:r3 = raw RingBuf.pop(rb);
    
    if (r1 == 1) {
        if (r2 == 2) {
            if (r3 == 3) { println(" [PASS] RingBuf FIFO order"); }
        }
    }
    if (r1 != 1) { println(" [FAIL] RingBuf wrong values"); }
    
    raw RingBuf.destroy(rb);
    
    println("=== Lock-Free Tests Done ===");
    exit 0;
};
