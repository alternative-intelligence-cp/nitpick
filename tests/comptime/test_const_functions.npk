// v0.20.3 — General comptime function tests
// Tests: Fibonacci (memoization), GCD, power function

comptime func:fib = int32(int32:n) {
    if (n <= 1i32) {
        pass n;
    }
    int32:a = raw fib(n - 1i32);
    int32:b = raw fib(n - 2i32);
    pass a + b;
};

comptime func:gcd = int32(int32:a, int32:b) {
    if (b == 0i32) {
        pass a;
    }
    int32:rem = a - (a / b) * b;
    pass raw gcd(b, rem);
};

comptime func:power = int32(int32:base, int32:exp) {
    if (exp == 0i32) {
        pass 1i32;
    }
    int32:sub = raw power(base, exp - 1i32);
    pass base * sub;
};

pub func:main = int32() {
    // fib(10) = 55
    int32:f = comptime(fib(10i32));
    if (f != 55) {
        exit 1;
    }

    // gcd(48, 18) = 6
    int32:g = comptime(gcd(48i32, 18i32));
    if (g != 6) {
        exit 1;
    }

    // 2^8 = 256
    int32:p = comptime(power(2i32, 8i32));
    if (p != 256) {
        exit 1;
    }

    exit 0;
};

func:failsafe = int32(tbb32:err) { exit 1; };
