// Basic File I/O Test
// Tests readFile, writeFile, fileExists, fileSize, deleteFile

func:main = int32() {
    print("=== File I/O Basic Test ===\n");
    
    // Test 1: Write a file
    print("Test 1: Writing file...\n");
    string:content = "Hello, Aria!\n";
    int64:write_result = writeFile("/tmp/aria_test.txt", content);
    print("SUCCESS: File written\n");
    
    // Test 2: Check file exists
    print("Test 2: Checking file exists...\n");
    bool:exists_result = fileExists("/tmp/aria_test.txt");
    print("SUCCESS: File exists\n");
    
    // Test 3: Get file size
    print("Test 3: Getting file size...\n");
    int64:size_result = fileSize("/tmp/aria_test.txt");
    print("File size OK\n");
    
    // Test 4: Read the file
    print("Test 4: Reading file...\n");
    string:read_result = readFile("/tmp/aria_test.txt");
    print("File content: ");
    print(read_result);
    
    // Test 5: Delete the file
    print("Test 5: Deleting file...\n");
    int64:delete_result = deleteFile("/tmp/aria_test.txt");
    print("SUCCESS: File deleted\n");
    
    // Test 6: Verify file is gone
    print("Test 6: Verifying file deleted...\n");
    bool:exists2_result = fileExists("/tmp/aria_test.txt");
    print("SUCCESS: File confirmed deleted\n");
    
    print("\n=== All File I/O Tests PASSED ===\n");
    int32:success = 0;
    pass(success);
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
