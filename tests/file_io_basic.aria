// Basic File I/O Test
// Tests readFile, writeFile, fileExists, fileSize, deleteFile
// File builtins use raw() since codegen returns raw values

func:main = int32() {
    print("=== File I/O Basic Test ===\n");

    // Test 1: Write a file
    print("Test 1: Writing file...\n");
    string:content = "Hello, Aria!\n";
    int64:write_result = raw writeFile("/tmp/aria_test.txt", content);
    if (write_result != 0i64) {
        print("FAIL: Could not write file\n");
        exit 1i32;
    }
    print("SUCCESS: File written\n");

    // Test 2: Check file exists
    print("Test 2: Checking file exists...\n");
    bool:exists_result = raw fileExists("/tmp/aria_test.txt");
    if (!exists_result) {
        print("FAIL: File does not exist after write\n");
        exit 1i32;
    }
    print("SUCCESS: File exists\n");

    // Test 3: Get file size
    print("Test 3: Getting file size...\n");
    int64:size_result = raw fileSize("/tmp/aria_test.txt");
    if (size_result < 0i64) {
        print("FAIL: fileSize returned error\n");
        exit 1i32;
    }
    print("File size OK\n");

    // Test 4: Read the file
    print("Test 4: Reading file...\n");
    string:read_content = raw readFile("/tmp/aria_test.txt");
    print("File content: ");
    print(read_content);

    // Test 5: Delete the file
    print("Test 5: Deleting file...\n");
    int64:delete_result = raw deleteFile("/tmp/aria_test.txt");
    if (delete_result != 0i64) {
        print("FAIL: Could not delete file\n");
        exit 1i32;
    }
    print("SUCCESS: File deleted\n");

    // Test 6: Verify file is gone
    print("Test 6: Verifying file deleted...\n");
    bool:exists2_result = raw fileExists("/tmp/aria_test.txt");
    if (exists2_result) {
        print("FAIL: File still exists after delete\n");
        exit 1i32;
    }
    print("SUCCESS: File confirmed deleted\n");

    print("\n=== All File I/O Tests PASSED ===\n");
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
