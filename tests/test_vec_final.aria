// Test Vec<T> Phase 3 -  FINAL TEST
// Testing struct field mutation with Vec<int8>

extern func:npk_array_new_simple = wild int8*(int64:element_size, int32:type_id);
extern func:npk_array_push_simple = void(wild int8*:arr, wild int8*:val);
extern func:npk_array_length = int64(wild int8*:arr);
extern func:npk_array_free = void(wild int8*:arr);

// Helper function to create a Vec<int8>
func:Vec_int8_new = Vec<int8>() {
    Vec<int8>:vec;
    
    vec.data = npk_array_new_simple(1i64, 0i32);
    vec.length = 0i64;
    vec.capacity = 0i64;
    vec.element_size = 1i64;
    vec.type_id = 0i32;
    
    pass vec;
};

func:main = int32() {
    // Create Vec<int8> struct using constructor
    Vec<int8>:numbers = raw Vec_int8_new();
    
    // Push 3 values
    int8:v1 = 42i8;
    npk_array_push_simple(numbers.data, @v1);
    
    int8:v2 = 99i8;
    npk_array_push_simple(numbers.data, @v2);
    
    int8:v3 = 7i8;
    npk_array_push_simple(numbers.data, @v3);
    
    // CRITICAL TEST: Update struct field from function return
    numbers.length = npk_array_length(numbers.data);
    
    // Verify it worked!
    if (numbers.length != 3i64) {
        exit 1i32;  // FAIL: Field mutation didn't persist
    }
    
    npk_array_free(numbers.data);
    exit 0;  // SUCCESS!
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};
