/**
 * Test: New struct declaration syntax
 * 
 * Verifies that struct:name = { }; syntax works correctly
 */

// Simple struct without generics
struct:Point = {
    int64:x;
    int64:y;
};

// Struct with multiple field types
struct:Person = {
    int32:age;
    int64:id;
    bool:active;
};

// Test instantiation (if supported)
// Point:p = { x: 10, y: 20 };

func:main = int64() {
    pass(0);
};
