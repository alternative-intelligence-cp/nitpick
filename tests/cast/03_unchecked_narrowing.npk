// Test 3: Unchecked Narrowing Casts
// These casts truncate without runtime checks (may lose data)

func:test_unchecked_truncation = int32() {
    // Truncate large value (will wrap/truncate)
    int64:large = 1000i64;
    int8:truncated = @cast_unchecked<int8>(large);
    
    // Truncate with data loss
    uint64:big_val = 500u64;
    uint8:small_val = @cast_unchecked<uint8>(big_val);
    
    pass 0i32;
};

func:test_unchecked_multi_step = int32() {
    // Multi-step unchecked casts
    int64:x = 5000i64;
    int32:y = @cast_unchecked<int32>(x);
    int16:z = @cast_unchecked<int16>(y);
    int8:w = @cast_unchecked<int8>(z);
    
    pass 0i32;
};

func:main = int32() {
    int32:r1 = raw test_unchecked_truncation();
    int32:r2 = raw test_unchecked_multi_step();
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
