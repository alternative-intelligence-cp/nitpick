// Test 5: Float to Integer Conversions

func:test_float_to_signed = int32() {
    // Float to signed integers (checked)
    flt32:f1 = 42.5f32;
    int32:i1 = @cast<int32>(f1);  // Truncates to 42
    
    flt64:f2 = 100.99f64;
    int64:i2 = @cast<int64>(f2);  // Truncates to 100
    
    pass(0i32);
};

func:test_float_to_unsigned = int32() {
    // Float to unsigned integers (checked)
    flt32:f1 = 255.7f32;
    uint8:u1 = @cast<uint8>(f1);  // Truncates to 255
    
    flt64:f2 = 1000.0f64;
    uint32:u2 = @cast<uint32>(f2);  // 1000
    
    pass(0i32);
};

func:test_float_to_int_unchecked = int32() {
    // Unchecked float to int (no range check)
    flt64:large = 1000000.5f64;
    int8:small = @cast_unchecked<int8>(large);  // Truncates/wraps
    
    pass(0i32);
};

func:main = int32() {
    int32:r1 = test_float_to_signed();
    int32:r2 = test_float_to_unsigned();
    int32:r3 = test_float_to_int_unchecked();
    pass(0i32);
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
