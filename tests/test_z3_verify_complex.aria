// test_z3_verify_complex.aria — v0.2.45 Z3 verification of complex conditions
// These conditions involve arithmetic that Z3 proves/disproves nicely

extern func:puts = int32(string:s);

// Complex rules with modular arithmetic and multi-condition
Rules:r_complex = {
    $ > 0,
    $ < 500,
    $ % 7 == 0
};

// Even and divisible by 3 (i.e., divisible by 6)  
Rules:r_div6 = {
    $ % 2 == 0,
    $ % 3 == 0,
    $ > 0,
    $ <= 1000
};

func:failsafe = int32(tbb32:err) {
    drop(puts("FAILSAFE"));
    exit(1);
};

func:main = int32() {
    // 42 is divisible by 7, > 0, < 500 → PROVEN
    limit<r_complex> int32:a = 42;
    drop(puts("42 is valid for r_complex"));
    
    // 210 is divisible by 7, > 0, < 500 → PROVEN
    limit<r_complex> int32:b = 210;
    drop(puts("210 is valid for r_complex"));
    
    // 126 = 2*3*3*7 → div by 6, > 0, <= 1000 → PROVEN
    limit<r_div6> int32:c = 126;
    drop(puts("126 is valid for r_div6"));
    
    // 600 = 2*3*100 → div by 6, > 0, <= 1000 → PROVEN    
    limit<r_div6> int32:d = 600;
    drop(puts("600 is valid for r_div6"));
    
    return 0i32;
};
