// Comprehensive test of all power-of-two integer types (1 -> 128 bits)
// Tests coverage: declaration, arithmetic, comparisons
// Note: Avoiding extreme boundary literals due to lexer int64 limitation

func:main = int32() {
    // ========================================================================
    // 1-bit types (boolean-compatible)
    // ========================================================================
    int1:i1_zero;    // Uninitialized but allocated
    uint1:u1_one;    // 0 or 1
    
    // ========================================================================
    // 2-bit types (crumbs: 0-3 unsigned, -2 to 1 signed)
    // ========================================================================
    int2:i2_neg;     // -2, -1, 0, 1
    uint2:u2_max;    // 0, 1, 2, 3
    
    // ========================================================================
    // 4-bit types (nibbles: 0-15 unsigned, -8 to 7 signed)
    // ========================================================================
    int4:i4_min;     // -8
    uint4:u4_max;    // 15
    
    // ========================================================================
    // 8-bit types (bytes: standard)
    // ========================================================================
    int8:i8_a = 10;
    int8:i8_b = 20;
    uint8:u8_val = 200;
    
    // Arithmetic test
    int8:sum8 = i8_a + i8_b;  // Should be 30
    
    // Comparison test
    bool:cmp8 = i8_a < i8_b;  // true
    
    // ========================================================================
    // 16-bit types (already tested elsewhere, quick validation)
    // ========================================================================
    int16:i16 = 1000;
    uint16:u16 = 60000;
    
    // ========================================================================
    // 32-bit types (standard, used throughout)
    // ========================================================================
    int32:i32_a = 100000;
    int32:i32_b = 200000;
    int32:i32_sum = i32_a + i32_b;  // 300000
    
    uint32:u32 = 3000000000;
    
    // ========================================================================
    // 64-bit types (default for literals)
    // ========================================================================
    int64:i64 = 1000000000000;
    uint64:u64 = 10000000000000;
    
    // ========================================================================
    // 128-bit types (already tested in int128_basic.aria)
    // ========================================================================
    int128:i128_pos;  // Placeholder - literals don't work yet
    uint128:u128_max; // Placeholder
    
    // ========================================================================
    // Return success
    // ========================================================================
    int32:exit_code = 0;
    pass(exit_code);
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
