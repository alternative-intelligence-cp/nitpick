use "arena.aria".*;

func:failsafe = int32(tbb32:err_code) {
    println("FAILSAFE triggered");
    exit(1);
};

func:test_create_basic = int32() {
    int64:arena = raw Arena.create(1024i64);
    if (arena == 0i64) { println("FAIL: T01 create"); pass 1i32; }
    println("OK: T01 create");

    int64:rem = raw Arena.remaining(arena);
    if (rem != 1024i64) { println("FAIL: T02 remaining"); pass 1i32; }
    println("OK: T02 remaining = capacity");

    int64:u = raw Arena.used(arena);
    if (u != 0i64) { println("FAIL: T03 used != 0"); pass 1i32; }
    println("OK: T03 used = 0");

    int32:dr = raw Arena.destroy(arena);
    pass 0i32;
};

func:test_alloc = int32() {
    int64:arena = raw Arena.create(256i64);

    int64:off1 = raw Arena.alloc(arena, 64i64);
    if (off1 != 0i64) { println("FAIL: T04 first alloc != 0"); pass 1i32; }
    println("OK: T04 first alloc at 0");

    int64:u1 = raw Arena.used(arena);
    if (u1 != 64i64) { println("FAIL: T05 used != 64"); pass 1i32; }
    println("OK: T05 used = 64");

    int64:off2 = raw Arena.alloc(arena, 32i64);
    if (off2 != 64i64) { println("FAIL: T06 second alloc != 64"); pass 1i32; }
    println("OK: T06 second alloc at 64");

    int64:rem = raw Arena.remaining(arena);
    if (rem != 160i64) { println("FAIL: T07 remaining != 160"); pass 1i32; }
    println("OK: T07 remaining = 160");

    int32:dr = raw Arena.destroy(arena);
    pass 0i32;
};

func:test_readwrite = int32() {
    int64:arena = raw Arena.create(128i64);
    int64:off = raw Arena.alloc(arena, 16i64);

    int32:wr = raw Arena.write_int64(arena, 0i64, 12345i64);
    int64:val = raw Arena.read_int64(arena, 0i64);
    if (val != 12345i64) { println("FAIL: T08 read != 12345"); pass 1i32; }
    println("OK: T08 write/read_int64");

    int32:wr2 = raw Arena.write_int64(arena, 8i64, 99999i64);
    int64:val2 = raw Arena.read_int64(arena, 8i64);
    if (val2 != 99999i64) { println("FAIL: T09 read offset 8"); pass 1i32; }
    println("OK: T09 write/read at offset 8");

    int32:dr = raw Arena.destroy(arena);
    pass 0i32;
};

func:test_reset_destroy = int32() {
    int64:arena = raw Arena.create(128i64);
    int64:off = raw Arena.alloc(arena, 64i64);

    int32:rr = raw Arena.reset(arena);
    int64:u = raw Arena.used(arena);
    if (u != 0i64) { println("FAIL: T10 used after reset"); pass 1i32; }
    println("OK: T10 reset clears used");

    int64:rem = raw Arena.remaining(arena);
    if (rem != 128i64) { println("FAIL: T11 remaining after reset"); pass 1i32; }
    println("OK: T11 remaining restored");

    int64:off2 = raw Arena.alloc(arena, 32i64);
    if (off2 != 0i64) { println("FAIL: T12 alloc after reset"); pass 1i32; }
    println("OK: T12 alloc after reset at 0");

    int32:dr = raw Arena.destroy(arena);
    pass 0i32;
};

func:main = int32() {
    int32:r1 = raw test_create_basic();
    if (r1 != 0i32) { exit(1); }
    int32:r2 = raw test_alloc();
    if (r2 != 0i32) { exit(1); }
    int32:r3 = raw test_readwrite();
    if (r3 != 0i32) { exit(1); }
    int32:r4 = raw test_reset_destroy();
    if (r4 != 0i32) { exit(1); }
    println("PASS: all 12 arena tests passed");
    exit(0);
};
