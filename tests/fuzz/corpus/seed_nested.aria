func:main = int32() {
    int64:outer = 0;
    while (outer < 3) {
        int64:inner = 0;
        while (inner < 3) {
            int64:val = (outer * 10);
            val = (val + inner);
            print(val);
            inner = (inner + 1);
        }
        outer = (outer + 1);
    }
    return 0;
};

