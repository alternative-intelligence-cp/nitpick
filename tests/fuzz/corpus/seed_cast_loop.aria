// seed_cast_loop.aria — flt64 cast + while loop pattern
func:failsafe = int32(tbb32:err) { exit(1); };
func:main = int32() {
    int64:i = 0i64;
    float64:sum = 0.0;
    while (i < 10i64) {
        float64:f = i => flt64;
        sum = sum + f;
        i = i + 1i64;
    }
    int64:result = sum => int64;
    exit(0);
};
