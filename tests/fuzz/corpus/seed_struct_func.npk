// seed_struct_func.aria — struct with float64 fields + function that uses it
func:failsafe = int32(tbb32:err) { exit 1; };

struct:Rectangle = {
    float64:width;
    float64:height;
};

func:area = float64(float64:w, float64:h) {
    pass w * h;
};

func:main = int32() {
    Rectangle:r = { 5.0, 3.0 };
    float64:w = r.width;
    float64:h = r.height;
    float64:a = raw area(w, h);
    exit 0;
};
