// seed_array_till.aria — array declaration + till loop with direct [$] indexing
func:failsafe = NIL(int32:err_code) { };

func:main = int32() {
    int32[5]:values = [10, 20, 30, 40, 50];
    int32:sum = 0i32;
    till(5, 1) {
        sum = sum + values[$];
    }
    // sum should be 150
    int32:first = values[0];
    int32:last = values[4];
    pass(sum);
};
