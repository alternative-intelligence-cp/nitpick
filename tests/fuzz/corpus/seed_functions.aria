func:add = int64(int64:a, int64:b) {
    int64:result = (a + b);
    return result;
};

func:multiply = int64(int64:a, int64:b) {
    int64:result = (a * b);
    return result;
};

func:main = int32() {
    int64:x = 10;
    int64:y = 20;
    int64:sum = add(x, y);
    int64:prod = multiply(x, y);
    print(sum);
    print(prod);
    return 0;
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
