// seed_ring_buffer.aria — ring buffer with modulo indexing
func:failsafe = int32(tbb32:err) { exit(1); };
extern func:aria_alloc = wild int64*(int64:size);
extern func:aria_free  = void(wild int64*:ptr);
pub func:ring_write = int64(wild int64->:buf, int64:cap, int64:head, int64:val) {
    buf[head] = val;
    int64:next = head + 1i64;
    if (next >= cap) { next = 0i64; }
    pass(next);
};
func:main = int32() {
    int64:cap = 4i64;
    wild int64->:buf = aria_alloc(cap * 8i64);
    int64:head = 0i64;
    head = raw(ring_write(buf, cap, head, 10i64));
    head = raw(ring_write(buf, cap, head, 20i64));
    head = raw(ring_write(buf, cap, head, 30i64));
    head = raw(ring_write(buf, cap, head, 40i64));
    head = raw(ring_write(buf, cap, head, 50i64));
    aria_free(buf);
    exit(0);
};
