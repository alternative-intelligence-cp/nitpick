    test_bug005_nit_and_logic();
    test_bug005_nit_or_logic();
    print("");
    
    print("=== BUG-006: Trit/Nit Sentinel Healing Tests ===");
    test_bug006_trit_err_propagation_add();
    test_bug006_trit_err_propagation_mul();
    test_bug006_trit_err_propagation_and();
    test_bug006_nit_err_propagation();
    print("");
    
    print("=== BUG-007: Nit Error Swallowing Tests ===");
    test_bug007_nit_add_overflow();
    test_bug007_nit_add_underflow();
    test_bug007_nit_mul_overflow();
    test_bug007_nit_valid_addition();
    test_bug007_nit_edge_valid();
