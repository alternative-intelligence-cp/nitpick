func:failsafe = int32(tbb32:err) {
    exit(1);
};

func:main = int32() {
    drop(println("=== Q3 Constructor Test ==="));
    
    // Test 1: q3_create with explicit confidence
    drop(println("Test 1: q3_create"));
    Q3<int32>:q1 = q3_create(10, 20, 0);
    
    if (q1.a == 10 && q1.b == 20 && q1.c == 0) {
        drop(println("  PASS: q3_create works"));
    }
    
    // Test 2: q3_unknown (c = 0)
    drop(println("Test 2: q3_unknown"));
    Q3<int32>:q2 = q3_unknown(100, 200);
    
    if (q2.a == 100 && q2.b == 200 && q2.c == 0) {
