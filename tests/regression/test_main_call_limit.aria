// Regression test: main function call limit (Bug 1a)
// Previously, too many function calls in main caused crashes.
// This test verifies 100+ calls in main compile and run correctly.

func:failsafe = int32(tbb32:err) { exit 1; };

func:increment = NIL(int32:x) {
    pass NIL;
};

func:main = int32() {
    drop increment(1i32);
    drop increment(2i32);
    drop increment(3i32);
    drop increment(4i32);
    drop increment(5i32);
