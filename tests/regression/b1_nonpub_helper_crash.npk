// B1 Regression Test: Non-pub helper function called from pub function
// Expected: Should compile and run without crashing

func:helper = int64() {
    pass 42;
};

pub func:caller = int64() {
    int64:x = raw helper();
    pass x;
};

func:main = int32() {
    int64:val = raw caller();
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};
