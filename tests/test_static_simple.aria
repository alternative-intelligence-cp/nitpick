// Simple test for Type.MEMBER static access transformation
// Validates that Counter.nextId() desugars to Counter_nextId()

func:Counter_nextId = int32() {
    pass(42i32);
};

func:test_static = int32() {
    // This should transform Counter.nextId to Counter_nextId() call
    int32:id = raw(Counter.nextId());
    pass(0i32);
};

func:main = int32() {
    exit(0);
};

func:failsafe = int32(tbb32:err) { exit(1); };
