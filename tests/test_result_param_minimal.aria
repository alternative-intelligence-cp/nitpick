// Minimal test to debug Result parameter passing
// Tests basic Result creation and member access

func:make_result_ok = int32() {
    pass 42i32;
};

func:make_result_err = int32() {
    fail 1i32;
};

func:main = int32() {
    Result<int32>:ok_result = make_result_ok();
    if (!ok_result.is_error) {
        int32:val = ok_result.value;  // Should be 42
        exit 0;
    }
    pass 1i32;
};

func:failsafe = int32(tbb32:err) { exit 1; };
