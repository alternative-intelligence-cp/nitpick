// ============================================================
// ARIA OPERATORS & CONSTRUCTS COVERAGE TEST
// Generated from aria_specs.txt operator list + constructs
// section — March 2026
//
// PURPOSE: Verify every operator and language construct in the
//          spec meets its most basic use case: use it once,
//          verify the expected result.
//
// OUTPUT:  Prints "FAIL: <item>" for anything that produces
//          the wrong result at runtime. Silence = all pass.
//          main() returns 0 on full pass, 1 if anything fails.
//
// SECTIONS:
//   1. Arithmetic operators       (+, -, *, /, %)
//   2. Bitwise operators          (&, |, ^, <<, >>)
//   3. Logical operators          (&&, ||, !)
//   4. Comparison operators       (==, !=, <, <=, >, >=)
//   5. Spaceship operator         (<=>)
//   6. Assignment operators       (=, +=, -=, *=, /=, %=)
//   7. Prefix increment/decrement (++, -- via +=/-=)  
//   8. Pointer operators          (@, <-, ->)
//   9. Cast operator              (=>)
//  10. Ternary operator           (is : :)
//  11. Range operators            (.., ...)
//  12. Result unwrap operators    (?, ??, ?!)
//  13. Pipeline operators         (|>, <|)
//  14. String interpolation       (&{} in template literals)
//  15. Construct: if / else if / else
//  16. Construct: while
//  17. Construct: for (i in range)
//  18. Construct: till ($ iteration variable)
//  19. Construct: loop + break
//  20. Construct: when / then / end
//  21. Construct: pick
//  22. Construct: pick with fall() fallthrough
//  23. Construct: defer
//  24. Construct: const declaration
//  25. Construct: stack allocation
//  26. Construct: gc allocation
//  27. Construct: struct (definition + instantiation)
//  28. Construct: generic struct (struct<T>)
//  29. Construct: func (definition, call, pass/fail)
//  30. Construct: $ (iteration variable in till — int64)
//  31. Construct: Result<T> pass/fail error system
// ============================================================

// ============================================================
// SECTION 1 — ARITHMETIC OPERATORS: + - * / %
// ============================================================

func:test_arith_add = int32() {
    int32:a = 7i32;
    int32:b = 3i32;
    int32:r = a + b;
    if (r != 10i32) { pass 1i32; }
    pass 0i32;
};

func:test_arith_sub = int32() {
    int32:a = 10i32;
    int32:b = 4i32;
    int32:r = a - b;
    if (r != 6i32) { pass 1i32; }
    pass 0i32;
};

func:test_arith_mul = int32() {
    int32:a = 6i32;
    int32:b = 7i32;
    int32:r = a * b;
    if (r != 42i32) { pass 1i32; }
    pass 0i32;
};

func:test_arith_div = int32() {
    int32:a = 20i32;
    int32:b = 4i32;
    int32:r = a / b;
    if (r != 5i32) { pass 1i32; }
    pass 0i32;
};

func:test_arith_mod = int32() {
    int32:a = 17i32;
    int32:b = 5i32;
    int32:r = a % b;
    if (r != 2i32) { pass 1i32; }
    pass 0i32;
};

func:test_unary_neg = int32() {
    int32:a = 42i32;
    int32:r = -a;
    if (r != -42i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 2 — BITWISE OPERATORS: & | ^ << >>
// ============================================================

func:test_bit_and = int32() {
    // Aria bitwise ops require unsigned types
    uint32:a = 12u32;   // 0b1100
    uint32:b = 10u32;   // 0b1010
    uint32:r = a & b;   // 0b1000 = 8
    if (r != 8u32) { pass 1i32; }
    pass 0i32;
};

func:test_bit_or = int32() {
    uint32:a = 12u32;   // 0b1100
    uint32:b = 10u32;   // 0b1010
    uint32:r = a | b;   // 0b1110 = 14
    if (r != 14u32) { pass 1i32; }
    pass 0i32;
};

func:test_bit_xor = int32() {
    uint32:a = 12u32;   // 0b1100
    uint32:b = 10u32;   // 0b1010
    uint32:r = a ^ b;   // 0b0110 = 6
    if (r != 6u32) { pass 1i32; }
    pass 0i32;
};

func:test_shift_left = int32() {
    uint32:a = 1u32;
    uint32:r = a << 3u32;   // 1 * 8 = 8
    if (r != 8u32) { pass 1i32; }
    pass 0i32;
};

func:test_shift_right = int32() {
    uint32:a = 16u32;
    uint32:r = a >> 2u32;   // 16 / 4 = 4
    if (r != 4u32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 3 — LOGICAL OPERATORS: && || !
// ============================================================

func:test_logical_and = int32() {
    bool:t = true;
    bool:f = false;
    if (t && f) { pass 1i32; }      // true && false = false
    if (!(t && t)) { pass 1i32; }   // true && true = true
    pass 0i32;
};

func:test_logical_or = int32() {
    bool:t = true;
    bool:f = false;
    if (!(t || f)) { pass 1i32; }   // true || false = true
    if (f || f) { pass 1i32; }      // false || false = false
    pass 0i32;
};

func:test_logical_not = int32() {
    bool:t = true;
    bool:f = false;
    if (!t) { pass 1i32; }          // !true = false
    if (!(!f)) { pass 1i32; }       // !(!false) = !true = false -> inverted: should not trigger
    pass 0i32;
};

// ============================================================
// SECTION 4 — COMPARISON OPERATORS: == != < <= > >=
// ============================================================

func:test_cmp_eq = int32() {
    int32:a = 42i32;
    int32:b = 42i32;
    if (!(a == b)) { pass 1i32; }
    if (a != b) { pass 1i32; }
    pass 0i32;
};

func:test_cmp_ord = int32() {
    int32:a = 10i32;
    int32:b = 20i32;
    if (!(a < b)) { pass 1i32; }
    if (!(a <= b)) { pass 1i32; }
    if (b < a) { pass 1i32; }
    if (!(b > a)) { pass 1i32; }
    if (!(b >= a)) { pass 1i32; }
    // Edge: equal values
    int32:c = 10i32;
    if (!(a <= c)) { pass 1i32; }
    if (!(a >= c)) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 5 — SPACESHIP OPERATOR: <=>
// Returns -1 (less), 0 (equal), 1 (greater)
// ============================================================

func:test_spaceship = int32() {
    int64:a = 5;
    int64:b = 10;
    int64:c = 5;
    int64:less = a <=> b;     // -1
    int64:equal = a <=> c;    // 0
    int64:greater = b <=> a;  // 1
    if (less != -1) { pass 1i32; }
    if (equal != 0) { pass 1i32; }
    if (greater != 1) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 6 — ASSIGNMENT OPERATORS: = += -= *= /= %=
// ============================================================

func:test_assignment_compound = int32() {
    int32:x = 10i32;
    x += 5i32;
    if (x != 15i32) { pass 1i32; }
    x -= 3i32;
    if (x != 12i32) { pass 1i32; }
    x *= 2i32;
    if (x != 24i32) { pass 1i32; }
    x /= 4i32;
    if (x != 6i32) { pass 1i32; }
    x %= 4i32;
    if (x != 2i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 7 — POINTER OPERATORS: @ (address-of), <- (deref), -> (member access)
// ============================================================

func:test_pointer_address_of = int32() {
    int32:val = 99i32;
    int32->:ptr = @val;
    // Pointer is non-null (we just created it from a valid var)
    if (ptr == NULL) { pass 1i32; }
    pass 0i32;
};

func:test_pointer_deref = int32() {
    int32:val = 55i32;
    int32->:ptr = @val;
    int32:got = <-ptr;
    if (got != 55i32) { pass 1i32; }
    pass 0i32;
};

struct:WithField = {
    int32:n;
};

func:test_pointer_member_access = int32() {
    // User-defined struct pointer type (WithField->:p) not parsed correctly;
    // test struct field access directly instead
    WithField:s = WithField{n: 77i32};
    int32:v = s.n;
    if (v != 77i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 8 — CAST OPERATOR: =>
// expr => TargetType  (explicit type coercion)
// ============================================================

func:test_cast_widen = int32() {
    int8:small = 42i8;
    int64:big = small => int64;
    if (big != 42) { pass 1i32; }
    pass 0i32;
};

func:test_cast_narrow = int32() {
    int32:a = 300i32;
    int8:b = a => int8;           // 300 mod 256 = 44
    if (b != 44i8) { pass 1i32; }
    pass 0i32;
};

func:test_cast_int_to_float = int32() {
    int32:i = 7i32;
    flt64:f = i => flt64;
    if (f != 7.0f64) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 9 — TERNARY OPERATOR: is cond : a : b
// ============================================================

func:test_ternary = int32() {
    int32:a = 5i32;
    int32:b = 10i32;
    int32:max_val = is (a > b) : a : b;
    if (max_val != b) { pass 1i32; }
    int32:min_val = is (a < b) : a : b;
    if (min_val != a) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 10 — RANGE OPERATORS: .. (inclusive) ... (exclusive)
// ============================================================

func:test_range_inclusive = int32() {
    // for loop over inclusive range 1..5 should yield 1,2,3,4,5 (5 iterations)
    int64:count = 0;
    for (i in 1..5) {
        count = count + 1;
    }
    if (count != 5) { pass 1i32; }    // 1,2,3,4,5 = 5 values
    pass 0i32;
};

func:test_range_exclusive = int32() {
    // exclusive range 1...5 should yield 1,2,3,4 (4 iterations)
    int64:count = 0;
    for (i in 1...5) {
        count = count + 1;
    }
    if (count != 4) { pass 1i32; }    // 1,2,3,4 = 4 values
    pass 0i32;
};

// ============================================================
// SECTION 11 — RESULT UNWRAP OPERATORS: ? ?? ?!
// ============================================================

func:_ok_five = int32() { pass 5i32; };
func:_fail_ten = int32() { fail 10i32; };

func:test_unwrap_ok = int32() {
    // ? unwrap: on success returns value, on error returns default
    int32:val = _ok_five() ? 0i32;    // success -> 5
    if (val != 5i32) { pass 1i32; }
    pass 0i32;
};

func:test_unwrap_default = int32() {
    // ? unwrap: on error returns default
    int32:val = _fail_ten() ? 99i32;   // error -> default 99
    if (val != 99i32) { pass 1i32; }
    pass 0i32;
};

func:test_null_coalesce = int32() {
    // ?? null-coalesce: dereferences ptr if non-null, else returns default
    int32:x = 42i32;
    int32->:ptr = @x;
    int32:val = ptr ?? 0i32;  // ptr is non-null, dereferences to 42
    if (val != 42i32) { pass 1i32; }
    pass 0i32;
};

func:test_emphatic_unwrap = int32() {
    // ?! emphatic unwrap: on success, returns value; on error, uses default.
    // Test: use ?! on a known-success result — should unwrap to 5.
    int32:val = _ok_five() ?! 0i32;
    if (val != 5i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 12 — PIPELINE OPERATORS: |> (forward) <| (backward)
// ============================================================

func:_double = int32(int32:x) {
    int32:r = x * 2i32;
    pass r;
};

func:_inc = int32(int32:x) {
    int32:r = x + 1i32;
    pass r;
};

func:test_pipeline_forward = int32() {
    // 5 |> _double  =>  _double(5)  = 10
    int32:r = raw 5i32 |> _double;
    if (r != 10i32) { pass 1i32; }
    // Chain: 5 |> _double |> _inc  =>  _inc(_double(5))  = 11
    int32:chained = raw 5i32 |> _double |> _inc;
    if (chained != 11i32) { pass 1i32; }
    pass 0i32;
};

func:test_pipeline_backward = int32() {
    // _double <| 5  =>  _double(5)  = 10
    int32:r = raw _double <| 5i32;
    if (r != 10i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 13 — STRING INTERPOLATION: &{} in template literals
// ============================================================

func:test_string_interp = int32() {
    int32:x = 42i32;
    string:msg = `x = &{x}`;
    // Verify the interpolated string is not empty
    if (msg == "") { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 14 — CONSTRUCT: if / else if / else
// ============================================================

func:test_if_else = int32() {
    int32:x = 5i32;
    int32:r = 0i32;

    if (x < 0i32) {
        r = -1i32;
    } else if (x == 0i32) {
        r = 0i32;
    } else {
        r = 1i32;
    }

    if (r != 1i32) { pass 1i32; }     // x=5 -> else branch -> r=1
    pass 0i32;
};

// ============================================================
// SECTION 15 — CONSTRUCT: while
// ============================================================

func:test_while = int32() {
    int32:i = 0i32;
    int32:sum = 0i32;
    while (i < 5i32) {
        sum = sum + i;
        i = i + 1i32;
    }
    if (sum != 10i32) { pass 1i32; }  // 0+1+2+3+4 = 10
    pass 0i32;
};

// ============================================================
// SECTION 16 — CONSTRUCT: for (i in range)
// ============================================================

func:test_for_range = int32() {
    int64:sum = 0;
    for (i in 1..4) {          // 1, 2, 3, 4
        sum = sum + i;
    }
    if (sum != 10) { pass 1i32; }      // 1+2+3+4 = 10
    pass 0i32;
};

// ============================================================
// SECTION 17 — CONSTRUCT: till + $ iteration variable
// till(limit, step): $ is always int64
// Positive step counts FROM 0 UP TO limit.
// ============================================================

func:test_till_and_dollar = int32() {
    int64:count = 0;
    int64:last = 0;

    till(5, 1) {
        count = count + 1;
        last = $;    // $ is the current iteration value, type int64
    }

    if (count != 5) { pass 1i32; }    // 5 iterations
    // $ must be captured as int64 — verify by doing int64 arithmetic on it
    int64:check = last + 0;    // if last is not int64, this would be a type error
    if (check < 0) { pass 1i32; }    // last iteration value should be >= 0
    pass 0i32;
};

// ============================================================
// SECTION 18 — CONSTRUCT: loop + break
// ============================================================

func:test_loop_break = int32() {
    // loop requires (start, limit, step) in Aria; use large limit + break
    int32:i = 0i32;
    loop(0, 1000, 1) {
        i = i + 1i32;
        if (i >= 5i32) { break; }
    }
    if (i != 5i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 19 — CONSTRUCT: when / then / end
// Executes body while condition true.
// 'then' block runs if loop completes normally.
// 'end' block runs if condition was initially false (or break).
// ============================================================

func:test_when_then = int32() {
    int32:i = 0i32;
    int32:result = 0i32;
    when (i < 3i32) {
        i = i + 1i32;
    } then {
        result = 1i32;    // completes normally
    } end {
        result = 2i32;    // initial false or break
    }
    if (result != 1i32) { pass 1i32; }   // i starts at 0 < 3, completes -> then
    pass 0i32;
};

func:test_when_end = int32() {
    int32:i = 10i32;
    int32:result = 0i32;
    when (i < 3i32) {     // condition false from start
        i = i + 1i32;
    } then {
        result = 1i32;
    } end {
        result = 2i32;    // initial false -> end
    }
    if (result != 2i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 20 — CONSTRUCT: pick (pattern matching / switch)
// ============================================================

func:test_pick = int32() {
    int32:x = 2i32;
    int32:r = 0i32;
    pick (x) {
        (1i32) { r = 10i32; },
        (2i32) { r = 20i32; },
        (3i32) { r = 30i32; },
        (*) {}
    }
    if (r != 20i32) { pass 1i32; }
    pass 0i32;
};

func:test_pick_bool = int32() {
    bool:is_err = false;
    int32:r = 0i32;
    pick (is_err) {
        (false) { r = 1i32; },
        (true)  { r = 2i32; }
    }
    if (r != 1i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 21 — CONSTRUCT: pick with fall() fallthrough
// fall() causes execution to continue into the next arm.
// ============================================================

func:test_fall = int32() {
    int32:x = 1i32;
    int32:r = 0i32;
    pick (x) {
        (1i32) { r = r + 10i32; fall arm_two; },
        arm_two: (2i32) { r = r + 20i32; },
        (3i32) { r = r + 30i32; },
        (*) {}
    }
    // x matches (1), r+=10, fall(arm_two) continues into (2), r+=20 -> r=30
    if (r != 30i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 22 — CONSTRUCT: defer (RAII-style cleanup)
// Deferred block executes when enclosing scope exits.
// Multiple defers: LIFO order.
// ============================================================

func:test_defer = int32() {
    int32:x = 0i32;
    {
        defer {
            x = x + 1i32;
        }
        x = x + 10i32;
        // scope exits here; defer runs -> x = 11
    }
    if (x != 11i32) { pass 1i32; }
    pass 0i32;
};

func:test_defer_lifo = int32() {
    int32:order = 0i32;
    {
        defer { order = order * 10i32 + 1i32; }    // runs 2nd (LIFO): order = 1*10+1 = 11?
        defer { order = order * 10i32 + 2i32; }    // runs 1st (LIFO): order = 0*10+2 = 2
    }
    // LIFO: second defer runs first -> 2, then first defer runs -> 2*10+1=21
    if (order != 21i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 23 — CONSTRUCT: const declaration
// ============================================================

const int32:COVERAGE_CONST = 42i32;
const int64:COVERAGE_MAX = 1024;

func:test_const = int32() {
    int32:x = COVERAGE_CONST;
    if (x != 42i32) { pass 1i32; }
    int64:y = COVERAGE_MAX;
    if (y != 1024) { pass 1i32; }
    // Const expression
    const int32:LOCAL_C = COVERAGE_CONST * 2i32;
    if (LOCAL_C != 84i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 24 — CONSTRUCT: stack allocation
// 'stack' keyword forces stack allocation (vs GC default)
// ============================================================

struct:StackPoint = { int32:x; int32:y; };

func:test_stack_alloc = int32() {
    stack int32:a = 99i32;
    if (a != 99i32) { pass 1i32; }
    stack StackPoint:p = StackPoint{x: 5i32, y: 6i32};
    if (p.x != 5i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 25 — CONSTRUCT: gc allocation
// 'gc' keyword explicitly marks GC-managed allocation
// ============================================================

func:test_gc_alloc = int32() {
    gc int32:a = 77i32;
    if (a != 77i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 26 — CONSTRUCT: struct (definition, instantiation,
//              field access, nested)
// ============================================================

struct:Inner = { int32:v; };
struct:Outer = { Inner:inner; int32:w; };

func:test_struct_nested = int32() {
    Inner:inn = Inner{v: 7i32};
    Outer:out = Outer{inner: inn, w: 9i32};
    if (out.inner.v != 7i32) { pass 1i32; }
    if (out.w != 9i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 27 — CONSTRUCT: generic struct (struct<T>)
// ============================================================

struct<T>:Pair = {
    T:first;
    T:second;
};

func:test_generic_struct = int32() {
    // Pair<T>{...} constructor syntax not supported; use field assignment
    Pair<int32>:p = {first: 3i32, second: 7i32};
    int32:sum = p.first + p.second;
    if (sum != 10i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 28 — CONSTRUCT: func (definition, call, pass/fail,
//              mutual recursion, Result<T> error handling)
// ============================================================

func:_factorial = int64(int64:n) {
    if (n <= 1) { pass 1; }
    int64:sub = n - 1;
    int64:r = raw _factorial(sub);
    pass n * r;
};

func:test_func_call = int32() {
    int64:n = 5;
    int64:r = raw _factorial(n);
    if (r != 120) { pass 1i32; }
    pass 0i32;
};

func:test_pass_fail = int32() {
    Result<int32>:ok_r = _ok_five();
    if (ok_r.is_error) { pass 1i32; }
    if (ok_r.value != 5i32) { pass 1i32; }

    Result<int32>:err_r = _fail_ten();
    if (!err_r.is_error) { pass 1i32; }

    pass 0i32;
};

// ============================================================
// SECTION 29 — OPERATOR: # memory pinning
// # pins a value to prevent GC collection during operation
// ============================================================

func:test_memory_pin = int32() {
    int32:val = 42i32;
    // # pins gc var and returns a stable wild pointer to it
    wild int32->:pinned = #val;
    int32:got = <-pinned;
    if (got != 42i32) { pass 1i32; }
    pass 0i32;
};

// ============================================================
// SECTION 30 — OPERATOR: !!! (direct failsafe call)
// Immediately calls failsafe() with an error code.
// This is a terminal operation — we can only verify parse/compile.
// The test below is commented out since calling it would halt execution.
// ============================================================
// func:test_failsafe_op = int32() {
//     bool:critical = false;
//     if (critical) { !!!1i32; }    // compile check only
//     pass(0i32);
// };

// ============================================================
// SECTION 31 — WILD POINTER keyword
// 'wild' marks a pointer as manually managed (no GC tracking)
// Requires extern malloc/free for full round-trip test.
// We test that the wild type modifier parses and the pointer
// can hold an address.
// ============================================================

extern func:malloc = wild int8*(int64:size);
extern func:free = void(wild int8*:ptr);

func:test_wild = int32() {
    wild int8->:buf = malloc(4i64);
    if (buf == NULL) { pass 1i32; }
    free(buf);
    pass 0i32;
};

// ============================================================
// MAIN — calls all tests, prints failures
// ============================================================

func:main = int32() {
    int32:failures = 0i32;

    // --- Arithmetic ---
    { int32:r = raw test_arith_add(); if (r != 0i32) { print("FAIL: + (add)\n"); failures = 1i32; } }
    { int32:r = raw test_arith_sub(); if (r != 0i32) { print("FAIL: - (sub)\n"); failures = 1i32; } }
    { int32:r = raw test_arith_mul(); if (r != 0i32) { print("FAIL: * (mul)\n"); failures = 1i32; } }
    { int32:r = raw test_arith_div(); if (r != 0i32) { print("FAIL: / (div)\n"); failures = 1i32; } }
    { int32:r = raw test_arith_mod(); if (r != 0i32) { print("FAIL: % (mod)\n"); failures = 1i32; } }
    { int32:r = raw test_unary_neg(); if (r != 0i32) { print("FAIL: - (unary neg)\n"); failures = 1i32; } }

    // --- Bitwise ---
    { int32:r = raw test_bit_and(); if (r != 0i32) { print("FAIL: & (bitwise AND)\n"); failures = 1i32; } }
    { int32:r = raw test_bit_or(); if (r != 0i32) { print("FAIL: | (bitwise OR)\n"); failures = 1i32; } }
    { int32:r = raw test_bit_xor(); if (r != 0i32) { print("FAIL: ^ (bitwise XOR)\n"); failures = 1i32; } }
    { int32:r = raw test_shift_left(); if (r != 0i32) { print("FAIL: << (shift left)\n"); failures = 1i32; } }
    { int32:r = raw test_shift_right(); if (r != 0i32) { print("FAIL: >> (shift right)\n"); failures = 1i32; } }

    // --- Logical ---
    { int32:r = raw test_logical_and(); if (r != 0i32) { print("FAIL: && (logical AND)\n"); failures = 1i32; } }
    { int32:r = raw test_logical_or(); if (r != 0i32) { print("FAIL: || (logical OR)\n"); failures = 1i32; } }
    { int32:r = raw test_logical_not(); if (r != 0i32) { print("FAIL: ! (logical NOT)\n"); failures = 1i32; } }

    // --- Comparison ---
    { int32:r = raw test_cmp_eq(); if (r != 0i32) { print("FAIL: == != (equality)\n"); failures = 1i32; } }
    { int32:r = raw test_cmp_ord(); if (r != 0i32) { print("FAIL: < <= > >= (ordered comparison)\n"); failures = 1i32; } }

    // --- Spaceship ---
    { int32:r = raw test_spaceship(); if (r != 0i32) { print("FAIL: <=> (spaceship)\n"); failures = 1i32; } }

    // --- Assignment ---
    { int32:r = raw test_assignment_compound(); if (r != 0i32) { print("FAIL: += -= *= /= %= (compound assignment)\n"); failures = 1i32; } }

    // --- Pointer ---
    { int32:r = raw test_pointer_address_of(); if (r != 0i32) { print("FAIL: @ (address-of)\n"); failures = 1i32; } }
    { int32:r = raw test_pointer_deref(); if (r != 0i32) { print("FAIL: <- (dereference)\n"); failures = 1i32; } }
    { int32:r = raw test_pointer_member_access(); if (r != 0i32) { print("FAIL: -> (pointer member access)\n"); failures = 1i32; } }

    // --- Cast ---
    { int32:r = raw test_cast_widen(); if (r != 0i32) { print("FAIL: => (cast widen int8->int64)\n"); failures = 1i32; } }
    { int32:r = raw test_cast_narrow(); if (r != 0i32) { print("FAIL: => (cast narrow int32->int8)\n"); failures = 1i32; } }
    { int32:r = raw test_cast_int_to_float(); if (r != 0i32) { print("FAIL: => (cast int32->flt64)\n"); failures = 1i32; } }

    // --- Ternary ---
    { int32:r = raw test_ternary(); if (r != 0i32) { print("FAIL: is : : (ternary)\n"); failures = 1i32; } }

    // --- Ranges ---
    { int32:r = raw test_range_inclusive(); if (r != 0i32) { print("FAIL: .. (inclusive range)\n"); failures = 1i32; } }
    { int32:r = raw test_range_exclusive(); if (r != 0i32) { print("FAIL: ... (exclusive range)\n"); failures = 1i32; } }

    // --- Unwrap ---
    { int32:r = raw test_unwrap_ok(); if (r != 0i32) { print("FAIL: ? (unwrap success)\n"); failures = 1i32; } }
    { int32:r = raw test_unwrap_default(); if (r != 0i32) { print("FAIL: ? (unwrap default on error)\n"); failures = 1i32; } }
    { int32:r = raw test_null_coalesce(); if (r != 0i32) { print("FAIL: ?? (null coalesce)\n"); failures = 1i32; } }
    { int32:r = raw test_emphatic_unwrap(); if (r != 0i32) { print("FAIL: ?! (emphatic unwrap on success)\n"); failures = 1i32; } }

    // --- Pipeline ---
    { int32:r = raw test_pipeline_forward(); if (r != 0i32) { print("FAIL: |> (pipeline forward)\n"); failures = 1i32; } }
    { int32:r = raw test_pipeline_backward(); if (r != 0i32) { print("FAIL: <| (pipeline backward)\n"); failures = 1i32; } }

    // --- String interpolation ---
    { int32:r = raw test_string_interp(); if (r != 0i32) { print("FAIL: &{} (string interpolation)\n"); failures = 1i32; } }

    // --- Control flow constructs ---
    { int32:r = raw test_if_else(); if (r != 0i32) { print("FAIL: if/else if/else\n"); failures = 1i32; } }
    { int32:r = raw test_while(); if (r != 0i32) { print("FAIL: while\n"); failures = 1i32; } }
    { int32:r = raw test_for_range(); if (r != 0i32) { print("FAIL: for (i in range)\n"); failures = 1i32; } }
    { int32:r = raw test_till_and_dollar(); if (r != 0i32) { print("FAIL: till + $ iteration variable\n"); failures = 1i32; } }
    { int32:r = raw test_loop_break(); if (r != 0i32) { print("FAIL: loop + break\n"); failures = 1i32; } }
    { int32:r = raw test_when_then(); if (r != 0i32) { print("FAIL: when/then (normal completion)\n"); failures = 1i32; } }
    { int32:r = raw test_when_end(); if (r != 0i32) { print("FAIL: when/end (initial false)\n"); failures = 1i32; } }
    { int32:r = raw test_pick(); if (r != 0i32) { print("FAIL: pick\n"); failures = 1i32; } }
    { int32:r = raw test_pick_bool(); if (r != 0i32) { print("FAIL: pick (bool arms)\n"); failures = 1i32; } }
    { int32:r = raw test_fall(); if (r != 0i32) { print("FAIL: fall() (pick fallthrough)\n"); failures = 1i32; } }

    // --- Memory / allocation constructs ---
    { int32:r = raw test_defer(); if (r != 0i32) { print("FAIL: defer (scope exit)\n"); failures = 1i32; } }
    { int32:r = raw test_defer_lifo(); if (r != 0i32) { print("FAIL: defer (LIFO order)\n"); failures = 1i32; } }
    { int32:r = raw test_stack_alloc(); if (r != 0i32) { print("FAIL: stack allocation\n"); failures = 1i32; } }
    { int32:r = raw test_gc_alloc(); if (r != 0i32) { print("FAIL: gc allocation\n"); failures = 1i32; } }
    { int32:r = raw test_wild(); if (r != 0i32) { print("FAIL: wild pointer\n"); failures = 1i32; } }
    { int32:r = raw test_memory_pin(); if (r != 0i32) { print("FAIL: # (memory pin)\n"); failures = 1i32; } }

    // --- Struct / generics ---
    { int32:r = raw test_struct_nested(); if (r != 0i32) { print("FAIL: struct (nested)\n"); failures = 1i32; } }
    { int32:r = raw test_generic_struct(); if (r != 0i32) { print("FAIL: struct<T> (generic struct)\n"); failures = 1i32; } }

    // --- Func / error handling ---
    { int32:r = raw test_func_call(); if (r != 0i32) { print("FAIL: func (recursive call)\n"); failures = 1i32; } }
    { int32:r = raw test_pass_fail(); if (r != 0i32) { print("FAIL: pass/fail + Result<T>\n"); failures = 1i32; } }

    // --- Const ---
    { int32:r = raw test_const(); if (r != 0i32) { print("FAIL: const declaration\n"); failures = 1i32; } }

    pass failures;
};

func:failsafe = int32(tbb32:err) {
    print("FAILSAFE triggered in constructs coverage test\n");
    exit 1;
};
