// ============================================================
// TIER 1 — TWISTED BALANCED BINARY (TBB)
// Symmetric range; min value is ERR sentinel
// ============================================================

func:test_tbb8 = int32() {
    tbb8:a = 50tbb8;
    tbb8:b = 25tbb8;
    tbb8:sum = a + b;
    if (sum != 75tbb8) { pass(1i32); }
    pass(0i32);
};

func:test_tbb16 = int32() {
    tbb16:a = 10000tbb16;
    tbb16:b = 5000tbb16;
    tbb16:sum = a + b;
    if (sum != 15000tbb16) { pass(1i32); }
    pass(0i32);
};

func:test_tbb32 = int32() {
    tbb32:a = 1000000tbb32;
    tbb32:b = 500000tbb32;
    tbb32:sum = a + b;
    if (sum != 1500000tbb32) { pass(1i32); }
    pass(0i32);
};

func:test_tbb64 = int32() {
    tbb64:a = 1000000000tbb64;
    tbb64:b = 2000000000tbb64;
    tbb64:sum = a + b;
    if (sum != 3000000000tbb64) { pass(1i32); }
    pass(0i32);
};

// ============================================================
// TIER 1 — BOOL
// ============================================================

func:test_bool = int32() {
    bool:t = true;
    bool:f = false;
    if (!t) { pass(1i32); }
    if (f) { pass(1i32); }
    bool:anded = t && f;
    if (anded) { pass(1i32); }
    bool:ored = t || f;
    if (!ored) { pass(1i32); }
    pass(0i32);
};

// ============================================================
// TIER 1 — STRING
// ============================================================

func:test_string = int32() {
    string:a = "hello";
    string:b = " world";
    string:c = string_concat(a, b);
    if (c != "hello world") { pass(1i32); }
    pass(0i32);
};

// ============================================================
// TIER 2 — BALANCED TERNARY / NONARY
// ============================================================

func:test_trit = int32() {
    trit:neg = -1;
    trit:zero = 0;
    trit:pos = 1;
    if (zero != 0) { pass(1i32); }
    if (!(neg < pos)) { pass(1i32); }
    pass(0i32);
};

func:test_tryte = int32() {
    tryte:val = 100;
    if (val != 100) { pass(1i32); }
    pass(0i32);
};

func:test_nit = int32() {
    nit:neg = -4;   // min nonary digit
    nit:zero = 0;
    nit:pos = 4;    // max nonary digit
    if (zero != 0) { pass(1i32); }
    if (!(neg < pos)) { pass(1i32); }
    pass(0i32);
};

func:test_nyte = int32() {
    nyte:val = 50;
    if (val != 50) { pass(1i32); }
    pass(0i32);
};

// ============================================================
// TIER 2 — VECTORS
// ============================================================

func:test_vec2 = int32() {
    vec2:a = vec2(3.0, 4.0);
    vec2:b = vec2(1.0, 2.0);
    flt64:ax = a.x;
    flt64:ay = a.y;
    if (ax != 3.0) { pass(1i32); }
    if (ay != 4.0) { pass(1i32); }
    vec2:sum = a + b;
    flt64:sx = sum.x;
    if (sx != 4.0) { pass(1i32); }
    pass(0i32);
};

func:test_vec3 = int32() {
    vec3:a = vec3(1.0, 2.0, 3.0);
    flt64:z = a.z;
    if (z != 3.0) { pass(1i32); }
    pass(0i32);
};

func:test_vec9 = int32() {
    // make_vec9 and a[0] indexing not yet in IR generator; verify type declares OK
    vec9:a = 0;
    pass(0i32);
};

