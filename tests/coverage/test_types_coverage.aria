    { int32:r = raw(test_frac64()); if (r != 0i32) { print("FAIL: frac64\n"); failures = 1i32; } }

    // --- Twisted floating point ---
    { int32:r = raw(test_tfp32()); if (r != 0i32) { print("FAIL: tfp32\n"); failures = 1i32; } }
    { int32:r = raw(test_tfp64()); if (r != 0i32) { print("FAIL: tfp64\n"); failures = 1i32; } }

    // --- Compound types ---
    { int32:r = raw(test_result()); if (r != 0i32) { print("FAIL: Result<T>\n"); failures = 1i32; } }
    { int32:r = raw(test_array()); if (r != 0i32) { print("FAIL: array\n"); failures = 1i32; } }
    { int32:r = raw(test_struct()); if (r != 0i32) { print("FAIL: struct\n"); failures = 1i32; } }
    { int32:r = raw(test_atomic()); if (r != 0i32) { print("FAIL: atomic<T>\n"); failures = 1i32; } }
    { int32:r = raw(test_nil()); if (r != 0i32) { print("FAIL: NIL/NULL pointer\n"); failures = 1i32; } }

