// ============================================================
// ARIA TYPES COVERAGE TEST
// Generated from aria_specs.txt — March 2026
//
// PURPOSE: Verify every type in the spec meets the most basic
//          use case: declare, assign, operate, check result.
//
// OUTPUT:  Prints "FAIL: <type>" for any type that produces the
//          wrong result at runtime. Silence means all pass.
//          main() returns 0 on full pass, 1 if anything fails.
//
// NOTES:
//   - If this file fails to COMPILE, the compiler error line
//     identifies which type is not yet implemented.
//   - Tier 3+ types (marked below) may not fully compile.
//     Comment out the failing section, re-run, repeat.
//   - Types requiring external stdlib (Handle<T> arena, etc.)
//     are noted but not fully tested here.
// ============================================================

// ============================================================
// TIER 1 — CORE SIGNED INTEGERS
// ============================================================

func:test_int8 = int32() {
    int8:a = 10;
    int8:b = 20;
    int8:sum = a + b;
    if (sum != 30) { pass(1i32); }
    int8:diff = b - a;
    if (diff != 10) { pass(1i32); }
    int8:prod = a * 2;
    if (prod != 20) { pass(1i32); }
    pass(0i32);
};

func:test_int16 = int32() {
    int16:a = 1000;
    int16:b = 2000;
    int16:sum = a + b;
    if (sum != 3000) { pass(1i32); }
    pass(0i32);
};

func:test_int32 = int32() {
    int32:a = 100000i32;
    int32:b = 200000i32;
    int32:sum = a + b;
    if (sum != 300000i32) { pass(1i32); }
    pass(0i32);
};

func:test_int64 = int32() {
    int64:a = 1000000000;
    int64:b = 2000000000;
    int64:sum = a + b;
    if (sum != 3000000000) { pass(1i32); }
    pass(0i32);
};

// ============================================================
// TIER 1 — SMALL SIGNED INTEGERS (int1, int2, int4)
// ============================================================

func:test_int4 = int32() {
    int4:a = 3;
    int4:b = 4;
    int4:sum = a + b;
    if (sum != 7) { pass(1i32); }
    pass(0i32);
};

func:test_int2 = int32() {
    // int2: 2-bit signed — range -2 to 1 (1+1=2 overflows, use 1+(-1)=0)
    int2:a = 1;
    int2:b = -1;
    int2:sum = a + b;
    if (sum != 0) { pass(1i32); }
    pass(0i32);
};

func:test_int1 = int32() {
    // int1: range is just -1, 0 (1-bit signed — two's complement)
    int1:a = 0;
    int1:b = 0;
    int1:sum = a + b;
    if (sum != 0) { pass(1i32); }
    pass(0i32);
};

