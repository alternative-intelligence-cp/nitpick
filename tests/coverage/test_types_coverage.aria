// ============================================================
// TIER 1 — CORE UNSIGNED INTEGERS
// ============================================================

func:test_uint8 = int32() {
    // Use values where sum <= 127 to avoid signed-overflow UB in add nsw i8
    uint8:a = 60u8;
    uint8:b = 40u8;
    uint8:sum = a + b;  // 100, fits in signed i8 range too
    if (sum != 100u8) { pass(1i32); }
    pass(0i32);
};

func:test_uint16 = int32() {
    uint16:a = 1000u16;
    uint16:b = 2000u16;
    uint16:sum = a + b;
    if (sum != 3000u16) { pass(1i32); }
    pass(0i32);
};

func:test_uint32 = int32() {
    uint32:a = 100000u32;
    uint32:b = 200000u32;
    uint32:sum = a + b;
    if (sum != 300000u32) { pass(1i32); }
    pass(0i32);
};

func:test_uint64 = int32() {
    uint64:a = 1000000000u64;
    uint64:b = 2000000000u64;
    uint64:sum = a + b;
    if (sum != 3000000000u64) { pass(1i32); }
    pass(0i32);
};

// ============================================================
// TIER 1 — SMALL UNSIGNED INTEGERS (uint1, uint2, uint4)
// ============================================================

func:test_uint1 = int32() {
    // uint1: 1-bit unsigned — only values 0 and 1
    // Cross-type comparison (uint1 != uint8) sign-extends incorrectly; use same-type
    uint1:a = 0;
    uint1:b = 1;
    uint1:sum = a + b;  // 0+1=1
    uint1:expected = 1;
    if (sum != expected) { pass(1i32); }
    pass(0i32);
};

func:test_uint2 = int32() {
    // uint2: 2-bit unsigned — values 0..3
    // Cross-type comparison sign-extends incorrectly; use same-type
    uint2:a = 1;
    uint2:b = 2;
    uint2:sum = a + b;  // 3
    uint2:expected = 3;
    if (sum != expected) { pass(1i32); }
    pass(0i32);
};

func:test_uint4 = int32() {
    // uint4: 4-bit unsigned — values 0..15 (nibble)
    // Cross-type comparison sign-extends incorrectly; use same-type
    uint4:a = 9;
    uint4:b = 6;
    uint4:sum = a + b;   // 15 — max nibble
    uint4:expected = 15;
    if (sum != expected) { pass(1i32); }
    pass(0i32);
};

