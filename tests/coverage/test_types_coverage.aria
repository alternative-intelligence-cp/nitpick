// ============================================================
// MAIN — calls all tests, prints failures
// ============================================================

func:main = int32() {
    int32:failures = 0i32;

    // --- Core signed integers ---
    { int32:r = raw(test_int8()); if (r != 0i32) { print("FAIL: int8\n"); failures = 1i32; } }
    { int32:r = raw(test_int16()); if (r != 0i32) { print("FAIL: int16\n"); failures = 1i32; } }
    { int32:r = raw(test_int32()); if (r != 0i32) { print("FAIL: int32\n"); failures = 1i32; } }
    { int32:r = raw(test_int64()); if (r != 0i32) { print("FAIL: int64\n"); failures = 1i32; } }

    // --- Small signed integers ---
    { int32:r = raw(test_int4()); if (r != 0i32) { print("FAIL: int4\n"); failures = 1i32; } }
    { int32:r = raw(test_int2()); if (r != 0i32) { print("FAIL: int2\n"); failures = 1i32; } }
    { int32:r = raw(test_int1()); if (r != 0i32) { print("FAIL: int1\n"); failures = 1i32; } }

    // --- Large signed integers ---
    { int32:r = raw(test_int128()); if (r != 0i32) { print("FAIL: int128\n"); failures = 1i32; } }
    { int32:r = raw(test_int256()); if (r != 0i32) { print("FAIL: int256\n"); failures = 1i32; } }
    { int32:r = raw(test_int512()); if (r != 0i32) { print("FAIL: int512\n"); failures = 1i32; } }
    { int32:r = raw(test_int1024()); if (r != 0i32) { print("FAIL: int1024\n"); failures = 1i32; } }
    { int32:r = raw(test_int2048()); if (r != 0i32) { print("FAIL: int2048\n"); failures = 1i32; } }
    { int32:r = raw(test_int4096()); if (r != 0i32) { print("FAIL: int4096\n"); failures = 1i32; } }

    // --- Small unsigned integers ---
    { int32:r = raw(test_uint1()); if (r != 0i32) { print("FAIL: uint1\n"); failures = 1i32; } }
    { int32:r = raw(test_uint2()); if (r != 0i32) { print("FAIL: uint2\n"); failures = 1i32; } }
    { int32:r = raw(test_uint4()); if (r != 0i32) { print("FAIL: uint4\n"); failures = 1i32; } }

    // --- Core unsigned integers ---
    { int32:r = raw(test_uint8()); if (r != 0i32) { print("FAIL: uint8\n"); failures = 1i32; } }
    { int32:r = raw(test_uint16()); if (r != 0i32) { print("FAIL: uint16\n"); failures = 1i32; } }
    { int32:r = raw(test_uint32()); if (r != 0i32) { print("FAIL: uint32\n"); failures = 1i32; } }
    { int32:r = raw(test_uint64()); if (r != 0i32) { print("FAIL: uint64\n"); failures = 1i32; } }

    // --- Large unsigned integers ---
    { int32:r = raw(test_uint128()); if (r != 0i32) { print("FAIL: uint128\n"); failures = 1i32; } }
    { int32:r = raw(test_uint256()); if (r != 0i32) { print("FAIL: uint256\n"); failures = 1i32; } }
    { int32:r = raw(test_uint512()); if (r != 0i32) { print("FAIL: uint512\n"); failures = 1i32; } }
    { int32:r = raw(test_uint1024()); if (r != 0i32) { print("FAIL: uint1024\n"); failures = 1i32; } }
    { int32:r = raw(test_uint2048()); if (r != 0i32) { print("FAIL: uint2048\n"); failures = 1i32; } }
    { int32:r = raw(test_uint4096()); if (r != 0i32) { print("FAIL: uint4096\n"); failures = 1i32; } }

    // --- Fixed point ---
    { int32:r = raw(test_fix256()); if (r != 0i32) { print("FAIL: fix256\n"); failures = 1i32; } }

    // --- Floating point ---
    { int32:r = raw(test_flt32()); if (r != 0i32) { print("FAIL: flt32\n"); failures = 1i32; } }
    { int32:r = raw(test_flt64()); if (r != 0i32) { print("FAIL: flt64\n"); failures = 1i32; } }
    { int32:r = raw(test_flt128()); if (r != 0i32) { print("FAIL: flt128\n"); failures = 1i32; } }
    { int32:r = raw(test_flt256()); if (r != 0i32) { print("FAIL: flt256\n"); failures = 1i32; } }
    { int32:r = raw(test_flt512()); if (r != 0i32) { print("FAIL: flt512\n"); failures = 1i32; } }

    // --- TBB types ---
    { int32:r = raw(test_tbb8()); if (r != 0i32) { print("FAIL: tbb8\n"); failures = 1i32; } }
    { int32:r = raw(test_tbb16()); if (r != 0i32) { print("FAIL: tbb16\n"); failures = 1i32; } }
    { int32:r = raw(test_tbb32()); if (r != 0i32) { print("FAIL: tbb32\n"); failures = 1i32; } }
    { int32:r = raw(test_tbb64()); if (r != 0i32) { print("FAIL: tbb64\n"); failures = 1i32; } }

    // --- Bool ---
    { int32:r = raw(test_bool()); if (r != 0i32) { print("FAIL: bool\n"); failures = 1i32; } }

    // --- String ---
    { int32:r = raw(test_string()); if (r != 0i32) { print("FAIL: string\n"); failures = 1i32; } }

    // --- Balanced ternary / nonary ---
    { int32:r = raw(test_trit()); if (r != 0i32) { print("FAIL: trit\n"); failures = 1i32; } }
