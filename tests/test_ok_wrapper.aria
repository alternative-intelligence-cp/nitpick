// Test: ok() wrapper for unknown state acknowledgment
// Phase 5.2: Propagation safety

func:main = int32() {
    // Test 1: ok() passes through unknown value
    int32:x = unknown;
    int32:y = ok x;  // Explicitly acknowledge unknown state
    
    // Test 2: Check that y is indeed unknown
    if (y == unknown) {
        exit 0i32;  // Success - unknown propagated correctly
    } else {
        exit 1i32;   // Failure
    }
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
