// ----------------------------------------------------------------------------
// TBB Arithmetic Tests
// ----------------------------------------------------------------------------

TEST_CASE(const_eval_tbb_addition) {
    ConstEvaluator evaluator;
    
    auto left = ComptimeValue::makeTBB(100, "tbb8", 8);
    auto right = ComptimeValue::makeTBB(20, "tbb8", 8);
    ComptimeValue result = evaluator.tbbAdd(left, right);
    
    ASSERT(result.isTBB(), "Result should be TBB");
    ASSERT_EQ(result.getInt(), 120, "100 + 20 should be 120");
    ASSERT(!evaluator.hasErrors(), "Should have no errors");
}

TEST_CASE(const_eval_tbb_overflow) {
    ConstEvaluator evaluator;
    
    auto left = ComptimeValue::makeTBB(100, "tbb8", 8);
    auto right = ComptimeValue::makeTBB(50, "tbb8", 8);
    ComptimeValue result = evaluator.tbbAdd(left, right);
    
    ASSERT(result.isERR(), "Result should be ERR sentinel");
    ASSERT(!evaluator.hasErrors(), "Overflow is not an error, it's ERR value");
}

TEST_CASE(const_eval_tbb_sticky_error) {
    ConstEvaluator evaluator;
    
    auto err = ComptimeValue::makeERR("tbb8", 8);
    auto val = ComptimeValue::makeTBB(10, "tbb8", 8);
    ComptimeValue result = evaluator.tbbAdd(err, val);
    
    ASSERT(result.isERR(), "ERR + value should be ERR (sticky)");
}

