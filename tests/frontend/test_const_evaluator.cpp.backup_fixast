TEST_CASE(const_eval_addition) {
    ConstEvaluator evaluator;
    
    auto left = std::make_unique<LiteralExpr>(static_cast<int64_t>(10));
    auto right = std::make_unique<LiteralExpr>(static_cast<int64_t>(32));
    auto binOp = std::make_unique<BinaryExpr>(
        std::move(left), Token(TokenType::TOKEN_PLUS, "+", 0, 0), std::move(right)
    );
    
    ComptimeValue result = evaluator.evaluateExpr(binOp.get());
    
    ASSERT(result.isInteger(), "Result should be integer");
    ASSERT_EQ(result.getInt(), 42, "10 + 32 should be 42");
    ASSERT(!evaluator.hasErrors(), "Should have no errors");
}

