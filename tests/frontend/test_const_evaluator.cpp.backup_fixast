// Literal Evaluation Tests
// ----------------------------------------------------------------------------

TEST_CASE(const_eval_integer_literal) {
    ConstEvaluator evaluator;
    
    auto lit = std::make_unique<LiteralExpr>(static_cast<int64_t>(42));
    ComptimeValue result = evaluator.evaluateExpr(lit.get());
    
    ASSERT(result.isInteger(), "Result should be integer");
    ASSERT_EQ(result.getInt(), 42, "Value should be 42");
    ASSERT(!evaluator.hasErrors(), "Should have no errors");
}

