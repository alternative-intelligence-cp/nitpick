TEST_CASE(const_integration_symbol_table_storage) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    
    // Define const in symbol table
    evaluator.defineConstant("ANSWER", ComptimeValue::makeInteger(42, "int64", 64));
    
    // Lookup via evaluator (should use symbol table)
    ComptimeValue result = evaluator.lookupConstant("ANSWER");
    
    ASSERT(!evaluator.hasErrors(), "Should have no errors");
    ASSERT(result.isInteger(), "Result should be integer");
    ASSERT_EQ(result.getInt(), 42, "Value should be 42");
}

