TEST_CASE(const_integration_arithmetic_complex_expression) {
    ConstEvaluator evaluator;
    
    // Evaluate: (10 + 5) * 2 + 12 = 30 + 12 = 42
    auto ten = std::make_unique<LiteralExpr>(static_cast<int64_t>(10));
    auto five = std::make_unique<LiteralExpr>(static_cast<int64_t>(5));
    auto add = std::make_unique<BinaryExpr>(
        std::move(ten), Token(TokenType::TOKEN_PLUS, "+", 0, 0), std::move(five)
    );
    
    auto two = std::make_unique<LiteralExpr>(static_cast<int64_t>(2));
    auto mul = std::make_unique<BinaryExpr>(
        std::move(add), Token(TokenType::TOKEN_STAR, "*", 0, 0), std::move(two)
    );
    
    auto twelve = std::make_unique<LiteralExpr>(static_cast<int64_t>(12));
    auto final = std::make_unique<BinaryExpr>(
        std::move(mul), Token(TokenType::TOKEN_PLUS, "+", 0, 0), std::move(twelve)
    );
    
    ComptimeValue result = evaluator.evaluateExpr(final.get());
    
    ASSERT(result.isInteger(), "Result should be integer");
    ASSERT_EQ(result.getInt(), 42, "(10 + 5) * 2 + 12 should be 42");
    ASSERT(!evaluator.hasErrors(), "Should have no errors");
}

