// ----------------------------------------------------------------------------
// Float Arithmetic Tests
// ----------------------------------------------------------------------------

TEST_CASE(const_integration_float_arithmetic) {
    ConstEvaluator evaluator;
    
    // Test: 3.14 + 2.86 = 6.0
    auto left = std::make_unique<LiteralExpr>(3.14);
    auto right = std::make_unique<LiteralExpr>(2.86);
    auto binOp = std::make_unique<BinaryExpr>(
        std::move(left), Token(TokenType::TOKEN_PLUS, "+", 0, 0), std::move(right)
    );
    
    ComptimeValue result = evaluator.evaluateExpr(binOp.get());
    
    ASSERT(result.isFloat(), "Result should be float");
    // Allow small floating point error
    double diff = result.getFloat() - 6.0;
    ASSERT(diff > -0.0001 && diff < 0.0001, "3.14 + 2.86 should be approximately 6.0");
    ASSERT(!evaluator.hasErrors(), "Should have no errors");
}

TEST_CASE(const_integration_float_multiplication) {
    ConstEvaluator evaluator;
    
    // Test: 2.5 * 4.0 = 10.0
    auto left = std::make_unique<LiteralExpr>(2.5);
