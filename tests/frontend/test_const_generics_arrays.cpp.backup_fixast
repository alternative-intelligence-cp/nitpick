TEST_CASE(task10_const_loop_unrolling_hint) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    
    // Define const iteration count
    evaluator.defineConstant("UNROLL_COUNT", ComptimeValue::makeInteger(4, "int64", 64));
    
    ComptimeValue count = evaluator.lookupConstant("UNROLL_COUNT");
    
    ASSERT(!evaluator.hasErrors(), "Should have no errors");
    ASSERT_EQ(count.getInt(), 4, "Unroll count should be 4");
    
    // In codegen, this could trigger loop unrolling optimization
    // when UNROLL_COUNT is small (<= 8)
    bool shouldUnroll = (count.getInt() > 0 && count.getInt() <= 8);
    ASSERT(shouldUnroll, "Should enable loop unrolling for count = 4");
}

TEST_CASE(task10_const_inline_threshold) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    
    // Define const complexity threshold for inlining
    evaluator.defineConstant("MAX_INLINE_SIZE", ComptimeValue::makeInteger(50, "int64", 64));
    evaluator.defineConstant("FUNCTION_SIZE", ComptimeValue::makeInteger(32, "int64", 64));
    
    ComptimeValue maxSize = evaluator.lookupConstant("MAX_INLINE_SIZE");
    ComptimeValue funcSize = evaluator.lookupConstant("FUNCTION_SIZE");
    
    // Decision: should this function be inlined?
    bool shouldInline = (funcSize.getInt() < maxSize.getInt());
    
    ASSERT(shouldInline, "32-instruction function should be inlined (< 50 threshold)");
}

