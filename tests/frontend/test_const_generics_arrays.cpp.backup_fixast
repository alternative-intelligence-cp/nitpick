TEST_CASE(task10_generic_const_different_instantiations) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    TypeSystem typeSystem;
    
    // Simulate two instantiations of func<const SIZE: int64>:buffer
    
    // Instance 1: SIZE = 128
    evaluator.pushLocalScope();
    evaluator.defineLocalConstant("SIZE", ComptimeValue::makeInteger(128, "int64", 64));
    ComptimeValue size1 = evaluator.lookupConstant("SIZE");
    auto array1Type = new ArrayType(typeSystem.getPrimitiveType("uint8"), 
                                     static_cast<int>(size1.getInt()));
    evaluator.popLocalScope();
    
    // Instance 2: SIZE = 512
    evaluator.pushLocalScope();
    evaluator.defineLocalConstant("SIZE", ComptimeValue::makeInteger(512, "int64", 64));
    ComptimeValue size2 = evaluator.lookupConstant("SIZE");
    auto array2Type = new ArrayType(typeSystem.getPrimitiveType("uint8"),
                                     static_cast<int>(size2.getInt()));
    evaluator.popLocalScope();
    
    // Verify distinct instantiations
    ASSERT_EQ(array1Type->getSize(), 128, "First instance should be 128");
    ASSERT_EQ(array2Type->getSize(), 512, "Second instance should be 512");
    ASSERT(!array1Type->equals(array2Type), "Should be different types");
}

TEST_CASE(task10_const_generic_with_expression) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    TypeSystem typeSystem;
    
    // Simulate: func<const BASE: int64>:allocate_buffer(int64:multiplier)
    // Array size = BASE * multiplier (compile-time * runtime)
    
    // BASE is const (compile-time known)
    evaluator.defineConstant("BASE", ComptimeValue::makeInteger(64, "int64", 64));
    
    // multiplier is a parameter (runtime value)
    // But in const context, we can compute derived values
    auto baseRef = std::make_unique<IdentifierExpr>("BASE");
    auto multiplier = std::make_unique<LiteralExpr>(static_cast<int64_t>(4));
    auto mulExpr = std::make_unique<BinaryExpr>(
        std::move(baseRef), Token(TokenType::TOKEN_STAR, "*", 0, 0), std::move(multiplier)
    );
    
    ComptimeValue size = evaluator.evaluateExpr(mulExpr.get());
    
    ASSERT(!evaluator.hasErrors(), "Should have no errors");
    ASSERT_EQ(size.getInt(), 256, "BASE * 4 should be 256");
}

