    // Some data structures require power-of-2 sizes
    evaluator.defineConstant("CACHE_SIZE", ComptimeValue::makeInteger(256, "int64", 64));
    
    ComptimeValue size = evaluator.lookupConstant("CACHE_SIZE");
    
    // Check if power of 2: (n & (n-1)) == 0 and n != 0
    int64_t n = size.getInt();
    bool isPowerOfTwo = (n > 0) && ((n & (n - 1)) == 0);
    
    ASSERT(isPowerOfTwo, "256 is a power of 2");
    
