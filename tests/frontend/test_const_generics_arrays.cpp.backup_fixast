TEST_CASE(task10_tbb_array_size_within_range) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    TypeSystem typeSystem;
    
    // Use TBB for array size (safe range checking)
    auto size = ComptimeValue::makeTBB(100, "tbb8", 8);
    
    ASSERT(!size.isERR(), "100 is within tbb8 range");
    ASSERT(size.isTBB(), "Should be TBB type");
    
    // Use as array size
    auto elementType = typeSystem.getPrimitiveType("int8");
    auto arrayType = new ArrayType(elementType, static_cast<int>(size.getInt()));
    
    ASSERT_EQ(arrayType->getSize(), 100, "Array size should be 100");
}

TEST_CASE(task10_tbb_array_size_overflow_detection) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    
    // Try to create array with size > tbb8 max (127)
    auto base = ComptimeValue::makeTBB(100, "tbb8", 8);
    auto increment = ComptimeValue::makeTBB(50, "tbb8", 8);
    ComptimeValue size = evaluator.tbbAdd(base, increment);
    
    ASSERT(size.isERR(), "100 + 50 = 150 exceeds tbb8 max (127) → ERR");
    
    // In real implementation, this would be a compile-time error
    // "Array size computation overflowed: cannot create array of size ERR"
}

