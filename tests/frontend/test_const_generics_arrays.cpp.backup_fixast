TEST_CASE(task10_const_propagation_through_function) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    
    // Define const values
    evaluator.defineConstant("PAGE_SIZE", ComptimeValue::makeInteger(4096, "int64", 64));
    evaluator.defineConstant("NUM_PAGES", ComptimeValue::makeInteger(16, "int64", 64));
    
    // Create function that computes total allocation
    std::vector<ASTNodePtr> params;
    auto pageSizeRef = std::make_unique<IdentifierExpr>("PAGE_SIZE");
    auto numPagesRef = std::make_unique<IdentifierExpr>("NUM_PAGES");
    auto mulExpr = std::make_unique<BinaryExpr>(
        std::move(pageSizeRef), Token(TokenType::TOKEN_STAR, "*", 0, 0), std::move(numPagesRef)
    );
    auto retStmt = std::make_unique<ReturnStmt>(std::move(mulExpr));
    
    std::vector<ASTNodePtr> stmts;
    stmts.push_back(std::move(retStmt));
    auto body = std::make_unique<BlockStmt>(std::move(stmts));
    
    auto funcDecl = std::make_unique<FuncDeclStmt>(
        "computeTotalSize", "int64", params, std::move(body)
    );
    
    evaluator.registerFunction("computeTotalSize", funcDecl.get());
    
    // Call function - result should be const-folded
    auto callee = std::make_unique<IdentifierExpr>("computeTotalSize");
    std::vector<ASTNodePtr> args;
    auto callExpr = std::make_unique<CallExpr>(std::move(callee), std::move(args));
    
    ComptimeValue totalSize = evaluator.evaluateExpr(callExpr.get());
    
    ASSERT(!evaluator.hasErrors(), "Should have no errors");
    ASSERT_EQ(totalSize.getInt(), 65536, "4096 * 16 should be 65536");
    
    // This value can now be used as an array size or allocation hint
}

TEST_CASE(task10_const_default_generic_parameter) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    TypeSystem typeSystem;
    
    // Simulate: func<const SIZE: int64 = 1024>:buffer
    // If SIZE not provided, use default value of 1024
    
    // Check if SIZE is defined
    ComptimeValue size = evaluator.lookupConstant("SIZE");
    
    // If undefined, use default
    if (evaluator.hasErrors()) {
        evaluator.clearErrors();
        evaluator.defineConstant("SIZE", ComptimeValue::makeInteger(1024, "int64", 64));
        size = evaluator.lookupConstant("SIZE");
    }
    
    ASSERT(!evaluator.hasErrors(), "Should have no errors after default");
    ASSERT_EQ(size.getInt(), 1024, "Should use default SIZE = 1024");
}

