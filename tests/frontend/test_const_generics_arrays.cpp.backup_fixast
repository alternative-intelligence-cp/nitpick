TEST_CASE(task10_type_checker_const_array_bounds) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    TypeSystem typeSystem;
    
    // Define const bounds
    evaluator.defineConstant("MIN_SIZE", ComptimeValue::makeInteger(8, "int64", 64));
    evaluator.defineConstant("MAX_SIZE", ComptimeValue::makeInteger(4096, "int64", 64));
    evaluator.defineConstant("REQUEST_SIZE", ComptimeValue::makeInteger(256, "int64", 64));
    
    ComptimeValue minVal = evaluator.lookupConstant("MIN_SIZE");
    ComptimeValue maxVal = evaluator.lookupConstant("MAX_SIZE");
    ComptimeValue requestVal = evaluator.lookupConstant("REQUEST_SIZE");
    
    // Type checker can validate bounds at compile time
    bool withinBounds = (requestVal.getInt() >= minVal.getInt() && 
                        requestVal.getInt() <= maxVal.getInt());
    
    ASSERT(withinBounds, "REQUEST_SIZE (256) should be within [8, 4096]");
}

TEST_CASE(task10_power_of_two_const_validation) {
    SymbolTable symTable;
