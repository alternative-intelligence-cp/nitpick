// ----------------------------------------------------------------------------
// Array Size Tests - Const Values as Array Bounds
// ----------------------------------------------------------------------------

TEST_CASE(task10_array_size_from_const_literal) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    TypeSystem typeSystem;
    
    // Define const size
    evaluator.defineConstant("BUFFER_SIZE", ComptimeValue::makeInteger(1024, "int64", 64));
    
    // Lookup for array declaration
    ComptimeValue size = evaluator.lookupConstant("BUFFER_SIZE");
    
    ASSERT(!evaluator.hasErrors(), "Should have no errors");
    ASSERT(size.isInteger(), "Size should be integer");
    ASSERT_EQ(size.getInt(), 1024, "Size should be 1024");
    
    // Create array type with const size
    auto elementType = typeSystem.getPrimitiveType("int32");
    auto arrayType = new ArrayType(elementType, static_cast<int>(size.getInt()));
    
    ASSERT(arrayType->isFixedSize(), "Array should be fixed size");
    ASSERT_EQ(arrayType->getSize(), 1024, "Array size should be 1024");
}

TEST_CASE(task10_array_size_from_const_expression) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    TypeSystem typeSystem;
    
    // Define base sizes
    evaluator.defineConstant("ROWS", ComptimeValue::makeInteger(32, "int64", 64));
    evaluator.defineConstant("COLS", ComptimeValue::makeInteger(32, "int64", 64));
    
    // Create expression: ROWS * COLS
    auto rowsRef = std::make_unique<IdentifierExpr>("ROWS");
    auto colsRef = std::make_unique<IdentifierExpr>("COLS");
    auto mulExpr = std::make_unique<BinaryExpr>(
        std::move(rowsRef), Token(TokenType::TOKEN_STAR, "*", 0, 0), std::move(colsRef)
    );
    
    // Evaluate expression at compile time
    ComptimeValue totalSize = evaluator.evaluateExpr(mulExpr.get());
    
    ASSERT(!evaluator.hasErrors(), "Should have no errors");
    ASSERT_EQ(totalSize.getInt(), 1024, "Total size should be 32 * 32 = 1024");
    
    // Use as array size
    auto elementType = typeSystem.getPrimitiveType("flt32");
    auto arrayType = new ArrayType(elementType, static_cast<int>(totalSize.getInt()));
    
    ASSERT_EQ(arrayType->getSize(), 1024, "Array size should be 1024");
}

TEST_CASE(task10_array_size_from_const_function) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    TypeSystem typeSystem;
    
    // Create function: func:computeBufferSize = int64() { return 512; }
    std::vector<ASTNodePtr> params;
    auto retValue = std::make_unique<LiteralExpr>(static_cast<int64_t>(512));
    auto retStmt = std::make_unique<ReturnStmt>(std::move(retValue));
    
    std::vector<ASTNodePtr> stmts;
    stmts.push_back(std::move(retStmt));
    auto body = std::make_unique<BlockStmt>(std::move(stmts));
    
    auto funcDecl = std::make_unique<FuncDeclStmt>(
        "computeBufferSize", "int64", params, std::move(body)
    );
    
    evaluator.registerFunction("computeBufferSize", funcDecl.get());
    
    // Call function for array size
    auto callee = std::make_unique<IdentifierExpr>("computeBufferSize");
    std::vector<ASTNodePtr> args;
    auto callExpr = std::make_unique<CallExpr>(std::move(callee), std::move(args));
    
    ComptimeValue size = evaluator.evaluateExpr(callExpr.get());
    
    ASSERT(!evaluator.hasErrors(), "Should have no errors");
    ASSERT_EQ(size.getInt(), 512, "Computed size should be 512");
    
    // Use as array size
    auto elementType = typeSystem.getPrimitiveType("uint8");
    auto arrayType = new ArrayType(elementType, static_cast<int>(size.getInt()));
    
    ASSERT_EQ(arrayType->getSize(), 512, "Array size should be 512");
}

TEST_CASE(task10_array_multidimensional_const_sizes) {
    SymbolTable symTable;
    ConstEvaluator evaluator(&symTable);
    TypeSystem typeSystem;
    
    // Define matrix dimensions
    evaluator.defineConstant("MATRIX_ROWS", ComptimeValue::makeInteger(4, "int64", 64));
    evaluator.defineConstant("MATRIX_COLS", ComptimeValue::makeInteger(8, "int64", 64));
    
    ComptimeValue rows = evaluator.lookupConstant("MATRIX_ROWS");
    ComptimeValue cols = evaluator.lookupConstant("MATRIX_COLS");
    
    // Create 2D array type: flt32[ROWS][COLS]
    auto elementType = typeSystem.getPrimitiveType("flt32");
    auto innerArray = new ArrayType(elementType, static_cast<int>(cols.getInt()));
    auto outerArray = new ArrayType(innerArray, static_cast<int>(rows.getInt()));
    
    ASSERT(outerArray->isFixedSize(), "Outer array should be fixed size");
    ASSERT_EQ(outerArray->getSize(), 4, "Outer size should be 4 rows");
    ASSERT(innerArray->isFixedSize(), "Inner array should be fixed size");
    ASSERT_EQ(innerArray->getSize(), 8, "Inner size should be 8 cols");
}

