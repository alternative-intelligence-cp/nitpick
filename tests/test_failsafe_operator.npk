// Test the !!! operator and mandatory failsafe() function

// Required failsafe function - handles unrecoverable errors
func:failsafe = int32(tbb32:err) {
    // In a real program, this would log, cleanup, and exit gracefully
    // For this test, just return the error code
    exit 1;
};

func:main = int32() {
    // Simulate a critical error scenario
    tbb32:critical_error = 5tbb32;
    
    // Use !!! to call failsafe(critical_error)
    // This desugars to: failsafe(critical_error)
    // The failsafe function will run and return exit code
    int32:result = raw !!! critical_error;
    
    exit result;
};
