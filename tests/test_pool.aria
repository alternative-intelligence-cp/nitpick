// test_pool.aria — Pool allocator tests
use "pool_alloc.aria".*;

func:failsafe = int32(tbb32:err_code) {
    println("FAILSAFE triggered");
    exit(1);
};

func:main = int32() {
    // create pool: 64-byte blocks, 4 blocks
    int64:pool = raw PoolAlloc.create(64i64, 4i64);

    if (pool == 0i64) {
        println("FAIL: create returned null");
        exit(1);
    }
    println("OK: create");

    // available should be 4
    int64:avail = raw PoolAlloc.available(pool);
    if (avail != 4i64) {
        println("FAIL: available != 4");
        exit(1);
    }
    println("OK: available");

    // get a block
    int64:b0 = raw PoolAlloc.get(pool);
    if (b0 < 0i64) {
        println("FAIL: get returned -1");
        exit(1);
    }
    println("OK: get");

    // available should be 3
    int64:avail2 = raw PoolAlloc.available(pool);
    if (avail2 != 3i64) {
        println("FAIL: available != 3 after get");
        exit(1);
    }
    println("OK: available after get");

    // write/read int64 in block
    drop raw PoolAlloc.write_int64(pool, b0, 0i64, 42i64);
    int64:val = raw PoolAlloc.read_int64(pool, b0, 0i64);
    if (val != 42i64) {
        println("FAIL: write/read_int64 mismatch");
        exit(1);
    }
    println("OK: write/read_int64");

    // put block back
    drop raw PoolAlloc.put(pool, b0);
    int64:avail3 = raw PoolAlloc.available(pool);
    if (avail3 != 4i64) {
        println("FAIL: available != 4 after put");
        exit(1);
    }
    println("OK: put");

    // exhaust all 4 blocks
    int64:a0 = raw PoolAlloc.get(pool);
    int64:a1 = raw PoolAlloc.get(pool);
    int64:a2 = raw PoolAlloc.get(pool);
    int64:a3 = raw PoolAlloc.get(pool);
    int64:avail4 = raw PoolAlloc.available(pool);
    if (avail4 != 0i64) {
        println("FAIL: available != 0 after exhaust");
        exit(1);
    }
    println("OK: exhaust");

    // next get should return -1
    int64:overflow = raw PoolAlloc.get(pool);
    if (overflow != 0i64 - 1i64) {
        println("FAIL: get after exhaust != -1");
        exit(1);
    }
    println("OK: overflow returns -1");

    // destroy
    drop raw PoolAlloc.destroy(pool);
    println("OK: destroy");

    println("PASS: all pool tests passed");
    exit(0);
};
