// Test high-precision floating-point literals
// Phase 3.2.5: String-as-Truth Architecture

func:main = int32() {
    // Test 1: Regular precision (flt64)
    flt64:regular1 = 3.14159;
    flt64:regular2 = 2.71828;
    
    // Test 2: High precision π (40+ digits) → should use FLT128
    flt128:pi_precise = 3.141592653589793238462643383279502884197;
    
    // Test 3: High precision e (Euler's number, 41 digits)
    flt128:e_precise = 2.718281828459045235360287471352662497757;
    
    // Test 4: Scientific notation
    flt64:sci_small = 1.23e-10;
    flt128:sci_large = 9.10938356e-31;  // Electron mass in kg
    
    // Test 5: Very small number (high precision)
    flt128:planck = 6.62607015e-34;  // Planck constant
    
    // Test 6: Speed of light (exact)
    flt64:speed_of_light = 299792458.0;  // m/s
    
    // Test 7: Golden ratio (high precision, 40 digits)
    flt128:golden_ratio = 1.618033988749894848204586834365638117720;
    
    // Test 8: Square root of 2 (high precision)
    flt128:sqrt2 = 1.414213562373095048801688724209698078569;
    
    // Test 9: Negative high-precision values
    flt128:neg_pi = -3.141592653589793238462643383279502884197;
    
    // Test 10: Zero and near-zero
    flt64:zero = 0.0;
    flt128:tiny = 0.000000000000000000000000000000000001;
    
    return 0;
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
