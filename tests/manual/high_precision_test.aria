// Test high-precision literal detection and validation
// This tests the String-as-Truth architecture for literal parsing

func:main = int32() {
    // Test 1: Regular precision (should work)
    flt64:pi_regular = 3.14159;
    int64:answer = 42;

    // Test 2: High-precision float literals
    // These have many digits and should be detected by the type checker
    flt128:pi_high = 3.141592653589793238462643383279502884197;
    flt128:e_high = 2.718281828459045235360287471352662497757;

    // Test 3: High-precision integer literals
    // These exceed int64 range and need int128
    int128:large_num = 9223372036854775808;  // 2^63 (just over int64::max)
    int128:huge_num = 170141183460469231731687303715884105727;  // Near int128::max

    // Test 4: Should fail - float literal to int type
    // int64:bad = 3.14159;  // Uncomment to test error reporting

    return 0;
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
