// Test high-precision integer literals
// Phase 3.2.5: String-as-Truth Architecture

func:main = int32() {
    // Test 1: Regular precision (int64)
    int64:regular1 = 42;
    int64:regular2 = 1000000;
    
    // Test 2: Maximum int64 value
    int64:max_i64 = 9223372036854775807;
    
    // Test 3: Just beyond int64 range → needs int128
    int128:beyond_i64 = 9223372036854775808;  // 2^63
    
    // Test 4: Negative large values
    int128:neg_large = -9223372036854775808;  // -2^63
    
    // Test 5: Very large int128 values
    int128:huge1 = 170141183460469231731687303715884105727;  // Near int128::max
    int128:huge2 = 123456789012345678901234567890123456789;
    
    // Test 6: Powers of 2
    int64:pow2_32 = 4294967296;      // 2^32
    int128:pow2_64 = 18446744073709551616;  // 2^64
    int128:pow2_100 = 1267650600228229401496703205376;  // 2^100
    
    // Test 7: Fibonacci-like large numbers
    int128:fib_large = 2880067194370816120;
    
    // Test 8: Zero and small values
    int64:zero = 0;
    int64:one = 1;
    int64:negative = -42;
    
    // Test 9: Hexadecimal (if supported by lexer)
    // int64:hex_val = 0x1234ABCD;
    
    // Test 10: Binary (if supported by lexer)  
    // int64:bin_val = 0b11010101;
    
    return 0;
};
