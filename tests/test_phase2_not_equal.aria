// Phase 2 Test 4: != operator recognition
// Should PASS - r.is_error != true means r.is_error == false

func:divide = int32(int32:a, int32:b) {
    if (b == 0i32) {
        fail -1i32;
    }
    pass a / b;
};

func:main = int32() {
    Result<int32>:r = divide(10i32, 2i32);
    
    // r.is_error != true means is_error == false
    if (r.is_error != true) {
        int32:x = r.value;  // SAFE: then knows is_error == false
    }
    
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
