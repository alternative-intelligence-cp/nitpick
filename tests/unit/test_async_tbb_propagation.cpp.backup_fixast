TEST_CASE(async_function_returns_future_tbb8) {
    TypeSystem typeSystem;
    
    Type* tbb8Type = typeSystem.getPrimitiveType("tbb8");
    std::vector<Type*> paramTypes;
    
    // async func:compute = tbb8() { ... }
    // Actual type: func() -> future<tbb8>
    FunctionType* asyncFunc = typeSystem.getFunctionType(paramTypes, tbb8Type, true, false);
    
    Type* returnType = asyncFunc->getReturnType();
    ASSERT(returnType->getKind() == TypeKind::FUTURE, "Should return future");
    
    FutureType* futureType = static_cast<FutureType*>(returnType);
    ASSERT(futureType->getOutputType() == tbb8Type, "Future should contain tbb8");
}

