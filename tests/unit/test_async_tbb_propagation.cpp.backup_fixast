TEST_CASE(chained_async_tbb_operations) {
    TypeSystem typeSystem;
    
    Type* tbb32Type = typeSystem.getPrimitiveType("tbb32");
    std::vector<Type*> paramTypes;
    
    // async func:step1 = tbb32() { ... }
    FunctionType* step1Func = typeSystem.getFunctionType(paramTypes, tbb32Type, true, false);
    Type* step1Return = step1Func->getReturnType();  // future<tbb32>
    
    // result1 = await step1()  → tbb32
    Type* result1 = typeSystem.unwrapFutureType(step1Return);
    ASSERT(result1 == tbb32Type, "First await extracts tbb32");
    
    // async func:step2 = tbb32(tbb32) { ... }
    std::vector<Type*> step2Params = {tbb32Type};
    FunctionType* step2Func = typeSystem.getFunctionType(step2Params, tbb32Type, true, false);
    Type* step2Return = step2Func->getReturnType();  // future<tbb32>
    
    // result2 = await step2(result1)  → tbb32
    Type* result2 = typeSystem.unwrapFutureType(step2Return);
    ASSERT(result2 == tbb32Type, "Second await extracts tbb32");
}

TEST_CASE(async_tbb_with_result_type) {
