// Test file for TBB error propagation through async/await
// TBB (Twisted Balanced Binary) types use min value as ERR sentinel
// ERR should propagate through Future<tbb*> and await chains
#include "../test_helpers.h"
#include "frontend/sema/type.h"

using namespace aria::sema;

TEST_CASE(future_tbb8_type) {
    TypeSystem typeSystem;
    
    Type* tbb8Type = typeSystem.getPrimitiveType("tbb8");
    FutureType* futureTbb8 = typeSystem.getFutureType(tbb8Type);
    
    ASSERT(futureTbb8 != nullptr, "Future<tbb8> should be created");
    ASSERT(futureTbb8->getKind() == TypeKind::FUTURE, "Should be Future type");
    ASSERT(futureTbb8->getOutputType() == tbb8Type, "Output type should be tbb8");
    ASSERT(futureTbb8->toString() == "future<tbb8>", "Should be future<tbb8>");
}

