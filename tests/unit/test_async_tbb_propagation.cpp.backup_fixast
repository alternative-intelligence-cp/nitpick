TEST_CASE(multiple_tbb_types_in_async) {
    TypeSystem typeSystem;
    
    Type* tbb8Type = typeSystem.getPrimitiveType("tbb8");
    Type* tbb16Type = typeSystem.getPrimitiveType("tbb16");
    Type* tbb32Type = typeSystem.getPrimitiveType("tbb32");
    Type* tbb64Type = typeSystem.getPrimitiveType("tbb64");
    
    // async func:mix = tbb32(tbb8, tbb16, tbb64) { ... }
    std::vector<Type*> paramTypes = {tbb8Type, tbb16Type, tbb64Type};
    FunctionType* asyncFunc = typeSystem.getFunctionType(paramTypes, tbb32Type, true, false);
    
    ASSERT(asyncFunc->getParamCount() == 3, "Should have 3 parameters");
    ASSERT(asyncFunc->getParamTypes()[0] == tbb8Type, "First param is tbb8");
    ASSERT(asyncFunc->getParamTypes()[1] == tbb16Type, "Second param is tbb16");
    ASSERT(asyncFunc->getParamTypes()[2] == tbb64Type, "Third param is tbb64");
    
    Type* returnType = asyncFunc->getReturnType();
    FutureType* futureType = static_cast<FutureType*>(returnType);
    ASSERT(futureType->getOutputType() == tbb32Type, "Returns future<tbb32>");
}

TEST_CASE(async_tbb_nested_structures) {
    TypeSystem typeSystem;
    
    Type* tbb32Type = typeSystem.getPrimitiveType("tbb32");
    ArrayType* arrayTbb = typeSystem.getArrayType(tbb32Type, 10);
    PointerType* ptrArray = typeSystem.getPointerType(arrayTbb);
    ResultType* resultPtr = typeSystem.getResultType(ptrArray);
    FutureType* futureComplex = typeSystem.getFutureType(resultPtr);
    
    // Type: future<result<tbb32[10]@>>
    ASSERT(futureComplex->toString() == "future<result<tbb32[10]@>>", 
           "Should be future<result<tbb32[10]@>>");
    
    // Unwrap: future<result<tbb32[10]@>> → result<tbb32[10]@>
    Type* unwrapped = typeSystem.unwrapFutureType(futureComplex);
    ASSERT(unwrapped == resultPtr, "Should unwrap to result<tbb32[10]@>");
}

TEST_CASE(tbb_function_equality_async_vs_sync) {
    TypeSystem typeSystem;
    
    Type* tbb32Type = typeSystem.getPrimitiveType("tbb32");
    std::vector<Type*> paramTypes = {tbb32Type};
    
    // sync func(tbb32) -> tbb32
    FunctionType* syncFunc = typeSystem.getFunctionType(paramTypes, tbb32Type, false, false);
    
    // async func(tbb32) -> tbb32  (becomes func(tbb32) -> future<tbb32>)
    FunctionType* asyncFunc = typeSystem.getFunctionType(paramTypes, tbb32Type, true, false);
    
    ASSERT(!syncFunc->equals(asyncFunc), "Sync and async should not be equal");
    ASSERT(syncFunc->getReturnType() == tbb32Type, "Sync returns tbb32");
    ASSERT(asyncFunc->getReturnType()->getKind() == TypeKind::FUTURE, "Async returns future");
}
