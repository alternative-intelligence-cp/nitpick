    Type* tbb32Type = typeSystem.getPrimitiveType("tbb32");
    ResultType* resultTbb32 = typeSystem.getResultType(tbb32Type);
    std::vector<Type*> paramTypes;
    
    // async func:compute = result<tbb32>() { ... }
    // Returns: future<result<tbb32>>
    FunctionType* asyncFunc = typeSystem.getFunctionType(paramTypes, resultTbb32, true, false);
    
    Type* returnType = asyncFunc->getReturnType();
    ASSERT(returnType->getKind() == TypeKind::FUTURE, "Should return future");
    
    FutureType* futureType = static_cast<FutureType*>(returnType);
    ASSERT(futureType->getOutputType() == resultTbb32, "Should contain result<tbb32>");
    
    // await future<result<tbb32>> → result<tbb32>
    Type* awaitType = typeSystem.unwrapFutureType(futureType);
    ASSERT(awaitType == resultTbb32, "Await extracts result<tbb32>");
    ASSERT(awaitType->toString() == "result<tbb32>", "Should be result<tbb32>");
}

