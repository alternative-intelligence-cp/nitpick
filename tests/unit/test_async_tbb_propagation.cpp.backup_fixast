TEST_CASE(await_future_tbb8_extracts_tbb8) {
    TypeSystem typeSystem;
    
    Type* tbb8Type = typeSystem.getPrimitiveType("tbb8");
    FutureType* futureTbb8 = typeSystem.getFutureType(tbb8Type);
    
    // await future<tbb8> → tbb8
    Type* awaitType = typeSystem.unwrapFutureType(futureTbb8);
    
    ASSERT(awaitType == tbb8Type, "Await should extract tbb8");
    ASSERT(awaitType->toString() == "tbb8", "Should be tbb8 type");
}

