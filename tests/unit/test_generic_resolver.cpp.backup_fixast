TEST_CASE(monomorphizer_clone_simple_expression) {
    GenericResolver resolver;
    Monomorphizer mono(&resolver);
    
    // Create a simple literal expression: 42
    auto lit = std::make_unique<LiteralExpr>(static_cast<int64_t>(42));
    
    // Clone it
    auto cloned = mono.cloneAST(lit.get());
    
    ASSERT(cloned != nullptr, "Cloned node should not be null");
    ASSERT_EQ(cloned->type, ASTNode::NodeType::LITERAL, "Cloned node should be LITERAL");
    
    // Verify independence (different memory addresses)
    ASSERT(static_cast<void*>(cloned.get()) != static_cast<void*>(lit.get()),
           "Cloned node should be independent");
}

TEST_CASE(monomorphizer_clone_identifier) {
    GenericResolver resolver;
    Monomorphizer mono(&resolver);
    
    // Create identifier: x
    auto id = std::make_unique<IdentifierExpr>("x", 1, 1);
    
    // Clone it
    auto cloned = mono.cloneAST(id.get());
    
    ASSERT(cloned != nullptr, "Cloned identifier should not be null");
    ASSERT_EQ(cloned->type, ASTNode::NodeType::IDENTIFIER, "Cloned node should be IDENTIFIER");
    
    IdentifierExpr* clonedId = static_cast<IdentifierExpr*>(cloned.get());
    ASSERT_EQ(clonedId->name, "x", "Name should be preserved");
}

TEST_CASE(monomorphizer_clone_block_statement) {
    GenericResolver resolver;
    Monomorphizer mono(&resolver);
    
    // Create block: { return 42; }
    auto retVal = std::make_unique<LiteralExpr>(static_cast<int64_t>(42), 1, 10);
    auto retStmt = std::make_unique<ReturnStmt>(std::move(retVal), 1, 3);
    std::vector<ASTNodePtr> stmts;
    stmts.push_back(std::move(retStmt));
    auto block = std::make_unique<BlockStmt>(std::move(stmts), 1, 1);
    
    // Clone it
    auto cloned = mono.cloneAST(block.get());
    
    ASSERT(cloned != nullptr, "Cloned block should not be null");
    ASSERT_EQ(cloned->type, ASTNode::NodeType::BLOCK, "Cloned node should be BLOCK");
    
    BlockStmt* clonedBlock = static_cast<BlockStmt*>(cloned.get());
    ASSERT_EQ(clonedBlock->statements.size(), 1, "Block should have 1 statement");
    ASSERT_EQ(clonedBlock->statements[0]->type, ASTNode::NodeType::RETURN,
              "Statement should be RETURN");
}

