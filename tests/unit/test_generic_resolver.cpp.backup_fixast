TEST_CASE(monomorphizer_substitute_var_decl) {
    TypeSystem typeSystem;
    GenericResolver resolver;
    Monomorphizer mono(&resolver);
    
    // Create var decl: *T:x = 42
    auto init = std::make_unique<LiteralExpr>(static_cast<int64_t>(42), 1, 10);
    auto varDecl = std::make_unique<VarDeclStmt>(
        "*T", "x", std::move(init), 1, 1);
    
    // Clone and substitute with int32
    auto cloned = mono.cloneAST(varDecl.get());
    ASSERT(cloned != nullptr, "Cloned var decl should not be null");
    
    TypeSubstitution substitution;
    auto int32Type = typeSystem.getPrimitiveType("int32");
    substitution["T"] = int32Type;
    
    mono.substituteTypes(cloned.get(), substitution);
    
    VarDeclStmt* clonedVar = static_cast<VarDeclStmt*>(cloned.get());
    ASSERT_EQ(clonedVar->typeNode->toString(), "int32", 
              "Type should be substituted from *T to int32");
    ASSERT_EQ(clonedVar->varName, "x", "Variable name should be preserved");
}

