TEST_CASE(monomorphizer_substitute_nested) {
    TypeSystem typeSystem;
    GenericResolver resolver;
    Monomorphizer mono(&resolver);
    
    // Create: { *T:x = 42; return x; }
    auto init = std::make_unique<LiteralExpr>(static_cast<int64_t>(42), 1, 17);
    auto varDecl = std::make_unique<VarDeclStmt>(
