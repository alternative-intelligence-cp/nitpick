TEST_CASE(monomorphizer_cache_hit) {
    GenericResolver resolver;
    Monomorphizer mono(&resolver);
    TypeSystem registry;
    
    // Create a simple generic function
    std::vector<ASTNodePtr> params;
    auto param = std::make_unique<ParameterNode>(std::make_shared<SimpleType>("*T"), "value");
    params.push_back(std::move(param));
    
    auto funcDecl = std::make_unique<FuncDeclStmt>(
        "identity", std::make_shared<SimpleType>("*T"), params, nullptr);
    funcDecl->genericParams.emplace_back("T");
    
    // Create substitution
    TypeSubstitution sub;
    sub["T"] = registry.getPrimitiveType("int32");
    
    // First request should create specialization
    Specialization* spec1 = mono.requestSpecialization(funcDecl.get(), sub);
    
    // Second request should hit cache
    Specialization* spec2 = mono.requestSpecialization(funcDecl.get(), sub);
    
    ASSERT(spec1 == spec2, "Should return same specialization from cache");
}

TEST_CASE(monomorphizer_different_types_different_specializations) {
    GenericResolver resolver;
    Monomorphizer mono(&resolver);
    TypeSystem registry;
    
    // Create a simple generic function
    std::vector<ASTNodePtr> params;
    auto param = std::make_unique<ParameterNode>(std::make_shared<SimpleType>("*T"), "value");
    params.push_back(std::move(param));
    
    auto funcDecl = std::make_unique<FuncDeclStmt>(
        "identity", std::make_shared<SimpleType>("*T"), params, nullptr);
    funcDecl->genericParams.emplace_back("T");
    
    // Create substitution for int32
    TypeSubstitution sub1;
    sub1["T"] = registry.getPrimitiveType("int32");
    
    // Create substitution for int64
    TypeSubstitution sub2;
    sub2["T"] = registry.getPrimitiveType("int64");
    
    // Request specializations
    Specialization* spec1 = mono.requestSpecialization(funcDecl.get(), sub1);
    Specialization* spec2 = mono.requestSpecialization(funcDecl.get(), sub2);
    
    ASSERT(spec1 != spec2, "Different types should create different specializations");
    
    // Check mangled names are different
    ASSERT(spec1->mangledName != spec2->mangledName,
           "Different types should have different mangled names");
}

