TEST_CASE(monomorphization_depth_limit_check) {
    GenericResolver resolver;
    Monomorphizer mono(&resolver);
    TypeSystem registry;
    
    // Create a generic function
    std::vector<ASTNodePtr> params;
    auto param = std::make_unique<ParameterNode>(std::make_shared<SimpleType>("*T"), "value");
    params.push_back(std::move(param));
    
    auto body = std::make_unique<ReturnStmt>(
        std::make_unique<IdentifierExpr>("value", 2, 5), 2, 1);
    
    auto funcDecl = std::make_unique<FuncDeclStmt>(
        "test_depth", std::make_shared<SimpleType>("*T"), params, std::move(body));
    funcDecl->genericParams.emplace_back("T");
    
    // Initially should be at depth 0
    ASSERT_EQ(mono.getInstantiationDepth(), 0, "Initial depth should be 0");
    
    // Check depth limit returns true when under limit
    ASSERT(mono.checkDepthLimit(), "Should be under depth limit initially");
    
    // Note: Full depth limit test would require 64 nested instantiations,
    // which is difficult to set up in unit tests. The implementation
    // is verified to check instantiationStack.size() >= MAX_INSTANTIATION_DEPTH
}

TEST_CASE(monomorphization_cycle_detection_via_cache) {
    GenericResolver resolver;
    Monomorphizer mono(&resolver);
    TypeSystem registry;
    
    // Create a generic function
    std::vector<ASTNodePtr> params;
    auto param = std::make_unique<ParameterNode>(std::make_shared<SimpleType>("*T"), "value");
    params.push_back(std::move(param));
    
    auto body = std::make_unique<ReturnStmt>(
        std::make_unique<IdentifierExpr>("value", 2, 5), 2, 1);
    
    auto funcDecl = std::make_unique<FuncDeclStmt>(
        "cycle_test", std::make_shared<SimpleType>("*T"), params, std::move(body));
    funcDecl->genericParams.emplace_back("T");
    
    TypeSubstitution sub;
    sub["T"] = registry.getPrimitiveType("int32");
    
    // First instantiation should succeed
    Specialization* spec1 = mono.requestSpecialization(funcDecl.get(), sub);
    ASSERT(spec1 != nullptr, "First instantiation should succeed");
    ASSERT(!mono.hasErrors(), "Should not have errors after first instantiation");
    
    // Second instantiation with same type should hit cache (not cycle)
    Specialization* spec2 = mono.requestSpecialization(funcDecl.get(), sub);
    ASSERT(spec1 == spec2, "Should return cached specialization");
    
    // Note: True cycle detection happens during recursive instantiation
    // (e.g., when instantiating foo<T> calls foo<Vector<T>> calls foo<T>).
    // The cycle detection logic in requestSpecialization() checks the
    // instantiationStack before pushing a new key, preventing infinite loops.
}

