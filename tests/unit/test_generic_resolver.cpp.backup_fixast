TEST_CASE(type_inference_conflicting_types_error) {
    TypeSystem typeSystem;
    GenericResolver resolver;
    
    // Create generic function: func<T>:max = *T(*T:a, *T:b) { ... }
    std::vector<ASTNodePtr> params;
    params.push_back(std::make_unique<ParameterNode>(std::make_shared<SimpleType>("*T"), "a", nullptr, 1, 20));
    params.push_back(std::make_unique<ParameterNode>(std::make_shared<SimpleType>("*T"), "b", nullptr, 1, 28));
    
    auto funcDecl = std::make_unique<FuncDeclStmt>(
        "max", std::make_shared<SimpleType>("*T"), params, nullptr, 1, 1);
    funcDecl->genericParams.emplace_back("T");
    
    // Create call: max(10, 20.5)  // int32 and float32 - conflict!
    auto callee = std::make_unique<IdentifierExpr>("max", 5, 1);
    std::vector<ASTNodePtr> args;
    args.push_back(std::make_unique<LiteralExpr>(static_cast<int64_t>(10), 5, 5));
    args.push_back(std::make_unique<LiteralExpr>(3.14, 5, 9));
    auto callExpr = std::make_unique<CallExpr>(
        std::move(callee), std::move(args), 5, 1);
    
    // Conflicting types: int32 and float32
    std::vector<Type*> argTypes;
    argTypes.push_back(typeSystem.getPrimitiveType("int32"));
    argTypes.push_back(typeSystem.getPrimitiveType("float32"));
    
    // Perform type inference - should fail
    TypeSubstitution substitution = resolver.inferTypeArgs(
        funcDecl.get(), callExpr.get(), argTypes);
    
    ASSERT(resolver.hasErrors(), "Should have errors for conflicting types");
    ASSERT_EQ(substitution.size(), 0, "Should return empty substitution on error");
}

TEST_CASE(type_inference_multiple_type_params) {
    TypeSystem typeSystem;
    GenericResolver resolver;
    
    // Create generic function: func<T,U>:convert = *T(*U:value) { ... }
    std::vector<ASTNodePtr> params;
    params.push_back(std::make_unique<ParameterNode>(std::make_shared<SimpleType>("*U"), "value", nullptr, 1, 30));
    
    auto funcDecl = std::make_unique<FuncDeclStmt>(
        "convert", std::make_shared<SimpleType>("*T"), params, nullptr, 1, 1);
    funcDecl->genericParams.emplace_back("T");
    funcDecl->genericParams.emplace_back("U");
    
    // Create call: convert(42)
    auto callee = std::make_unique<IdentifierExpr>("convert", 5, 1);
    std::vector<ASTNodePtr> args;
    args.push_back(std::make_unique<LiteralExpr>(static_cast<int64_t>(42), 5, 9));
    auto callExpr = std::make_unique<CallExpr>(
        std::move(callee), std::move(args), 5, 1);
    
    // Argument type is int32
