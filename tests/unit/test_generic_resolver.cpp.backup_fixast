    sub["T"] = registry.getPrimitiveType("int32");
    
    // First request
    Specialization* spec1 = mono.requestSpecialization(funcDecl.get(), sub);
    size_t initial_count = mono.getSpecializations().size();
    
    // Second request (should hit cache)
    Specialization* spec2 = mono.requestSpecialization(funcDecl.get(), sub);
