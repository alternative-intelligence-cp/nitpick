TEST_CASE(type_inference_simple_single_param) {
    TypeSystem typeSystem;
    GenericResolver resolver;
    
    // Create generic function: func<T>:identity = *T(*T:value) { ... }
    std::vector<ASTNodePtr> params;
    auto param = std::make_unique<ParameterNode>(std::make_shared<SimpleType>("*T"), "value", nullptr, 1, 20);
    params.push_back(std::move(param));
    
    auto funcDecl = std::make_unique<FuncDeclStmt>(
        "identity", std::make_shared<SimpleType>("*T"), params, nullptr, 1, 1);
    funcDecl->genericParams.emplace_back("T");
    
    // Create call with int32 argument: identity(42)
    auto callee = std::make_unique<IdentifierExpr>("identity", 5, 1);
    std::vector<ASTNodePtr> args;
    auto argLit = std::make_unique<LiteralExpr>(static_cast<int64_t>(42), 5, 10);
    args.push_back(std::move(argLit));
    auto callExpr = std::make_unique<CallExpr>(
        std::move(callee), std::move(args), 5, 1);
    
    // Prepare argument types
    std::vector<Type*> argTypes;
    argTypes.push_back(typeSystem.getPrimitiveType("int32"));
    
    // Perform type inference
    TypeSubstitution substitution = resolver.inferTypeArgs(
        funcDecl.get(), callExpr.get(), argTypes);
    
    ASSERT(!resolver.hasErrors(), "Type inference should not have errors");
    ASSERT_EQ(substitution.size(), 1, "Should infer one type parameter");
    ASSERT(substitution.find("T") != substitution.end(), "Should infer T");
    ASSERT_EQ(substitution["T"]->toString(), "int32", "T should be inferred as int32");
}

