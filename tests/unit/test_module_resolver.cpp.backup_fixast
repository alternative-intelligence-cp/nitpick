// Test 18: Loading stack management
TEST_CASE(module_resolver_loading_stack) {
    initializeTestEnvironment();
    
    std::string path1 = testRoot + "/a.aria";
    std::string path2 = testRoot + "/b.aria";
    
    ASSERT_FALSE(resolver->isCurrentlyLoading(path1), "Path not loading initially");
    
    resolver->beginLoading(path1);
    ASSERT_TRUE(resolver->isCurrentlyLoading(path1), "Path should be loading");
    
    resolver->beginLoading(path2);
    ASSERT_TRUE(resolver->isCurrentlyLoading(path2), "Second path should be loading");
    
    resolver->endLoading(path2);
    ASSERT_FALSE(resolver->isCurrentlyLoading(path2), "Second path unloaded");
    ASSERT_TRUE(resolver->isCurrentlyLoading(path1), "First path still loading");
    
    resolver->endLoading(path1);
    ASSERT_FALSE(resolver->isCurrentlyLoading(path1), "First path unloaded");
}

