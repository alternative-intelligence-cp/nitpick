// Test 10: Module not found error
TEST_CASE(module_resolver_not_found) {
    initializeTestEnvironment();
    resolver->clearErrors();
    
    auto useStmt = createUseStmt({"nonexistent"});
    std::string resolved = resolver->resolveImport(useStmt, testRoot + "/main.aria");
    
    ASSERT_TRUE(resolved.empty(), "Should not resolve nonexistent module");
    ASSERT_TRUE(resolver->hasErrors(), "Should have error");
    
    std::string error = resolver->getErrors()[0];
    ASSERT_TRUE(error.find("Could not resolve module") != std::string::npos, "Should have resolution error");
    delete useStmt;
}

// Test 11: Circular dependency detection
TEST_CASE(module_resolver_circular_dependency) {
    initializeTestEnvironment();
    resolver->clearErrors();
    
    std::string moduleA = testRoot + "/main.aria";
    std::string moduleB = testRoot + "/utils.aria";
    
    resolver->beginLoading(moduleA);
    resolver->beginLoading(moduleB);
    
    ASSERT_TRUE(resolver->isCurrentlyLoading(moduleA), "Module A should be loading");
    ASSERT_TRUE(resolver->isCurrentlyLoading(moduleB), "Module B should be loading");
    
    auto useStmt = createUseStmt({"main"});
    std::string resolved = resolver->resolveImport(useStmt, moduleB);
    
    ASSERT_TRUE(resolved.empty(), "Should not resolve circular dependency");
    ASSERT_TRUE(resolver->hasErrors(), "Should have circular dependency error");
    
    std::string error = resolver->getErrors()[0];
    ASSERT_TRUE(error.find("Circular dependency") != std::string::npos, "Should detect circular dependency");
    
    resolver->endLoading(moduleB);
    resolver->endLoading(moduleA);
    delete useStmt;
}

// Test 12: Path normalization
TEST_CASE(module_resolver_path_normalization) {
    initializeTestEnvironment();
    
    std::string path1 = testRoot + "/./math/../utils.aria";
    std::string normalized = ModuleResolver::normalizePath(path1);
    
    ASSERT_TRUE(normalized.find("utils.aria") != std::string::npos, "Should normalize to utils.aria");
    ASSERT_TRUE(normalized.find("math") == std::string::npos, "Should not contain math");
}

// Test 13: isAbsolutePath
TEST_CASE(module_resolver_is_absolute_path) {
    ASSERT_TRUE(ModuleResolver::isAbsolutePath("/usr/lib/aria"), "Unix absolute path");
    ASSERT_FALSE(ModuleResolver::isAbsolutePath("./relative"), "Relative path");
    ASSERT_FALSE(ModuleResolver::isAbsolutePath("local"), "Local path");
}

// Test 14: isRelativePath
TEST_CASE(module_resolver_is_relative_path) {
    ASSERT_TRUE(ModuleResolver::isRelativePath("./file.aria"), "Relative with ./");
    ASSERT_TRUE(ModuleResolver::isRelativePath("../other.aria"), "Relative with ../");
    ASSERT_FALSE(ModuleResolver::isRelativePath("/absolute/path"), "Absolute path");
    ASSERT_FALSE(ModuleResolver::isRelativePath("logical.path"), "Logical path");
}

// Test 15: isValidAriaFile
TEST_CASE(module_resolver_is_valid_aria_file) {
    initializeTestEnvironment();
    
    ASSERT_TRUE(ModuleResolver::isValidAriaFile(testRoot + "/utils.aria"), "Valid Aria file");
    ASSERT_FALSE(ModuleResolver::isValidAriaFile(testRoot + "/nonexistent.aria"), "Nonexistent file");
    ASSERT_FALSE(ModuleResolver::isValidAriaFile(testRoot + "/math"), "Directory not file");
