using namespace aria;
using namespace aria::sema;
namespace fs = std::filesystem;

// Test root directory and resolver (initialized once for all tests)
static std::string testRoot;
static std::unique_ptr<ModuleResolver> resolver;

// Helper function to create files
static void createFile(const std::string& path) {
    std::ofstream file(path);
    file << "// Test file\n";
    file.close();
}

// Helper function to create UseStmt
static UseStmt* createUseStmt(const std::vector<std::string>& path, bool isFilePath = false) {
    auto stmt = new UseStmt(path, 1, 1);
    stmt->isFilePath = isFilePath;
    return stmt;
}

// Initialize test environment (called once)
static void initializeTestEnvironment() {
    if (!testRoot.empty()) return;  // Already initialized
    
    testRoot = fs::temp_directory_path() / "aria_module_test";
    
    // Clean up if exists from previous run
    if (fs::exists(testRoot)) {
        fs::remove_all(testRoot);
    }
    
    fs::create_directories(testRoot);
    
    // Create test file structure
    createFile(testRoot + "/main.aria");
    createFile(testRoot + "/utils.aria");
    
    fs::create_directories(testRoot + "/math");
    createFile(testRoot + "/math/mod.aria");
    createFile(testRoot + "/math/calc.aria");
    
    fs::create_directories(testRoot + "/std");
    createFile(testRoot + "/std/io.aria");
    
    fs::create_directories(testRoot + "/std/collections");
    createFile(testRoot + "/std/collections/mod.aria");
    createFile(testRoot + "/std/collections/array.aria");
    
    fs::create_directories(testRoot + "/relative");
    createFile(testRoot + "/relative/a.aria");
    createFile(testRoot + "/relative/b.aria");
    
    fs::create_directories(testRoot + "/relative/sub");
    createFile(testRoot + "/relative/sub/c.aria");
    
    resolver = std::make_unique<ModuleResolver>(testRoot);
}

// Test 1: Simple logical path
TEST_CASE(module_resolver_simple_logical_path) {
    initializeTestEnvironment();
    resolver->clearErrors();
    
    auto useStmt = createUseStmt({"utils"});
    std::string resolved = resolver->resolveImport(useStmt, testRoot + "/main.aria");
    
    ASSERT_FALSE(resolved.empty(), "Should resolve utils module");
    ASSERT_TRUE(fs::exists(resolved), "Resolved path should exist");
    ASSERT_TRUE(resolved.find("utils.aria") != std::string::npos, "Should contain utils.aria");
    delete useStmt;
}

