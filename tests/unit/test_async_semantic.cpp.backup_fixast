/**
 * Test mixed async and non-async functions
 */
TEST_CASE(async_mixed_functions) {
    std::string source = R"(
        func:syncFunc = int32() {
            return 42;
        };
        
        async func:asyncFunc = int32() {
            int32:res = await computeValue;
            return res;
        };
    )";
    
    Lexer lexer(source);
    auto tokens = lexer.tokenize();
    Parser parser(tokens);
    auto ast = parser.parse();
    
    if (parser.hasErrors()) {
        std::cout << "Parser errors in async_mixed_functions:\n";
        for (const auto& error : parser.getErrors()) {
            std::cout << "  " << error << "\n";
        }
    }
    ASSERT(!parser.hasErrors(), "Parser should not have errors");
    
    AsyncSemanticAnalyzer analyzer;
    analyzer.analyze(ast);
    
    ASSERT(!analyzer.hasErrors(), "Async analyzer should not have errors");
}

