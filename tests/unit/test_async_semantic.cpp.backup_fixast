#include "../test_helpers.h"
#include "frontend/lexer/lexer.h"
#include "frontend/parser/parser.h"
#include "frontend/sema/async_analyzer.h"
#include <iostream>

using namespace aria;
using namespace aria::sema;
using namespace aria::frontend;

/**
 * Test await in async function (valid)
 */
TEST_CASE(async_await_valid_context) {
    std::string source = R"(
        async func:test = int32() {
            return await future;
        };
    )";
    
    Lexer lexer(source);
    auto tokens = lexer.tokenize();
    Parser parser(tokens);
    auto ast = parser.parse();
    
    ASSERT(!parser.hasErrors(), "Parser should not have errors");
    
    AsyncSemanticAnalyzer analyzer;
    analyzer.analyze(ast);
    
    ASSERT(!analyzer.hasErrors(), "Async analyzer should not have errors");
}

/**
 * Test await in non-async function (invalid)
 */
TEST_CASE(async_await_invalid_context) {
    std::string source = R"(
        func:test = int32() {
            return await future;
        };
    )";
    
    Lexer lexer(source);
    auto tokens = lexer.tokenize();
    Parser parser(tokens);
    auto ast = parser.parse();
    
    ASSERT(!parser.hasErrors(), "Parser should not have errors");
    
    AsyncSemanticAnalyzer analyzer;
    analyzer.analyze(ast);
    
    ASSERT(analyzer.hasErrors(), "Async analyzer should have errors");
    ASSERT(analyzer.getErrors().size() == 1, "Should have exactly one error");
    
    std::string error = analyzer.getErrors()[0];
    ASSERT(error.find("E_ASYNC_OUTSIDE_CONTEXT") != std::string::npos, 
           "Error should mention E_ASYNC_OUTSIDE_CONTEXT");
    ASSERT(error.find("await") != std::string::npos, 
           "Error should mention 'await'");
}

