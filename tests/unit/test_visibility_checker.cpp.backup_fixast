using namespace aria::sema;

// ============================================================================
// Test 1: PUBLIC symbols accessible from any module
// ============================================================================
TEST_CASE(visibility_public_symbol_access) {
    TypeSystem typeSystem;
    ModuleTable moduleTable;
    SymbolTable symTable;
    VisibilityChecker checker(&moduleTable);
    
    Module* moduleA = moduleTable.createModule("moduleA", "/path/to/moduleA.aria");
    Module* moduleB = moduleTable.createModule("moduleB", "/path/to/moduleB.aria");
    
    Symbol* publicSymbol = symTable.defineSymbol("publicFunc", SymbolKind::FUNCTION, 
                                                 typeSystem.getPrimitiveType("int32"), 1, 1);
    publicSymbol->isPublic = true;
    
    bool allowed = checker.checkAccess(publicSymbol, moduleA, moduleB, 5, 10);
    
    ASSERT(allowed, "Public symbol should be accessible from any module");
    ASSERT(!checker.hasErrors(), "No errors should occur for public access");
}

// ============================================================================
// Test 2: PRIVATE symbols NOT accessible from other modules
// ============================================================================
TEST_CASE(visibility_private_symbol_blocked) {
    TypeSystem typeSystem;
    ModuleTable moduleTable;
    SymbolTable symTable;
    VisibilityChecker checker(&moduleTable);
    
    Module* moduleA = moduleTable.createModule("moduleA", "/path/to/moduleA.aria");
    Module* moduleB = moduleTable.createModule("moduleB", "/path/to/moduleB.aria");
    
    Symbol* privateSymbol = symTable.defineSymbol("privateFunc", SymbolKind::FUNCTION,
                                                  typeSystem.getPrimitiveType("int32"), 1, 1);
    privateSymbol->isPublic = false;
    
    bool allowed = checker.checkAccess(privateSymbol, moduleA, moduleB, 5, 10);
    
    ASSERT(!allowed, "Private symbol should be blocked from other modules");
    ASSERT(checker.hasErrors(), "Error should be generated for private access");
    
    const auto& errors = checker.getErrors();
    bool hasE002 = !errors.empty() && errors[0].find("E002") != std::string::npos;
    ASSERT(hasE002, "Error message should contain E002 code");
}

