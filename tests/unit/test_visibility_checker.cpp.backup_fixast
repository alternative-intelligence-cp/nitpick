}

// ============================================================================
// Test 7: isAccessAllowed direct check
// ============================================================================
TEST_CASE(visibility_is_access_allowed) {
    ModuleTable moduleTable;
    VisibilityChecker checker(&moduleTable);
    
    Module* moduleA = moduleTable.createModule("moduleA", "/path/to/moduleA.aria");
    Module* moduleB = moduleTable.createModule("moduleB", "/path/to/moduleB.aria");
    
    bool pubAllowed = checker.isAccessAllowed(VisibilityLevel::PUBLIC, moduleA, moduleB);
    ASSERT(pubAllowed, "PUBLIC accessible from different module");
    
    bool privDenied = checker.isAccessAllowed(VisibilityLevel::PRIVATE, moduleA, moduleB);
    ASSERT(!privDenied, "PRIVATE denied from different module");
    
    bool privAllowed = checker.isAccessAllowed(VisibilityLevel::PRIVATE, moduleA, moduleA);
    ASSERT(privAllowed, "PRIVATE allowed from same module");
}

// ============================================================================
// Test 8: Null parameter handling
// ============================================================================
TEST_CASE(visibility_null_parameters) {
    TypeSystem typeSystem;
    ModuleTable moduleTable;
    SymbolTable symTable;
    VisibilityChecker checker(&moduleTable);
    
    Module* moduleA = moduleTable.createModule("moduleA", "/path/to/moduleA.aria");
    Symbol* symbol = symTable.defineSymbol("func", SymbolKind::FUNCTION,
                                          typeSystem.getPrimitiveType("int32"), 1, 1);
    
    bool result1 = checker.checkAccess(nullptr, moduleA, moduleA, 1, 1);
    ASSERT(!result1, "Null symbol handled gracefully");
    ASSERT(checker.hasErrors(), "Error generated for null symbol");
    checker.clearErrors();
    
    bool result2 = checker.checkAccess(symbol, nullptr, moduleA, 1, 1);
    ASSERT(!result2, "Null symbol module handled gracefully");
    checker.clearErrors();
    
    bool result3 = checker.checkAccess(symbol, moduleA, nullptr, 1, 1);
    ASSERT(!result3, "Null current module handled gracefully");
}

// ============================================================================
// Test 9: Error message format validation
// ============================================================================
TEST_CASE(visibility_error_message_format) {
    TypeSystem typeSystem;
    ModuleTable moduleTable;
    SymbolTable symTable;
    VisibilityChecker checker(&moduleTable);
    
    Module* moduleA = moduleTable.createModule("moduleA", "/path/to/moduleA.aria");
    Module* moduleB = moduleTable.createModule("moduleB", "/path/to/moduleB.aria");
    
    Symbol* privateSym = symTable.defineSymbol("secretFunc", SymbolKind::FUNCTION,
                                               typeSystem.getPrimitiveType("int32"), 1, 1);
    privateSym->isPublic = false;
    
    checker.checkAccess(privateSym, moduleA, moduleB, 10, 25);
    
    const auto& errors = checker.getErrors();
    ASSERT(!errors.empty(), "Error message generated");
    
    if (!errors.empty()) {
        const std::string& err = errors[0];
        bool hasE002 = err.find("E002") != std::string::npos;
        bool hasSymbolName = err.find("secretFunc") != std::string::npos;
        bool hasLocation = err.find("line 10") != std::string::npos;
        bool hasHelp = err.find("Help:") != std::string::npos;
        
        ASSERT(hasE002, "Error contains E002 code");
        ASSERT(hasSymbolName, "Error contains symbol name");
        ASSERT(hasLocation, "Error contains location");
        ASSERT(hasHelp, "Error contains help message");
    }
}

// ============================================================================
// Test 10: Different symbol kinds
// ============================================================================
TEST_CASE(visibility_different_symbol_kinds) {
    TypeSystem typeSystem;
    ModuleTable moduleTable;
    SymbolTable symTable;
    VisibilityChecker checker(&moduleTable);
    
    Module* moduleA = moduleTable.createModule("moduleA", "/path/to/moduleA.aria");
    Module* moduleB = moduleTable.createModule("moduleB", "/path/to/moduleB.aria");
    
    Symbol* varSym = symTable.defineSymbol("privateVar", SymbolKind::VARIABLE,
                                           typeSystem.getPrimitiveType("int32"), 1, 1);
    varSym->isPublic = false;
    
    Symbol* funcSym = symTable.defineSymbol("privateFunc", SymbolKind::FUNCTION,
                                            typeSystem.getPrimitiveType("int32"), 2, 1);
    funcSym->isPublic = false;
    
    Symbol* typeSym = symTable.defineSymbol("PrivateType", SymbolKind::TYPE,
                                            typeSystem.getPrimitiveType("int32"), 3, 1);
    typeSym->isPublic = false;
    
    bool varBlocked = !checker.checkAccess(varSym, moduleA, moduleB, 5, 1);
    checker.clearErrors();
    bool funcBlocked = !checker.checkAccess(funcSym, moduleA, moduleB, 6, 1);
    checker.clearErrors();
    bool typeBlocked = !checker.checkAccess(typeSym, moduleA, moduleB, 7, 1);
    
    ASSERT(varBlocked, "Private variable blocked");
    ASSERT(funcBlocked, "Private function blocked");
    ASSERT(typeBlocked, "Private type blocked");
}
