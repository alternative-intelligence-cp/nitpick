// ============================================================================
// Test 4: Visibility level detection
// ============================================================================
TEST_CASE(visibility_level_detection) {
    TypeSystem typeSystem;
    ModuleTable moduleTable;
    SymbolTable symTable;
    VisibilityChecker checker(&moduleTable);
    
    Symbol* publicSym = symTable.defineSymbol("publicFunc", SymbolKind::FUNCTION,
                                              typeSystem.getPrimitiveType("int32"), 1, 1);
    publicSym->isPublic = true;
    
    Symbol* privateSym = symTable.defineSymbol("privateFunc", SymbolKind::FUNCTION,
                                               typeSystem.getPrimitiveType("int32"), 2, 1);
    privateSym->isPublic = false;
    
    VisibilityLevel pubLevel = checker.getVisibility(publicSym);
    VisibilityLevel privLevel = checker.getVisibility(privateSym);
    
    ASSERT(pubLevel == VisibilityLevel::PUBLIC, "Public symbol detected as PUBLIC");
    ASSERT(privLevel == VisibilityLevel::PRIVATE, "Private symbol detected as PRIVATE");
}

// ============================================================================
// Test 5: Multiple access violations accumulate errors
// ============================================================================
TEST_CASE(visibility_multiple_violations) {
    TypeSystem typeSystem;
    ModuleTable moduleTable;
    SymbolTable symTable;
    VisibilityChecker checker(&moduleTable);
    
    Module* moduleA = moduleTable.createModule("moduleA", "/path/to/moduleA.aria");
    Module* moduleB = moduleTable.createModule("moduleB", "/path/to/moduleB.aria");
    
    Symbol* privateSym1 = symTable.defineSymbol("private1", SymbolKind::FUNCTION,
                                                typeSystem.getPrimitiveType("int32"), 1, 1);
    privateSym1->isPublic = false;
    
    Symbol* privateSym2 = symTable.defineSymbol("private2", SymbolKind::FUNCTION,
                                                typeSystem.getPrimitiveType("int32"), 2, 1);
    privateSym2->isPublic = false;
    
    checker.checkAccess(privateSym1, moduleA, moduleB, 5, 10);
    checker.checkAccess(privateSym2, moduleA, moduleB, 6, 10);
    
    ASSERT(checker.getErrors().size() == 2, "Should have 2 errors");
}

// ============================================================================
// Test 6: Clear errors functionality
// ============================================================================
TEST_CASE(visibility_clear_errors) {
    TypeSystem typeSystem;
    ModuleTable moduleTable;
    SymbolTable symTable;
    VisibilityChecker checker(&moduleTable);
    
    Module* moduleA = moduleTable.createModule("moduleA", "/path/to/moduleA.aria");
    Module* moduleB = moduleTable.createModule("moduleB", "/path/to/moduleB.aria");
    
    Symbol* privateSym = symTable.defineSymbol("privateFunc", SymbolKind::FUNCTION,
                                               typeSystem.getPrimitiveType("int32"), 1, 1);
