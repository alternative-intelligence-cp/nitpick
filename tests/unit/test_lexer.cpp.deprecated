#include "../test_helpers.h"
#include "frontend/lexer/lexer.h"

using namespace aria::frontend;

// ============================================================================
// Basic Lexer Tests
// ============================================================================

TEST_CASE(lexer_empty_source) {
    Lexer lexer("");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 1, "Should have 1 token (EOF)");
}

TEST_CASE(lexer_single_char_tokens) {
    Lexer lexer("( ) { } [ ] ; , @ $ #");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 12, "Should have 12 tokens (11 + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_LEFT_PAREN, "Should be LEFT_PAREN");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_RIGHT_PAREN, "Should be RIGHT_PAREN");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_LEFT_BRACE, "Should be LEFT_BRACE");
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_RIGHT_BRACE, "Should be RIGHT_BRACE");
    ASSERT_EQ(tokens[4].type, TokenType::TOKEN_LEFT_BRACKET, "Should be LEFT_BRACKET");
    ASSERT_EQ(tokens[5].type, TokenType::TOKEN_RIGHT_BRACKET, "Should be RIGHT_BRACKET");
    ASSERT_EQ(tokens[6].type, TokenType::TOKEN_SEMICOLON, "Should be SEMICOLON");
    ASSERT_EQ(tokens[7].type, TokenType::TOKEN_COMMA, "Should be COMMA");
    ASSERT_EQ(tokens[8].type, TokenType::TOKEN_AT, "Should be AT");
    ASSERT_EQ(tokens[9].type, TokenType::TOKEN_DOLLAR, "Should be DOLLAR");
    ASSERT_EQ(tokens[10].type, TokenType::TOKEN_HASH, "Should be HASH");
}

TEST_CASE(lexer_operators) {
    Lexer lexer("+ - * / % = == != < > <= >=");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_PLUS, "Should be PLUS");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_MINUS, "Should be MINUS");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_STAR, "Should be STAR");
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_SLASH, "Should be SLASH");
    ASSERT_EQ(tokens[4].type, TokenType::TOKEN_PERCENT, "Should be PERCENT");
    ASSERT_EQ(tokens[5].type, TokenType::TOKEN_EQUAL, "Should be EQUAL");
    ASSERT_EQ(tokens[6].type, TokenType::TOKEN_EQUAL_EQUAL, "Should be EQUAL_EQUAL");
    ASSERT_EQ(tokens[7].type, TokenType::TOKEN_BANG_EQUAL, "Should be BANG_EQUAL");
    ASSERT_EQ(tokens[8].type, TokenType::TOKEN_LESS, "Should be LESS");
    ASSERT_EQ(tokens[9].type, TokenType::TOKEN_GREATER, "Should be GREATER");
    ASSERT_EQ(tokens[10].type, TokenType::TOKEN_LESS_EQUAL, "Should be LESS_EQUAL");
    ASSERT_EQ(tokens[11].type, TokenType::TOKEN_GREATER_EQUAL, "Should be GREATER_EQUAL");
}

TEST_CASE(lexer_compound_operators) {
    Lexer lexer("++ -- += -= *= /= %= && || -> ?. ?? <=> |> <|");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_PLUS_PLUS, "Should be PLUS_PLUS");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_MINUS_MINUS, "Should be MINUS_MINUS");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_PLUS_EQUAL, "Should be PLUS_EQUAL");
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_MINUS_EQUAL, "Should be MINUS_EQUAL");
    ASSERT_EQ(tokens[4].type, TokenType::TOKEN_STAR_EQUAL, "Should be STAR_EQUAL");
    ASSERT_EQ(tokens[5].type, TokenType::TOKEN_SLASH_EQUAL, "Should be SLASH_EQUAL");
    ASSERT_EQ(tokens[6].type, TokenType::TOKEN_PERCENT_EQUAL, "Should be PERCENT_EQUAL");
    ASSERT_EQ(tokens[7].type, TokenType::TOKEN_AND_AND, "Should be AND_AND");
    ASSERT_EQ(tokens[8].type, TokenType::TOKEN_OR_OR, "Should be OR_OR");
    ASSERT_EQ(tokens[9].type, TokenType::TOKEN_ARROW, "Should be ARROW");
    ASSERT_EQ(tokens[10].type, TokenType::TOKEN_SAFE_NAV, "Should be SAFE_NAV");
    ASSERT_EQ(tokens[11].type, TokenType::TOKEN_NULL_COALESCE, "Should be NULL_COALESCE");
    ASSERT_EQ(tokens[12].type, TokenType::TOKEN_SPACESHIP, "Should be SPACESHIP");
    ASSERT_EQ(tokens[13].type, TokenType::TOKEN_PIPE_RIGHT, "Should be PIPE_RIGHT");
    ASSERT_EQ(tokens[14].type, TokenType::TOKEN_PIPE_LEFT, "Should be PIPE_LEFT");
}

TEST_CASE(lexer_range_operators) {
    Lexer lexer(".. ...");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_DOT_DOT, "Should be DOT_DOT");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_DOT_DOT_DOT, "Should be DOT_DOT_DOT");
}

TEST_CASE(lexer_bitwise_operators) {
    Lexer lexer("& | ^ ~ << >>");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_AMPERSAND, "Should be AMPERSAND");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_PIPE, "Should be PIPE");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_CARET, "Should be CARET");
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_TILDE, "Should be TILDE");
    ASSERT_EQ(tokens[4].type, TokenType::TOKEN_SHIFT_LEFT, "Should be SHIFT_LEFT");
    ASSERT_EQ(tokens[5].type, TokenType::TOKEN_SHIFT_RIGHT, "Should be SHIFT_RIGHT");
}

TEST_CASE(lexer_skip_whitespace) {
    Lexer lexer("   +   \t  -  \n  *  \r\n  /  ");
    std::vector<Token> tokens = lexer.tokenize();
    
    // Should skip all whitespace and get 4 operators + EOF
    ASSERT_EQ(tokens.size(), 5, "Should have 5 tokens (4 operators + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_PLUS, "Should be PLUS");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_MINUS, "Should be MINUS");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_STAR, "Should be STAR");
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_SLASH, "Should be SLASH");
}

TEST_CASE(lexer_line_comments) {
    Lexer lexer("+ // this is a comment\n- // another comment");
    std::vector<Token> tokens = lexer.tokenize();
    
    // Should skip comments and get 2 operators + EOF
    ASSERT_EQ(tokens.size(), 3, "Should have 3 tokens (2 operators + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_PLUS, "Should be PLUS");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_MINUS, "Should be MINUS");
}

TEST_CASE(lexer_block_comments) {
    Lexer lexer("+ /* this is\na block\ncomment */ -");
    std::vector<Token> tokens = lexer.tokenize();
    
    // Should skip block comment and get 2 operators + EOF
    ASSERT_EQ(tokens.size(), 3, "Should have 3 tokens (2 operators + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_PLUS, "Should be PLUS");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_MINUS, "Should be MINUS");
}

TEST_CASE(lexer_unterminated_block_comment) {
    Lexer lexer("+ /* unterminated comment");
    std::vector<Token> tokens = lexer.tokenize();
    const std::vector<std::string>& errors = lexer.getErrors();
    
    // Should report error for unterminated comment
    ASSERT_EQ(errors.size(), 1, "Should have 1 error");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_PLUS, "Should still get PLUS token");
}

TEST_CASE(lexer_line_tracking) {
    Lexer lexer("+ \n - \n * \n /");
    std::vector<Token> tokens = lexer.tokenize();
    
    // Check that line numbers are tracked correctly
    ASSERT_EQ(tokens[0].line, 1, "First token should be on line 1");
    ASSERT_EQ(tokens[1].line, 2, "Second token should be on line 2");
    ASSERT_EQ(tokens[2].line, 3, "Third token should be on line 3");
    ASSERT_EQ(tokens[3].line, 4, "Fourth token should be on line 4");
}

TEST_CASE(lexer_identifiers) {
    Lexer lexer("myVar _private count123 variable_name");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 5, "Should have 5 tokens (4 identifiers + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_IDENTIFIER, "Should be IDENTIFIER");
    ASSERT_EQ(tokens[0].lexeme, "myVar", "Lexeme should be 'myVar'");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_IDENTIFIER, "Should be IDENTIFIER");
    ASSERT_EQ(tokens[1].lexeme, "_private", "Lexeme should be '_private'");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_IDENTIFIER, "Should be IDENTIFIER");
    ASSERT_EQ(tokens[2].lexeme, "count123", "Lexeme should be 'count123'");
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_IDENTIFIER, "Should be IDENTIFIER");
    ASSERT_EQ(tokens[3].lexeme, "variable_name", "Lexeme should be 'variable_name'");
}

TEST_CASE(lexer_keywords) {
    Lexer lexer("wild defer if else while for loop func mod use");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 11, "Should have 11 tokens (10 keywords + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_KW_WILD, "Should be KW_WILD");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_KW_DEFER, "Should be KW_DEFER");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_KW_IF, "Should be KW_IF");
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_KW_ELSE, "Should be KW_ELSE");
    ASSERT_EQ(tokens[4].type, TokenType::TOKEN_KW_WHILE, "Should be KW_WHILE");
    ASSERT_EQ(tokens[5].type, TokenType::TOKEN_KW_FOR, "Should be KW_FOR");
    ASSERT_EQ(tokens[6].type, TokenType::TOKEN_KW_LOOP, "Should be KW_LOOP");
    ASSERT_EQ(tokens[7].type, TokenType::TOKEN_KW_FUNC, "Should be KW_FUNC");
    ASSERT_EQ(tokens[8].type, TokenType::TOKEN_KW_MOD, "Should be KW_MOD");
    ASSERT_EQ(tokens[9].type, TokenType::TOKEN_KW_USE, "Should be KW_USE");
}

TEST_CASE(lexer_type_keywords) {
    Lexer lexer("int8 int32 uint64 flt32 bool string");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 7, "Should have 7 tokens (6 type keywords + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_KW_INT8, "Should be KW_INT8");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_KW_INT32, "Should be KW_INT32");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_KW_UINT64, "Should be KW_UINT64");
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_KW_FLT32, "Should be KW_FLT32");
    ASSERT_EQ(tokens[4].type, TokenType::TOKEN_KW_BOOL, "Should be KW_BOOL");
    ASSERT_EQ(tokens[5].type, TokenType::TOKEN_KW_STRING, "Should be KW_STRING");
}

TEST_CASE(lexer_boolean_literals) {
    Lexer lexer("true false NULL ERR");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 5, "Should have 5 tokens (4 keywords + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_KW_TRUE, "Should be TRUE keyword");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_KW_FALSE, "Should be FALSE keyword");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_KW_NULL, "Should be NULL keyword");
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_KW_ERR, "Should be ERR keyword");
}

TEST_CASE(lexer_integer_literals) {
    Lexer lexer("0 42 123456 1_000_000");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 5, "Should have 5 tokens (4 integers + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_INTEGER, "Should be INTEGER");
    ASSERT_EQ(tokens[0].value.int_value, 0, "Should be 0");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_INTEGER, "Should be INTEGER");
    ASSERT_EQ(tokens[1].value.int_value, 42, "Should be 42");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_INTEGER, "Should be INTEGER");
    ASSERT_EQ(tokens[2].value.int_value, 123456, "Should be 123456");
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_INTEGER, "Should be INTEGER");
    ASSERT_EQ(tokens[3].value.int_value, 1000000, "Should be 1000000");
}

TEST_CASE(lexer_hex_literals) {
    Lexer lexer("0xFF 0x1A2B 0xDEADBEEF");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 4, "Should have 4 tokens (3 hex + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_INTEGER, "Should be INTEGER");
    ASSERT_EQ(tokens[0].value.int_value, 0xFF, "Should be 255");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_INTEGER, "Should be INTEGER");
    ASSERT_EQ(tokens[1].value.int_value, 0x1A2B, "Should be 6699");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_INTEGER, "Should be INTEGER");
    ASSERT_EQ(tokens[2].value.int_value, 0xDEADBEEF, "Should be 3735928559");
}

TEST_CASE(lexer_binary_literals) {
    Lexer lexer("0b1010 0b11111111");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 3, "Should have 3 tokens (2 binary + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_INTEGER, "Should be INTEGER");
    ASSERT_EQ(tokens[0].value.int_value, 10, "Should be 10");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_INTEGER, "Should be INTEGER");
    ASSERT_EQ(tokens[1].value.int_value, 255, "Should be 255");
}

TEST_CASE(lexer_octal_literals) {
    Lexer lexer("0o777 0o123");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 3, "Should have 3 tokens (2 octal + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_INTEGER, "Should be INTEGER");
    ASSERT_EQ(tokens[0].value.int_value, 511, "Should be 511");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_INTEGER, "Should be INTEGER");
    ASSERT_EQ(tokens[1].value.int_value, 83, "Should be 83");
}

TEST_CASE(lexer_float_literals) {
    Lexer lexer("3.14 0.5 123.456");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 4, "Should have 4 tokens (3 floats + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_FLOAT, "Should be FLOAT");
    ASSERT_EQ(tokens[0].value.float_value, 3.14, "Should be 3.14");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_FLOAT, "Should be FLOAT");
    ASSERT_EQ(tokens[1].value.float_value, 0.5, "Should be 0.5");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_FLOAT, "Should be FLOAT");
    ASSERT_EQ(tokens[2].value.float_value, 123.456, "Should be 123.456");
}

TEST_CASE(lexer_scientific_notation) {
    Lexer lexer("1e10 2.5e-3 6.022e23");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 4, "Should have 4 tokens (3 scientific + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_FLOAT, "Should be FLOAT");
    ASSERT_EQ(tokens[0].value.float_value, 1e10, "Should be 1e10");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_FLOAT, "Should be FLOAT");
    ASSERT_EQ(tokens[1].value.float_value, 2.5e-3, "Should be 2.5e-3");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_FLOAT, "Should be FLOAT");
    ASSERT_EQ(tokens[2].value.float_value, 6.022e23, "Should be 6.022e23");
}

TEST_CASE(lexer_string_literals) {
    Lexer lexer("\"hello\" \"world\" \"\"");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 4, "Should have 4 tokens (3 strings + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_STRING, "Should be STRING");
    ASSERT_EQ(tokens[0].string_value, "hello", "Should be 'hello'");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_STRING, "Should be STRING");
    ASSERT_EQ(tokens[1].string_value, "world", "Should be 'world'");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_STRING, "Should be STRING");
    ASSERT_EQ(tokens[2].string_value, "", "Should be empty string");
}

TEST_CASE(lexer_string_escapes) {
    Lexer lexer("\"hello\\nworld\" \"tab\\there\" \"quote\\\"end\"");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 4, "Should have 4 tokens (3 strings + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_STRING, "Should be STRING");
    ASSERT_EQ(tokens[0].string_value, "hello\nworld", "Should have newline");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_STRING, "Should be STRING");
    ASSERT_EQ(tokens[1].string_value, "tab\there", "Should have tab");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_STRING, "Should be STRING");
    ASSERT_EQ(tokens[2].string_value, "quote\"end", "Should have escaped quote");
}

TEST_CASE(lexer_character_literals) {
    Lexer lexer("'a' 'Z' '0'");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 4, "Should have 4 tokens (3 chars + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_CHAR, "Should be CHAR");
    ASSERT_EQ(tokens[0].string_value, "a", "Should be 'a'");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_CHAR, "Should be CHAR");
    ASSERT_EQ(tokens[1].string_value, "Z", "Should be 'Z'");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_CHAR, "Should be CHAR");
    ASSERT_EQ(tokens[2].string_value, "0", "Should be '0'");
}

TEST_CASE(lexer_character_escapes) {
    Lexer lexer("'\\n' '\\t' '\\''");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 4, "Should have 4 tokens (3 chars + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_CHAR, "Should be CHAR");
    ASSERT_EQ(tokens[0].string_value, "\n", "Should be newline");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_CHAR, "Should be CHAR");
    ASSERT_EQ(tokens[1].string_value, "\t", "Should be tab");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_CHAR, "Should be CHAR");
    ASSERT_EQ(tokens[2].string_value, "'", "Should be single quote");
}

TEST_CASE(lexer_mixed_tokens) {
    Lexer lexer("wild int8 count = 42;");
    std::vector<Token> tokens = lexer.tokenize();
    
    ASSERT_EQ(tokens.size(), 7, "Should have 7 tokens (6 + EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_KW_WILD, "Should be KW_WILD");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_KW_INT8, "Should be KW_INT8");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_IDENTIFIER, "Should be IDENTIFIER");
    ASSERT_EQ(tokens[2].lexeme, "count", "Should be 'count'");
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_EQUAL, "Should be EQUAL");
    ASSERT_EQ(tokens[4].type, TokenType::TOKEN_INTEGER, "Should be INTEGER");
    ASSERT_EQ(tokens[4].value.int_value, 42, "Should be 42");
    ASSERT_EQ(tokens[5].type, TokenType::TOKEN_SEMICOLON, "Should be SEMICOLON");
}

TEST_CASE(lexer_complex_expression) {
    Lexer lexer("func add(a int32, b int32) -> int32 { pass a + b; }");
    std::vector<Token> tokens = lexer.tokenize();
    
    // Just verify we can tokenize a complex expression without errors
    ASSERT_TRUE(tokens.size() > 0, "Should have tokens");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_KW_FUNC, "Should start with func");
}

// ============================================================================
// Template Literal Token Tests
// Template literals emit proper token sequences:
//   TEMPLATE_START, TEMPLATE_PART*, (INTERP_START, expr tokens, INTERP_END)*, TEMPLATE_PART*, TEMPLATE_END
// ============================================================================

TEST_CASE(lexer_template_literal_basic) {
    Lexer lexer("`hello world`");
    std::vector<Token> tokens = lexer.tokenize();

    // Expected: TEMPLATE_START, TEMPLATE_PART("hello world"), TEMPLATE_END, EOF
    ASSERT_EQ(tokens.size(), 4, "Should have 4 tokens (START, PART, END, EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_TEMPLATE_START, "Should start with TEMPLATE_START");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_TEMPLATE_PART, "Should have TEMPLATE_PART");
    ASSERT_EQ(tokens[1].string_value, "hello world", "Part should be 'hello world'");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_TEMPLATE_END, "Should end with TEMPLATE_END");
}

TEST_CASE(lexer_template_literal_empty) {
    Lexer lexer("``");
    std::vector<Token> tokens = lexer.tokenize();

    // Expected: TEMPLATE_START, TEMPLATE_PART(""), TEMPLATE_END, EOF
    ASSERT_EQ(tokens.size(), 4, "Should have 4 tokens (START, empty PART, END, EOF)");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_TEMPLATE_START, "Should start with TEMPLATE_START");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_TEMPLATE_PART, "Should have empty TEMPLATE_PART");
    ASSERT_EQ(tokens[1].string_value, "", "Part should be empty");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_TEMPLATE_END, "Should end with TEMPLATE_END");
}

TEST_CASE(lexer_template_literal_interpolation) {
    Lexer lexer("`The value is &{x}`");
    std::vector<Token> tokens = lexer.tokenize();

    // Expected: TEMPLATE_START, TEMPLATE_PART("The value is "), INTERP_START, IDENTIFIER(x), INTERP_END, TEMPLATE_PART(""), TEMPLATE_END, EOF
    ASSERT_EQ(tokens.size(), 8, "Should have 8 tokens");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_TEMPLATE_START, "Should start with TEMPLATE_START");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_TEMPLATE_PART, "Should have first TEMPLATE_PART");
    ASSERT_EQ(tokens[1].string_value, "The value is ", "First part should be 'The value is '");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_INTERP_START, "Should have INTERP_START");
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_IDENTIFIER, "Should have identifier x");
    ASSERT_EQ(tokens[4].type, TokenType::TOKEN_INTERP_END, "Should have INTERP_END");
    ASSERT_EQ(tokens[5].type, TokenType::TOKEN_TEMPLATE_PART, "Should have final TEMPLATE_PART");
    ASSERT_EQ(tokens[6].type, TokenType::TOKEN_TEMPLATE_END, "Should end with TEMPLATE_END");
}

TEST_CASE(lexer_template_literal_multiple_interpolations) {
    Lexer lexer("`User &{name} has &{points} points`");
    std::vector<Token> tokens = lexer.tokenize();

    // Expected: START, PART("User "), INTERP_START, IDENT(name), INTERP_END, PART(" has "),
    //           INTERP_START, IDENT(points), INTERP_END, PART(" points"), END, EOF
    ASSERT_EQ(tokens.size(), 12, "Should have 12 tokens for multiple interpolations");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_TEMPLATE_START, "Should start with TEMPLATE_START");
    ASSERT_EQ(tokens[1].string_value, "User ", "First part should be 'User '");
    ASSERT_EQ(tokens[3].lexeme, "name", "First interpolation should be 'name'");
    ASSERT_EQ(tokens[5].string_value, " has ", "Middle part should be ' has '");
    ASSERT_EQ(tokens[7].lexeme, "points", "Second interpolation should be 'points'");
    ASSERT_EQ(tokens[9].string_value, " points", "Final part should be ' points'");
}

TEST_CASE(lexer_template_literal_expression_interpolation) {
    Lexer lexer("`Result: &{a + b}`");
    std::vector<Token> tokens = lexer.tokenize();

    // Expression inside interpolation should be tokenized
    ASSERT_TRUE(tokens.size() >= 8, "Should have tokens for expression interpolation");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_TEMPLATE_START, "Should start with TEMPLATE_START");
    ASSERT_EQ(tokens[1].string_value, "Result: ", "First part should be 'Result: '");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_INTERP_START, "Should have INTERP_START");
    // Expression tokens: a, +, b
    ASSERT_EQ(tokens[3].type, TokenType::TOKEN_IDENTIFIER, "Should have identifier a");
    ASSERT_EQ(tokens[4].type, TokenType::TOKEN_PLUS, "Should have plus operator");
    ASSERT_EQ(tokens[5].type, TokenType::TOKEN_IDENTIFIER, "Should have identifier b");
    ASSERT_EQ(tokens[6].type, TokenType::TOKEN_INTERP_END, "Should have INTERP_END");
}

TEST_CASE(lexer_template_literal_nested_braces) {
    Lexer lexer("`Data: &{obj.func(1, 2)}`");
    std::vector<Token> tokens = lexer.tokenize();

    // Should handle function calls with parentheses
    ASSERT_TRUE(tokens.size() >= 8, "Should have tokens for nested parens");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_TEMPLATE_START, "Should start with TEMPLATE_START");
    ASSERT_EQ(tokens[1].string_value, "Data: ", "First part should be 'Data: '");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_INTERP_START, "Should have INTERP_START");
    // The expression tokens are between INTERP_START and INTERP_END
}

TEST_CASE(lexer_template_literal_escape_backtick) {
    Lexer lexer("`Escaped backtick: \\` here`");
    std::vector<Token> tokens = lexer.tokenize();

    // Expected: TEMPLATE_START, TEMPLATE_PART("Escaped backtick: ` here"), TEMPLATE_END, EOF
    ASSERT_EQ(tokens.size(), 4, "Should have 4 tokens");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_TEMPLATE_START, "Should start with TEMPLATE_START");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_TEMPLATE_PART, "Should have TEMPLATE_PART");
    ASSERT_EQ(tokens[1].string_value, "Escaped backtick: ` here", "Should have escaped backtick in content");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_TEMPLATE_END, "Should end with TEMPLATE_END");
}

TEST_CASE(lexer_template_literal_escape_sequences) {
    Lexer lexer("`Line 1\\nLine 2\\ttabbed`");
    std::vector<Token> tokens = lexer.tokenize();

    ASSERT_EQ(tokens.size(), 4, "Should have 4 tokens");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_TEMPLATE_START, "Should start with TEMPLATE_START");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_TEMPLATE_PART, "Should have TEMPLATE_PART");
    ASSERT_EQ(tokens[1].string_value, "Line 1\nLine 2\ttabbed", "Should process escape sequences");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_TEMPLATE_END, "Should end with TEMPLATE_END");
}

TEST_CASE(lexer_template_literal_multiline) {
    Lexer lexer("`Line 1\nLine 2\nLine 3`");
    std::vector<Token> tokens = lexer.tokenize();

    ASSERT_EQ(tokens.size(), 4, "Should have 4 tokens");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_TEMPLATE_START, "Should start with TEMPLATE_START");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_TEMPLATE_PART, "Should have TEMPLATE_PART");
    ASSERT_EQ(tokens[1].string_value, "Line 1\nLine 2\nLine 3", "Should preserve newlines");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_TEMPLATE_END, "Should end with TEMPLATE_END");
}

TEST_CASE(lexer_template_literal_complex) {
    Lexer lexer("`Status: &{response.success ? \"OK\" : \"FAIL\"} - &{count} items`");
    std::vector<Token> tokens = lexer.tokenize();

    // Should have proper template tokens with complex expression inside
    ASSERT_TRUE(tokens.size() >= 10, "Should have multiple tokens for complex template");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_TEMPLATE_START, "Should start with TEMPLATE_START");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_TEMPLATE_PART, "Should have first TEMPLATE_PART");
    ASSERT_EQ(tokens[1].string_value, "Status: ", "First part should be 'Status: '");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_INTERP_START, "Should have first INTERP_START");
}

TEST_CASE(lexer_template_with_operators) {
    Lexer lexer("`Progress: &{Math.round((current / total) * 100)}%`");
    std::vector<Token> tokens = lexer.tokenize();

    // Should handle nested parentheses in expression
    ASSERT_TRUE(tokens.size() >= 10, "Should have multiple tokens");
    ASSERT_EQ(tokens[0].type, TokenType::TOKEN_TEMPLATE_START, "Should start with TEMPLATE_START");
    ASSERT_EQ(tokens[1].type, TokenType::TOKEN_TEMPLATE_PART, "Should have first TEMPLATE_PART");
    ASSERT_EQ(tokens[1].string_value, "Progress: ", "First part should be 'Progress: '");
    ASSERT_EQ(tokens[2].type, TokenType::TOKEN_INTERP_START, "Should have INTERP_START");
}
