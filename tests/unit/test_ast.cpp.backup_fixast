#include "test_helpers.h"
#include "frontend/ast/ast_node.h"
#include "frontend/ast/expr.h"
#include "frontend/ast/stmt.h"
#include "frontend/ast/type.h"
#include "frontend/token.h"
#include <memory>

using namespace aria;
using aria::frontend::Token;
using aria::frontend::TokenType;

TEST_CASE(ast_literal_integer) {
    auto lit = std::make_shared<LiteralExpr>(static_cast<int64_t>(42));
    ASSERT_EQ(lit->type, ASTNode::NodeType::LITERAL, "Should be LITERAL node");
    ASSERT_TRUE(lit->isExpression(), "Should be an expression");
    ASSERT_FALSE(lit->isStatement(), "Should not be a statement");
    ASSERT_EQ(lit->toString(), "Literal(42)", "Should have correct string representation");
}

TEST_CASE(ast_literal_float) {
    auto lit = std::make_shared<LiteralExpr>(3.14);
    ASSERT_EQ(lit->type, ASTNode::NodeType::LITERAL, "Should be LITERAL node");
    ASSERT_EQ(lit->toString(), "Literal(3.14)", "Should have correct string representation");
}

TEST_CASE(ast_literal_string) {
    auto lit = std::make_shared<LiteralExpr>(std::string("hello"));
    ASSERT_EQ(lit->type, ASTNode::NodeType::LITERAL, "Should be LITERAL node");
    ASSERT_EQ(lit->toString(), "Literal(\"hello\")", "Should have correct string representation");
}

TEST_CASE(ast_literal_boolean) {
    auto lit_true = std::make_shared<LiteralExpr>(true);
    auto lit_false = std::make_shared<LiteralExpr>(false);
    ASSERT_EQ(lit_true->toString(), "Literal(true)", "Should be true");
    ASSERT_EQ(lit_false->toString(), "Literal(false)", "Should be false");
}

TEST_CASE(ast_literal_null) {
    auto lit = std::make_shared<LiteralExpr>(std::monostate{});
    ASSERT_EQ(lit->toString(), "Literal(null)", "Should be null");
}

TEST_CASE(ast_identifier) {
    auto ident = std::make_shared<IdentifierExpr>("myVariable");
    ASSERT_EQ(ident->type, ASTNode::NodeType::IDENTIFIER, "Should be IDENTIFIER node");
    ASSERT_TRUE(ident->isExpression(), "Should be an expression");
    ASSERT_EQ(ident->name, "myVariable", "Should have correct name");
    ASSERT_EQ(ident->toString(), "Identifier(myVariable)", "Should have correct string representation");
}

TEST_CASE(ast_binary_expr) {
    auto left = std::make_shared<LiteralExpr>(static_cast<int64_t>(10));
    auto right = std::make_shared<LiteralExpr>(static_cast<int64_t>(20));
    Token op(TokenType::TOKEN_PLUS, "+", 1, 5);
    
    auto binary = std::make_shared<BinaryExpr>(left, op, right);
    ASSERT_EQ(binary->type, ASTNode::NodeType::BINARY_OP, "Should be BINARY_OP node");
    ASSERT_TRUE(binary->isExpression(), "Should be an expression");
    ASSERT_EQ(binary->left, left, "Should have correct left operand");
    ASSERT_EQ(binary->right, right, "Should have correct right operand");
}

TEST_CASE(ast_unary_expr) {
    auto operand = std::make_shared<LiteralExpr>(static_cast<int64_t>(42));
    Token op(TokenType::TOKEN_MINUS, "-", 1, 1);
    
    auto unary = std::make_shared<UnaryExpr>(op, operand);
    ASSERT_EQ(unary->type, ASTNode::NodeType::UNARY_OP, "Should be UNARY_OP node");
    ASSERT_TRUE(unary->isExpression(), "Should be an expression");
    ASSERT_EQ(unary->operand, operand, "Should have correct operand");
}

TEST_CASE(ast_call_expr) {
    auto callee = std::make_shared<IdentifierExpr>("myFunc");
    auto arg1 = std::make_shared<LiteralExpr>(static_cast<int64_t>(1));
    auto arg2 = std::make_shared<LiteralExpr>(static_cast<int64_t>(2));
    std::vector<ASTNodePtr> args = {arg1, arg2};
    
    auto call = std::make_shared<CallExpr>(callee, args);
    ASSERT_EQ(call->type, ASTNode::NodeType::CALL, "Should be CALL node");
    ASSERT_TRUE(call->isExpression(), "Should be an expression");
    ASSERT_EQ(call->callee, callee, "Should have correct callee");
    ASSERT_EQ(call->arguments.size(), 2, "Should have 2 arguments");
}

TEST_CASE(ast_index_expr) {
    auto array = std::make_shared<IdentifierExpr>("arr");
    auto index = std::make_shared<LiteralExpr>(static_cast<int64_t>(0));
    
    auto indexExpr = std::make_shared<IndexExpr>(array, index);
    ASSERT_EQ(indexExpr->type, ASTNode::NodeType::INDEX, "Should be INDEX node");
    ASSERT_TRUE(indexExpr->isExpression(), "Should be an expression");
    ASSERT_EQ(indexExpr->array, array, "Should have correct array");
    ASSERT_EQ(indexExpr->index, index, "Should have correct index");
}

TEST_CASE(ast_member_access) {
    auto object = std::make_shared<IdentifierExpr>("obj");
    auto member = std::make_shared<MemberAccessExpr>(object, "field", false);
    
    ASSERT_EQ(member->type, ASTNode::NodeType::MEMBER_ACCESS, "Should be MEMBER_ACCESS node");
    ASSERT_TRUE(member->isExpression(), "Should be an expression");
    ASSERT_EQ(member->object, object, "Should have correct object");
    ASSERT_EQ(member->member, "field", "Should have correct member name");
    ASSERT_FALSE(member->isPointerAccess, "Should not be pointer access");
}

TEST_CASE(ast_pointer_member_access) {
    auto pointer = std::make_shared<IdentifierExpr>("ptr");
    auto member = std::make_shared<MemberAccessExpr>(pointer, "field", true);
    
    ASSERT_EQ(member->type, ASTNode::NodeType::POINTER_MEMBER, "Should be POINTER_MEMBER node");
    ASSERT_TRUE(member->isPointerAccess, "Should be pointer access");
}

TEST_CASE(ast_var_decl) {
    auto init = std::make_shared<LiteralExpr>(static_cast<int64_t>(42));
    auto varDecl = std::make_shared<VarDeclStmt>("int8", "x", init);
    
    ASSERT_EQ(varDecl->type, ASTNode::NodeType::VAR_DECL, "Should be VAR_DECL node");
    ASSERT_TRUE(varDecl->isStatement(), "Should be a statement");
    ASSERT_EQ(varDecl->typeNode->toString(), "int8", "Should have correct type");
    ASSERT_EQ(varDecl->varName, "x", "Should have correct variable name");
    ASSERT_EQ(varDecl->initializer, init, "Should have initializer");
}

TEST_CASE(ast_var_decl_wild) {
    auto init = std::make_shared<LiteralExpr>(static_cast<int64_t>(100));
    auto varDecl = std::make_shared<VarDeclStmt>("int64", "ptr", init);
    varDecl->isWild = true;
    
    ASSERT_TRUE(varDecl->isWild, "Should be wild");
    ASSERT_FALSE(varDecl->isConst, "Should not be const");
    ASSERT_FALSE(varDecl->isStack, "Should not be stack");
}

TEST_CASE(ast_func_decl) {
    auto param1 = std::make_shared<ParameterNode>(std::make_shared<SimpleType>("int8"), "a");
    auto param2 = std::make_shared<ParameterNode>(std::make_shared<SimpleType>("int8"), "b");
    std::vector<ASTNodePtr> params = {param1, param2};
    auto body = std::make_shared<BlockStmt>();
    
    auto funcDecl = std::make_shared<FuncDeclStmt>("add", std::make_shared<SimpleType>("int8"), params, body);
    
    ASSERT_EQ(funcDecl->type, ASTNode::NodeType::FUNC_DECL, "Should be FUNC_DECL node");
    ASSERT_TRUE(funcDecl->isStatement(), "Should be a statement");
    ASSERT_EQ(funcDecl->funcName, "add", "Should have correct function name");
    ASSERT_EQ(funcDecl->returnType->toString(), "int8", "Should have correct return type");
    ASSERT_EQ(funcDecl->parameters.size(), 2, "Should have 2 parameters");
}

TEST_CASE(ast_parameter_node) {
    auto param = std::make_shared<ParameterNode>(std::make_shared<SimpleType>("string"), "name");
    
    ASSERT_EQ(param->type, ASTNode::NodeType::PARAMETER, "Should be PARAMETER node");
    ASSERT_EQ(param->typeNode->toString(), "string", "Should have correct type");
    ASSERT_EQ(param->paramName, "name", "Should have correct parameter name");
    ASSERT_EQ(param->defaultValue, nullptr, "Should not have default value");
}

TEST_CASE(ast_block_stmt) {
    auto stmt1 = std::make_shared<VarDeclStmt>("int8", "x", std::make_shared<LiteralExpr>(static_cast<int64_t>(1)));
    auto stmt2 = std::make_shared<VarDeclStmt>("int8", "y", std::make_shared<LiteralExpr>(static_cast<int64_t>(2)));
    std::vector<ASTNodePtr> stmts = {stmt1, stmt2};
    
    auto block = std::make_shared<BlockStmt>(stmts);
    
    ASSERT_EQ(block->type, ASTNode::NodeType::BLOCK, "Should be BLOCK node");
    ASSERT_TRUE(block->isStatement(), "Should be a statement");
    ASSERT_EQ(block->statements.size(), 2, "Should have 2 statements");
}

TEST_CASE(ast_return_stmt) {
    auto value = std::make_shared<LiteralExpr>(static_cast<int64_t>(42));
    auto returnStmt = std::make_shared<ReturnStmt>(value);
    
    ASSERT_EQ(returnStmt->type, ASTNode::NodeType::RETURN, "Should be RETURN node");
    ASSERT_TRUE(returnStmt->isStatement(), "Should be a statement");
    ASSERT_EQ(returnStmt->value, value, "Should have return value");
}

TEST_CASE(ast_if_stmt) {
    auto condition = std::make_shared<LiteralExpr>(true);
    auto thenBranch = std::make_shared<BlockStmt>();
    auto elseBranch = std::make_shared<BlockStmt>();
    
    auto ifStmt = std::make_shared<IfStmt>(condition, thenBranch, elseBranch);
    
    ASSERT_EQ(ifStmt->type, ASTNode::NodeType::IF, "Should be IF node");
    ASSERT_TRUE(ifStmt->isStatement(), "Should be a statement");
    ASSERT_EQ(ifStmt->condition, condition, "Should have condition");
    ASSERT_EQ(ifStmt->thenBranch, thenBranch, "Should have then branch");
    ASSERT_EQ(ifStmt->elseBranch, elseBranch, "Should have else branch");
}

TEST_CASE(ast_while_stmt) {
    auto condition = std::make_shared<IdentifierExpr>("running");
    auto body = std::make_shared<BlockStmt>();
    
    auto whileStmt = std::make_shared<WhileStmt>(condition, body);
    
    ASSERT_EQ(whileStmt->type, ASTNode::NodeType::WHILE, "Should be WHILE node");
    ASSERT_TRUE(whileStmt->isStatement(), "Should be a statement");
    ASSERT_EQ(whileStmt->condition, condition, "Should have condition");
    ASSERT_EQ(whileStmt->body, body, "Should have body");
}

TEST_CASE(ast_program_node) {
    auto decl1 = std::make_shared<VarDeclStmt>("int8", "x", std::make_shared<LiteralExpr>(static_cast<int64_t>(1)));
    auto decl2 = std::make_shared<VarDeclStmt>("int8", "y", std::make_shared<LiteralExpr>(static_cast<int64_t>(2)));
    std::vector<ASTNodePtr> decls = {decl1, decl2};
    
    auto program = std::make_shared<ProgramNode>(decls);
    
    ASSERT_EQ(program->type, ASTNode::NodeType::PROGRAM, "Should be PROGRAM node");
    ASSERT_EQ(program->declarations.size(), 2, "Should have 2 declarations");
}

TEST_CASE(ast_node_type_to_string) {
    ASSERT_EQ(ASTNode::nodeTypeToString(ASTNode::NodeType::LITERAL), "LITERAL", "Should be LITERAL");
    ASSERT_EQ(ASTNode::nodeTypeToString(ASTNode::NodeType::IDENTIFIER), "IDENTIFIER", "Should be IDENTIFIER");
    ASSERT_EQ(ASTNode::nodeTypeToString(ASTNode::NodeType::BINARY_OP), "BINARY_OP", "Should be BINARY_OP");
    ASSERT_EQ(ASTNode::nodeTypeToString(ASTNode::NodeType::VAR_DECL), "VAR_DECL", "Should be VAR_DECL");
}
