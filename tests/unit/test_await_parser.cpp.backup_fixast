/**
 * Test multiple await expressions in same function
 * Tests: Can have many await expressions
 */
TEST_CASE(parser_multiple_awaits) {
    std::string source = R"(
        async func:test = int32() {
            int32:a = await futureA;
            int32:b = await futureB;
            int32:c = await futureC;
            pass(a + b + c);
        };
    )";
    
    Lexer lexer(source);
    auto tokens = lexer.tokenize();
    Parser parser(tokens);
    auto ast = parser.parse();
    
    ASSERT(!parser.hasErrors(), "Parser should handle multiple awaits");
    
    auto prog = std::dynamic_pointer_cast<ProgramNode>(ast);
    auto funcDecl = std::dynamic_pointer_cast<FuncDeclStmt>(prog->declarations[0]);
    auto body = std::dynamic_pointer_cast<BlockStmt>(funcDecl->body);
    
    ASSERT(body->statements.size() >= 3, "Should have at least 3 await statements");
    
    // Verify each is an await
    for (int i = 0; i < 3; i++) {
        auto varDecl = std::dynamic_pointer_cast<VarDeclStmt>(body->statements[i]);
        ASSERT(varDecl != nullptr, "Statement should be variable declaration");
        
        auto awaitExpr = std::dynamic_pointer_cast<AwaitExpr>(varDecl->initializer);
        ASSERT(awaitExpr != nullptr, "Each initializer should be await");
    }
}
