/**
 * Test basic await expression: await someFunction()
 * Tests: await <expression>
 */
TEST_CASE(parser_await_basic) {
    std::string source = R"(
        async func:test = int32() {
            pass(await future);
        };
    )";
    
    Lexer lexer(source);
    auto tokens = lexer.tokenize();
    Parser parser(tokens);
    auto ast = parser.parse();
    
    // Print errors for debugging
    if (parser.hasErrors()) {
        for (const auto& err : parser.getErrors()) {
            std::cerr << "Parser error: " << err << std::endl;
        }
    }
    
    ASSERT(!parser.hasErrors(), "Parser should not have errors");
    
    auto prog = std::dynamic_pointer_cast<ProgramNode>(ast);
    ASSERT(prog != nullptr, "Should create program node");
    
    auto funcDecl = std::dynamic_pointer_cast<FuncDeclStmt>(prog->declarations[0]);
    ASSERT(funcDecl != nullptr, "Should be func declaration");
    ASSERT(funcDecl->isAsync, "Function should be async");
    
    // Check that body has pass statement with await expression
    auto body = std::dynamic_pointer_cast<BlockStmt>(funcDecl->body);
    ASSERT(body != nullptr, "Should have block body");
    ASSERT(body->statements.size() >= 1, "Should have at least one statement");
}

/**
 * Test await with nested expression
 * Tests: await (complex expression)
 */
TEST_CASE(parser_await_nested) {
    std::string source = R"(
        async func:test = int32() {
            int32:sum = await futureA + await futureB;
            pass(sum);
        };
    )";
    
    Lexer lexer(source);
    auto tokens = lexer.tokenize();
    Parser parser(tokens);
    auto ast = parser.parse();
    
    ASSERT(!parser.hasErrors(), "Parser should not have errors");
    
    auto prog = std::dynamic_pointer_cast<ProgramNode>(ast);
    auto funcDecl = std::dynamic_pointer_cast<FuncDeclStmt>(prog->declarations[0]);
    auto body = std::dynamic_pointer_cast<BlockStmt>(funcDecl->body);
    auto varDecl = std::dynamic_pointer_cast<VarDeclStmt>(body->statements[0]);
    
    // Check that the initializer is a binary expression with await operands
    auto binaryExpr = std::dynamic_pointer_cast<BinaryExpr>(varDecl->initializer);
    ASSERT(binaryExpr != nullptr, "Initializer should be binary expression");
    
    auto leftAwait = std::dynamic_pointer_cast<AwaitExpr>(binaryExpr->left);
    auto rightAwait = std::dynamic_pointer_cast<AwaitExpr>(binaryExpr->right);
    
    ASSERT(leftAwait != nullptr, "Left operand should be await");
    ASSERT(rightAwait != nullptr, "Right operand should be await");
}

