#include "../test_helpers.h"
#include "frontend/token.h"

using namespace aria::frontend;

TEST_CASE(token_construction) {
    // Test basic token construction
    Token t1(TokenType::TOKEN_KW_INT8, "int8", 1, 5);
    ASSERT_EQ(t1.type, TokenType::TOKEN_KW_INT8, "Token type should be INT8");
    ASSERT_EQ(t1.lexeme, "int8", "Token lexeme should be 'int8'");
    ASSERT_EQ(t1.line, 1, "Token line should be 1");
    ASSERT_EQ(t1.column, 5, "Token column should be 5");
}

TEST_CASE(token_with_int_value) {
    // Test token with integer value
    Token t2(TokenType::TOKEN_INTEGER, "42", 2, 10, (int64_t)42);
    ASSERT_EQ(t2.type, TokenType::TOKEN_INTEGER, "Token type should be INTEGER");
    ASSERT_EQ(t2.value.int_value, 42, "Token value should be 42");
}

TEST_CASE(token_with_float_value) {
    // Test token with float value
    Token t3(TokenType::TOKEN_FLOAT, "3.14", 3, 15, 3.14);
    ASSERT_EQ(t3.type, TokenType::TOKEN_FLOAT, "Token type should be FLOAT");
    ASSERT_TRUE(t3.value.float_value > 3.13 && t3.value.float_value < 3.15, "Float value should be approximately 3.14");
}

TEST_CASE(token_with_string_value) {
    // Test token with string value
    Token t4(TokenType::TOKEN_STRING, "\"hello\"", 4, 1, std::string("hello"));
    ASSERT_EQ(t4.type, TokenType::TOKEN_STRING, "Token type should be STRING");
    ASSERT_EQ(t4.string_value, std::string("hello"), "String value should be 'hello'");
}

TEST_CASE(token_is_keyword) {
    Token keyword(TokenType::TOKEN_KW_FUNC, "func", 1, 1);
    Token identifier(TokenType::TOKEN_IDENTIFIER, "myFunc", 1, 6);
    
    ASSERT_TRUE(keyword.isKeyword(), "func should be identified as keyword");
    ASSERT_FALSE(identifier.isKeyword(), "myFunc should not be identified as keyword");
}

TEST_CASE(token_is_operator) {
    Token plus(TokenType::TOKEN_PLUS, "+", 1, 1);
    Token arrow(TokenType::TOKEN_ARROW, "->", 1, 3);
    Token identifier(TokenType::TOKEN_IDENTIFIER, "x", 1, 6);
    
    ASSERT_TRUE(plus.isOperator(), "+ should be identified as operator");
    ASSERT_TRUE(arrow.isOperator(), "-> should be identified as operator");
    ASSERT_FALSE(identifier.isOperator(), "identifier should not be operator");
}

TEST_CASE(token_is_literal) {
    Token integer(TokenType::TOKEN_INTEGER, "42", 1, 1);
    Token float_tok(TokenType::TOKEN_FLOAT, "3.14", 1, 5);
    Token true_tok(TokenType::TOKEN_KW_TRUE, "true", 1, 10);
    Token keyword(TokenType::TOKEN_KW_FUNC, "func", 1, 15);
    
    ASSERT_TRUE(integer.isLiteral(), "integer should be literal");
    ASSERT_TRUE(float_tok.isLiteral(), "float should be literal");
    ASSERT_TRUE(true_tok.isLiteral(), "true should be literal");
    ASSERT_FALSE(keyword.isLiteral(), "func should not be literal");
}

TEST_CASE(token_is_type) {
    Token int8(TokenType::TOKEN_KW_INT8, "int8", 1, 1);
    Token tbb16(TokenType::TOKEN_KW_TBB16, "tbb16", 1, 6);
    Token string_type(TokenType::TOKEN_KW_STRING, "string", 1, 12);
    Token identifier(TokenType::TOKEN_IDENTIFIER, "myVar", 1, 19);
    
    ASSERT_TRUE(int8.isType(), "int8 should be identified as type");
    ASSERT_TRUE(tbb16.isType(), "tbb16 should be identified as type");
    ASSERT_TRUE(string_type.isType(), "string should be identified as type");
    ASSERT_FALSE(identifier.isType(), "identifier should not be type");
}

TEST_CASE(token_type_to_string) {
    // Test a few token type to string conversions
    ASSERT_EQ(tokenTypeToString(TokenType::TOKEN_KW_FUNC), "FUNC", "FUNC should convert correctly");
    ASSERT_EQ(tokenTypeToString(TokenType::TOKEN_PLUS), "PLUS", "PLUS should convert correctly");
    ASSERT_EQ(tokenTypeToString(TokenType::TOKEN_INTEGER), "INTEGER", "INTEGER should convert correctly");
    ASSERT_EQ(tokenTypeToString(TokenType::TOKEN_EOF), "EOF", "EOF should convert correctly");
}

TEST_CASE(token_to_string_method) {
    // Test token toString() method
    Token t1(TokenType::TOKEN_KW_INT8, "int8", 5, 10);
    std::string str = t1.toString();
    
    // Should contain type, lexeme, line, and column
    ASSERT_TRUE(str.find("INT8") != std::string::npos, "toString should contain type name");
    ASSERT_TRUE(str.find("int8") != std::string::npos, "toString should contain lexeme");
    ASSERT_TRUE(str.find("5") != std::string::npos, "toString should contain line number");
    ASSERT_TRUE(str.find("10") != std::string::npos, "toString should contain column number");
}
