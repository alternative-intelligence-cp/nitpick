#include "../test_helpers.h"

// Sample test to verify test infrastructure works
TEST_CASE(sample_pass) {
    ASSERT_TRUE(true, "This should pass");
    ASSERT_EQ(1 + 1, 2, "Basic arithmetic works");
    ASSERT_NE(1, 2, "Numbers are different");
}

TEST_CASE(sample_math) {
    int a = 5;
    int b = 10;
    ASSERT_EQ(a + b, 15, "Addition works");
    ASSERT_EQ(a * b, 50, "Multiplication works");
    ASSERT_TRUE(b > a, "Comparison works");
}

