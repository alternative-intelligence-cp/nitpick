TEST_CASE(server_error_codes_defined) {
    // Verify error code constants exist and are correct
    // (they're in server.cpp as constexpr, can't test values directly)
    // But we can verify error response structure
    
    json error = {
        {"code", -32600},
        {"message", "Invalid Request"}
    };
    
    ASSERT(error.contains("code"), "Error must have code");
    ASSERT(error.contains("message"), "Error must have message");
    ASSERT_EQ(error["code"], -32600, "Code must be int");
}

TEST_CASE(diagnostic_lsp_format) {
    // Verify diagnostic structure matches LSP spec
    json diag = {
        {"range", {
            {"start", {{"line", 5}, {"character", 10}}},
            {"end", {{"line", 5}, {"character", 15}}}
        }},
        {"severity", 1},
        {"message", "Undefined variable"},
        {"source", "aria"}
    };
    
    ASSERT(diag.contains("range"), "Must have range");
    ASSERT(diag.contains("severity"), "Must have severity");
    ASSERT(diag.contains("message"), "Must have message");
    ASSERT_EQ(diag["range"]["start"]["line"], 5, "Line must be 0-based");
}

TEST_CASE(publish_diagnostics_notification_format) {
    // Verify publishDiagnostics notification structure
    json notification = Transport::makeNotification("textDocument/publishDiagnostics", {
        {"uri", "file:///test.aria"},
        {"diagnostics", json::array({
            {
                {"range", {{"start", {{"line", 0}, {"character", 0}}}, {"end", {{"line", 0}, {"character", 5}}}}},
                {"severity", 1},
                {"message", "Test error"}
            }
        })}
    });
    
    ASSERT(notification.contains("method"), "Must have method");
    ASSERT_EQ(notification["method"], "textDocument/publishDiagnostics", "Method must match");
    ASSERT(notification["params"].contains("uri"), "Params must have uri");
    ASSERT(notification["params"].contains("diagnostics"), "Params must have diagnostics");
    ASSERT(notification["params"]["diagnostics"].is_array(), "Diagnostics must be array");
}

TEST_CASE(hover_response_format) {
    // Verify hover response structure
    json hover = {
        {"contents", {
            {"kind", "markdown"},
            {"value", "**Token:** `myVar`"}
        }},
        {"range", {
            {"start", {{"line", 5}, {"character", 10}}},
            {"end", {{"line", 5}, {"character", 15}}}
        }}
    };
    
    ASSERT(hover.contains("contents"), "Must have contents");
    ASSERT(hover["contents"].contains("kind"), "Contents must have kind");
    ASSERT(hover["contents"].contains("value"), "Contents must have value");
    ASSERT_EQ(hover["contents"]["kind"], "markdown", "Kind should be markdown");
    ASSERT(hover.contains("range"), "Should have range");
}

TEST_CASE(definition_response_format) {
    // Verify go-to-definition response structure (Location)
    json location = {
        {"uri", "file:///test.aria"},
        {"range", {
            {"start", {{"line", 0}, {"character", 4}}},
            {"end", {{"line", 0}, {"character", 9}}}
        }}
    };
    
    ASSERT(location.contains("uri"), "Must have uri");
    ASSERT(location.contains("range"), "Must have range");
    ASSERT(location["range"].contains("start"), "Range must have start");
    ASSERT(location["range"].contains("end"), "Range must have end");
}

