TEST_CASE(server_capabilities_default) {
    ServerCapabilities caps;
    
    ASSERT_EQ(caps.textDocumentSync, 1, "Should default to full sync");
    ASSERT_EQ(caps.hoverProvider, false, "Hover not implemented yet");
    ASSERT_EQ(caps.definitionProvider, false, "Definition not implemented yet");
}

TEST_CASE(server_capabilities_to_json) {
    ServerCapabilities caps;
    caps.textDocumentSync = 1;
    caps.hoverProvider = true;
    
    json j = caps.to_json();
    
    ASSERT(j.contains("textDocumentSync"), "Must have textDocumentSync");
    ASSERT_EQ(j["textDocumentSync"], 1, "Sync kind must match");
    ASSERT_EQ(j["hoverProvider"], true, "Hover must match");
}

