// Test file for await expression type extraction (Future<T> → T)
#include "../test_helpers.h"
#include "frontend/sema/type.h"

using namespace aria::sema;

TEST_CASE(unwrap_future_int32) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    FutureType* futureInt = typeSystem.getFutureType(int32Type);
    
    // Unwrap future<int32> → int32
    Type* unwrapped = typeSystem.unwrapFutureType(futureInt);
    
    ASSERT(unwrapped != nullptr, "Unwrapped type should not be null");
    ASSERT(unwrapped == int32Type, "Should unwrap to int32");
    ASSERT(unwrapped->getKind() == TypeKind::PRIMITIVE, "Should be primitive type");
}

