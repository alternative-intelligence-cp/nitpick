TEST_CASE(await_complex_return_types) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    ArrayType* arrayInt = typeSystem.getArrayType(int32Type, 100);
    PointerType* ptrArray = typeSystem.getPointerType(arrayInt);
    ResultType* resultPtr = typeSystem.getResultType(ptrArray);
    FutureType* futureComplex = typeSystem.getFutureType(resultPtr);
    
    // await future<result<int32[100]@>> → result<int32[100]@>
    Type* unwrapped = typeSystem.unwrapFutureType(futureComplex);
    
    ASSERT(unwrapped == resultPtr, "Should unwrap to result<int32[100]@>");
    ASSERT(unwrapped->getKind() == TypeKind::RESULT, "Should be result type");
}

TEST_CASE(multiple_await_in_expression) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    FutureType* futureInt = typeSystem.getFutureType(int32Type);
    
    // Simulate: (await future1) + (await future2)
    Type* await1 = typeSystem.unwrapFutureType(futureInt);
    Type* await2 = typeSystem.unwrapFutureType(futureInt);
    
    ASSERT(await1 == int32Type, "First await extracts int32");
    ASSERT(await2 == int32Type, "Second await extracts int32");
    ASSERT(await1 == await2, "Both awaits extract same type");
}
