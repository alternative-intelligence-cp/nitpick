TEST_CASE(await_async_function_call) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    std::vector<Type*> paramTypes;
    
    // Create async function: async func() -> int32
    // This becomes: func() -> future<int32> (from Task #3)
    FunctionType* asyncFunc = typeSystem.getFunctionType(paramTypes, int32Type, true, false);
    
    // The function return type is future<int32>
    Type* returnType = asyncFunc->getReturnType();
    ASSERT(returnType->getKind() == TypeKind::FUTURE, "Async function returns future");
    
    // Simulate: result = await asyncFunc()
    // The await expression type is the unwrapped future type
    Type* awaitResultType = typeSystem.unwrapFutureType(returnType);
    
    ASSERT(awaitResultType == int32Type, "Await should extract int32 from future<int32>");
    ASSERT(awaitResultType->toString() == "int32", "Result type should be int32");
}

TEST_CASE(await_chained_async_calls) {
    TypeSystem typeSystem;
    
    Type* stringType = typeSystem.getPrimitiveType("string");
    std::vector<Type*> paramTypes;
    
    // async func fetchData() -> string
    // Returns: future<string>
    FunctionType* fetchFunc = typeSystem.getFunctionType(paramTypes, stringType, true, false);
    Type* fetchReturn = fetchFunc->getReturnType();
    
    // result = await fetchData()
    Type* fetchAwait = typeSystem.unwrapFutureType(fetchReturn);
    ASSERT(fetchAwait == stringType, "First await extracts string");
    
    // async func processData(string) -> string
    std::vector<Type*> processParams = {stringType};
    FunctionType* processFunc = typeSystem.getFunctionType(processParams, stringType, true, false);
    Type* processReturn = processFunc->getReturnType();
    
    // result = await processData(await fetchData())
    Type* processAwait = typeSystem.unwrapFutureType(processReturn);
    ASSERT(processAwait == stringType, "Second await extracts string");
}

