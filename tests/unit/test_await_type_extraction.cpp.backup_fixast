TEST_CASE(unwrap_nested_future) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    FutureType* innerFuture = typeSystem.getFutureType(int32Type);
    FutureType* outerFuture = typeSystem.getFutureType(innerFuture);
    
    // Unwrap future<future<int32>> → future<int32>
    Type* unwrapped = typeSystem.unwrapFutureType(outerFuture);
    
    ASSERT(unwrapped == innerFuture, "Should unwrap one level");
    ASSERT(unwrapped->getKind() == TypeKind::FUTURE, "Should still be future");
    ASSERT(unwrapped->toString() == "future<int32>", "Should be future<int32>");
    
    // Unwrap again: future<int32> → int32
    Type* fullyUnwrapped = typeSystem.unwrapFutureType(unwrapped);
    ASSERT(fullyUnwrapped == int32Type, "Should unwrap to int32");
}

