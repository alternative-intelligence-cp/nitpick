TEST_CASE(borrow_checker_wild_alloc_and_free) {
    BorrowChecker checker;
    
    // wild int32:ptr = alloc();
    // free(ptr);
    auto ptr_init = std::make_unique<LiteralExpr>(int64_t(0));  // Placeholder for alloc
    auto ptr_decl = std::make_unique<aria::VarDeclStmt>("wild int32", "ptr", std::move(ptr_init));
    
    // Note: Actual free() call would be a CallExpr, but we'd need more AST setup
    // For now, this test just verifies the allocation is tracked
    
    std::vector<ASTNodePtr> stmts;
    stmts.push_back(std::move(ptr_decl));
    aria::BlockStmt block(std::move(stmts));
    
    auto errors = checker.analyze(&block);
    
    // Should have leak error (no free call)
    ASSERT(checker.hasErrors(), "Should have leak error for wild memory not freed");
}

