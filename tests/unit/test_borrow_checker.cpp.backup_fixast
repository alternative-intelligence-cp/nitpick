// ----------------------------------------------------------------------------
// Control Flow Tests
// ----------------------------------------------------------------------------

TEST_CASE(borrow_checker_if_statement_branching) {
    BorrowChecker checker;
    
    // int32:x = 10;
    // if (true) {
    //   int32:y = 20;
    // }
    auto x_init = std::make_unique<LiteralExpr>(int64_t(10));
    auto x_decl = std::make_unique<aria::VarDeclStmt>("int32", "x", std::move(x_init));
    
    auto cond = std::make_unique<LiteralExpr>(true);
    
    auto y_init = std::make_unique<LiteralExpr>(int64_t(20));
    auto y_decl = std::make_unique<aria::VarDeclStmt>("int32", "y", std::move(y_init));
    std::vector<ASTNodePtr> then_stmts;
    then_stmts.push_back(std::move(y_decl));
    auto then_block = std::make_unique<aria::BlockStmt>(std::move(then_stmts));
    
    auto if_stmt = std::make_unique<aria::IfStmt>(std::move(cond), std::move(then_block));
    
    std::vector<ASTNodePtr> stmts;
    stmts.push_back(std::move(x_decl));
    stmts.push_back(std::move(if_stmt));
    aria::BlockStmt block(std::move(stmts));
    
    auto errors = checker.analyze(&block);
    
    ASSERT(!checker.hasErrors(), "Should have no errors for simple if statement");
}

TEST_CASE(borrow_checker_while_loop) {
    BorrowChecker checker;
    
    // int32:i = 0;
    // while (true) {
    //   int32:j = 1;
    // }
    auto i_init = std::make_unique<LiteralExpr>(int64_t(0));
    auto i_decl = std::make_unique<aria::VarDeclStmt>("int32", "i", std::move(i_init));
    
    auto cond = std::make_unique<LiteralExpr>(true);
    
    auto j_init = std::make_unique<LiteralExpr>(int64_t(1));
    auto j_decl = std::make_unique<aria::VarDeclStmt>("int32", "j", std::move(j_init));
    std::vector<ASTNodePtr> body_stmts;
    body_stmts.push_back(std::move(j_decl));
    auto body = std::make_unique<aria::BlockStmt>(std::move(body_stmts));
    
    auto while_stmt = std::make_unique<aria::WhileStmt>(std::move(cond), std::move(body));
    
    std::vector<ASTNodePtr> stmts;
    stmts.push_back(std::move(i_decl));
    stmts.push_back(std::move(while_stmt));
    aria::BlockStmt block(std::move(stmts));
    
    auto errors = checker.analyze(&block);
    
    ASSERT(!checker.hasErrors(), "Should have no errors for simple while loop");
}
