    // Second borrow
    auto x_ref2 = std::make_unique<IdentifierExpr>("x");
    Token dollar_op2(TokenType::TOKEN_DOLLAR, "$", 3, 1);
    auto borrow2 = std::make_unique<UnaryExpr>(dollar_op2, std::move(x_ref2));
    auto r2_decl = std::make_unique<aria::VarDeclStmt>("int32$", "r2", std::move(borrow2));
    
