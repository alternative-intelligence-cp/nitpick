// ----------------------------------------------------------------------------
// Pinning Tests (Phase 3.3.2)
// ----------------------------------------------------------------------------

TEST_CASE(borrow_checker_pin_valid) {
    BorrowChecker checker;
    
    // string:data = "hello";
    // wild int8*:ptr = #data;  // Valid: pin GC object
    auto data_init = std::make_unique<LiteralExpr>(std::string("hello"));
    auto data_decl = std::make_unique<aria::VarDeclStmt>("string", "data", std::move(data_init));
    
    // Create pin: #data
    auto data_ref = std::make_unique<IdentifierExpr>("data");
    Token hash_op(TokenType::TOKEN_HASH, "#", 2, 1);
    auto pin = std::make_unique<UnaryExpr>(hash_op, std::move(data_ref));
    auto ptr_decl = std::make_unique<aria::VarDeclStmt>("wild int8*", "ptr", std::move(pin));
    
    std::vector<ASTNodePtr> stmts;
    stmts.push_back(std::move(data_decl));
    stmts.push_back(std::move(ptr_decl));
    aria::BlockStmt block(std::move(stmts));
    
    auto errors = checker.analyze(&block);
    
    if (checker.hasErrors()) {
        for (const auto& err : checker.getErrors()) {
            std::cout << "Error: " << err.message << " at line " << err.line << std::endl;
        }
    }
    ASSERT(!checker.hasErrors(), "Should have no errors for valid pin");
}

TEST_CASE(borrow_checker_cannot_pin_twice) {
    BorrowChecker checker;
    
    // string:data = "hello";
    // wild int8*:ptr1 = #data;
    // wild int8*:ptr2 = #data;  // Error: already pinned
    auto data_init = std::make_unique<LiteralExpr>(std::string("hello"));
    auto data_decl = std::make_unique<aria::VarDeclStmt>("string", "data", std::move(data_init));
    
