    Token hash_op2(TokenType::TOKEN_HASH, "#", 3, 1);
    auto pin2 = std::make_unique<UnaryExpr>(hash_op2, std::move(data_ref2));
    auto ptr2_decl = std::make_unique<aria::VarDeclStmt>("wild int8*", "ptr2", std::move(pin2));
    
