// ----------------------------------------------------------------------------
// Lifetime Tracking Tests (Phase 3.3.1)
// ----------------------------------------------------------------------------

TEST_CASE(borrow_checker_simple_scope) {
    BorrowChecker checker;
    
    // {
    //   int32:x = 10;
    // }
    auto init = std::make_unique<LiteralExpr>(int64_t(10));
    auto decl = std::make_unique<aria::VarDeclStmt>("int32", "x", std::move(init));
    
    std::vector<ASTNodePtr> stmts;
    stmts.push_back(std::move(decl));
    aria::BlockStmt block(std::move(stmts));
    
    auto errors = checker.analyze(&block);
    
    ASSERT(!checker.hasErrors(), "Should have no errors for simple scope");
}

TEST_CASE(borrow_checker_nested_scopes) {
    BorrowChecker checker;
    
    // {
    //   int32:x = 10;
    //   {
    //     int32:y = 20;
    //   }
    // }
    auto x_init = std::make_unique<LiteralExpr>(int64_t(10));
    auto x_decl = std::make_unique<aria::VarDeclStmt>("int32", "x", std::move(x_init));
    
    auto y_init = std::make_unique<LiteralExpr>(int64_t(20));
    auto y_decl = std::make_unique<aria::VarDeclStmt>("int32", "y", std::move(y_init));
    
    std::vector<ASTNodePtr> inner_stmts;
    inner_stmts.push_back(std::move(y_decl));
    auto inner_block = std::make_unique<aria::BlockStmt>(std::move(inner_stmts));
    
    std::vector<ASTNodePtr> outer_stmts;
    outer_stmts.push_back(std::move(x_decl));
    outer_stmts.push_back(std::move(inner_block));
    aria::BlockStmt outer_block(std::move(outer_stmts));
    
    auto errors = checker.analyze(&outer_block);
    
    ASSERT(!checker.hasErrors(), "Should have no errors for nested scopes");
}

// ----------------------------------------------------------------------------
// Borrow Rules Tests (Phase 3.3.2)
// ----------------------------------------------------------------------------

TEST_CASE(borrow_checker_immutable_borrow_valid) {
    BorrowChecker checker;
    
    // int32:x = 10;
    // int32$:r = $x;  // Valid: immutable borrow
    auto x_init = std::make_unique<LiteralExpr>(int64_t(10));
    auto x_decl = std::make_unique<aria::VarDeclStmt>("int32", "x", std::move(x_init));
    
    // Create borrow: $x
    auto x_ref = std::make_unique<IdentifierExpr>("x");
    Token dollar_op(TokenType::TOKEN_DOLLAR, "$", 2, 1);
    auto borrow = std::make_unique<UnaryExpr>(dollar_op, std::move(x_ref));
    auto r_decl = std::make_unique<aria::VarDeclStmt>("int32$", "r", std::move(borrow));
    
    std::vector<ASTNodePtr> stmts;
    stmts.push_back(std::move(x_decl));
    stmts.push_back(std::move(r_decl));
    aria::BlockStmt block(std::move(stmts));
    
    auto errors = checker.analyze(&block);
    
    ASSERT(!checker.hasErrors(), "Should have no errors for valid immutable borrow");
}

