TEST_CASE(future_type_equality) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    Type* int64Type = typeSystem.getPrimitiveType("int64");
    Type* stringType = typeSystem.getPrimitiveType("string");
    
    FutureType* futureInt32_1 = typeSystem.getFutureType(int32Type);
    FutureType* futureInt32_2 = typeSystem.getFutureType(int32Type);
    FutureType* futureInt64 = typeSystem.getFutureType(int64Type);
    FutureType* futureString = typeSystem.getFutureType(stringType);
    
    // Same output type should be equal
    ASSERT(futureInt32_1->equals(futureInt32_2), "future<int32> should equal future<int32>");
    ASSERT(futureInt32_2->equals(futureInt32_1), "Equality should be symmetric");
    
    // Different output types should not be equal
    ASSERT(!futureInt32_1->equals(futureInt64), "future<int32> should not equal future<int64>");
    ASSERT(!futureInt32_1->equals(futureString), "future<int32> should not equal future<string>");
    ASSERT(!futureInt64->equals(futureString), "future<int64> should not equal future<string>");
    
    // Should not equal non-future types
    ASSERT(!futureInt32_1->equals(int32Type), "future<int32> should not equal int32");
    
    // Should not equal nullptr
    ASSERT(!futureInt32_1->equals(nullptr), "future<int32> should not equal nullptr");
}

TEST_CASE(future_type_assignability) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    Type* int64Type = typeSystem.getPrimitiveType("int64");
    
    FutureType* futureInt32_1 = typeSystem.getFutureType(int32Type);
    FutureType* futureInt32_2 = typeSystem.getFutureType(int32Type);
    FutureType* futureInt64 = typeSystem.getFutureType(int64Type);
    
    // Same type should be assignable
    ASSERT(futureInt32_1->isAssignableTo(futureInt32_2), "future<int32> should be assignable to future<int32>");
    
    // Different types should not be assignable
    ASSERT(!futureInt32_1->isAssignableTo(futureInt64), "future<int32> should not be assignable to future<int64>");
    ASSERT(!futureInt64->isAssignableTo(futureInt32_1), "future<int64> should not be assignable to future<int32>");
    
    // Future types should not be assignable to non-future types
    ASSERT(!futureInt32_1->isAssignableTo(int32Type), "future<int32> should not be assignable to int32");
    
    // Should handle nullptr
    ASSERT(!futureInt32_1->isAssignableTo(nullptr), "Should handle nullptr assignment check");
}

TEST_CASE(future_type_nested_futures) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    
    // Create future<int32>
    FutureType* futureInt32 = typeSystem.getFutureType(int32Type);
    ASSERT(futureInt32->toString() == "future<int32>", "Should create future<int32>");
    
    // Create future<future<int32>>
    FutureType* futureFutureInt32 = typeSystem.getFutureType(futureInt32);
    ASSERT(futureFutureInt32->getKind() == TypeKind::FUTURE, "Nested future should have FUTURE kind");
    ASSERT(futureFutureInt32->getOutputType() == futureInt32, "Output type should be future<int32>");
    ASSERT(futureFutureInt32->toString() == "future<future<int32>>", "Should create future<future<int32>>");
}

