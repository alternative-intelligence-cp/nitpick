// Test file for Future<T> type system
#include "../test_helpers.h"
#include "frontend/sema/type.h"

using namespace aria::sema;

TEST_CASE(future_type_basic_creation) {
    TypeSystem typeSystem;
    
    // Get int32 type
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    ASSERT(int32Type != nullptr, "int32Type should not be null");
    
    // Create future<int32>
    FutureType* futureInt32 = typeSystem.getFutureType(int32Type);
    ASSERT(futureInt32 != nullptr, "futureInt32 should not be null");
    ASSERT(futureInt32->getKind() == TypeKind::FUTURE, "Kind should be FUTURE");
    ASSERT(futureInt32->getOutputType() == int32Type, "Output type should be int32");
}

TEST_CASE(future_type_toString_int32) {
    TypeSystem typeSystem;
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    FutureType* futureInt32 = typeSystem.getFutureType(int32Type);
    ASSERT(futureInt32->toString() == "future<int32>", "toString should be 'future<int32>'");
}

