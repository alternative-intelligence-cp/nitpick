/**
 * Test async keyword without func causes parse error
 * Tests: async by itself is not a valid statement
 */
TEST_CASE(parser_async_without_func) {
    // async is a keyword and only valid before func
    // Using it elsewhere should cause a parse error
    std::string source = "async;";  // async without func is invalid
    
    Lexer lexer(source);
    auto tokens = lexer.tokenize();
    Parser parser(tokens);
    auto ast = parser.parse();
    
    // Should have parser errors since async alone isn't a valid statement
    ASSERT(parser.hasErrors(), "Parser should reject async without func");
}

/**
 * Test multiple async functions in same file
 * Tests: Can have multiple async function declarations
 */
TEST_CASE(parser_multiple_async_funcs) {
    std::string source = R"(
        async func:fetch1 = int32() {
            pass(1);
        };
        
        async func:fetch2 = int32() {
            pass(2);
        };
        
        func:regular = int32() {
            pass(0);
        };
    )";
    
    Lexer lexer(source);
    auto tokens = lexer.tokenize();
    Parser parser(tokens);
    auto ast = parser.parse();
    
    ASSERT(!parser.hasErrors(), "Parser should not have errors");
    
    auto prog = std::dynamic_pointer_cast<ProgramNode>(ast);
    ASSERT_EQ(prog->declarations.size(), 3, "Should have 3 functions");
    
    auto func1 = std::dynamic_pointer_cast<FuncDeclStmt>(prog->declarations[0]);
    auto func2 = std::dynamic_pointer_cast<FuncDeclStmt>(prog->declarations[1]);
    auto func3 = std::dynamic_pointer_cast<FuncDeclStmt>(prog->declarations[2]);
    
    ASSERT(func1->isAsync, "First function should be async");
    ASSERT(func2->isAsync, "Second function should be async");
    ASSERT(!func3->isAsync, "Third function should be sync");
}
