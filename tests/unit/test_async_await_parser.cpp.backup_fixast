// ============================================================================
// Phase 4.5.3: Async/Await Parser Tests
// ============================================================================

/**
 * Test basic async function declaration syntax
 * Tests: async func:name = result<type>(params) { body };
 */
TEST_CASE(parser_async_func_basic) {
    std::string source = R"(
        async func:fetchUser = int64(int32:id) {
            pass(id + 100);
        };
    )";
    
    Lexer lexer(source);
    auto tokens = lexer.tokenize();
    Parser parser(tokens);
    auto ast = parser.parse();
    
    ASSERT(!parser.hasErrors(), "Parser should not have errors");
    
    auto prog = std::dynamic_pointer_cast<ProgramNode>(ast);
    ASSERT(prog != nullptr, "Should create program node");
    ASSERT_EQ(prog->declarations.size(), 1, "Should have one statement");
    
    auto funcDecl = std::dynamic_pointer_cast<FuncDeclStmt>(prog->declarations[0]);
    ASSERT(funcDecl != nullptr, "Should be func declaration");
    ASSERT_EQ(funcDecl->funcName, "fetchUser", "Function name should be fetchUser");
    ASSERT(funcDecl->isAsync, "Should be marked as async");
    ASSERT_EQ(funcDecl->returnType->toString(), "int64", "Return type should be int64");
}

