/**
 * @file test_project_config.cpp
 * @brief Unit tests for aria.toml project configuration parser
 */

#include "../test_helpers.h"
#include "tools/project_config.h"
#include <fstream>
#include <filesystem>

using namespace aria;
using namespace aria::tools;

// ============================================================================
// Basic Parsing Tests
// ============================================================================

TEST_CASE(project_config_minimal_valid) {
    std::string toml_content = R"(
        [package]
        name = "hello"
        version = "1.0.0"
    )";
    
    auto config = ProjectConfigParser::parse_string(toml_content);
    
    ASSERT_EQ(config.package.name, "hello", "Package name should be 'hello'");
    ASSERT_EQ(config.package.version, "1.0.0", "Package version should be '1.0.0'");
    ASSERT_EQ(config.package.edition, "2025", "Default edition should be '2025'");
}

TEST_CASE(project_config_complete_package) {
    std::string toml_content = R"(
        [package]
        name = "myproject"
        version = "2.1.0"
        authors = ["Alice <alice@example.com>", "Bob <bob@example.com>"]
        edition = "2026"
        license = "MIT"
        description = "A test project"
    )";
    
    auto config = ProjectConfigParser::parse_string(toml_content);
    
    ASSERT_EQ(config.package.name, "myproject", "Package name should be 'myproject'");
    ASSERT_EQ(config.package.version, "2.1.0", "Package version should be '2.1.0'");
    ASSERT(config.package.authors.size() == 2, "Should have 2 authors");
    ASSERT_EQ(config.package.authors[0], "Alice <alice@example.com>", "First author should match");
    ASSERT_EQ(config.package.edition, "2026", "Edition should be '2026'");
    ASSERT_EQ(config.package.license, "MIT", "License should be 'MIT'");
}

TEST_CASE(project_config_simple_dependencies) {
    std::string toml_content = R"(
        [package]
        name = "test"
        version = "1.0.0"
        
        [dependencies]
        std = "0.1"
        aria-http = "1.2.3"
    )";
    
    auto config = ProjectConfigParser::parse_string(toml_content);
    
    ASSERT(config.dependencies.size() == 2, "Should have 2 dependencies");
    ASSERT_EQ(config.dependencies["std"].name, "std", "Dependency name should be 'std'");
    ASSERT_EQ(config.dependencies["std"].version, "0.1", "std version should be '0.1'");
    ASSERT_EQ(config.dependencies["aria-http"].version, "1.2.3", "aria-http version should be '1.2.3'");
}

TEST_CASE(project_config_build_config) {
    std::string toml_content = R"(
        [package]
        name = "test"
        version = "1.0.0"
        
        [build]
        target = "library"
        optimization = "release"
        output = "dist/"
        main = "src/lib.aria"
    )";
    
    auto config = ProjectConfigParser::parse_string(toml_content);
    
    ASSERT(config.build.target == TargetType::Library, "Build target should be Library");
    ASSERT(config.build.optimization == OptimizationLevel::Release, "Optimization should be Release");
    ASSERT_EQ(config.build.output, "dist/", "Output should be 'dist/'");
    ASSERT_EQ(config.build.main, "src/lib.aria", "Main should be 'src/lib.aria'");
}

TEST_CASE(project_config_features) {
    std::string toml_content = R"(
        [package]
        name = "test"
        version = "1.0.0"
        
        [features]
        default = ["std"]
        experimental = ["feature1", "feature2"]
    )";
    
    auto config = ProjectConfigParser::parse_string(toml_content);
    
    ASSERT(config.features.size() == 2, "Should have 2 features");
    ASSERT(config.has_feature("default"), "Should have 'default' feature");
    ASSERT(config.has_feature("experimental"), "Should have 'experimental' feature");
    
    auto defaults = config.get_default_features();
    ASSERT(defaults.size() == 1, "Should have 1 default feature");
    ASSERT_EQ(defaults[0], "std", "Default feature should be 'std'");
}

// ============================================================================
// Validation Tests
// ============================================================================

TEST_CASE(project_config_valid_package_name) {
    std::string toml_content = R"(
        [package]
        name = "valid_name-123"
        version = "1.0.0"
    )";
    
    auto config = ProjectConfigParser::parse_string(toml_content);
    ASSERT_EQ(config.package.name, "valid_name-123", "Package name should be 'valid_name-123'");
}

TEST_CASE(project_config_invalid_package_name_start) {
    std::string toml_content = R"(
        [package]
        name = "123invalid"
        version = "1.0.0"
    )";
    
    try {
        auto config = ProjectConfigParser::parse_string(toml_content);
        ASSERT(false, "Should have thrown validation error");
    } catch (const std::runtime_error& e) {
        std::string error = e.what();
        ASSERT(error.find("start with a letter") != std::string::npos, "Error should mention 'start with a letter'");
    }
}

TEST_CASE(project_config_invalid_version) {
    std::string toml_content = R"(
        [package]
        name = "test"
        version = "1.2"
    )";
    
    try {
        auto config = ProjectConfigParser::parse_string(toml_content);
        ASSERT(false, "Should have thrown validation error");
    } catch (const std::runtime_error& e) {
        std::string error = e.what();
        ASSERT(error.find("semantic version") != std::string::npos, "Error should mention 'semantic version'");
    }
}

TEST_CASE(project_config_missing_package_section) {
    std::string toml_content = R"(
        [build]
        target = "executable"
    )";
    
    try {
        auto config = ProjectConfigParser::parse_string(toml_content);
        ASSERT(false, "Should have thrown error for missing [package]");
    } catch (const std::runtime_error& e) {
        std::string error = e.what();
        ASSERT(error.find("package") != std::string::npos, "Error should mention 'package'");
    }
}

TEST_CASE(project_config_file_not_found) {
    try {
        auto config = ProjectConfigParser::parse_file("/nonexistent/aria.toml");
        ASSERT(false, "Should have thrown error for missing file");
    } catch (const std::runtime_error& e) {
        std::string error = e.what();
        ASSERT(error.find("not found") != std::string::npos, "Error should mention 'not found'");
    }
}
