// Test file for async function return types (Future<T>)
#include "../test_helpers.h"
#include "frontend/sema/type.h"

using namespace aria::sema;

TEST_CASE(async_function_returns_future_int32) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    std::vector<Type*> paramTypes;
    
    // Create async function: async func() -> int32
    // Should actually become: func() -> future<int32>
    FunctionType* asyncFunc = typeSystem.getFunctionType(paramTypes, int32Type, true, false);
    
    ASSERT(asyncFunc != nullptr, "Async function type should not be null");
    ASSERT(asyncFunc->isAsyncFunction(), "Should be marked as async");
    
    // Return type should be future<int32>, not int32
    Type* returnType = asyncFunc->getReturnType();
    ASSERT(returnType != nullptr, "Return type should not be null");
    ASSERT(returnType->getKind() == TypeKind::FUTURE, "Return type should be FUTURE");
    
    FutureType* futureReturnType = static_cast<FutureType*>(returnType);
    ASSERT(futureReturnType->getOutputType() == int32Type, "Future output should be int32");
    ASSERT(futureReturnType->toString() == "future<int32>", "Should be future<int32>");
}

TEST_CASE(sync_function_returns_raw_type) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    std::vector<Type*> paramTypes;
    
    // Create sync function: func() -> int32
    // Should stay as: func() -> int32 (no Future wrapping)
    FunctionType* syncFunc = typeSystem.getFunctionType(paramTypes, int32Type, false, false);
    
    ASSERT(syncFunc != nullptr, "Sync function type should not be null");
    ASSERT(!syncFunc->isAsyncFunction(), "Should not be marked as async");
    
    // Return type should be int32, not future<int32>
    Type* returnType = syncFunc->getReturnType();
    ASSERT(returnType == int32Type, "Return type should be int32");
    ASSERT(returnType->getKind() == TypeKind::PRIMITIVE, "Return type should be PRIMITIVE");
}

TEST_CASE(async_function_with_params_returns_future) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    Type* stringType = typeSystem.getPrimitiveType("string");
    std::vector<Type*> paramTypes = {int32Type, stringType};
    
    // Create: async func(int32, string) -> int32
    // Should become: func(int32, string) -> future<int32>
    FunctionType* asyncFunc = typeSystem.getFunctionType(paramTypes, int32Type, true, false);
    
    ASSERT(asyncFunc->isAsyncFunction(), "Should be async");
    ASSERT(asyncFunc->getParamCount() == 2, "Should have 2 parameters");
    ASSERT(asyncFunc->getParamTypes()[0] == int32Type, "First param should be int32");
    ASSERT(asyncFunc->getParamTypes()[1] == stringType, "Second param should be string");
    
    Type* returnType = asyncFunc->getReturnType();
    ASSERT(returnType->getKind() == TypeKind::FUTURE, "Return should be future");
    
    FutureType* futureType = static_cast<FutureType*>(returnType);
    ASSERT(futureType->getOutputType() == int32Type, "Future output should be int32");
}

