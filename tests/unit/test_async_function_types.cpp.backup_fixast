TEST_CASE(async_function_with_complex_return_types) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    Type* stringType = typeSystem.getPrimitiveType("string");
    PointerType* ptrString = typeSystem.getPointerType(stringType);
    ArrayType* arrayInt = typeSystem.getArrayType(int32Type, 10);
    ResultType* resultInt = typeSystem.getResultType(int32Type);
    
    std::vector<Type*> paramTypes;
    
    // Test: async func() -> string@
    // Should become: func() -> future<string@>
    FunctionType* asyncFunc1 = typeSystem.getFunctionType(paramTypes, ptrString, true, false);
    FutureType* future1 = static_cast<FutureType*>(asyncFunc1->getReturnType());
    ASSERT(future1->getOutputType() == ptrString, "Future should wrap pointer type");
    ASSERT(future1->toString() == "future<string@>", "Should be future<string@>");
    
    // Test: async func() -> int32[10]
    // Should become: func() -> future<int32[10]>
    FunctionType* asyncFunc2 = typeSystem.getFunctionType(paramTypes, arrayInt, true, false);
    FutureType* future2 = static_cast<FutureType*>(asyncFunc2->getReturnType());
    ASSERT(future2->getOutputType() == arrayInt, "Future should wrap array type");
    ASSERT(future2->toString() == "future<int32[10]>", "Should be future<int32[10]>");
    
    // Test: async func() -> result<int32>
    // Should become: func() -> future<result<int32>>
    FunctionType* asyncFunc3 = typeSystem.getFunctionType(paramTypes, resultInt, true, false);
    FutureType* future3 = static_cast<FutureType*>(asyncFunc3->getReturnType());
    ASSERT(future3->getOutputType() == resultInt, "Future should wrap result type");
    ASSERT(future3->toString() == "future<result<int32>>", "Should be future<result<int32>>");
}

TEST_CASE(async_function_no_double_wrapping) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    FutureType* futureInt = typeSystem.getFutureType(int32Type);
    std::vector<Type*> paramTypes;
    
    // User manually specifies: async func() -> future<int32>
    // Should NOT become: func() -> future<future<int32>>
    // The system wraps the declared return type, so this becomes future<future<int32>>
    // This is actually correct behavior - if user wants future<int32>, they write:
    // async func() -> int32 (NOT async func() -> future<int32>)
    
    FunctionType* asyncFunc = typeSystem.getFunctionType(paramTypes, futureInt, true, false);
    Type* returnType = asyncFunc->getReturnType();
    
    // The system DOES wrap it, creating future<future<int32>>
    // This is by design - async functions always return future<DeclaredType>
    ASSERT(returnType->getKind() == TypeKind::FUTURE, "Should be future");
    FutureType* outerFuture = static_cast<FutureType*>(returnType);
    ASSERT(outerFuture->getOutputType() == futureInt, "Should be future<future<int32>>");
    ASSERT(outerFuture->toString() == "future<future<int32>>", "Nested futures allowed");
}

TEST_CASE(async_vs_sync_function_equality) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    std::vector<Type*> paramTypes;
    
    FunctionType* syncFunc = typeSystem.getFunctionType(paramTypes, int32Type, false, false);
    FunctionType* asyncFunc = typeSystem.getFunctionType(paramTypes, int32Type, true, false);
    
    // async func() -> int32 creates func() -> future<int32>
    // sync func() -> int32 stays func() -> int32
    // These should NOT be equal (different return types + async flag)
    ASSERT(!syncFunc->equals(asyncFunc), "Sync and async functions should not be equal");
    ASSERT(!asyncFunc->equals(syncFunc), "Equality should be symmetric");
    
    // Verify return types differ
    ASSERT(syncFunc->getReturnType() != asyncFunc->getReturnType(), "Return types should differ");
    ASSERT(syncFunc->getReturnType() == int32Type, "Sync returns int32");
    ASSERT(asyncFunc->getReturnType()->getKind() == TypeKind::FUTURE, "Async returns future");
}

TEST_CASE(async_function_toString) {
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    Type* stringType = typeSystem.getPrimitiveType("string");
    std::vector<Type*> paramTypes = {int32Type, stringType};
    
    // async func(int32, string) -> int32
    FunctionType* asyncFunc = typeSystem.getFunctionType(paramTypes, int32Type, true, false);
    
    std::string funcStr = asyncFunc->toString();
    
    // Should contain "async" keyword
    ASSERT(funcStr.find("async") != std::string::npos, "toString should include 'async'");
    
    // Should show future<int32> as return type
    ASSERT(funcStr.find("future<int32>") != std::string::npos, "toString should show future<int32>");
}

