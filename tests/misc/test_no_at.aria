// Test SIMD reduction without @ prefix syntax

func:failsafe = int32(tbb32:err) { exit 1; };

func:test_reduction = int32(simd<int32, 4>:vec) {
    int32:result = simd_sum(vec);
    pass result;
};

func:test_broadcast_reduction = int32() {
    simd<int32, 4>:vec = simd_broadcast(5i32, 4);
    int32:sum = simd_sum(vec);
    pass sum;  // 20
};

func:main = int32() {
    exit 0;
};
