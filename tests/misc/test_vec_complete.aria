// Vec<T> Phase 2: Comprehensive Runtime Test
// Tests create, push, length, pop operations

// Extern declarations for runtime array functions
extern func:aria_array_new_simple = wild int8*(int64:element_size, int32:type_id);
extern func:aria_array_length = int64(wild int8*:arr);
extern func:aria_array_free = void(wild int8*:arr);
extern func:aria_array_push_simple = void(wild int8*:arr, wild int8*:val);
extern func:aria_array_pop_simple = void(wild int8*:arr, wild int8*:out_val);

func:main = int32() {
    // Test 1: Create array for int8 values
    wild int8->:vec = aria_array_new_simple(1i64, 1i32);  // element_size=1, type_id=1
    if (vec == NULL) {
        exit 1i32;  // FAIL: Array creation failed
    }
    
    int64:len = aria_array_length(vec);
    if (len != 0i64) {
        exit 2i32;  // FAIL: Initial length should be 0
    }
    
    // Test 2: Push values (using int8 to match wild int8* FFI signature)
    int8:val1 = 42i8;
    int8:val2 = 99i8;
    int8:val3 = 123i8;
    
    aria_array_push_simple(vec, @val1);
    len = aria_array_length(vec);
    if (len != 1i64) {
        exit 3i32;  // FAIL: Length should be 1 after push
    }
    
    aria_array_push_simple(vec, @val2);
    aria_array_push_simple(vec, @val3);
    len = aria_array_length(vec);
    if (len != 3i64) {
        exit 4i32;  // FAIL: Length should be 3 after 3 pushes
    }
    
    // Test 3: Pop values and verify
    int8:popped = 0i8;
    aria_array_pop_simple(vec, @popped);
    if (popped != 123i8) {
        exit 5i32;  // FAIL: Popped value should be 123
    }
    
    len = aria_array_length(vec);
    if (len != 2i64) {
        exit 6i32;  // FAIL: Length should be 2 after pop
    }
    
    // Test 4: Pop remaining values
    aria_array_pop_simple(vec, @popped);
    if (popped != 99i8) {
        exit 7i32;  // FAIL: Popped value should be 99
    }
    
    aria_array_pop_simple(vec, @popped);
    if (popped != 42i8) {
        exit 8i32;  // FAIL: Popped value should be 42
    }
    
    len = aria_array_length(vec);
    if (len != 0i64) {
        exit 9i32;  // FAIL: Length should be 0 after popping all
    }
    
    // Cleanup
    _ = aria_array_free(vec);
    
    exit 0;  // SUCCESS: All tests passed!
};

// Required failsafe function
func:failsafe = int32(tbb32:err) {
    exit 1;
};
