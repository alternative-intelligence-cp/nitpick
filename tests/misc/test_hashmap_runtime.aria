// HashMap<K,V> Complete Test - Phase 2: Runtime Integration
// Testing actual HashMap operations with runtime functions

// FFI declarations for HashMap runtime
extern func:aria_map_new_simple = wild int8*(int64:key_size, int64:value_size);
extern func:aria_map_insert_simple = void(wild int8*:map, wild int8*:key, wild int8*:value);
extern func:aria_map_get_simple = wild int8*(wild  int8*:map, wild int8*:key);
extern func:aria_map_length = int64(wild int8*:map);
extern func:aria_map_has = int32(wild int8*:map, wild int8*:key);
extern func:aria_map_free = void(wild int8*:map);

func:main = int32() {
    // Create HashMap<int8, int8> for simple test (1 byte key and value)
    wild int8->:map = aria_map_new_simple(1i64, 1i64);  // key= int8(1 byte), value=int8(1 byte)
    
    // Insert some key-value pairs
    int8:key1 = 1i8;
    int8:val1 = 95i8;
    aria_map_insert_simple(map, @key1, @val1);
    
    int8:key2 = 2i8;
    int8:val2 = 88i8;
    aria_map_insert_simple(map, @key2, @val2);
    
    int8:key3 = 3i8;
    int8:val3 = 92i8;
    aria_map_insert_simple(map, @key3, @val3);
    
    // Check length
    int64:length = aria_map_length(map);
    if (length != 3i64) {
        pass 1i32;  // FAIL: Should have 3 entries
    }
    
    // Check if keys exist
    if (aria_map_has(map, @key1) == 0i32) {
        pass 2i32;  // FAIL: key1 should exist
    }
    
    if (aria_map_has(map, @key2) == 0i32) {
        pass 3i32;  // FAIL: key2 should exist
    }
    
    // Clean up
    aria_map_free(map);
    
    exit 0;  // SUCCESS!
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};
