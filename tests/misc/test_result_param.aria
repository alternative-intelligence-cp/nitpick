// P1-4 Contract Type Checking - Success Test
// Test that 'result' as parameter name works correctly

func:result_as_param = int32(int32:result)
  requires result > 0
{
    pass result * 2;
};

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    Result<int32>:r =result_as_param(5);
    if (r.is_error) {
        exit -1;
    }
    exit r.value;
};
