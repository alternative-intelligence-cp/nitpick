// Comprehensive Type declaration test
// Tests all components: create, destroy, internal, interface, type, and methods

Type:Person = {
    // Constructor
    func:create = Person(string:name, int32:age) {
        Person:p = Person{id: 0i32, name: name, age: age};
        pass p;
    };
    
    // Destructor
    func:destroy = NIL(Person:self) {
        // Cleanup logic here
        pass NIL;
    };
    
    // Private members
    struct:internal = {
        int32:id;
    };
    
    // Public members
    struct:interface = {
        string:name;
        int32:age;
    };
    
    // Static members
    struct:type = {
        int32:nextId;
    };
    
    // Instance method
    func:greet = NIL(Person:self) {
        pass NIL;
    };
    
    // Another instance method
    func:birthday = NIL(Person:self) {
        pass NIL;
    };
};

func:main = int32() {
    exit 0;
};

func:failsafe = int32(tbb32:err) { exit 1; };
