// Comprehensive test demonstrating all three bug fixes:
// 1. Negative integer literals in struct fields (nit types)
// 2. Module import system (no double type-checking)
// 3. Wave9 9D coordinate system functionality

use stdlib.wave;

func:failsafe = NIL(int32:code) { pass(NIL); };

func:main = int32() {
    println("=== Bug Fix Verification Suite ===");
    println("");
    
    // Fix 1: Negative literals in struct fields
    println("1. Testing negative literals in struct fields:");
    Wave9:w_negative = Wave9 {
        r: -4, s: -3, t: -2,
        u: -1, v: 0, w: 1,
        x: 2, y: 3, z: 4
    };
    println("   ✓ Created Wave9 with negative coordinates");
    
    // Fix 2: Module imports (stdlib.wave loaded without errors)
    println("");
    println("2. Testing module import system:");
    Wave9:w_zero = raw(wave_zero());
    println("   ✓ Imported and called wave_zero() from stdlib.wave");
    
    // Fix 3: Wave9 core functionality
    println("");
    println("3. Testing Wave9 operations:");
    
    Wave9:w1 = Wave9 { r: 1, s: 0, t: -1, u: 2, v: -2, w: 0, x: 3, y: -3, z: 1 };
    Wave9:w2 = Wave9 { r: -1, s: 1, t: 0, u: -1, v: 1, w: 0, x: -2, y: 2, z: 0 };
    
    Wave9:interference = raw(wave_interfere(w1, w2));
    println("   ✓ Wave interference (superposition)");
    
    Wave9:negated = raw(wave_negate(w1));
    println("   ✓ Wave negation (phase inversion)");
    
    nit:scale_factor = 2;
    Wave9:scaled = raw(wave_scale(w1, scale_factor));
    println("   ✓ Wave scaling");
    
    int32:mag = raw(wave_magnitude_squared(w1));
    println("   ✓ Magnitude calculation");
    
    bool:eq = raw(wave_equals(w1, w1));
    println("   ✓ Equality testing");
    
    nit:x = 3;
    nit:y = -2;
    nit:z = 1;
    Wave9:spatial = raw(wave_from_spatial(x, y, z));
    println("   ✓ Spatial wave creation");
    
    nit:u = 2;
    nit:v = -1;
    nit:w = 0;
    Wave9:quantum = raw(wave_from_quantum(u, v, w));
    println("   ✓ Quantum wave creation");
    
    println("");
    println("=================================");
    println("ALL TESTS PASSED ✓");
    println("Wave9 system fully operational!");
    
    pass(0i32);
};
