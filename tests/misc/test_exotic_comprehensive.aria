// Comprehensive Test of Ternary/Nonary Operations
func:failsafe = int32(tbb32:err) { exit 1; };

func:test_trit_ops = int32() {
    println("Testing trit operations...");
    
    trit:a = 1;
    trit:b = -1;
    trit:c = 0;
    
    // Addition
    trit:sum = a + b;  // 1 + (-1) = 0
    
    // Multiplication
    trit:product = a * b;  // 1 * (-1) = -1
    
    // Negation
    trit:neg_a = -a;  // -(1) = -1
    
    println("  ✓ Trit operations work");
    pass 0i32;
};

func:test_tryte_ops = int32() {
    println("Testing tryte operations...");
    
    tryte:x = 100;
    tryte:y = 50;
    
    // Addition
    tryte:sum = x + y;  // 100 + 50 = 150
    
    // Subtraction
    tryte:diff = x - y;  // 100 - 50 = 50
    
    // Multiplication
    tryte:product = x * y;
    
    println("  ✓ Tryte operations work");
    pass 0i32;
};

func:test_nit_ops = int32() {
    println("Testing nit operations...");
    
    nit:a = 4;
    nit:b = -4;
    nit:c = 0;
    
    // Addition
    nit:sum = a + b;  // 4 + (-4) = 0
    
    // Multiplication
    nit:product = a * c;  // 4 * 0 = 0
    
    // Negation
    nit:neg_a = -a;  // -(4) = -4
    
    println("  ✓ Nit operations work");
    pass 0i32;
};

func:test_nyte_ops = int32() {
    println("Testing nyte operations...");
    
    nyte:x = 1000;
    nyte:y = 500;
    
    // Addition
    nyte:sum = x + y;
    
    // Subtraction
    nyte:diff = x - y;
    
    // Multiplication
    nyte:product = x * y;
    
    println("  ✓ Nyte operations work");
    pass 0i32;
};

func:main = int32() {
    println("========================================");
    println("EXOTIC TYPES COMPREHENSIVE TEST");
    println("========================================");
    println("");
    
    drop test_trit_ops();
    drop test_tryte_ops();
    drop test_nit_ops();
    drop test_nyte_ops();
    
    println("");
    println("========================================");
    println("ALL EXOTIC TYPE TESTS PASSED ✓");
    println("========================================");
    
    exit 0;
};
