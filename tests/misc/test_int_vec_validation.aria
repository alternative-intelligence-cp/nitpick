// Type:IntVec - Array Operations Test
// Validates get/set methods work correctly

// External memory functions
func:failsafe = int32(tbb32:err) { exit 1; };

extern func:malloc = wild int8*(int64:size);
extern func:free = NIL(wild int8*:ptr);
extern func:ptr_to_int64 = int64(wild int8*:ptr);
extern func:int64_to_ptr = wild int8*(int64:val);
extern func:int_array_get = int32(wild int8*:buf, int32:idx);
extern func:int_array_set = NIL(wild int8*:buf, int32:idx, int32:val);

Type:IntVec = {

    func:create = IntVec(int32:initial_capacity) {
        int64:bytes = 64i64;  // 16 int32s = 64 bytes
        wild int8->:buffer = malloc(bytes);
        IntVec:vec = IntVec{
            dataptr: ptr_to_int64(buffer),
            length: 0i32,
            capacity: initial_capacity
        };
        pass vec;
    };
    
    func:destroy = NIL(IntVec:self) {
        _ = free(int64_to_ptr(self.dataptr));
        pass NIL;
    };
    
    func:get = int32(IntVec:self, int32:index) {
        wild int8->:buffer = int64_to_ptr(self.dataptr);
        int32:element = int_array_get(buffer, index);
        pass element;
    };
    
    func:set = NIL(IntVec:self, int32:index, int32:value) {
        wild int8->:buffer = int64_to_ptr(self.dataptr);
        _ = int_array_set(buffer, index, value);
        pass NIL;
    };
    
    struct:interface = {
        int64:dataptr;
        int32:length;
        int32:capacity;
    };
};

func:main = int32() {
    // Create vector
    IntVec:vec = raw instance<IntVec>(10i32);
    
    // Write test values
    _ = vec.set(0i32, 42i32);
    _ = vec.set(1i32, 100i32);
    _ = vec.set(2i32, 255i32);
    _ = vec.set(3i32, 1000i32);
    
    // Read back and verify
    int32:val0 = raw vec.get(0i32);    // Should be 42
    int32:val1 = raw vec.get(1i32);    // Should be 100
    int32:val2 = raw vec.get(2i32);    // Should be 255
    int32:val3 = raw vec.get(3i32);    // Should be 1000
    
    // Verification logic (42 + 100 + 255 + 1000 = 1397)
    int32:sum = val0 + val1 + val2 + val3;
    int32:expected = 1397i32;
    
    // Check if correct
    bool:success = (sum == expected);
    
    // Clean up
    _ = vec.destroy();
    
    // Return 0 for success, 1 for failure
    int32:result = 0i32;
    pass result;
};
