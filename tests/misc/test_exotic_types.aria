// Quick test of ternary/nonary types
func:failsafe = int32(tbb32:err) { exit(1); };

func:main = int32() {
    // Trit: Single balanced ternary digit (-1, 0, 1)
    trit:zero = 0;
    trit:positive = 1;
    trit:negative = -1;
    
    // Tryte: 10 trits packed in uint16
    tryte:data = 0;
    
    // Nit: Single nonary digit (-4 to 4)
    nit:n_zero = 0;
    nit:n_positive = 4;
    nit:n_negative = -4;
    
    // Nyte: 5 nits packed in uint16
    nyte:n_data = 0;
    
    exit(0);
};
