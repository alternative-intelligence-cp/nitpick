/**
 * Test: Simplified P2.7 - Array literal parsing
 * Goal: Check if array literals parse at all
 */

func:failsafe = NIL(int32:code) { pass(NIL); };

struct:Point = {
    int32:x;
    int32:y;
};

func:main = int32() {
    // Test 1: Simple array literal (should work)
    int32[3]:nums = [10, 20, 30];
    drop(println("✅ Array literal created"));
    
    // Test 2: Array literal with object literals  
    Point[2]:points = [{x: 1, y: 2}, {x: 3, y: 4}];
    drop(println("✅ Object literal array created"));
    
    pass(0i32);
};
