// Simple test to verify Numeric trait system works

use "stdlib/traits/numeric.aria".*;
use "stdlib/traits/numeric_impls.aria".*;

// Test function using Numeric constraint
pub func<T: Numeric>:add_two = *T(*T:a, *T:b) {
    *T:result = a + b;
    pass(result);
};

// Entry point
pub func:main = int32() {
    int64:x = 5;
    int64:y = 10;
    int64:sum = raw(add_two(x, y));
    pass(0);
};

pub func:failsafe = NIL(int32:code) {
    pass(NIL);
};
