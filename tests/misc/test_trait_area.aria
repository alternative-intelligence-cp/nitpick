// Trait impl on a struct type with UFCS

trait:HasArea = {
    func:area = int32(int32:self_x, int32:self_y);
};

// Implement for int32 (since struct UFCS needs more infrastructure)
impl:HasArea:for:int32 = {
    func:area = int32(int32:self_x, int32:self_y) {
        pass(self_x * self_y);
    };
};

pub func:main = int32() {
    int32:width = 6;
    int32:height = 7;
    int32:result = raw(int32_area(width, height));
    pass(result);
};

func:failsafe = int32(tbb32:err) { exit(1); };
