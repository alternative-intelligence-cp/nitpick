// Test: HashMap<int32, int64> library wrapper
// Tests all operations: new, insert, get, has, remove, length, clear, free

use "stdlib/lib_hashmap_int32_int64.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

pub func:main = int32() {
    // TEST 1: Create new HashMap
    HashMap<int32, int64>:scores = raw HashMap_int32_int64_new();

    // Verify initial state
    if (scores.capacity != 16i64) { exit 1i32; }
    if (scores.length != 0i64) { exit 2i32; }
    if (scores.key_size != 4i64) { exit 3i32; }
    if (scores.value_size != 8i64) { exit 4i32; }

    // TEST 2: Insert student scores
    raw HashMap_int32_int64_insert(scores.entries, 1001i32, 95i64);
    raw HashMap_int32_int64_insert(scores.entries, 1002i32, 88i64);
    raw HashMap_int32_int64_insert(scores.entries, 1003i32, 92i64);

    // Sync length from runtime
    scores.length = raw HashMap_int32_int64_length(scores.entries);
    if (scores.length != 3i64) { exit 5i32; }

    // TEST 3: Check existence (has)
    if (raw HashMap_int32_int64_has(scores.entries, 1001i32) != 1i32) { exit 6i32; }
    if (raw HashMap_int32_int64_has(scores.entries, 1002i32) != 1i32) { exit 7i32; }
    if (raw HashMap_int32_int64_has(scores.entries, 1003i32) != 1i32) { exit 8i32; }
    if (raw HashMap_int32_int64_has(scores.entries, 9999i32) != 0i32) { exit 9i32; }

    // TEST 4: Get values
    int64:score1 = 0i64;
    int64:score2 = 0i64;
    int64:score3 = 0i64;
    int64:score_missing = 0i64;

    if (raw HashMap_int32_int64_get(scores.entries, 1001i32, @score1) != 1i32) { exit 10i32; }
    if (score1 != 95i64) { exit 11i32; }

    if (raw HashMap_int32_int64_get(scores.entries, 1002i32, @score2) != 1i32) { exit 12i32; }
    if (score2 != 88i64) { exit 13i32; }

    if (raw HashMap_int32_int64_get(scores.entries, 1003i32, @score3) != 1i32) { exit 14i32; }
    if (score3 != 92i64) { exit 15i32; }

    if (raw HashMap_int32_int64_get(scores.entries, 9999i32, @score_missing) != 0i32) { exit 16i32; }

    // TEST 5: Update existing value
    raw HashMap_int32_int64_insert(scores.entries, 1001i32, 98i64);

    int64:updated_score = 0i64;
    if (raw HashMap_int32_int64_get(scores.entries, 1001i32, @updated_score) != 1i32) { exit 17i32; }
    if (updated_score != 98i64) { exit 18i32; }

    scores.length = raw HashMap_int32_int64_length(scores.entries);
    if (scores.length != 3i64) { exit 19i32; }

    // TEST 6: Remove entry
    if (raw HashMap_int32_int64_remove(scores.entries, 1002i32) != 1i32) { exit 20i32; }

    scores.length = raw HashMap_int32_int64_length(scores.entries);
    if (scores.length != 2i64) { exit 21i32; }
    if (raw HashMap_int32_int64_has(scores.entries, 1002i32) != 0i32) { exit 22i32; }

    if (raw HashMap_int32_int64_remove(scores.entries, 9999i32) != 0i32) { exit 23i32; }

    // TEST 7: Length function
    int64:current_length = raw HashMap_int32_int64_length(scores.entries);
    if (current_length != 2i64) { exit 24i32; }

    // TEST 8: Clear map
    raw HashMap_int32_int64_clear(scores.entries);
    scores.length = raw HashMap_int32_int64_length(scores.entries);

    if (scores.length != 0i64) { exit 25i32; }
    if (raw HashMap_int32_int64_has(scores.entries, 1001i32) != 0i32) { exit 26i32; }

    // TEST 9: Insert after clear
    raw HashMap_int32_int64_insert(scores.entries, 2001i32, 100i64);
    scores.length = raw HashMap_int32_int64_length(scores.entries);

    if (scores.length != 1i64) { exit 27i32; }

    int64:new_score = 0i64;
    if (raw HashMap_int32_int64_get(scores.entries, 2001i32, @new_score) != 1i32) { exit 28i32; }
    if (new_score != 100i64) { exit 29i32; }

    // TEST 10: Cleanup
    raw HashMap_int32_int64_free(scores.entries);

    exit 0;
};
