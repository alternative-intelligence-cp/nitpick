// Test: Simple pointer dereference with <- operator
// This should work according to specs and compiler code

func:failsafe = int32(tbb32:err) { exit(1); };

func:main = int32() {
    // Create a value
    int64:value = 42i64;
    
    // Get pointer to it
    int64->:ptr = @value;
    
    // TEST 1: Try to dereference and read (THIS IS THE ISSUE)
    int64:retrieved = <-ptr;
    
    // Verify
    if (retrieved != 42i64) {
        pass(1i32);  // FAIL
    }
    
    // TEST 2: Try to write through dereference
    <-ptr = 99i64;
    
    // Verify write worked
    if (value != 99i64) {
        pass(2i32);  // FAIL
    }
    
    exit(0);  // SUCCESS
};
