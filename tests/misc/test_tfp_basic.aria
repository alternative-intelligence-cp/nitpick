// Test TFP (Twisted Floating Point) implementation

func:main = int32() {
    // Create tfp32 from parts (exp, mant)
    tfp32:half = tfp32_from_parts(0i16, 16384i16);  // 0.5
    tfp32:one = tfp32_from_parts(0i16, 32767i16);   // ~1.0
    
    // Basic arithmetic
    tfp32:sum = tfp32_add(half, half);     // 0.5 + 0.5 = 1.0
   tfp32:product = tfp32_mul(half, one);   // 0.5 * 1.0 = 0.5
    tfp32:quotient = tfp32_div(one, half);  // 1.0 / 0.5 = 2.0
    
    // Negation
    tfp32:neg_half = tfp32_neg(half);  // -0.5
    
    // Comparison
    int32:cmp = tfp32_cmp(half, one);  // 0.5 < 1.0  -> -1
    
    return 0i32;
};

func:failsafe = NIL(int32:err_code) {};
