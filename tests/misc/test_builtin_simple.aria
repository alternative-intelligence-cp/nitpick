// Test SIMD builtins: reduction and broadcast

func:failsafe = NIL(int32:err_code) {};

// Test SIMD reduction with simd_sum
func:test_reduction = int32(simd<int32, 4>:vec) {
    int32:sum = simd_sum(vec);
    pass(sum);
};

// Test SIMD broadcast and arithmetic
func:test_broadcast_and_sum = int32() {
    simd<int32, 4>:vec = simd_broadcast(10i32, 4);
    int32:total = simd_sum(vec);
    pass(total);
};

// Test SIMD product reduction
func:test_product = int32(simd<int32, 4>:vec) {
    int32:product = simd_product(vec);
    pass(product);
};

func:main = int32() {
    pass(0i32);
};
