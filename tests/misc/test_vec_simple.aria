// Test Vec<T> Phase 3 - Using library functions
// This tests the critical struct field mutation capability

// Import library (inline for now)
extern func:aria_array_new_simple = wild int8*(int64:element_size, int32:type_id);
extern func:aria_array_push_simple = void(wild int8*:arr, wild int8*:val);
extern func:aria_array_length = int64(wild int8*:arr);
extern func:aria_array_free = void(wild int8*:arr);

func:main = int32() {
    // Create Vec directly using runtime
    wild int8->:data = aria_array_new_simple(1i64, 0i32);
    int64:length = 0i64;
    
    // Push 3 values
    int8:v1 = 42i8;
    aria_array_push_simple(data, @v1);
    
    int8:v2 = 99i8;
    aria_array_push_simple(data, @v2);
    
    int8:v3 = 7i8;
    aria_array_push_simple(data, @v3);
    
    // THIS IS THE CRITICAL TEST: Can we update a variable from a function call?
    length = aria_array_length(data);
    
    if (length != 3i64) {
        pass(1i32);  // FAIL
    }
    
    aria_array_free(data);
    pass(0i32);  // SUCCESS
};

func:failsafe = int32(int32:err_code) {
    pass(err_code);
};
