/// Test basic write output

func:failsafe = int32(tbb32:err) { exit 1; };

pub func:test_write = NIL() {
    // Test 1: Write a single character using stdout_write
    drop stdout_write("A");
    
    // Test 2: Write a word
    drop stdout_write("Hello");
};

func:main = int32() {
    raw test_write();
    exit 0;
};
