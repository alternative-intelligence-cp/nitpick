// Test if nit struct literals work with integer values

struct:Point9 = {
    nit:x;
    nit:y;
};

func:failsafe = int32(tbb32:err) { exit(1); };

func:main = int32() {
    println("Testing nit struct literals...");
    
    // This should work: all values fit in nit range [-4, 4]
    Point9:p = Point9 { x: 0, y: -2 };
    
    println("Success!");
    exit(0);
};
