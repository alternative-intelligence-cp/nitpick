// Test: Numeric trait constraint without imports  
// Define a minimal trait inline to test constraint syntax

pub func<T: Numeric>:test_add = *T(*T:a, *T:b) {
    *T:result = a + b;
    pass(result);
};

pub func:main = int32() {
    pass(0);
};

pub func:failsafe = NIL(int32:code) {
    // Void function - no return value needed
};
