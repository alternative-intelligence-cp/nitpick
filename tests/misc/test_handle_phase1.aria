// P1-3 Phase 1 Test: Handle<T> Type System
// Test that Handle<T> type is recognized and parsed correctly

struct:Neuron = {
    int64:id;
    fix256:value;
};

func:main = int32() {
    // Test Handle<T> type annotations compile
    Handle<Neuron>:neuron_handle;
    Handle<int64>:number_handle;
    Handle<fix256>:fixed_handle;
    
    print("✅ Handle<T> type system works!");
    return 0;
};

func:failsafe = int32(int32:err_code) {
    pass(1);
};
