// Minimal test - just one get operation

func:failsafe = int32(tbb32:err) { exit 1; };

func:failsafe = int32(tbb32:err) { exit 1; };

extern func:malloc = wild int8*(int64:size);
extern func:ptr_to_int64 = int64(wild int8*:ptr);
extern func:int64_to_ptr = wild int8*(int64:val);
extern func:int_array_set = void(wild int8*:buf, int32:idx, int32:val);
extern func:int_array_get = int32(wild int8*:buf, int32:idx);

Type:IntVec = {

func:failsafe = int32(tbb32:err) { exit 1; };
    func:new = IntVec() {
        wild int8->:buffer = malloc(40i64);
        int64:ptr_as_int = ptr_to_int64(buffer);
        IntVec:result = IntVec{dataptr: ptr_as_int, length: 0i32, capacity: 10i32};
        pass result;
    };
    
    func:push = IntVec(IntVec:self, int32:value) {
        wild int8->:buffer = int64_to_ptr(self.dataptr);
        _ = int_array_set(buffer, self.length, value);
        int32:new_length = self.length + 1i32;
        IntVec:result = IntVec{
            dataptr: self.dataptr,
            length: new_length,
            capacity: self.capacity
        };
        pass result;
    };
    
    func:get = int32(IntVec:self, int32:index) {
        wild int8->:buffer = int64_to_ptr(self.dataptr);
        int32:val = int_array_get(buffer, index);
        pass val;
    };
    
    struct:interface = {
        int64:dataptr;
        int32:length;
        int32:capacity;
    };
};

func:main = int32() {
    // Create vector
    IntVec:empty = IntVec{dataptr: 0i64, length: 0i32, capacity: 0i32};
    IntVec:vec = IntVec.new() ? empty;
    
    // Push ONE value
    vec = vec.push(42i32) ? vec;
    
    // Get it back
    int32:value = vec.get(0i32) ? 999i32;  // Default to 999 if it fails
    
    // Should return 42 if everything works
    pass value;
};
