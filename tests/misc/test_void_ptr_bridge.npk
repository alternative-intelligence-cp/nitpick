// Test void* ↔ wild T-> conversion bridge (P1.5)

extern "libc" {
    func:malloc = void*(int64:size);
    func:free = NIL(void*:ptr);
}

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    // Test: Try direct assignment - does void* → wild-> work?
    wild int32->:ptr1 = malloc(400i64);
    
    if (ptr1 == NULL) {
        exit -1;
    }
    
    // Cleanup (should auto-convert wild int32-> → void*)
    free(ptr1);
    
    exit 0;
};
