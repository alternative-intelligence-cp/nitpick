// Absolutely minimal test of unwrap operator


func:failsafe = NIL(int32:err_code) { pass(NIL); };
func:get_number = int32(int32:val) {
    pass(val);
};

func:main = int32() {
    // Test unwrap with explicit default
    int32:x = 42i32;
    int32:result = get_number(x) ? 0i32;
    
    // Should return 42 if unwrap works
    pass(result);
};
