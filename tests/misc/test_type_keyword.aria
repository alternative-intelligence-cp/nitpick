// Test Type keyword lexing
// Should recognize "Type" as TOKEN_KW_TYPE

Type:Counter = {
    func:create = Counter(int32:initial) {
        Counter:c = Counter{count: initial};
        pass(c);
    };
    
    struct:interface = {
        int32:count;
    };
};

func:main = int32() {
    pass(0);
};

func:failsafe = NIL(int32:err_code) { pass(NIL); };
