// Test: Comprehensive global array declarations
// Tests multiple array types at global scope

func:failsafe = NIL(int32:code) { pass(NIL); };

struct:Point = {
    int32:x;
    int32:y;
};

// Global arrays of different types
int32[10]:global_numbers;
Point[5]:global_points;

// Global primitives for comparison
int32:counter;

func:main = int32() {
    // Test: int32 array
    global_numbers[0] = 42i32;
    global_numbers[1] = 99i32;
    global_numbers[9] = 123i32;
    
    // Test: struct array
    global_points[0].x = 10i32;
    global_points[0].y = 20i32;
    
    global_points[4].x = 50i32;
    global_points[4].y = 60i32;
    
    // Test: regular global
    counter = 777i32;
    
    pass(0i32);
};
