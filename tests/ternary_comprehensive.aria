// Comprehensive test for balanced ternary types (Session 15)
// Tests trit/tryte/nit/nyte arithmetic with range clamping

func:main = int64() {
    // ========================================================================
    // Trit tests: Single balanced ternary digit (-1, 0, 1)
    // ========================================================================
    
    trit:t1 = 0;
    trit:t2 = 1;
    trit:t3 = -1;
    
    // Test basic values
    if (t1 == 0) {
        // pass: trit zero works
    } else {
        pass(1);  // fail
    }
    
    if (t2 == 1) {
        // pass: trit positive works
    } else {
        pass(2);  // fail
    }
    
    if (t3 == -1) {
        // pass: trit negative works
    } else {
        pass(3);  // fail
    }
    
    // Test trit addition with clamping
    trit:t_add = 1;
    trit:t_one = 1;
    trit:t_sum = t_add + t_one;  // 1 + 1 = 1 (clamped to max)
    
    if (t_sum == 1) {
        // pass: trit addition clamping works
    } else {
        pass(4);  // fail
    }
    
    // Test trit subtraction with clamping
    trit:t_neg = -1;
    trit:t_neg_one = -1;
    trit:t_diff = t_neg - t_one;  // -1 - 1 = -1 (clamped to min)
    
    if (t_diff == -1) {
        // pass: trit subtraction clamping works
    } else {
        pass(5);  // fail
    }
    
    // ========================================================================
    // Nit tests: Single nonary digit (-4 to 4)
    // ========================================================================
    
    nit:n1 = 0;
    nit:n2 = 4;
    nit:n3 = -4;
    
    // Test basic values
    if (n1 == 0) {
        // pass: nit zero works
    } else {
        pass(6);  // fail
    }
    
    if (n2 == 4) {
        // pass: nit max works
    } else {
        pass(7);  // fail
    }
    
    if (n3 == -4) {
        // pass: nit min works
    } else {
        pass(8);  // fail
    }
    
    // Test nit addition with clamping
    nit:n_add = 4;
    nit:n_one = 1;
    nit:n_sum = n_add + n_one;  // 4 + 1 = 4 (clamped to max)
    
    if (n_sum == 4) {
        // pass: nit addition clamping works
    } else {
        pass(9);  // fail
    }
    
    // Test nit subtraction with clamping
    nit:n_neg = -4;
    nit:n_diff = n_neg - n_one;  // -4 - 1 = -4 (clamped to min)
    
    if (n_diff == -4) {
        // pass: nit subtraction clamping works
    } else {
        pass(10);  // fail
    }
    
    // Test nit multiplication with clamping
    nit:n_two = 2;
    nit:n_three = 3;
    nit:n_prod = n_two * n_three;  // 2 * 3 = 4 (clamped, would be 6)
    
    if (n_prod == 4) {
        // pass: nit multiplication clamping works
    } else {
        pass(11);  // fail
    }
    
    // ========================================================================
    // All tests passed!
    // ========================================================================
    
    pass(42);  // Success!
};
