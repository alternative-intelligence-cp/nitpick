// Test that uint1/uint2/uint4 tokens are properly recognized
func:main = int32() {
    // Test uint1 (single bit - 0 or 1)
    uint1:flag;
    
    // Test uint2 (2-bit unsigned - 0 to 3)
    uint2:crumb;
    
    // Test uint4 (nibble - 0 to 15)
    uint4:nibble;
    
    // Test uint8 (byte - 0 to 255) - already existed
    uint8:byte_val;
    
    int32:zero = 0;
    pass zero;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
