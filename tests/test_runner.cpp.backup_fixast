#include "test_helpers.h"
#include <iostream>

// Global test statistics
TestStats g_test_stats;

// Global test case registry
std::vector<TestCase> g_test_cases;

void run_all_tests() {
    std::cout << COLOR_GREEN << "========================================" << COLOR_RESET << std::endl;
    std::cout << COLOR_GREEN << "Running Aria Compiler Test Suite" << COLOR_RESET << std::endl;
    std::cout << COLOR_GREEN << "========================================" << COLOR_RESET << std::endl;
    std::cout << std::endl;
    
    for (const auto& test : g_test_cases) {
        std::cout << COLOR_YELLOW << "Running: " << test.name << COLOR_RESET << std::endl;
        
        // Reset stats for this test
        int before_total = g_test_stats.total;
        int before_passed = g_test_stats.passed;
        
        try {
            test.func();
            
            int test_passed = g_test_stats.passed - before_passed;
            int test_total = g_test_stats.total - before_total;
            
            if (test_total == test_passed) {
                std::cout << COLOR_GREEN << "✓ PASSED: " << test.name 
                         << " (" << test_total << " assertions)" << COLOR_RESET << std::endl;
            } else {
                std::cout << COLOR_RED << "✗ FAILED: " << test.name << COLOR_RESET << std::endl;
            }
        } catch (const std::exception& e) {
            std::cout << COLOR_RED << "✗ EXCEPTION in " << test.name 
                     << ": " << e.what() << COLOR_RESET << std::endl;
            g_test_stats.failed++;
        } catch (...) {
            std::cout << COLOR_RED << "✗ UNKNOWN EXCEPTION in " << test.name << COLOR_RESET << std::endl;
            g_test_stats.failed++;
        }
        
        std::cout << std::endl;
    }
}

void print_test_summary() {
    std::cout << COLOR_GREEN << "========================================" << COLOR_RESET << std::endl;
    std::cout << COLOR_GREEN << "Test Summary" << COLOR_RESET << std::endl;
    std::cout << COLOR_GREEN << "========================================" << COLOR_RESET << std::endl;
    std::cout << "Total tests:      " << g_test_cases.size() << std::endl;
    std::cout << "Total assertions: " << g_test_stats.total << std::endl;
    std::cout << COLOR_GREEN << "Passed:           " << g_test_stats.passed << COLOR_RESET << std::endl;
    std::cout << COLOR_RED << "Failed:           " << g_test_stats.failed << COLOR_RESET << std::endl;
    
    if (!g_test_stats.failures.empty()) {
        std::cout << std::endl;
        std::cout << COLOR_RED << "Failures:" << COLOR_RESET << std::endl;
        for (const auto& failure : g_test_stats.failures) {
            std::cout << COLOR_RED << "  " << failure << COLOR_RESET << std::endl;
        }
    }
    
    std::cout << COLOR_GREEN << "========================================" << COLOR_RESET << std::endl;
    
    if (g_test_stats.failed == 0) {
        std::cout << COLOR_GREEN << "✓ All tests passed!" << COLOR_RESET << std::endl;
    } else {
        std::cout << COLOR_RED << "✗ Some tests failed" << COLOR_RESET << std::endl;
    }
}

int main() {
    run_all_tests();
    print_test_summary();
    
    // Return non-zero exit code if tests failed
    return g_test_stats.failed > 0 ? 1 : 0;
}
