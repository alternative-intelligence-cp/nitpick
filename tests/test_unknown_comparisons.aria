// Test Phase 5.5: Three-valued logic for comparisons
// Comparisons with unknown should propagate unknown (except self-comparison)

func:main = int32() {
    int32:x = unknown;
    
    // Test special case: unknown == unknown → TRUE (identity check)
    // Should return exit code 3 if working correctly
    pick(unknown == unknown) {
        (true) {
            pass(3i32);  // Should match here - CORRECT
        },
        (false) {
            pass(1i32);  // Wrong
        },
        (unknown) {
            pass(2i32);  // Wrong
        }
    }
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
