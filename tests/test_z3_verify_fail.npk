// Expected: Z3 reports DISPROVEN for value -5 against $ > 0
// test_z3_verify_fail.aria — v0.2.45 Z3 should detect this violation
// Compile with: ariac test_z3_verify_fail.aria --verify

extern func:puts = int32(string:s);

Rules:r_positive = {
    $ > 0
};

func:failsafe = int32(tbb32:err) {
    drop puts("FAILSAFE");
    exit 1;
};

func:main = int32() {
    // This should be flagged by both compile-time check AND Z3
    limit<r_positive> int32:x = -5;
    return 0i32;
};
