// Test Phase 3.2.5 - Literal Parsing
// Test that high-precision numeric literals are stored correctly

// High-precision float - should store raw string
flt128:pi = 3.141592653589793238462643383279502884197;

// Large integer beyond int64 - should store raw string  
int128:big = 9223372036854775808i128;  // 2^63 (exceeds int64)

// Normal float - still works
flt64:normal_float = 3.14;

// Normal int - still works
int32:normal_int = 42;

func:main = int32() {
    pass(0);
};
