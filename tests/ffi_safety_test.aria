// ARIA-026 FFI Safety Tests
// Testing critical security fixes from Gemini audits 13-15

// Integer to string conversion for int64
func:int64_toString = string(int64:value) {
    if (value == 0) { pass("0"); }
    bool:is_negative = false;
    int64:work_value = value;
    if (value < 0) { is_negative = true; work_value = -value; }
    string:result = "";
    int64:remaining = work_value;
    while (remaining > 0) {
        int64:digit = remaining % 10;
        remaining = remaining / 10;
        string:digit_char = "";
        if (digit == 0) { digit_char = "0"; }
        if (digit == 1) { digit_char = "1"; }
        if (digit == 2) { digit_char = "2"; }
        if (digit == 3) { digit_char = "3"; }
        if (digit == 4) { digit_char = "4"; }
        if (digit == 5) { digit_char = "5"; }
        if (digit == 6) { digit_char = "6"; }
        if (digit == 7) { digit_char = "7"; }
        if (digit == 8) { digit_char = "8"; }
        if (digit == 9) { digit_char = "9"; }
        result = string_concat(digit_char, result);
    }
    if (is_negative) { result = string_concat("-", result); }
    pass(result);
};

// int32_toString: Cast to int64 to avoid compiler int32 modulo bug
func:int32_toString = string(int32:value) {
    int64:value64 = value;
    string:result = raw(int64_toString(value64));
    pass(result);

};

// Test 1: String parameters in extern should be REJECTED
// This should fail to compile with FFI Safety Violation error
/*
extern "test" {
    pub func:bad_ffi_string = void(str:message);
}
*/

// Test 2: Correct FFI string usage (wild int8*)
extern "test" {
    pub func:good_ffi_string = void(wild int8*:message);
}

// Test 3: String return type should be REJECTED
