/// Regression test: pointer member store-through via ptr->field.
/// Expected process exit: 37

struct:Point = {
    int32:x;
    int32:y;
};

func:main = int32() {
    stack Point:p = Point{x: 10, y: 20};
    stack Point->:ptr = @p;
    ptr->x = 37;
    exit p.x;
};

func:failsafe = int32(tbb32:err) {
    exit 99;
};
