/// Test arrow operator for struct member access through pointer

struct:Point = {
    int32:x;
    int32:y;
};

func:main = int32() {
    // Create a Point with initialization
    stack Point:p;
    stack int32:init_x = 10;
    stack int32:init_y = 20;
    p.x = init_x;
    p.y = init_y;
    
    // Get pointer to it
    wild Point->ptr = @p;
    
    // Access members through pointer with ->
    int32:x_val = ptr->x;
    int32:y_val = ptr->y;
    
    // Modify through pointer
    ptr->x = 100;
    ptr->y = 200;
    
    // Verify changes
    int32:new_x = p.x;  // Should be 100
    int32:new_y = p.y;  // Should be 200
    
    pass(0);
};
