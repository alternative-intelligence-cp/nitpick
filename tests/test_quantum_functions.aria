/**
 * Test generic helper functions from stdlib.quantum
 */

use stdlib.quantum;

func:failsafe = int32(tbb32:err) {
    exit(1);
};

func:main = int32() {
    // Test calling a generic function from the module
    // Note: Due to type inference limitations, we may need explicit types
    
    // Create using struct literals (known working)
    trit:c_zero = 0;
    Q3<int32>:q1 = {a: 10, b: 20, c: c_zero};
    
    // Try manual "add" operation
    Q3<int32>:q2 = {a: 5, b: 8, c: c_zero};
    
    // Manual field addition (without helper functions for now)
    int32:sum_a = q1.a + q2.a;
    int32:sum_b = q1.b + q2.b;
    
    if (sum_a == 15 && sum_b == 28) {
        drop(println("✅ Q3 arithmetic working (manually)"));
        exit(0);
    }
    
    drop(println("❌ Arithmetic failed"));
    pass(1);
};
