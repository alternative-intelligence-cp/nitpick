// Test basic flt128 operations
// Part of Phase 3.2: Extended Precision Floats
// NOTE: Float literal casting needs work - using flt64 literals for now

func:main = int32() {
    // Test flt128 variables (literals default to flt64, auto-promoted)
    flt64:temp_a = 1.5;
    flt64:temp_b = 2.5;
    
    // This will test if type system registered flt128
    // (Actual flt128 literals need lexer/codegen work)
    flt128:a = temp_a;  // Should promote flt64 to flt128
    flt128:b = temp_b;

    // Test that flt128 type exists and compiles
    int32:zero = 0;
    pass(zero);
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
