// Test int2048 with arithmetic
// ARIA-025: int2048 for RSA-2048 cryptography
func:main = int32() {
    int2048:a = 1000000;
    int2048:b = 2000000;
    int2048:sum = a + b;
    int2048:expected = 3000000;
    
    bool:correct = (sum == expected);
    
    if (correct) {
        return 0;
    }
    return 1;
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
