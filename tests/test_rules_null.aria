// test_rules_null.aria — v0.2.44 Rules with $ != NULL / $ != NIL
extern func:puts = int32(string:s);

// Rules that value must not be NIL (zero for integers)
Rules<int32>:not_nil = {
    $ != NIL
};

// Rules that value must not be zero (equivalent using numeric comparison)
Rules<int64>:not_zero = {
    $ != 0
};

// Combine NIL check with range
Rules<int32>:valid_positive = {
    $ != NIL,
    $ > 0,
    $ < 1000
};

func:failsafe = int32(tbb32:err) {
    drop(puts("FAILSAFE: null/nil rule violation!"));
    exit(1);
};

func:main = int32() {
    int32:passed = 0i32;
    int32:failed = 0i32;

    // ----------------------------------------------------------
    // Test 1: Rules<int32> $ != NIL with non-zero value
    // ----------------------------------------------------------
    limit<not_nil> int32:a = 42;
    if (a == 42) {
        drop(puts("PASS: Test 1 — Rules $ != NIL with non-zero int32"));
        passed += 1i32;
    } else {
        drop(puts("FAIL: Test 1"));
        failed += 1i32;
    }

    // ----------------------------------------------------------
    // Test 2: Rules<int64> $ != 0 with non-zero value
    // ----------------------------------------------------------
    limit<not_zero> int64:b = 100;
    if (b == 100) {
        drop(puts("PASS: Test 2 — Rules $ != 0 with non-zero int64"));
        passed += 1i32;
    } else {
        drop(puts("FAIL: Test 2"));
        failed += 1i32;
    }

    // ----------------------------------------------------------
    // Test 3: Combined NIL check + range
    // ----------------------------------------------------------
    limit<valid_positive> int32:c = 500;
    if (c == 500) {
        drop(puts("PASS: Test 3 — Rules $ != NIL + range"));
        passed += 1i32;
    } else {
        drop(puts("FAIL: Test 3"));
        failed += 1i32;
    }

    // ----------------------------------------------------------
    // Results
    // ----------------------------------------------------------
    if (failed > 0i32) {
        drop(puts("SOME TESTS FAILED"));
        pass(1);
    }
    drop(puts("All null/nil rules tests passed!"));
    exit(0);
};
