// Test: @sizeof operator — advanced and exotic types
// Verifies @sizeof with unsigned, exotic, and wide numeric types

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    // Unsigned integer sizes
    int64:s_u8  = @sizeof(uint8);
    int64:s_u16 = @sizeof(uint16);
    int64:s_u32 = @sizeof(uint32);
    int64:s_u64 = @sizeof(uint64);

    // Exotic numeric types
    int64:s_trit = @sizeof(trit);
    int64:s_nit  = @sizeof(nit);

    // Wide integers
    int64:s_i128 = @sizeof(int128);

    exit 0;
};
