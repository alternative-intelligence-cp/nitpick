// test_rules_compile_error.aria — v0.2.41 Compile-time limit violation
// Expected: compiler error — value 100 violates $ < 100

extern func:puts = int32(string:s);

Rules:r_lt_100 = {
    $ < 100
};

func:failsafe = int32(tbb32:err) {
    drop(puts("FAILSAFE"));
    exit(1);
};

func:main = int32() {
    limit<r_lt_100> int32:x = 100;
    exit(0);
};
