// Basic range-based for loop test
// Testing for (i in range) syntax

// Inline int64_toString for explicit conversion
func:int64_toString = string(int64:value) {
    if (value == 0) { pass("0"); }
    bool:is_negative = false;
    int64:work_value = value;
    if (value < 0) { is_negative = true; work_value = -value; }
    string:result = "";
    int64:remaining = work_value;
    while (remaining > 0) {
        int64:digit = remaining % 10;
        remaining = remaining / 10;
        string:digit_char = "";
        if (digit == 0) { digit_char = "0"; }
        if (digit == 1) { digit_char = "1"; }
        if (digit == 2) { digit_char = "2"; }
        if (digit == 3) { digit_char = "3"; }
        if (digit == 4) { digit_char = "4"; }
        if (digit == 5) { digit_char = "5"; }
        if (digit == 6) { digit_char = "6"; }
        if (digit == 7) { digit_char = "7"; }
        if (digit == 8) { digit_char = "8"; }
        if (digit == 9) { digit_char = "9"; }
        result = string_concat(digit_char, result);
    }
    if (is_negative) { result = string_concat("-", result); }
    pass(result);
};

func:main = int32() {
    drop(println("Testing range-based for loops:"));
    
    // Inclusive range: 1..5 iterates 1,2,3,4,5
    drop(println("Inclusive range 1..5:"));
    for (i in 1..5) {
        string:i_str = int64_toString(i);
        drop(println(i_str));
    }
    
    // Exclusive range: 1...5 iterates 1,2,3,4
    drop(println("Exclusive range 1...5:"));
    for (i in 1...5) {
        string:i_str = int64_toString(i);
        drop(println(i_str));
    }
    
    // Range with variables
    drop(println("Range with variables 0..3:"));
    int64:start = 0;
    int64:finish = 3;
    for (i in start..finish) {
        string:i_str = int64_toString(i);
        drop(println(i_str));
    }
    
    pass(0);
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
