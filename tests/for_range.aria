// Basic range-based for loop test
// Testing for (i in range) syntax

func:main = int64() {
    print("Testing range-based for loops:");
    
    // Inclusive range: 1..5 iterates 1,2,3,4,5
    print("Inclusive range 1..5:");
    for (i in 1..5) {
        print(i);
    }
    
    // Exclusive range: 1...5 iterates 1,2,3,4
    print("Exclusive range 1...5:");
    for (i in 1...5) {
        print(i);
    }
    
    // Range with variables
    print("Range with variables 0..3:");
    int64:start = 0;
    int64:finish = 3;
    for (i in start..finish) {
        print(i);
    }
    
    pass(0);
};
