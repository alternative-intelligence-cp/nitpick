// Test: Check what value unknown == unknown produces
func:main = int32() {
    pick(unknown == unknown) {
        (0i32) { exit 10i32; },  // Exit 10 if 0
        (1i32) { exit 11i32; },  // Exit 11 if 1
        (2147483647i32) { exit 12i32; },  // Exit 12 if max (unknown sentinel)
        (*) { exit 99i32; }  // Exit 99 if something else
    }
};

