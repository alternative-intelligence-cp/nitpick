// test_rules_one_limit.aria — Single limit variable test
extern func:puts = int32(string:s);

Rules:r_lt_100 = {
    $ < 100
};

func:failsafe = NIL() {
    drop(puts("FAILSAFE"));
};

func:main = int32() {
    limit<r_lt_100> int32:a = 50;
    drop(puts("Limit variable created OK"));
    pass(0);
};
