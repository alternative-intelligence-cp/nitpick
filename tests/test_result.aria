/**
 * Test built-in Result<T> type with pass/fail mechanism
 */

func:get_value = int32() {
    pass(42i32);
};

func:main = int32() {
    Result<int32>:r = get_value();
    
    pick(r.is_error) {
        (false) {
            // Success — value was returned
            exit(0);
        },
        (true) {
            pass(1i32);
        }
    }
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit(1);
};
