#include "semantic/literal_converter.h"
#include <iostream>
#include <llvm/Support/raw_ostream.h>
#include <llvm/ADT/SmallString.h>

using namespace aria::semantic;

int main() {
    std::cout << "=== Testing Literal Converter ===" << std::endl;
    
    // Test 1: High-precision float
    std::cout << "\n Test 1: High-precision float (flt128)" << std::endl;
    auto flt128_result = LiteralConverter::convertFloatLiteral(
        "3.141592653589793238462643383279502884197",
        FloatPrecision::FLT128
    );
    
    if (flt128_result.has_value()) {
        llvm::SmallString<128> str;
        flt128_result->toString(str);
        std::cout << "  ✓ Converted: " << str.c_str() << std::endl;
    } else {
        std::cout << "  ✗ Conversion failed!" << std::endl;
    }
    
    // Test 2: Regular float
    std::cout << "\n✓ Test 2: Regular float (flt64)" << std::endl;
    auto flt64_result = LiteralConverter::convertFloatLiteral(
        "3.14",
        FloatPrecision::FLT64
    );
    
    if (flt64_result.has_value()) {
        llvm::SmallString<64> str;
        flt64_result->toString(str);
        std::cout << "  ✓ Converted: " << str.c_str() << std::endl;
    } else {
        std::cout << "  ✗ Conversion failed!" << std::endl;
    }
    
    // Test 3: Large integer (int128)
    std::cout << "\n✓ Test 3: Large integer (int128, 128 bits)" << std::endl;
    auto int128_result = LiteralConverter::convertIntLiteral(
        "9223372036854775808",  // 2^63 (exceeds int64)
        128,
        true  // signed
    );
    
    if (int128_result.has_value()) {
        llvm::SmallString<64> str;
        int128_result->toStringUnsigned(str);
        std::cout << "  ✓ Converted: " << str.c_str() << std::endl;
    } else {
        std::cout << "  ✗ Conversion failed!" << std::endl;
    }
    
    // Test 4: Regular integer (int64)
    std::cout << "\n✓ Test 4: Regular integer (int64, 64 bits)" << std::endl;
    auto int64_result = LiteralConverter::convertIntLiteral(
        "42",
        64,
        true
    );
    
    if (int64_result.has_value()) {
        llvm::SmallString<64> str;
        int64_result->toString(str, 10, true);
        std::cout << "  ✓ Converted: " << str.c_str() << std::endl;
    } else {
        std::cout << "  ✗ Conversion failed!" << std::endl;
    }
    
    // Test 5: Validation
    std::cout << "\n✓ Test 5: Literal validation" << std::endl;
    bool valid_float = LiteralConverter::validateLiteral("3.14159", true);
    bool valid_int = LiteralConverter::validateLiteral("123456", false);
    bool invalid = LiteralConverter::validateLiteral("not_a_number", true);
    
    std::cout << "  Float '3.14159' valid: " << (valid_float ? "✓ yes" : "✗ no") << std::endl;
    std::cout << "  Int '123456' valid: " << (valid_int ? "✓ yes" : "✗ no") << std::endl;
    std::cout << "  'not_a_number' valid: " << (invalid ? "✗ yes" : "✓ no (correct)") << std::endl;
    
    std::cout << "\n=== All Tests Complete ===" << std::endl;
    
    return 0;
}
