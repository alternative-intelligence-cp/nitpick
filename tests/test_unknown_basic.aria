// Test: unknown literal basic parsing and compilation
// Phase 5.1: Core unknown literal

func:test_unknown_literal = int32() {
    // Test that unknown is recognized as a literal
    int32:x = 5i32;
    
    // Test unknown in pick pattern (already supported by exhaustiveness checker)
    pick(x) {
        (unknown) {
            pass 1i32;
        },
        (5i32) {
            pass 2i32;
        },
        (*) {
            pass 3i32;
        }
    }
};

func:main = int32() {
    int32:result = raw test_unknown_literal();
    exit result;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
