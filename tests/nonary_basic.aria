// Test nonary types (nit/nyte)
// Part of Phase 3.3: Balanced Ternary/Nonary Types

func:main = int32() {
    // Test nit - single nonary digit (-4 to 4)
    nit:neg = -4;
    nit:zero = 0;
    nit:pos = 4;
    nit:mid = 2;
    
    // Test nyte - 5 nits packed in 16 bits
    nyte:small = 10;
    nyte:medium = 100;
    
    // Test basic arithmetic on nits
    nit:sum = mid + mid;  // 2 + 2 = 4
    
    // Test comparisons
    bool:eq = (zero == 0);
    bool:lt = (neg < pos);
    bool:gt = (pos > neg);
    bool:mid_check = (sum == pos);
    
    // Verify basic operations work
    if (!eq) {
        int32:one = 1;
        pass(one);
    }
    
    if (!lt) {
        int32:one = 1;
        pass(one);
    }
    
    if (!mid_check) {
        int32:one = 1;
        pass(one);
    }

    int32:ret = 0;
    pass(ret);
};
