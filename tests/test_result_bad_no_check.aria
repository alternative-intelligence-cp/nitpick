// Expected: COMPILER ERROR
// Test for Result enforcement - BAD cases that should FAIL

// Generic function returning Result
func<T>:maybe_value = Result<T>(T:value, bool:should_fail) {
    is should_fail : fail(1i64) : pass(value);
};

func:main = int32() {
    # BAD - Access value without checking
    Result<int64>:r1 = maybe_value::<int64>(42i64, false);
    
    # Should ERROR here
    int64:bad_access = r1.value;
    
    exit(0);
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit(1);
};
