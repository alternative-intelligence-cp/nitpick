use "process.aria".*;

func:failsafe = int32(tbb32:err_code) {
    println("FAILSAFE triggered");
    exit(1);
};

func:test_pid = int32() {
    int64:pid = raw Process.getpid();
    if (pid < 1i64) { println("FAIL: T01 getpid < 1"); pass 1i32; }
    println("OK: T01 getpid");

    int64:ppid = raw Process.getppid();
    if (ppid < 1i64) { println("FAIL: T02 getppid < 1"); pass 1i32; }
    println("OK: T02 getppid");

    if (pid == ppid) { println("FAIL: T03 pid == ppid"); pass 1i32; }
    println("OK: T03 pid != ppid");
    pass 0i32;
};

func:test_env = int32() {
    string:path = raw Process.getenv("PATH");
    println("OK: T04 getenv PATH");

    string:home = raw Process.getenv("HOME");
    println("OK: T05 getenv HOME");

    string:user = raw Process.getenv("USER");
    println("OK: T06 getenv USER");

    string:empty = raw Process.getenv("ARIA_NONEXISTENT_VAR_12345");
    println("OK: T07 getenv nonexistent");
    pass 0i32;
};

func:test_system = int32() {
    int32:r1 = raw Process.system("true");
    if (r1 != 0i32) { println("FAIL: T08 system true"); pass 1i32; }
    println("OK: T08 system true");

    int32:r2 = raw Process.system("false");
    if (r2 == 0i32) { println("FAIL: T09 system false"); pass 1i32; }
    println("OK: T09 system false nonzero");

    int32:r3 = raw Process.system("echo aria > /dev/null");
    if (r3 != 0i32) { println("FAIL: T10 system echo"); pass 1i32; }
    println("OK: T10 system echo");
    pass 0i32;
};

func:test_consistency = int32() {
    int64:pid1 = raw Process.getpid();
    int64:pid2 = raw Process.getpid();
    if (pid1 != pid2) { println("FAIL: T11 pid stable"); pass 1i32; }
    println("OK: T11 pid stable");

    int64:ppid1 = raw Process.getppid();
    int64:ppid2 = raw Process.getppid();
    if (ppid1 != ppid2) { println("FAIL: T12 ppid stable"); pass 1i32; }
    println("OK: T12 ppid stable");
    pass 0i32;
};

func:main = int32() {
    int32:r1 = raw test_pid();
    if (r1 != 0i32) { exit(1); }
    int32:r2 = raw test_env();
    if (r2 != 0i32) { exit(1); }
    int32:r3 = raw test_system();
    if (r3 != 0i32) { exit(1); }
    int32:r4 = raw test_consistency();
    if (r4 != 0i32) { exit(1); }
    println("PASS: all 12 process tests passed");
    exit(0);
};
