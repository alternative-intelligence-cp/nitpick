/**
 * Test async function IR generation
 * 
 * Tests that async functions generate proper LLVM coroutine IR with:
 * - @llvm.coro.id call
 * - @llvm.coro.begin call
 * - @llvm.coro.suspend calls
 * - @llvm.coro.end call
 * - Proper basic block structure (entry, suspend, cleanup)
 */
TEST_CASE(async_function_ir_generation) {
    // Create LLVM context and module
    llvm::LLVMContext context;
    llvm::IRBuilder<> builder(context);
    auto module = std::make_unique<llvm::Module>("test_async", context);
    std::map<std::string, llvm::Value*> named_values;
    
    // Create codegen instances
    StmtCodegen stmt_codegen(context, builder, module.get(), named_values);
    ExprCodegen expr_codegen(context, builder, module.get(), named_values);
    stmt_codegen.setExprCodegen(&expr_codegen);
    expr_codegen.setStmtCodegen(&stmt_codegen);
    
    // Create async function: async func:simpleAsync = NIL() { }
    // Note: Using NIL return type to avoid return value handling for now
    std::vector<ASTNodePtr> body_stmts;
    auto body = std::make_shared<BlockStmt>(body_stmts);
    
    auto func_decl = std::make_shared<FuncDeclStmt>(
        "simpleAsync",
        "NIL",  // NIL return type for simplicity
        std::vector<ASTNodePtr>(),  // No parameters
        body
    );
    func_decl->isAsync = true;  // Mark as async
    
    // Generate LLVM IR
    llvm::Function* func = stmt_codegen.codegenFuncDecl(func_decl.get());
    
    // Verify function was created
    ASSERT(func != nullptr, "Async function should be generated");
    ASSERT_EQ(func->getName().str(), "simpleAsync", "Function name should match");
    
    // Verify return type is i8* (coroutine handle)
    ASSERT(func->getReturnType()->isPointerTy(), "Async function should return pointer (i8*)");
    
    // Dump IR to string for inspection
    std::string ir_string;
    llvm::raw_string_ostream ir_stream(ir_string);
    func->print(ir_stream);
    ir_stream.flush();
    
    // Verify coroutine intrinsics are present
    ASSERT(ir_string.find("@llvm.coro.id") != std::string::npos, 
           "IR should contain @llvm.coro.id call");
    ASSERT(ir_string.find("@llvm.coro.size") != std::string::npos,
           "IR should contain @llvm.coro.size call");
    ASSERT(ir_string.find("@llvm.coro.begin") != std::string::npos,
           "IR should contain @llvm.coro.begin call");
    ASSERT(ir_string.find("@llvm.coro.suspend") != std::string::npos,
           "IR should contain @llvm.coro.suspend call");
    ASSERT(ir_string.find("@llvm.coro.end") != std::string::npos,
           "IR should contain @llvm.coro.end call");
    
    // Verify basic blocks exist
    ASSERT(ir_string.find("entry:") != std::string::npos,
           "IR should have entry block");
    ASSERT(ir_string.find("coro.suspend:") != std::string::npos,
           "IR should have coro.suspend block");
    ASSERT(ir_string.find("coro.cleanup:") != std::string::npos,
           "IR should have coro.cleanup block");
    
    // Print IR for manual inspection (helpful for debugging)
    // std::cout << "\n=== Generated Async Function IR ===\n" << ir_string << "\n";
}

/**
 * Test await expression IR generation
 * 
 * Tests that await expressions generate proper suspension points with:
 * - @llvm.coro.save call
 * - @llvm.coro.suspend call with final=false
 * - await.resume block
 * - await.cleanup block
 * - Switch instruction for suspend result
 */
TEST_CASE(await_expression_ir_generation) {
    // Create LLVM context and module
    llvm::LLVMContext context;
    llvm::IRBuilder<> builder(context);
    auto module = std::make_unique<llvm::Module>("test_await", context);
    std::map<std::string, llvm::Value*> named_values;
    
    // Create codegen instances
    StmtCodegen stmt_codegen(context, builder, module.get(), named_values);
    ExprCodegen expr_codegen(context, builder, module.get(), named_values);
    stmt_codegen.setExprCodegen(&expr_codegen);
    expr_codegen.setStmtCodegen(&stmt_codegen);
    
    // Create async function with await:
    // async func:withAwait = int64() {
    //     int64:result = await someOp();
    //     pass(result);
    // }
    
    // First, create the awaited function call
    auto call_expr = std::make_shared<CallExpr>(
        std::make_shared<IdentifierExpr>("someOp"),
        std::vector<ASTNodePtr>()
    );
    
    // Wrap in await expression
    auto await_expr = std::make_shared<AwaitExpr>(call_expr);
    
    // Create expression statement with await (no variable assignment)
    auto expr_stmt = std::make_shared<ExpressionStmt>(await_expr);
    
    // Build function body
    std::vector<ASTNodePtr> body_stmts;
    body_stmts.push_back(expr_stmt);
    auto body = std::make_shared<BlockStmt>(body_stmts);
    
    auto func_decl = std::make_shared<FuncDeclStmt>(
        "withAwait",
        "NIL",  // NIL return for simplicity
        std::vector<ASTNodePtr>(),
        body
    );
    func_decl->isAsync = true;
    
    // First, create a dummy someOp async function  
    auto dummy_body = std::make_shared<BlockStmt>(std::vector<ASTNodePtr>());
    auto dummy_func = std::make_shared<FuncDeclStmt>(
        "someOp",
        "NIL",
        std::vector<ASTNodePtr>(),
        dummy_body
    );
    dummy_func->isAsync = true;  // Make it async so it returns i8*
    stmt_codegen.codegenFuncDecl(dummy_func.get());
    
    // Generate LLVM IR for async function
    llvm::Function* func = stmt_codegen.codegenFuncDecl(func_decl.get());
    
    // Verify function was created
    ASSERT(func != nullptr, "Async function with await should be generated");
    
    // Dump IR to string
    std::string ir_string;
    llvm::raw_string_ostream ir_stream(ir_string);
    func->print(ir_stream);
    ir_stream.flush();
    
    // Verify await-specific intrinsics
    ASSERT(ir_string.find("@llvm.coro.save") != std::string::npos,
           "IR should contain @llvm.coro.save for await");
    ASSERT(ir_string.find("@llvm.coro.resume") != std::string::npos,
           "IR should contain @llvm.coro.resume for awaited coroutine");
    
    // Verify await blocks
    ASSERT(ir_string.find("await.resume") != std::string::npos,
           "IR should have await.resume block");
    ASSERT(ir_string.find("await.cleanup") != std::string::npos,
           "IR should have await.cleanup block");
    
    // Verify switch instruction (state machine)
    ASSERT(ir_string.find("switch") != std::string::npos,
           "IR should have switch for suspend result");
    
    // Print IR for manual inspection
    // std::cout << "\n=== Generated Await Expression IR ===\n" << ir_string << "\n";
}

/**
 * Test multiple await points generate unique blocks
 * 
 * Verifies that multiple await expressions create separate suspension points
 * with unique block names (state machine with multiple states)
 */
TEST_CASE(multiple_await_points_ir) {
    // Create LLVM context and module
    llvm::LLVMContext context;
    llvm::IRBuilder<> builder(context);
    auto module = std::make_unique<llvm::Module>("test_multi_await", context);
    std::map<std::string, llvm::Value*> named_values;
    
    // Create codegen instances
    StmtCodegen stmt_codegen(context, builder, module.get(), named_values);
    ExprCodegen expr_codegen(context, builder, module.get(), named_values);
    stmt_codegen.setExprCodegen(&expr_codegen);
    expr_codegen.setStmtCodegen(&stmt_codegen);
    
    // Create async function with multiple awaits:
    // async func:multiAwait = int64() {
    //     await op1();
    //     await op2();
    //     pass(42);
    // }
    
    // First await
    auto await1 = std::make_shared<AwaitExpr>(
        std::make_shared<CallExpr>(
            std::make_shared<IdentifierExpr>("op1"),
            std::vector<ASTNodePtr>()
        )
    );
    auto expr_stmt1 = std::make_shared<ExpressionStmt>(await1);
    
    // Second await
    auto await2 = std::make_shared<AwaitExpr>(
        std::make_shared<CallExpr>(
            std::make_shared<IdentifierExpr>("op2"),
            std::vector<ASTNodePtr>()
        )
    );
    auto expr_stmt2 = std::make_shared<ExpressionStmt>(await2);
    
    // Build function (no return, just awaits)
    std::vector<ASTNodePtr> body_stmts;
    body_stmts.push_back(expr_stmt1);
    body_stmts.push_back(expr_stmt2);
    auto body = std::make_shared<BlockStmt>(body_stmts);
    
    auto func_decl = std::make_shared<FuncDeclStmt>(
        "multiAwait",
        "NIL",
        std::vector<ASTNodePtr>(),
        body
    );
    func_decl->isAsync = true;
    
    // Create dummy op1 and op2 async functions
    auto dummy_body = std::make_shared<BlockStmt>(std::vector<ASTNodePtr>());
    auto op1_func = std::make_shared<FuncDeclStmt>("op1", "NIL", std::vector<ASTNodePtr>(), dummy_body);
    auto op2_func = std::make_shared<FuncDeclStmt>("op2", "NIL", std::vector<ASTNodePtr>(), dummy_body);
    op1_func->isAsync = true;
    op2_func->isAsync = true;
    stmt_codegen.codegenFuncDecl(op1_func.get());
    stmt_codegen.codegenFuncDecl(op2_func.get());
    
    // Generate IR
    llvm::Function* func = stmt_codegen.codegenFuncDecl(func_decl.get());
    
    ASSERT(func != nullptr, "Multi-await function should be generated");
    
    // Dump IR
    std::string ir_string;
    llvm::raw_string_ostream ir_stream(ir_string);
    func->print(ir_stream);
    ir_stream.flush();
    
    // Count suspend calls (should have at least 2: one for each await, plus final)
    size_t suspend_count = 0;
    size_t pos = 0;
    while ((pos = ir_string.find("@llvm.coro.suspend", pos)) != std::string::npos) {
        suspend_count++;
        pos++;
    }
    
    ASSERT(suspend_count >= 2, "Should have at least 2 suspend points (2 awaits + final)");
    
    // Verify we have await.resume blocks (multiple suspension points)
    ASSERT(ir_string.find("await.resume") != std::string::npos,
           "Should have await.resume blocks for suspension points");
    
    // Print IR for inspection
    // std::cout << "\n=== Multi-Await IR ===\n" << ir_string << "\n";
}

/**
 * Test async function with no await points
 * 
 * Even without await, async functions should generate coroutine infrastructure
 * This is important for consistent behavior and future-proofing
 */
TEST_CASE(async_no_await_still_coroutine) {
    llvm::LLVMContext context;
    llvm::IRBuilder<> builder(context);
    auto module = std::make_unique<llvm::Module>("test_no_await", context);
    std::map<std::string, llvm::Value*> named_values;
    
    StmtCodegen stmt_codegen(context, builder, module.get(), named_values);
    ExprCodegen expr_codegen(context, builder, module.get(), named_values);
    stmt_codegen.setExprCodegen(&expr_codegen);
    expr_codegen.setStmtCodegen(&stmt_codegen);
    
    // async func:noAwait = NIL() { }
    std::vector<ASTNodePtr> body_stmts;
    auto body = std::make_shared<BlockStmt>(body_stmts);
    
    auto func_decl = std::make_shared<FuncDeclStmt>(
        "noAwait",
        "NIL",
        std::vector<ASTNodePtr>(),
        body
    );
    func_decl->isAsync = true;
    
    llvm::Function* func = stmt_codegen.codegenFuncDecl(func_decl.get());
    
    ASSERT(func != nullptr, "Async function without await should still be generated");
    ASSERT(func->getReturnType()->isPointerTy(), "Should return i8* (coroutine handle)");
    
    // Dump IR
    std::string ir_string;
    llvm::raw_string_ostream ir_stream(ir_string);
    func->print(ir_stream);
    ir_stream.flush();
    
    // Should still have coroutine infrastructure
    ASSERT(ir_string.find("@llvm.coro.id") != std::string::npos,
           "Should have coroutine setup even without await");
    ASSERT(ir_string.find("@llvm.coro.end") != std::string::npos,
           "Should have coroutine cleanup");
    
    // This is important for RAMP optimization: if no actual suspension occurs,
    // LLVM can optimize away the heap allocation and make it synchronous
}
