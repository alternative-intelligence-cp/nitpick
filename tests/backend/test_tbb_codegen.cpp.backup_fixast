// TBB Codegen Tests
// ============================================================================

TEST_CASE(tbb_codegen_err_sentinel_values) {
    llvm::LLVMContext context;
    llvm::Module module("test_tbb", context);
    llvm::IRBuilder<> builder(context);
    
    llvm::FunctionType* funcType = llvm::FunctionType::get(builder.getVoidTy(), false);
    llvm::Function* func = llvm::Function::Create(funcType, llvm::Function::ExternalLinkage, "test_func", &module);
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", func);
    builder.SetInsertPoint(entry);
    
    TBBCodegen tbbGen(context, builder);
    TypeSystem types;
    
    // Test ERR sentinel values
    Type* tbb8Type = types.getPrimitiveType("tbb8");
    llvm::Value* err8 = tbbGen.getErrSentinel(tbb8Type);
    ASSERT(err8 != nullptr, "tbb8 ERR sentinel should not be null");
    
    auto* c8 = llvm::cast<llvm::ConstantInt>(err8);
    ASSERT_EQ(c8->getSExtValue(), -128, "tbb8 ERR sentinel should be -128");
}

TEST_CASE(tbb_codegen_max_min_values) {
    llvm::LLVMContext context;
    llvm::Module module("test_tbb", context);
    llvm::IRBuilder<> builder(context);
    
    llvm::FunctionType* funcType = llvm::FunctionType::get(builder.getVoidTy(), false);
    llvm::Function* func = llvm::Function::Create(funcType, llvm::Function::ExternalLinkage, "test_func", &module);
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", func);
    builder.SetInsertPoint(entry);
    
    TBBCodegen tbbGen(context, builder);
    TypeSystem types;
    Type* tbb8Type = types.getPrimitiveType("tbb8");
    
    llvm::Value* max8 = tbbGen.getMaxValue(tbb8Type);
    llvm::Value* min8 = tbbGen.getMinValue(tbb8Type);
    
    auto* cMax = llvm::cast<llvm::ConstantInt>(max8);
    auto* cMin = llvm::cast<llvm::ConstantInt>(min8);
    
    ASSERT_EQ(cMax->getSExtValue(), 127, "tbb8 max should be 127");
    ASSERT_EQ(cMin->getSExtValue(), -127, "tbb8 min should be -127");
}

TEST_CASE(tbb_codegen_add_basic) {
    llvm::LLVMContext context;
    llvm::Module module("test_tbb", context);
    llvm::IRBuilder<> builder(context);
    
    llvm::Type* tbb8LLVMType = builder.getInt8Ty();
    llvm::FunctionType* funcType = llvm::FunctionType::get(tbb8LLVMType, {tbb8LLVMType, tbb8LLVMType}, false);
    llvm::Function* func = llvm::Function::Create(funcType, llvm::Function::ExternalLinkage, "add_test", &module);
    
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", func);
    builder.SetInsertPoint(entry);
    
    TBBCodegen tbbGen(context, builder);
    TypeSystem types;
    Type* tbb8Type = types.getPrimitiveType("tbb8");
    
    auto args = func->arg_begin();
    llvm::Value* lhs = &(*args++);
    llvm::Value* rhs = &(*args);
    
    llvm::Value* result = tbbGen.generateAdd(lhs, rhs, tbb8Type);
    ASSERT(result != nullptr, "TBB addition should generate valid LLVM value");
    
    builder.CreateRet(result);
    
    std::string errorStr;
    llvm::raw_string_ostream errorStream(errorStr);
    bool hasErrors = llvm::verifyFunction(*func, &errorStream);
    ASSERT(!hasErrors, "Generated TBB add function should be valid LLVM IR");
}

