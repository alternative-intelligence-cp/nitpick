TEST_CASE(tbb_codegen_all_types_supported) {
    llvm::LLVMContext context;
    llvm::Module module("test_tbb", context);
    llvm::IRBuilder<> builder(context);
    
    llvm::FunctionType* funcType = llvm::FunctionType::get(builder.getVoidTy(), false);
    llvm::Function* func = llvm::Function::Create(funcType, llvm::Function::ExternalLinkage, "all_types_test", &module);
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", func);
    builder.SetInsertPoint(entry);
    
    TBBCodegen tbbGen(context, builder);
    TypeSystem types;
    
    // Test that all TBB types can generate ERR sentinels
    Type* tbb8Type = types.getPrimitiveType("tbb8");
    Type* tbb16Type = types.getPrimitiveType("tbb16");
    Type* tbb32Type = types.getPrimitiveType("tbb32");
    Type* tbb64Type = types.getPrimitiveType("tbb64");
    
    llvm::Value* err8 = tbbGen.getErrSentinel(tbb8Type);
    llvm::Value* err16 = tbbGen.getErrSentinel(tbb16Type);
    llvm::Value* err32 = tbbGen.getErrSentinel(tbb32Type);
    llvm::Value* err64 = tbbGen.getErrSentinel(tbb64Type);
    
    ASSERT(err8 != nullptr, "tbb8 ERR sentinel generated");
    ASSERT(err16 != nullptr, "tbb16 ERR sentinel generated");
    ASSERT(err32 != nullptr, "tbb32 ERR sentinel generated");
    ASSERT(err64 != nullptr, "tbb64 ERR sentinel generated");
}
