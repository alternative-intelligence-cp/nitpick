/**
 * Test: Integer literal code generation
 */
TEST_CASE(codegen_expr_int_literal) {
    llvm::LLVMContext context;
    llvm::IRBuilder<> builder(context);
    llvm::Module module("test_module", context);
    std::map<std::string, llvm::Value*> named_values;
    
    ExprCodegen codegen(context, builder, &module, named_values);
    
    // Create a test function to hold the code
    llvm::FunctionType* ft = llvm::FunctionType::get(llvm::Type::getInt32Ty(context), false);
    llvm::Function* func = llvm::Function::Create(ft, llvm::Function::ExternalLinkage, "test_int", module);
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", func);
    builder.SetInsertPoint(entry);
    
    // Test integer literal: 42
    LiteralExpr int_expr(static_cast<int64_t>(42));
    llvm::Value* result = codegen.codegenLiteral(&int_expr);
    
    ASSERT(result != nullptr, "Integer literal should produce a value");
    ASSERT(llvm::isa<llvm::ConstantInt>(result), "Integer literal should produce ConstantInt");
    
    llvm::ConstantInt* ci = llvm::cast<llvm::ConstantInt>(result);
    ASSERT_EQ(ci->getSExtValue(), 42, "Integer value should be 42");
    
    // Complete the function
    builder.CreateRet(result);
    ASSERT(!llvm::verifyFunction(*func, &llvm::errs()), "Generated function should be valid");
}

