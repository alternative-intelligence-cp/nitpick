/**
 * Test: Undefined variable error
 */
TEST_CASE(codegen_expr_undefined_variable) {
    llvm::LLVMContext context;
    llvm::IRBuilder<> builder(context);
    llvm::Module module("test_module", context);
    std::map<std::string, llvm::Value*> named_values;
    
    ExprCodegen codegen(context, builder, &module, named_values);
    
    // Create a test function
    llvm::FunctionType* ft = llvm::FunctionType::get(llvm::Type::getInt32Ty(context), false);
    llvm::Function* func = llvm::Function::Create(ft, llvm::Function::ExternalLinkage, "test_undef", module);
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", func);
    builder.SetInsertPoint(entry);
    
    // Try to reference undefined variable
    IdentifierExpr id_expr("undefined_var");
    
    bool caught_error = false;
    try {
        codegen.codegenIdentifier(&id_expr);
    } catch (const std::runtime_error& e) {
        caught_error = true;
        std::string msg = e.what();
        ASSERT(msg.find("Undefined variable") != std::string::npos, "Error message should mention undefined variable");
    }
    
    ASSERT(caught_error, "Should throw error for undefined variable");
}

/**
 * Test: Non-alloca value (function parameter simulation)
 */
TEST_CASE(codegen_expr_function_parameter) {
    llvm::LLVMContext context;
    llvm::IRBuilder<> builder(context);
    llvm::Module module("test_module", context);
    std::map<std::string, llvm::Value*> named_values;
    
    ExprCodegen codegen(context, builder, &module, named_values);
    
    // Create a function with a parameter
    llvm::FunctionType* ft = llvm::FunctionType::get(
        llvm::Type::getInt32Ty(context),
        {llvm::Type::getInt32Ty(context)},
        false
    );
    llvm::Function* func = llvm::Function::Create(ft, llvm::Function::ExternalLinkage, "test_param", module);
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", func);
    builder.SetInsertPoint(entry);
    
    // Get the parameter
    llvm::Argument* param = func->arg_begin();
    param->setName("n");
    
    // Add parameter to symbol table (parameters are not allocas!)
    named_values["n"] = param;
    
    // Generate code for parameter reference
    IdentifierExpr id_expr("n");
    llvm::Value* result = codegen.codegenIdentifier(&id_expr);
    
    ASSERT(result != nullptr, "Parameter reference should produce a value");
    ASSERT(result == param, "Parameter reference should return the parameter directly (no load)");
    ASSERT(!llvm::isa<llvm::LoadInst>(result), "Parameter should not be loaded");
    
    builder.CreateRet(result);
    ASSERT(!llvm::verifyFunction(*func, &llvm::errs()), "Generated function should be valid");
}

