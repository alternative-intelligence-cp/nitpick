        llvm::Type::getVoidTy(context), false);
    llvm::Function* func = llvm::Function::Create(
        func_type, llvm::Function::ExternalLinkage, "test_if_nested", &module);
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", func);
    builder.SetInsertPoint(entry);
    
    // Create inner if statement: if (false) { i32:b = 2; } else { i32:c = 3; }
    auto inner_cond = std::make_unique<LiteralExpr>(false);
    
    auto two = std::make_unique<LiteralExpr>((int64_t)2);
    auto b_decl = std::make_unique<VarDeclStmt>("i32", "b", std::move(two));
    auto inner_then_block = std::make_unique<BlockStmt>();
    inner_then_block->statements.push_back(std::move(b_decl));
    
    auto three = std::make_unique<LiteralExpr>((int64_t)3);
    auto c_decl = std::make_unique<VarDeclStmt>("i32", "c", std::move(three));
    auto inner_else_block = std::make_unique<BlockStmt>();
    inner_else_block->statements.push_back(std::move(c_decl));
    
    auto inner_if = std::make_unique<IfStmt>(std::move(inner_cond), std::move(inner_then_block), std::move(inner_else_block));
    
    // Create outer if statement: if (true) { i32:a = 1; } else { <inner_if> }
    auto outer_cond = std::make_unique<LiteralExpr>(true);
    
    auto one = std::make_unique<LiteralExpr>((int64_t)1);
    auto a_decl = std::make_unique<VarDeclStmt>("i32", "a", std::move(one));
    auto outer_then_block = std::make_unique<BlockStmt>();
    outer_then_block->statements.push_back(std::move(a_decl));
    
    auto outer_if = std::make_unique<IfStmt>(std::move(outer_cond), std::move(outer_then_block), std::move(inner_if));
    
    // Generate code
    stmt_codegen.codegenIf(outer_if.get());
    
    // Verify we have multiple if.then/if.else/if.merge blocks from nesting
    int then_count = 0;
    int else_count = 0;
    int merge_count = 0;
    for (auto& bb : *func) {
        std::string bb_name = bb.getName().str();
        if (bb_name.find("if.then") != std::string::npos) then_count++;
        if (bb_name.find("if.else") != std::string::npos) else_count++;
        if (bb_name.find("if.merge") != std::string::npos) merge_count++;
    }
    ASSERT(then_count >= 2, "Should have at least 2 if.then blocks (nested)");
    ASSERT(else_count >= 1, "Should have at least 1 if.else block (nested)");
    ASSERT(merge_count >= 2, "Should have at least 2 if.merge blocks (nested)");
}

