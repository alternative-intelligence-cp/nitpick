        "identity",
        "T",  // Return type (will be substituted)
        params,
        std::move(body)
    );
    
    // Add generic parameter
    func_decl->genericParams.push_back(GenericParamInfo("T"));
    
    // Generate code - should return nullptr (template not directly compiled)
    llvm::Function* result = stmt_codegen.codegenFuncDecl(func_decl.get());
    
    ASSERT(result == nullptr, "Generic template should not generate code");
    
