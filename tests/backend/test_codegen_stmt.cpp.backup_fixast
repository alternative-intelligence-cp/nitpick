    stmt_codegen.setExprCodegen(&expr_codegen);
    
    // Create generic function: func<T>:identity = *T(*T:value) { return value; }
    // Note: This is just the declaration - the body would use *T syntax
    std::vector<ASTNodePtr> params;
    params.push_back(std::make_unique<ParameterNode>("T", "value"));  // Type will be substituted
    
    auto return_stmt = std::make_unique<ReturnStmt>(
        std::make_unique<IdentifierExpr>("value")
    );
    std::vector<ASTNodePtr> body_stmts;
    body_stmts.push_back(std::move(return_stmt));
