/**
 * Test: Variable declaration without initializer
 * Code: i32:x;
 * Should create: %x = alloca i32
 */
TEST_CASE(codegen_stmt_var_decl_no_init) {
    llvm::LLVMContext context;
    llvm::Module module("test", context);
    llvm::IRBuilder<> builder(context);
    std::map<std::string, llvm::Value*> named_values;
    
    // Create test function
    llvm::Function* func = createTestFunction(&module);
    llvm::BasicBlock* entry = &func->getEntryBlock();
    builder.SetInsertPoint(entry);
    
    // Create StmtCodegen and ExprCodegen
    StmtCodegen stmt_codegen(context, builder, &module, named_values);
    ExprCodegen expr_codegen(context, builder, &module, named_values);
    stmt_codegen.setExprCodegen(&expr_codegen);
    
    // Create variable declaration: i32:x;
    auto var_decl = std::make_unique<VarDeclStmt>("i32", "x", nullptr);
    
    // Generate code
    stmt_codegen.codegenVarDecl(var_decl.get());
    
    // Verify alloca was created
    ASSERT(named_values.count("x") > 0, "Variable x should be in named_values");
    llvm::Value* x_value = named_values["x"];
    ASSERT(x_value != nullptr, "Variable x value should not be null");
    
    // Verify it's an alloca instruction
    llvm::AllocaInst* alloca = llvm::dyn_cast<llvm::AllocaInst>(x_value);
    ASSERT(alloca != nullptr, "Variable x should be an alloca instruction");
    ASSERT(alloca->getAllocatedType()->isIntegerTy(32), "Variable x should be i32 type");
}

/**
 * Test: Variable declaration with integer initializer
 * Code: i32:x = 42;
 * Should create: %x = alloca i32
 *                store i32 42, i32* %x
 */
TEST_CASE(codegen_stmt_var_decl_with_init) {
    llvm::LLVMContext context;
    llvm::Module module("test", context);
    llvm::IRBuilder<> builder(context);
    std::map<std::string, llvm::Value*> named_values;
    
    // Create test function
    llvm::Function* func = createTestFunction(&module);
    llvm::BasicBlock* entry = &func->getEntryBlock();
    builder.SetInsertPoint(entry);
    
    // Create StmtCodegen and ExprCodegen
    StmtCodegen stmt_codegen(context, builder, &module, named_values);
    ExprCodegen expr_codegen(context, builder, &module, named_values);
    stmt_codegen.setExprCodegen(&expr_codegen);
    
    // Create variable declaration: i32:x = 42;
    auto init_expr = std::make_unique<LiteralExpr>(static_cast<int64_t>(42));
    auto var_decl = std::make_unique<VarDeclStmt>("i32", "x", std::move(init_expr));
    
    // Generate code
    stmt_codegen.codegenVarDecl(var_decl.get());
    
    // Verify alloca was created
    ASSERT(named_values.count("x") > 0, "Variable x should be in named_values");
    llvm::AllocaInst* alloca = llvm::dyn_cast<llvm::AllocaInst>(named_values["x"]);
    ASSERT(alloca != nullptr, "Variable x should be an alloca instruction");
    ASSERT(alloca->getAllocatedType()->isIntegerTy(32), "Variable x should be i32 type");
    
    // Verify store instruction was created
    // The store should be in the current block after the alloca
    bool found_store = false;
    for (auto& inst : *entry) {
        if (llvm::StoreInst* store = llvm::dyn_cast<llvm::StoreInst>(&inst)) {
            if (store->getPointerOperand() == alloca) {
                found_store = true;
                // Verify stored value is 42
                if (llvm::ConstantInt* const_val = llvm::dyn_cast<llvm::ConstantInt>(store->getValueOperand())) {
                    ASSERT_EQ(const_val->getSExtValue(), static_cast<int64_t>(42), "Stored value should be 42");
                }
                break;
            }
        }
    }
    ASSERT(found_store, "Store instruction should be created for initializer");
}

