    ExprCodegen expr_codegen(context, builder, &module, named_values);
    stmt_codegen.setExprCodegen(&expr_codegen);
    
    // Create function: func:double_it = i32(i32:x) { pass(x * 2); };
    std::vector<ASTNodePtr> params;
    params.push_back(std::make_unique<ParameterNode>("i32", "x"));
    
    // Create body: pass(x * 2);
    auto x_ref = std::make_unique<IdentifierExpr>("x");
    auto two = std::make_unique<LiteralExpr>(static_cast<int64_t>(2));
    Token mul_token(TokenType::TOKEN_STAR, "*", 0, 0);
    auto mul_expr = std::make_unique<BinaryExpr>(std::move(x_ref), mul_token, std::move(two));
    auto ret_stmt = std::make_unique<ReturnStmt>(std::move(mul_expr));
    
    std::vector<ASTNodePtr> body_stmts;
    body_stmts.push_back(std::move(ret_stmt));
    auto body = std::make_unique<BlockStmt>(body_stmts);
    
    auto func_decl = std::make_unique<FuncDeclStmt>("double_it", "i32", params, std::move(body));
    
    // Generate code
    llvm::Function* func = stmt_codegen.codegenFuncDecl(func_decl.get());
    
    // Verify function signature
    ASSERT(func != nullptr, "Function should be created");
    ASSERT_EQ(func->getName().str(), "double_it", "Function name should be 'double_it'");
    ASSERT(func->getReturnType()->isIntegerTy(32), "Return type should be i32");
    ASSERT_EQ(func->arg_size(), 1u, "Function should have 1 parameter");
    
    // Verify parameter name
    llvm::Argument* arg = func->getArg(0);
    ASSERT_EQ(arg->getName().str(), "x", "Parameter name should be 'x'");
    ASSERT(arg->getType()->isIntegerTy(32), "Parameter type should be i32");
}

