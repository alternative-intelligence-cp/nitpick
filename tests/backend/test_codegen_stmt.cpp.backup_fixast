    ASSERT(!func->empty(), "Function should have at least one basic block");
    llvm::BasicBlock* entry = &func->getEntryBlock();
    ASSERT(entry->getTerminator() != nullptr, "Entry block should have terminator");
}

/**
 * Test: Function with single parameter
 * Code: func:double_it = i32(i32:x) { pass(x * 2); };
 */
TEST_CASE(codegen_stmt_func_decl_one_param) {
    llvm::LLVMContext context;
    llvm::Module module("test", context);
    llvm::IRBuilder<> builder(context);
    std::map<std::string, llvm::Value*> named_values;
    
    // Create StmtCodegen and ExprCodegen
