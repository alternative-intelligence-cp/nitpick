/**
 * Create a test function to hold our generated code
 */
llvm::Function* createTestFunction(llvm::Module* module, llvm::Type* return_type = nullptr) {
    llvm::LLVMContext& context = module->getContext();
    
    if (!return_type) {
        return_type = llvm::Type::getInt32Ty(context);
    }
    
    llvm::FunctionType* func_type = llvm::FunctionType::get(return_type, false);
    llvm::Function* func = llvm::Function::Create(
        func_type,
        llvm::Function::ExternalLinkage,
        "test_func",
        module
    );
    
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", func);
    return func;
}

