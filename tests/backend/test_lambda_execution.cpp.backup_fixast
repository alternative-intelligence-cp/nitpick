/**
 * Test: Multiple lambdas in same module
 * Verifies unique naming and no conflicts
 */
TEST_CASE(lambda_multiple_in_module) {
    llvm::LLVMContext context;
    llvm::IRBuilder<> builder(context);
    std::unique_ptr<llvm::Module> module = std::make_unique<llvm::Module>("test", context);
    std::map<std::string, llvm::Value*> named_values;
    
    ExprCodegen expr_codegen(context, builder, module.get(), named_values);
    StmtCodegen stmt_codegen(context, builder, module.get(), named_values);
    stmt_codegen.setExprCodegen(&expr_codegen);
    expr_codegen.setStmtCodegen(&stmt_codegen);
    
    // Create dummy wrapper for builder context
    llvm::FunctionType* wrapper_type = llvm::FunctionType::get(
        llvm::Type::getInt32Ty(context), {}, false
    );
    llvm::Function* wrapper = llvm::Function::Create(
        wrapper_type, llvm::Function::ExternalLinkage, "test_wrapper", module.get()
    );
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", wrapper);
    builder.SetInsertPoint(entry);
    
    // Create 3 different lambdas
    for (int i = 0; i < 3; i++) {
        auto return_stmt = std::make_shared<ReturnStmt>(
            std::make_shared<LiteralExpr>(int64_t(i * 10), 1, 1),
            1, 1
        );
        auto body = std::make_shared<BlockStmt>(
            std::vector<std::shared_ptr<ASTNode>>{return_stmt}, 1, 1
        );
        auto lambda = std::make_unique<LambdaExpr>(
            std::vector<std::shared_ptr<ASTNode>>{}, "int64", body, 1, 1
        );
        
        llvm::Value* fat_ptr = expr_codegen.codegenLambda(lambda.get());
        ASSERT(fat_ptr != nullptr, "Lambda " + std::to_string(i) + " should codegen");
    }
    
    // Verify all lambda functions have unique names
    int lambda_count = 0;
    for (auto& func : module->functions()) {
        std::string name = func.getName().str();
        if (name.find("lambda_") == 0) {
            lambda_count++;
        }
    }
    ASSERT(lambda_count == 3, "Should have 3 lambda functions");
    
    // Add terminator for wrapper
    builder.CreateRet(llvm::ConstantInt::get(llvm::Type::getInt32Ty(context), 0));
    
    // Verify module
    std::string error_str;
    llvm::raw_string_ostream error_stream(error_str);
    ASSERT(!llvm::verifyModule(*module, &error_stream), "Module valid: " + error_str);
}
