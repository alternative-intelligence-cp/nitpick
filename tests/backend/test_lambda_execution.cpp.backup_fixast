        );
        
        llvm::Value* result = expr_codegen.codegenLambda(lambda_tbb8.get());
        ASSERT(result != nullptr, "tbb8 lambda should codegen");
    }
    
    // Add terminator for wrapper
    builder.CreateRet(llvm::ConstantInt::get(llvm::Type::getInt32Ty(context), 0));
    
    // Module should be valid
    std::string error_str;
    llvm::raw_string_ostream error_stream(error_str);
    ASSERT(!llvm::verifyModule(*module, &error_stream), "Module valid: " + error_str);
}

/**
 * Test: Lambda with BY_VALUE capture
 * Outer: int64:x = 5;
 * Lambda: int64(int64:y) { pass(x + y); }  // x captured by value
 * Call: lambda(10)
 * Expected: Returns 15
 */
TEST_CASE(lambda_capture_by_value) {
    llvm::LLVMContext context;
    llvm::IRBuilder<> builder(context);
    std::unique_ptr<llvm::Module> module = std::make_unique<llvm::Module>("test", context);
    std::map<std::string, llvm::Value*> named_values;
    SymbolTable symTable;
    
    ExprCodegen expr_codegen(context, builder, module.get(), named_values);
    StmtCodegen stmt_codegen(context, builder, module.get(), named_values);
    stmt_codegen.setExprCodegen(&expr_codegen);
    expr_codegen.setStmtCodegen(&stmt_codegen);
    
    // Create test wrapper
    llvm::FunctionType* wrapper_type = llvm::FunctionType::get(
        llvm::Type::getInt64Ty(context), {}, false
    );
    llvm::Function* wrapper = llvm::Function::Create(
        wrapper_type, llvm::Function::ExternalLinkage, "test_wrapper", module.get()
    );
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", wrapper);
    builder.SetInsertPoint(entry);
    
    // Create outer variable: x = 5
    llvm::AllocaInst* x_alloca = builder.CreateAlloca(llvm::Type::getInt64Ty(context), nullptr, "x");
    builder.CreateStore(llvm::ConstantInt::get(llvm::Type::getInt64Ty(context), 5), x_alloca);
    named_values["x"] = x_alloca;
    
    // Lambda: int64(int64:y) { return x + y; }
    auto param_y = std::make_shared<ParameterNode>("int64", "y", nullptr, 1, 1);
    auto binary_add = std::make_shared<BinaryExpr>(
        std::make_shared<IdentifierExpr>("x", 1, 1),
        Token{TokenType::TOKEN_PLUS, "+", 1, 1},
        std::make_shared<IdentifierExpr>("y", 1, 1),
        1, 1
    );
    auto return_stmt = std::make_shared<ReturnStmt>(binary_add, 1, 1);
    auto body = std::make_shared<BlockStmt>(
        std::vector<std::shared_ptr<ASTNode>>{return_stmt}, 1, 1
    );
    
    auto lambda = std::make_unique<LambdaExpr>(
        std::vector<std::shared_ptr<ASTNode>>{param_y},
        "int64",
        body,
        1, 1
    );
    
    // Analyze captures
    ClosureAnalyzer analyzer(&symTable);
    // Manually set captured variable (since we don't have full symbol table integration)
    lambda->capturedVars.emplace_back("x", LambdaExpr::CaptureMode::BY_VALUE, nullptr);
    
    // Generate lambda
    llvm::Value* fat_ptr = expr_codegen.codegenLambda(lambda.get());
    ASSERT(fat_ptr != nullptr, "Lambda with capture should codegen");
    
    // Add terminator for wrapper function
    builder.CreateRet(llvm::ConstantInt::get(llvm::Type::getInt64Ty(context), 0));
    
    // Verify module
    std::string error_str;
    llvm::raw_string_ostream error_stream(error_str);
    ASSERT(!llvm::verifyModule(*module, &error_stream), "Module valid: " + error_str);
}

