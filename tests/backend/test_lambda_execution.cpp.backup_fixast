/**
 * Test: Simple lambda returns constant
 * Lambda: int64() { pass(42); }
 * Expected: Returns 42
 */
TEST_CASE(lambda_return_constant) {
    llvm::LLVMContext context;
    llvm::IRBuilder<> builder(context);
    std::unique_ptr<llvm::Module> module = std::make_unique<llvm::Module>("test", context);
    std::map<std::string, llvm::Value*> named_values;
    
    ExprCodegen expr_codegen(context, builder, module.get(), named_values);
    StmtCodegen stmt_codegen(context, builder, module.get(), named_values);
    stmt_codegen.setExprCodegen(&expr_codegen);
    expr_codegen.setStmtCodegen(&stmt_codegen);
    
    // Create test wrapper function
    llvm::FunctionType* wrapper_type = llvm::FunctionType::get(
        llvm::Type::getInt64Ty(context), {}, false
    );
    llvm::Function* wrapper = llvm::Function::Create(
        wrapper_type, llvm::Function::ExternalLinkage, "test_wrapper", module.get()
    );
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", wrapper);
    builder.SetInsertPoint(entry);
    
    // Manually create lambda AST: int64() { pass(42); }
    auto return_stmt = std::make_shared<ReturnStmt>(
        std::make_shared<LiteralExpr>(int64_t(42), 1, 1),
        1, 1
    );
    auto body = std::make_shared<BlockStmt>(
        std::vector<std::shared_ptr<ASTNode>>{return_stmt},
        1, 1
    );
    auto lambda = std::make_unique<LambdaExpr>(
        std::vector<std::shared_ptr<ASTNode>>{},  // no parameters
        "int64",
        body,
        1, 1
    );
    
    // Generate lambda (creates fat pointer and lambda function)
    llvm::Value* fat_ptr = expr_codegen.codegenLambda(lambda.get());
    ASSERT(fat_ptr != nullptr, "Lambda codegen should succeed");
    
    // Extract method_ptr from fat pointer
    llvm::Value* method_ptr_field = builder.CreateExtractValue(fat_ptr, 0, "method_ptr");
    llvm::Value* env_ptr_field = builder.CreateExtractValue(fat_ptr, 1, "env_ptr");
    
    // Cast method_ptr to correct function type: i64(i8*)
    llvm::FunctionType* lambda_type = llvm::FunctionType::get(
        llvm::Type::getInt64Ty(context),
        {llvm::PointerType::get(context, 0)},  // env_ptr parameter
        false
    );
    llvm::Value* method_ptr_typed = builder.CreateBitCast(
        method_ptr_field,
        llvm::PointerType::get(lambda_type, 0),
        "method_func"
    );
    
    // Call lambda: result = lambda(env_ptr)
    llvm::Value* result = builder.CreateCall(lambda_type, method_ptr_typed, {env_ptr_field}, "result");
    builder.CreateRet(result);
    
    // Verify module
    std::string error_str;
    llvm::raw_string_ostream error_stream(error_str);
    ASSERT(!llvm::verifyModule(*module, &error_stream), "Module valid: " + error_str);
    
    // TODO: Execute and verify result == 42 when JIT integration ready
    // For now, successful codegen and module verification is enough
}

/**
 * Test: Lambda with parameters
 * Lambda: int64(int64:a, int64:b) { pass(a + b); }
 * Call: lambda(10, 32)
 * Expected: Returns 42
 */
TEST_CASE(lambda_with_parameters) {
    llvm::LLVMContext context;
    llvm::IRBuilder<> builder(context);
    std::unique_ptr<llvm::Module> module = std::make_unique<llvm::Module>("test", context);
    std::map<std::string, llvm::Value*> named_values;
    
    ExprCodegen expr_codegen(context, builder, module.get(), named_values);
    StmtCodegen stmt_codegen(context, builder, module.get(), named_values);
    stmt_codegen.setExprCodegen(&expr_codegen);
    expr_codegen.setStmtCodegen(&stmt_codegen);
    
    // Create test wrapper
    llvm::FunctionType* wrapper_type = llvm::FunctionType::get(
        llvm::Type::getInt64Ty(context), {}, false
    );
    llvm::Function* wrapper = llvm::Function::Create(
        wrapper_type, llvm::Function::ExternalLinkage, "test_wrapper", module.get()
    );
    llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", wrapper);
    builder.SetInsertPoint(entry);
    
    // Lambda AST: int64(int64:a, int64:b) { return a + b; }
    auto param_a = std::make_shared<ParameterNode>("int64", "a", nullptr, 1, 1);
    auto param_b = std::make_shared<ParameterNode>("int64", "b", nullptr, 1, 1);
    
    auto binary_add = std::make_shared<BinaryExpr>(
        std::make_shared<IdentifierExpr>("a", 1, 1),
        Token{TokenType::TOKEN_PLUS, "+", 1, 1},
        std::make_shared<IdentifierExpr>("b", 1, 1),
        1, 1
    );
    auto return_stmt = std::make_shared<ReturnStmt>(binary_add, 1, 1);
    auto body = std::make_shared<BlockStmt>(
        std::vector<std::shared_ptr<ASTNode>>{return_stmt},
        1, 1
    );
    
    auto lambda = std::make_unique<LambdaExpr>(
        std::vector<std::shared_ptr<ASTNode>>{param_a, param_b},
        "int64",
        body,
        1, 1
    );
    
    // Generate lambda
    llvm::Value* fat_ptr = expr_codegen.codegenLambda(lambda.get());
    ASSERT(fat_ptr != nullptr, "Lambda codegen should succeed");
    
    // Extract and call lambda with arguments (10, 32)
    llvm::Value* method_ptr = builder.CreateExtractValue(fat_ptr, 0, "method_ptr");
    llvm::Value* env_ptr = builder.CreateExtractValue(fat_ptr, 1, "env_ptr");
    
    llvm::FunctionType* lambda_type = llvm::FunctionType::get(
        llvm::Type::getInt64Ty(context),
        {llvm::PointerType::get(context, 0), llvm::Type::getInt64Ty(context), llvm::Type::getInt64Ty(context)},
        false
    );
    llvm::Value* method_typed = builder.CreateBitCast(
        method_ptr,
        llvm::PointerType::get(lambda_type, 0)
    );
    
    llvm::Value* arg1 = llvm::ConstantInt::get(llvm::Type::getInt64Ty(context), 10);
    llvm::Value* arg2 = llvm::ConstantInt::get(llvm::Type::getInt64Ty(context), 32);
    llvm::Value* result = builder.CreateCall(lambda_type, method_typed, {env_ptr, arg1, arg2});
    builder.CreateRet(result);
    
    // Verify module
    std::string error_str;
    llvm::raw_string_ostream error_stream(error_str);
    ASSERT(!llvm::verifyModule(*module, &error_stream), "Module valid: " + error_str);
}

