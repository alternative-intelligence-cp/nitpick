// SV-COMP MemSafety equivalent: use-after-free (BAD)
//
// C analog: MemSafety-Heap/use_after_free.c
// Property: valid-deref — VIOLATED (use after free is undefined behavior in C)
// Aria: compiler rejects this at compile time with ARIA-022.
//       The vulnerability is prevented before any binary is produced.
//
// Expected verdict: false   Strategy: compile_reject
// Compiler error: ARIA-022 "Use after free: variable 'buf' was already freed"

extern func:malloc = wild ?*(int64:size);
extern func:free = void(wild ?*:ptr);

func:main = int32() {
    wild ?->:buf = malloc(64i64);
    free(buf);
    wild ?->:alias = buf;    // ARIA-022: use after free — compile rejected
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    exit 99;
};
