// Comprehensive precedence test

func:get_value = int32(bool:succeed) {
    if (succeed) {
        pass(10i32);
    }
    fail(1i32);
};

func:main = int32() {
    int32:score = 0i32;
    
    // Test 1: !r.is_error (our fix)
    Result<int32>:r1 = get_value(true);
    if (!r1.is_error) {
        score = score + 1i32;  // +1 = 1
    }
    
    // Test 2: Double negation
    Result<int32>:r2 = get_value(false);
    if (r2.is_error) {  // !!bool == bool: same as r2.is_error
        score = score + 1i32;  // +1 = 2 (r2 failed, so is_error=true)
    }
    
    // Test 3: Negation with method calls (ensuring postfix still works)
    Result<int32>:r3 = get_value(true);
    bool:check = r3.is_error;  // Method access still works
    if (!check) {
        score = score + 1i32;  // +1 = 3
    }
    
   // Test 4: Negation with explicit comparison
    Result<int32>:r4 = get_value(true);
    if (!r4.is_error == true) {  // ! has higher precedence than ==
        score = score + 1i32;  // +1 = 4
    }
    
    // Test 5: Parentheses still work
    Result<int32>:r5 = get_value(true);
    if (!(r5.is_error)) {
        score = score + 1i32;  // +1 = 5
    }
    
    // Test 6: Negation with && 
    Result<int32>:r6 = get_value(true);
    bool:extra = true;
    if (!r6.is_error && extra) {
        score = score + 1i32;  // +1 = 6
    }
    
    pass(score);  // Expected: 6
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit(1);
};
