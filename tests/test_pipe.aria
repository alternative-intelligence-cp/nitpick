use "pipe.aria".*;

func:failsafe = int32(tbb32:err_code) {
    println("FAILSAFE triggered");
    exit(1);
};

func:test_create = int32() {
    int64:read_fd = raw Pipe.create();
    if (read_fd < 0i64) { println("FAIL: T01 create"); pass 1i32; }
    println("OK: T01 create");

    int64:wfd = raw Pipe.write_fd();
    if (wfd < 0i64) { println("FAIL: T02 write_fd"); pass 1i32; }
    println("OK: T02 write_fd valid");

    int32:cw = raw Pipe.close_write(wfd);
    int32:cr = raw Pipe.close_read(read_fd);
    pass 0i32;
};

func:test_write_read = int32() {
    int64:rfd = raw Pipe.create();
    int64:wfd = raw Pipe.write_fd();

    int32:wr = raw Pipe.write_int64(wfd, 42i64);
    if (wr != 0i32) { println("FAIL: T03 write"); pass 1i32; }
    println("OK: T03 write_int64");

    int64:val = raw Pipe.read_int64(rfd);
    if (val != 42i64) { println("FAIL: T04 read_int64"); pass 1i32; }
    println("OK: T04 read_int64");

    int32:cw = raw Pipe.close_write(wfd);
    int32:cr = raw Pipe.close_read(rfd);
    pass 0i32;
};

func:test_multi_values = int32() {
    int64:rfd = raw Pipe.create();
    int64:wfd = raw Pipe.write_fd();

    int32:w1 = raw Pipe.write_int64(wfd, 100i64);
    int32:w2 = raw Pipe.write_int64(wfd, 200i64);
    int32:w3 = raw Pipe.write_int64(wfd, 300i64);
    if (w1 != 0i32) { println("FAIL: T05 multi write 1"); pass 1i32; }
    if (w2 != 0i32) { println("FAIL: T05 multi write 2"); pass 1i32; }
    println("OK: T05 multi write");

    int64:v1 = raw Pipe.read_int64(rfd);
    int64:v2 = raw Pipe.read_int64(rfd);
    int64:v3 = raw Pipe.read_int64(rfd);
    if (v1 != 100i64) { println("FAIL: T06 multi read 1"); pass 1i32; }
    if (v2 != 200i64) { println("FAIL: T06 multi read 2"); pass 1i32; }
    if (v3 != 300i64) { println("FAIL: T06 multi read 3"); pass 1i32; }
    println("OK: T06 multi read order");

    int32:cw = raw Pipe.close_write(wfd);
    int32:cr = raw Pipe.close_read(rfd);
    pass 0i32;
};

func:test_special_values = int32() {
    int64:rfd = raw Pipe.create();
    int64:wfd = raw Pipe.write_fd();

    int32:w1 = raw Pipe.write_int64(wfd, 0i64);
    int64:v1 = raw Pipe.read_int64(rfd);
    if (v1 != 0i64) { println("FAIL: T07 zero"); pass 1i32; }
    println("OK: T07 zero roundtrip");

    int32:w2 = raw Pipe.write_int64(wfd, 0i64 - 1i64);
    int64:v2 = raw Pipe.read_int64(rfd);
    if (v2 != 0i64 - 1i64) { println("FAIL: T08 neg"); pass 1i32; }
    println("OK: T08 negative roundtrip");

    int32:cw = raw Pipe.close_write(wfd);
    int32:cr = raw Pipe.close_read(rfd);
    pass 0i32;
};

func:test_second_pipe = int32() {
    int64:rfd1 = raw Pipe.create();
    int64:wfd1 = raw Pipe.write_fd();
    int64:rfd2 = raw Pipe.create();
    int64:wfd2 = raw Pipe.write_fd();

    int32:w1 = raw Pipe.write_int64(wfd1, 111i64);
    int32:w2 = raw Pipe.write_int64(wfd2, 222i64);
    int64:v2 = raw Pipe.read_int64(rfd2);
    int64:v1 = raw Pipe.read_int64(rfd1);
    if (v1 != 111i64) { println("FAIL: T09 pipe1"); pass 1i32; }
    if (v2 != 222i64) { println("FAIL: T09 pipe2"); pass 1i32; }
    println("OK: T09 two pipes independent");

    int32:cw1 = raw Pipe.close_write(wfd1);
    int32:cr1 = raw Pipe.close_read(rfd1);
    int32:cw2 = raw Pipe.close_write(wfd2);
    int32:cr2 = raw Pipe.close_read(rfd2);
    pass 0i32;
};

func:test_close = int32() {
    int64:rfd = raw Pipe.create();
    int64:wfd = raw Pipe.write_fd();
    int32:cw = raw Pipe.close_write(wfd);
    if (cw != 0i32) { println("FAIL: T10 close_write"); pass 1i32; }
    println("OK: T10 close_write");

    int32:cr = raw Pipe.close_read(rfd);
    if (cr != 0i32) { println("FAIL: T11 close_read"); pass 1i32; }
    println("OK: T11 close_read");

    int64:rfd2 = raw Pipe.create();
    int64:wfd2 = raw Pipe.write_fd();
    int32:w = raw Pipe.write_int64(wfd2, 999i64);
    int64:v = raw Pipe.read_int64(rfd2);
    if (v != 999i64) { println("FAIL: T12 reuse after close"); pass 1i32; }
    println("OK: T12 pipe reuse after close");
    int32:cw2 = raw Pipe.close_write(wfd2);
    int32:cr2 = raw Pipe.close_read(rfd2);
    pass 0i32;
};

func:main = int32() {
    int32:r1 = raw test_create();
    if (r1 != 0i32) { exit(1); }
    int32:r2 = raw test_write_read();
    if (r2 != 0i32) { exit(1); }
    int32:r3 = raw test_multi_values();
    if (r3 != 0i32) { exit(1); }
    int32:r4 = raw test_special_values();
    if (r4 != 0i32) { exit(1); }
    int32:r5 = raw test_second_pipe();
    if (r5 != 0i32) { exit(1); }
    int32:r6 = raw test_close();
    if (r6 != 0i32) { exit(1); }
    println("PASS: all 12 pipe tests passed");
    exit(0);
};
