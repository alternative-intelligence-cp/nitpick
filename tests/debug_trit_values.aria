// Debug: Check actual trit values
func:main = int32() {
    print("=== Trit Value Debug ===");
    
    trit:a = 1;
    trit:b = -1;
    trit:c = 0;
    
    // Try to see if values are correct
    if (a == 1) {
        print("✓ a is 1");
    } else {
        print("✗ a is NOT 1");
    }
    
    if (b == -1) {
        print("✓ b is -1");
    } else {
        print("✗ b is NOT -1");
    }
    
    if (c == 0) {
        print("✓ c is 0");
    } else {
        print("✗ c is NOT 0");
    }
    
    return 0;
};

