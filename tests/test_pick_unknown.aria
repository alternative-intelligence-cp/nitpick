// Test: Pick statement with unknown patterns
// Phase 5.4: Runtime pattern matching on unknown

func:test_unknown_pattern = int32() {
    int32:x = unknown;
    
    pick(x) {
        (unknown) {
            pass(1i32);  // Should match
        },
        (*) {
            pass(0i32);  // Should not reach
        }
    }
};

func:test_known_value = int32() {
    int32:y = 42i32;
    
    pick(y) {
        (unknown) {
            pass(0i32);  // Should not match
        },
        (42i32) {
            pass(2i32);  // Should match
        },
        (*) {
            pass(0i32);  // Should not reach
        }
    }
};

func:test_priority_order = int32() {
    // Test that unknown is checked before wildcard
    int32:z = unknown;
    
    pick(z) {
        (unknown) {
            pass(3i32);  // Should match (unknown checked first)
        },
        (*) {
            pass(0i32);  // Should not reach
        }
    }
};

func:test_mixed_patterns = int32() {
    // Test unknown alongside other patterns
    int32:sensor = unknown;
    
    pick(sensor) {
        (0i32) {
            pass(0i32);  // Not unknown
        },
        (unknown) {
            pass(4i32);  // Should match
        },
        (100i32) {
            pass(0i32);  // Not reached
        },
        (*) {
            pass(0i32);  // Not reached
        }
    }
};

func:main = int32() {
    int32:test1 = raw(test_unknown_pattern());    // Should be 1
    int32:test2 = raw(test_known_value());        // Should be 2
    int32:test3 = raw(test_priority_order());     // Should be 3
    int32:test4 = raw(test_mixed_patterns());     // Should be 4
    
    int32:total = test1 + test2 + test3 + test4;
    
    if (total == 10i32) {
        pass(42i32);  // All tests passed!
    } else {
        pass(total);  // Return partial sum (debug)
    }
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
