// Debug atomic operations - create, store, load, destroy

extern func:aria_atomic_int32_create = wild int8*(int32:initial_value);
extern func:aria_atomic_int32_destroy = void(wild int8*:atomic_ptr);
extern func:aria_atomic_int32_store = void(wild int8*:atomic_ptr, int32:value, int32:order);
extern func:aria_atomic_int32_load = int32(wild int8*:atomic_ptr, int32:order);

func:main = int32() {
    // Create atomic with 0
    wild int8->:ptr = aria_atomic_int32_create(0);
    
    // Store 10
    _ = aria_atomic_int32_store(ptr, 10, 4);
    
    // Load back - should be 10
    int32:val = aria_atomic_int32_load(ptr, 4);
    
    // Cleanup
    _ = aria_atomic_int32_destroy(ptr);
    
    if (val == 10) {
        pass(0);  // SUCCESS
    } else {
        pass(1);  // FAIL
    }
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
