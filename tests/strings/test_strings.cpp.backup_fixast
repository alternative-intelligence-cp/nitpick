TEST_CASE(string_join) {
    init_gc();
    
    // Create array of strings
    AriaResultPtr array_result = aria_array_new(sizeof(AriaString*), 3, 0);
    ASSERT_MSG(array_result.error == NULL, "Array creation should succeed");
    AriaArray* array = (AriaArray*)array_result.value;
    
    AriaString* str1 = get_string(aria_string_from_cstr("hello"));
    AriaString* str2 = get_string(aria_string_from_cstr("world"));
    AriaString* str3 = get_string(aria_string_from_cstr("test"));
    
    aria_array_push(array, &str1);
    aria_array_push(array, &str2);
    aria_array_push(array, &str3);
    
    AriaString* delimiter = get_string(aria_string_from_cstr(","));
    AriaString* joined = get_string(aria_string_join(array, *delimiter));
    
    ASSERT_MSG(strings_equal(joined, "hello,world,test"), "Should join with commas");
    
    shutdown_gc();
}

TEST_CASE(string_join_empty_array) {
    init_gc();
    
