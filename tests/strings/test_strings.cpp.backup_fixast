TEST_CASE(string_split) {
    init_gc();
    
    AriaString* str = get_string(aria_string_from_cstr("hello,world,test"));
    AriaString* delimiter = get_string(aria_string_from_cstr(","));
    
    AriaResultPtr result = aria_string_split(*str, *delimiter);
    ASSERT_MSG(result.error == NULL, "Split should succeed");
    
    AriaArray* parts = (AriaArray*)result.value;
    ASSERT_EQ_MSG(parts->length, 3, "Should have 3 parts");
    
    AriaString** strings = (AriaString**)parts->data;
    ASSERT_MSG(strings_equal(strings[0], "hello"), "Part 0 should be 'hello'");
    ASSERT_MSG(strings_equal(strings[1], "world"), "Part 1 should be 'world'");
    ASSERT_MSG(strings_equal(strings[2], "test"), "Part 2 should be 'test'");
    
    shutdown_gc();
}

TEST_CASE(string_split_empty_delimiter) {
    init_gc();
    
    AriaString* str = get_string(aria_string_from_cstr("abc"));
    AriaString* empty_delim = aria_string_empty();
    
    AriaResultPtr result = aria_string_split(*str, *empty_delim);
    ASSERT_MSG(result.error == NULL, "Split with empty delimiter should succeed");
    
    AriaArray* parts = (AriaArray*)result.value;
    ASSERT_EQ_MSG(parts->length, 3, "Should split into 3 characters");
    
    AriaString** strings = (AriaString**)parts->data;
    ASSERT_MSG(strings_equal(strings[0], "a"), "Part 0 should be 'a'");
    ASSERT_MSG(strings_equal(strings[1], "b"), "Part 1 should be 'b'");
    ASSERT_MSG(strings_equal(strings[2], "c"), "Part 2 should be 'c'");
    
    shutdown_gc();
}

TEST_CASE(string_split_no_delimiter) {
    init_gc();
    
    AriaString* str = get_string(aria_string_from_cstr("hello"));
    AriaString* delimiter = get_string(aria_string_from_cstr(","));
    
    AriaResultPtr result = aria_string_split(*str, *delimiter);
