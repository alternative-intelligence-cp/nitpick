// ═══════════════════════════════════════════════════════════════════════
// Test Helpers
// ═══════════════════════════════════════════════════════════════════════

static void init_gc() {
    aria_gc_init(1024 * 1024, 512 * 1024);
}

static void shutdown_gc() {
    aria_gc_shutdown();
}

// Helper to extract AriaString* from result
static AriaString* get_string(AriaResultPtr result) {
    if (result.error) {
        return aria_string_empty();
    }
    return (AriaString*)result.value;
}

// Helper to compare strings
static bool strings_equal(AriaString* a, const char* b) {
    if (!a) return !b || strlen(b) == 0;
    if (!b) return a->length == 0;
    return a->length == (int64_t)strlen(b) && 
           memcmp(a->data, b, a->length) == 0;
}

// ═══════════════════════════════════════════════════════════════════════
// Creation Tests
// ═══════════════════════════════════════════════════════════════════════

TEST_CASE(string_from_cstr) {
    init_gc();
    
    AriaResultPtr result = aria_string_from_cstr("hello");
    ASSERT_MSG(result.error == NULL, "String creation should succeed");
    
    AriaString* str = get_string(result);
    ASSERT_EQ_MSG(str->length, 5, "Length should be 5");
    ASSERT_MSG(strings_equal(str, "hello"), "String should be 'hello'");
    
    shutdown_gc();
}

