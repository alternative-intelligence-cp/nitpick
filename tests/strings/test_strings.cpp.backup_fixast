TEST_CASE(string_trim) {
    init_gc();
    
    AriaString* str1 = get_string(aria_string_from_cstr("  hello  "));
    AriaString* trimmed1 = get_string(aria_string_trim(*str1));
    ASSERT_MSG(strings_equal(trimmed1, "hello"), "Should trim spaces");
    
    AriaString* str2 = get_string(aria_string_from_cstr("\t\nhello\r\n"));
    AriaString* trimmed2 = get_string(aria_string_trim(*str2));
    ASSERT_MSG(strings_equal(trimmed2, "hello"), "Should trim all whitespace types");
    
    AriaString* str3 = get_string(aria_string_from_cstr("   \t\n   "));
    AriaString* trimmed3 = get_string(aria_string_trim(*str3));
    ASSERT_MSG(aria_string_is_empty(*trimmed3), "All whitespace should become empty");
    
    AriaString* str4 = get_string(aria_string_from_cstr("hello"));
    AriaString* trimmed4 = get_string(aria_string_trim(*str4));
    ASSERT_MSG(strings_equal(trimmed4, "hello"), "No whitespace should stay same");
    
    shutdown_gc();
}

