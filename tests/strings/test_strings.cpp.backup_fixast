// ═══════════════════════════════════════════════════════════════════════
// Basic Operations Tests
// ═══════════════════════════════════════════════════════════════════════

TEST_CASE(string_length) {
    init_gc();
    
    AriaString* str = get_string(aria_string_from_cstr("hello"));
    ASSERT_EQ_MSG(aria_string_length(*str), 5, "Length should be 5");
    
    AriaString* empty = aria_string_empty();
    ASSERT_EQ_MSG(aria_string_length(*empty), 0, "Empty length should be 0");
    
    shutdown_gc();
}

TEST_CASE(string_equals) {
    init_gc();
    
    AriaString* a = get_string(aria_string_from_cstr("hello"));
    AriaString* b = get_string(aria_string_from_cstr("hello"));
    AriaString* c = get_string(aria_string_from_cstr("world"));
    AriaString* d = get_string(aria_string_from_cstr("hi"));
    
    ASSERT_MSG(aria_string_equals(*a, *b), "Same strings should be equal");
    ASSERT_MSG(!aria_string_equals(*a, *c), "Different strings should not be equal");
    ASSERT_MSG(!aria_string_equals(*a, *d), "Different length strings should not be equal");
    
    // Empty strings
    AriaString* e1 = aria_string_empty();
    AriaString* e2 = aria_string_empty();
    ASSERT_MSG(aria_string_equals(*e1, *e2), "Empty strings should be equal");
    
    shutdown_gc();
}

TEST_CASE(string_substring) {
    init_gc();
    
    AriaString* str = get_string(aria_string_from_cstr("hello world"));
    
    // Normal substring
    AriaString* sub1 = get_string(aria_string_substring(*str, 0, 5));
    ASSERT_MSG(strings_equal(sub1, "hello"), "Substring [0,5) should be 'hello'");
    
    AriaString* sub2 = get_string(aria_string_substring(*str, 6, 11));
    ASSERT_MSG(strings_equal(sub2, "world"), "Substring [6,11) should be 'world'");
    
    // Empty substring
    AriaString* sub3 = get_string(aria_string_substring(*str, 5, 5));
    ASSERT_MSG(aria_string_is_empty(*sub3), "Empty substring should be empty");
    
    // Out of bounds
    AriaResultPtr result = aria_string_substring(*str, -1, 5);
    ASSERT_MSG(result.is_error, "Negative start should fail");
    
    result = aria_string_substring(*str, 0, 100);
    ASSERT_MSG(result.is_error, "End beyond length should fail");
    
    result = aria_string_substring(*str, 5, 3);
    ASSERT_MSG(result.is_error, "End before start should fail");
    
    shutdown_gc();
}

TEST_CASE(string_index_of) {
    init_gc();
    
    AriaString* str = get_string(aria_string_from_cstr("hello world"));
    AriaString* needle1 = get_string(aria_string_from_cstr("world"));
    AriaString* needle2 = get_string(aria_string_from_cstr("xyz"));
    AriaString* needle3 = get_string(aria_string_from_cstr("o"));
    
    // Found
    AriaResultI64 result = aria_string_index_of(*str, *needle1);
    ASSERT_MSG(result.error == NULL, "Should find 'world'");
    ASSERT_EQ_MSG(result.value, 6, "Index should be 6");
    
    // Not found
    result = aria_string_index_of(*str, *needle2);
    ASSERT_MSG(result.is_error, "Should not find 'xyz'");
    
    // Find first occurrence
    result = aria_string_index_of(*str, *needle3);
    ASSERT_MSG(result.error == NULL, "Should find 'o'");
    ASSERT_EQ_MSG(result.value, 4, "First 'o' at index 4");
    
    // Empty needle
    AriaString* empty = aria_string_empty();
    result = aria_string_index_of(*str, *empty);
    ASSERT_MSG(result.error == NULL, "Empty needle should match at 0");
    ASSERT_EQ_MSG(result.value, 0, "Empty needle index should be 0");
    
    shutdown_gc();
}

TEST_CASE(string_contains) {
    init_gc();
    
    AriaString* str = get_string(aria_string_from_cstr("hello world"));
