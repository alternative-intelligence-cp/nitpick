TEST_CASE(string_concat) {
    init_gc();
    
    AriaString* a = get_string(aria_string_from_cstr("hello"));
    AriaString* b = get_string(aria_string_from_cstr(" world"));
    AriaString* result = get_string(aria_string_concat(*a, *b));
    
    ASSERT_MSG(strings_equal(result, "hello world"), "Should concatenate strings");
    ASSERT_EQ_MSG(result->length, 11, "Length should be sum of parts");
    
    // Concat with empty
    AriaString* empty = aria_string_empty();
    AriaString* result2 = get_string(aria_string_concat(*a, *empty));
    ASSERT_MSG(aria_string_equals(*result2, *a), "Concat with empty should equal original");
    
    shutdown_gc();
}

TEST_CASE(string_repeat) {
    init_gc();
    
    AriaString* str = get_string(aria_string_from_cstr("ha"));
    
    AriaString* repeat3 = get_string(aria_string_repeat(*str, 3));
    ASSERT_MSG(strings_equal(repeat3, "hahaha"), "Should repeat 3 times");
    
    AriaString* repeat0 = get_string(aria_string_repeat(*str, 0));
    ASSERT_MSG(aria_string_is_empty(*repeat0), "Repeat 0 times should be empty");
    
    AriaString* repeat1 = get_string(aria_string_repeat(*str, 1));
    ASSERT_MSG(strings_equal(repeat1, "ha"), "Repeat 1 time should equal original");
    
    // Negative count
    AriaResultPtr result = aria_string_repeat(*str, -1);
    ASSERT_MSG(result.is_error, "Negative count should fail");
    
    shutdown_gc();
}

