// ═══════════════════════════════════════════════════════════════════════
// Integration Tests
// ═══════════════════════════════════════════════════════════════════════

TEST_CASE(string_integration) {
    init_gc();
    
    // Complex string operations
    AriaString* str = get_string(aria_string_from_cstr("  Hello, World!  "));
    
    // Trim and lowercase
    AriaString* trimmed = get_string(aria_string_trim(*str));
    AriaString* lower = get_string(aria_string_to_lower(*trimmed));
    ASSERT_MSG(strings_equal(lower, "hello, world!"), "Trim + lower should work");
    
    // Split, modify, join
    AriaString* csv = get_string(aria_string_from_cstr("apple,banana,cherry"));
    AriaString* comma = get_string(aria_string_from_cstr(","));
    AriaResultPtr split_result = aria_string_split(*csv, *comma);
    AriaArray* fruits = (AriaArray*)split_result.value;
    
    AriaString* pipe = get_string(aria_string_from_cstr("|"));
    AriaString* joined = get_string(aria_string_join(fruits, *pipe));
    ASSERT_MSG(strings_equal(joined, "apple|banana|cherry"), "Split + join should work");
    
    shutdown_gc();
}
