    // Load back
    int32:value = atomic_int32_load(counter, 4);  // 4 = SEQ_CST
    
    // Cleanup
    atomic_int32_destroy(counter);
    
    // Check if value is 42
    if (value == 42) {
        exit 0;  // SUCCESS
    } else {
        pass 1;  // FAIL: value != 42
    }
};

