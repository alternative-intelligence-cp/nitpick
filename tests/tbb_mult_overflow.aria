// Systematically test overflow
func:main = int32() {
    tbb8:max = 127;
    tbb8:one = 1;
    tbb8:result = max + one;
    
    // If overflow IS working, result should be -128
    // If overflow NOT working, result wraps around normally (platform dependent)
    // On two's complement, 127 + 1 = -128 anyway!
    
    // So 127 + 1 in i8 = -128, which is same as ERR
    // This means we can't tell if overflow detection is working with this test!
    
    // Let's try a different test: 64 * 2 = 128, which is overflow for tbb8
    tbb8:x = 64;
    tbb8:two = 2;
    tbb8:prod = x * two;
    
    // For now, just test that multiplication compiles and runs
    // TODO: Proper ERR literal support for comparison
    return 42;
};
func:failsafe = void(int32:err_code) {
    // Error handling
};
