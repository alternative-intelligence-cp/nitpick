// Test nested Result member access in complex expressions

func:divide = int64(int64:a, int64:b) {
    if (b == 0i64) {
        fail(1i64);
    }
    pass(a / b);
};

func:safe_divide_and_double = int64(int64:a, int64:b) {
    Result<int64>:r = divide(a, b);
    if (r.is_error) {
        fail(r.error);
    }
    pass(r.value * 2i64);
};

func:main = int32() {
    // Test nested result access
    Result<int64>:r1 = safe_divide_and_double(10i64, 2i64);
    if (!r1.is_error) {
        int64:val = r1.value;  // Should be 10
    }

    Result<int64>:r2 = safe_divide_and_double(10i64, 0i64);
    if (r2.is_error) {
        int64:err = r2.error;
    }

    pass(0i32);
};

func:failsafe = NIL(int32:err_code) {};
