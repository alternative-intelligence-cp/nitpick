// Test Result member access with different value types

func:get_bool = bool() {
    pass(true);
};

func:get_int = int64() {
    pass(42i64);
};

func:get_int_fail = int64() {
    fail(1i64);
};

func:main = int32() {
    // Bool result
    Result<bool>:rb = get_bool();
    if (!rb.is_error) {
        bool:b = rb.value;
    }

    // Int result success
    Result<int64>:ri = get_int();
    if (!ri.is_error) {
        int64:v = ri.value;
    }

    // Int result error
    Result<int64>:re = get_int_fail();
    if (re.is_error) {
        int64:err = re.error;
    }

    exit(0);
};

func:failsafe = int32(tbb32:err) { exit(1); };
