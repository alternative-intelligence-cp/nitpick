// Ultra simple Result member access test
// Just test that .is_error, .value, .error compile

func:get_ok = int64() {
    pass 42;
};

func:main = int32() {
    Result<int64>:r = get_ok();
    
    // Use pick to safely access .value (compiler-enforced)
    pick(r.is_error) {
        (false) {
            // KNOWN_SUCCESS — safe to access .value
            int64:val = r.value;
            drop val;
            // .error is null on success
            int64:errptr = r.error;
            drop errptr;
            exit 0;
        },
        (true) {
            pass 1i32;
        }
    }
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
