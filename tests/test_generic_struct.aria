// Test generic pointer types (like complex numbers would use)

struct<T>:Pair = {
    T:first;
    T:second;
};

func<T>:make_pair = Pair<T>(T:a, T:b) {
    Pair<T>:p;
    p.first = a;
    p.second = b;
    pass(p);
};

func<T>:get_first = T(Pair<T>:p) {
    pass(p.first);
};

func:failsafe = NIL(int32:code) { };

func:main = int32() {
    // Test with int32 - returns Result<Pair<int32>>
    // For now, assign to untyped variable to test compilation
    Pair<int32>:r1 = raw(make_pair::<int32>(10, 20));
    
    pass(0);
};
