// Comprehensive Short-Circuit Evaluation Tests
// Tests proper short-circuit behavior for && and || operators  
// Simplified version - tests truth tables without side effects

func:main = int32() {
    // =================================================================
    // TEST 1: && truth table
    // =================================================================
    // false && false = false
    if ((1 == 0) && (2 == 0)) {
        pass(1);  // Should not execute
    }
    
    // false && true = false
    if ((1 == 0) && (1 == 1)) {
        pass(2);  // Should not execute
    }
    
    // true && false = false
    if ((1 == 1) && (1 == 0)) {
        pass(3);  // Should not execute
    }
    
    // true && true = true
    if ((1 == 1) && (2 == 2)) {
        // Should execute - this is correct
    } else {
        pass(4);  // ERROR: Should have been true
    }
    
    // =================================================================
    // TEST 2: || truth table
    // =================================================================
    // false || false = false
    if ((1 == 0) || (2 == 0)) {
        pass(5);  // Should not execute
    }
    
    // false || true = true
    if ((1 == 0) || (1 == 1)) {
        // Should execute - this is correct
    } else {
        pass(6);  // ERROR: Should have been true
    }
    
    // true || false = true
    if ((1 == 1) || (1 == 0)) {
        // Should execute - this is correct
    } else {
        pass(7);  // ERROR: Should have been true
    }
    
    // true || true = true
    if ((1 == 1) || (2 == 2)) {
        // Should execute - this is correct
    } else {
        pass(8);  // ERROR: Should have been true
    }
    
    // =================================================================
    // TEST 3: Chained && (all must be true)
    // =================================================================
    if ((1 == 1) && (2 == 2) && (3 == 3)) {
        // All true - should execute
    } else {
        pass(9);  // ERROR
    }
    
    if ((1 == 0) && (2 == 2) && (3 == 3)) {
        pass(10);  // First false - should not execute
    }
    
    if ((1 == 1) && (2 == 0) && (3 == 3)) {
        pass(11);  // Middle false - should not execute
    }
    
    if ((1 == 1) && (2 == 2) && (3 == 0)) {
        pass(12);  // Last false - should not execute
    }
    
    // =================================================================
    // TEST 4: Chained || (any can be true)
    // =================================================================
    if ((1 == 0) || (2 == 0) || (3 == 3)) {
        // Third is true - should execute
    } else {
        pass(13);  // ERROR
    }
    
    if ((1 == 1) || (2 == 0) || (3 == 0)) {
        // First is true - should execute
    } else {
        pass(14);  // ERROR
    }
    
    if ((1 == 0) || (2 == 2) || (3 == 0)) {
        // Middle is true - should execute
    } else {
        pass(15);  // ERROR
    }
    
    if ((1 == 0) || (2 == 0) || (3 == 0)) {
        pass(16);  // All false - should not execute
    }
    
    // =================================================================
    // TEST 5: Nested && and ||
    // =================================================================
    // (true && true) || false
    if (((1 == 1) && (2 == 2)) || (3 == 0)) {
        // Should execute
    } else {
        pass(17);  // ERROR
    }
    
    // (false && true) || true
    if (((1 == 0) && (2 == 2)) || (3 == 3)) {
        // Should execute (right side of || is true)
    } else {
        pass(18);  // ERROR
    }
    
    // true && (false || true)
    if ((1 == 1) && ((2 == 0) || (3 == 3))) {
        // Should execute
    } else {
        pass(19);  // ERROR
    }
    
    // false || (true && true)
    if ((1 == 0) || ((2 == 2) && (3 == 3))) {
        // Should execute (right side of || is true)
    } else {
        pass(20);  // ERROR
    }
    
    // =================================================================
    // TEST 6: Complex nested conditions
    // =================================================================
    if ((10 > 0) && (20 < 30)) {
        // true && true = true - should execute
    } else {
        pass(21);  // ERROR
    }
    
    if ((10 > 20) && (20 < 30)) {
        pass(22);  // false && true = false - should not execute
    }
    
    if ((10 > 0) || (20 > 30)) {
        // true || false = true - should execute
    } else {
        pass(23);  // ERROR
    }
    
    if ((10 > 20) || (20 > 30)) {
        pass(24);  // false || false = false - should not execute
    }
    
    // =================================================================
    // Success!
    // =================================================================
    pass(0);  // All tests passed
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
