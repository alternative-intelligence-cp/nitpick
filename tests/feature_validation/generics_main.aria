// Minimal generics test - just check if parser accepts generic syntax
// Focus ONLY on generic parsing, not on other features

// Test 1: Basic generic function declaration
func<T>:identity = *T(*T:value) {
    pass(value);
};

// Test 2: Generic with multiple parameters
func<T,U>:first_of_pair = *T(*T:a, *U:b) {
    pass(a);
};

// Test 3: Generic max (no constraints for now)
func<T>:max = *T(*T:a, *T:b) {
    if (a > b) {
        pass(a);
    }
    pass(b);
};

// Test 4: Main function calling generics
func:main = int64() {
    // Simple calls without explicit types (type inference)
    result:r1 = identity(42);
    result:r2 = first_of_pair(10, 3.14);
    
    // With turbofish (explicit types)
    result:r3 = identity::<int32>(100);
    
    pass(0);
};
