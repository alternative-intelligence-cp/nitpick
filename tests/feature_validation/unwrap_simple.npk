// Test: Unwrap operator (?) with Result<T> types

// Helper: returns 42 (at call site it becomes Result<int32>)
func:get_42 = int32() {
    pass 42i32;
};

// Helper: returns 10 (at call site it becomes Result<int32>)
func:get_10 = int32() {
    pass 10i32;
};

// Test 1: Simple unwrap - call returns Result<int32>, unwrap with default 99
func:test_unwrap = int32() {
    Result<int32>:r = get_42();
    int32:result = r ? 99i32;  // Should return 42 (success)
    pass result;
};

// Test 2: Unwrap in expression context
func:test_unwrap_expr = int32() {
    int32:five = 5i32;
    // Call returns Result<int32>, unwrap to get int32
    Result<int32>:r = get_10();
    int32:x = r ? 0i32;        // Should be 10
    int32:sum = x + five;      // Should be 10 + 5 = 15
    int32:expected_sum = 15i32;
    if (sum == expected_sum) {
        pass 0i32;  // Success
    }
    pass 1i32;  // Failure
};

// Main function
func:main = int32() {
    Result<int32>:r1 = test_unwrap();
    int32:result1 = r1 ? -1i32;
    int32:expected = 42i32;

    if (result1 == expected) {
        Result<int32>:r2 = test_unwrap_expr();
        int32:result2 = r2 ? -1i32;
        if (result2 == 0i32) {
            exit 0;  // All tests passed
        }
    }

    exit 1i32;  // Failed
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
