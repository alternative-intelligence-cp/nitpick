// Test break and continue with main function

func:test_break = int32() {
    int32:count = 0;
    
    while (count < 100) {
        count += 1;
        
        if (count == 10) {
            break;
        }
    }
    
    pass(count);  // Should return 10
};

func:test_continue = int32() {
    int32:sum = 0;
    int32:i = 0;
    
    while (i < 10) {
        i += 1;
        
        // Skip even numbers
        if (i % 2 == 0) {
            continue;
        }
        
        sum += i;
    }
    
    pass(sum);  // Should return 1+3+5+7+9 = 25
};

func:main = int32() {
    int32:result1 = test_break();
    int32:result2 = test_continue();
    
    // result1 should be 10, result2 should be 25 (1+3+5+7+9)
    // Return result1 for now
    pass(result1);
};
