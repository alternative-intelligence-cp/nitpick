// Test operators that should work with type system
// Simple arithmetic and demonstrate the IR generation

// Test simple arithmetic
func:test_add = int32() {
    pass(10 + 5);
};

func:test_subtract = int32() {
    pass(10 - 5);
};

func:test_multiply = int32() {
    pass(3 * 4);
};

func:test_divide = int32() {
    pass(20 / 4);
};

// Main
func:main = int32() {
    pass(test_add());
};
