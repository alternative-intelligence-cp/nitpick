// Test 5: Using generics with type inference (turbofish not implemented yet)
func:test_explicit = int64() {
    // Identity with int8
    int8:x1 = 42i8;
    int8:val1 = raw identity(x1);

    // Max with int64
    int64:bigger = max(100i64, 200i64);

    if (val1 == 42i8) {
        if (bigger == 200i64) {
            pass 0i64;
        }
    }
    pass 1i64;
};

// Test 6: Type inference
func:test_inference = int64() {
    // Compiler should infer T=int8
    int8:result1 = max(10i8, 20i8);

    // Compiler should infer T=int64
    int64:result3 = identity(12345678i64) ? -1i64;

    if (result1 == 20i8) {
        if (result3 == 12345678i64) {
            pass 0i64;
        }
    }
    pass 1i64;
};

