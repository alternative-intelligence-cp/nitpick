// Test 1: Basic generic identity function
func<T>:identity = *T(*T:value) {
    pass value;
};

// Test 2: Generic max function with comparison
func<T>:max = *T(*T:a, *T:b) {
    if (a > b) {
        pass a;
    }
    pass b;
};

// Test 3: Multiple generic parameters
func<T,U>:pair = int64(*T:first, *U:second) {
    // Just return success for now
    pass 0;
};

