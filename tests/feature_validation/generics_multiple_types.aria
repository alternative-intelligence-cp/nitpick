// Test: Multiple specializations of the same generic function

func<T>:identity = *T(*T:value) {
    pass(value);
};

func:main = int32() {
    // Instantiate with int32
    int32:x = 42;
    int32:y = identity(x);
    
    // Instantiate with int8 (should create another specialization)
    int8:a = 10;
    int8:b = identity(a);
    
    // Instantiate with flt64 (third specialization)
    flt64:f = 3.14;
    flt64:g = identity(f);
    
    pass(0);
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
