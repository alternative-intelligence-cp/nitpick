func:test = int32() {
    int32:counter = 0;
    {
        counter = counter + 1;
        defer {
            counter = counter + 10;
        }
        counter = counter + 1;
    }
    pass counter;
};

func:main = int32() {
    int32:value = raw test();
    if (value == 12) {
        exit 0;
    }
    exit 1;
};

