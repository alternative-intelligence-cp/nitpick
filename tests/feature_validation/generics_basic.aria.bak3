// Test 5: Using generics with explicit type parameters (turbofish ::< >)
func:test_explicit = result() {
    // Identity with explicit int8 - CORRECT turbofish syntax
    int8:val1 = identity::<int8>(42) ? 0;
    
    // Identity with explicit flt32
    flt32:val2 = identity::<flt32>(3.14) ? 0.0;
    
    // Max with explicit int32
    int32:bigger = max::<int32>(100, 200) ? 0;
    
    if (val1 == 42 && val2 == 3.14 && bigger == 200) {
        pass(0);
    }
    fail(1);
};

// Test 6: Type inference
func:test_inference = result() {
    // Compiler should infer T=int8
    int8:result1 = max(10, 20) ? 0;
    
    // Compiler should infer T=flt32
    flt32:result2 = max(1.5, 2.7) ? 0.0;
    
    // Compiler should infer T=int64
    int64:result3 = identity(12345678) ? 0;
    
    if (result1 == 20 && result2 == 2.7 && result3 == 12345678) {
        pass(0);
    }
    fail(1);
};

