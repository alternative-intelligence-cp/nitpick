// Simpler generics test - using void to avoid return type issues
// Goal: Demonstrate that type checker triggers generic specialization

// Generic function that returns the value (generic return type, not void)
func<T>:print_value = *T(*T:value) {
    pass(value);  // Return the value as-is
};

// Non-generic function that calls the generic
func:main = int32() {
    // These calls should trigger two specializations:
    // 1. print_value<int32>
    // 2. print_value<flt64>
    print_value(42);
    print_value(3.14);
    
    pass(0);
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
