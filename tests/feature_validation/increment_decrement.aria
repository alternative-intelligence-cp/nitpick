// Increment and decrement using compound operators
// (Parser doesn't support ++/-- syntax yet, but IR generation is ready)

func:test_increment = int32() {
    int32:x = 5;
    x += 1;         // 6 (equivalent to ++x)
    x += 1;         // 7
    x += 1;         // 8
    pass x;
};

func:test_decrement = int32() {
    int32:y = 10;
    y -= 1;         // 9 (equivalent to --y)
    y -= 1;         // 8
    y -= 1;         // 7
    pass y;
};

func:test_mixed = int32() {
    int32:z = 0;
    z += 1;         // 1
    z += 1;         // 2
    z += 1;         // 3
    z -= 1;         // 2
    z += 1;         // 3
    z += 1;         // 4
    pass z;
};

func:main = int32() {
    int32:a = raw test_increment();   // 8
    int32:b = raw test_decrement();   // 7
    int32:c = raw test_mixed();       // 4
    exit a + b + c;              // 8 + 7 + 4 = 19
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
