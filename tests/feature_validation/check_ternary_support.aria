// Test if parser supports ternary expressions

func:test_ternary = int32() {
    int32:x = 10;
    int32:y = 20;
    
    // Test ternary: is condition : true_value : false_value
    int32:max = is (x > y) : x : y;
    
    pass(max);
};

func:test_nested_ternary = int32() {
    int32:a = 5;
    int32:b = 10;
    int32:c = 15;
    
    // Nested ternary
    int32:max = is (a > b) : a : (is (b > c) : b : c);
    
    pass(max);
};

func:main = int32() {
    int32:r1 = raw(test_ternary());      // Should return 20
    int32:r2 = raw(test_nested_ternary()); // Should return 15
    
    pass(r1 + r2);  // 20 + 15 = 35
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
