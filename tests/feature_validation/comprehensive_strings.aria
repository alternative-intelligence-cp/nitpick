// Comprehensive string literal test
// Demonstrates string constant generation and usage

func:test_string_declaration = int64() {
    string:greeting = "Hello";
    string:name = "Aria";
    string:version = "v0.1.0";
    
    // All strings declared successfully
    pass(1);
};

func:test_empty_string = int64() {
    string:empty = "";
    
    // Empty string should work
    pass(2);
};

func:test_string_with_spaces = int64() {
    string:sentence = "The quick brown fox jumps";
    string:spaced = "  leading and trailing  ";
    
    pass(3);
};

func:test_string_with_special_chars = int64() {
    string:symbols = "!@#$%^&*()";
    string:numbers = "123456789";
    string:mixed = "Test123!@#";
    
    pass(4);
};

func:test_multiple_strings = int64() {
    string:s1 = "First";
    string:s2 = "Second";
    string:s3 = "Third";
    string:s4 = "Fourth";
    string:s5 = "Fifth";
    
    // All five strings declared
    pass(5);
};

func:test_long_string = int64() {
    string:long = "This is a much longer string that contains multiple words and demonstrates that the string literal system can handle longer text without issues.";
    
    pass(6);
};

func:test_string_reassignment = int64() {
    string:msg = "Initial";
    msg = "Changed";
    msg = "Final";
    
    // String reassignment works
    pass(7);
};

func:main = int64() {
    int32:r1 = test_string_declaration();
    int32:r2 = test_empty_string();
    int32:r3 = test_string_with_spaces();
    int32:r4 = test_string_with_special_chars();
    int32:r5 = test_multiple_strings();
    int32:r6 = test_long_string();
    int32:r7 = test_string_reassignment();
    
    // Sum: 1+2+3+4+5+6+7 = 28
    int32:total = r1 + r2 + r3;
    total += r4;
    total += r5;
    total += r6;
    total += r7;
    
    pass(total);
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
