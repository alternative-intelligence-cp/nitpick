// Quick test to see what the parser supports
// Arrays, structs, member access, indexing

func:test_array = int64() {
    // Can we declare arrays?
    int64[]:nums = [1, 2, 3, 4, 5];
    
    // Can we index them?
    int64:val = nums[2];
    
    pass(val);
};

// Can we define structs?
struct Point {
    int32:x;
    int32:y;
};

func:test_struct = int32() {
    // Can we create struct instances?
    Point:p = Point{x: 10, y: 20};
    
    // Can we access members?
    int32:x_val = p.x;
    
    pass(x_val);
};

func:main = int64() {
    int64:a = test_array();
    int32:s = test_struct();
    pass(0);
};
