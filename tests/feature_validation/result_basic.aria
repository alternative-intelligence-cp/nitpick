// TDD Test: Result Types with pass/fail and ? operator

// Test 1: Simple function returning int64
func:get_value = int64() {
    pass 42i64;
};

// Test 2: Conditional logic with fail
func:safe_divide = int64(int64:a, int64:b) {
    if (b == 0i64) {
        fail 1i32;
    }
    pass a;
};

// Test 3: Result unwrapping with ? operator
func:test_unwrap = int32() {
    // get_value() returns int64; at call site it's Result<int64>
    Result<int64>:r1 = get_value();
    int64:val = r1 ? 0i64;  // Unwrap with default value 0

    if (val == 42i64) {
        pass 0i32;  // Success
    }
    pass 1i32;  // Failure
};

func:main = int32() {
    Result<int32>:r = test_unwrap();
    int32:result = r ? -1i32;
    pass result;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
