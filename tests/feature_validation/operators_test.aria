// Test operators without control flow
// Tests: comparisons, logical ops, bitwise ops, arithmetic, unary

// Test comparison operators
func:test_equal = int32() {
    pass(10 == 10);  // Returns 1 (true)
};

func:test_not_equal = int32() {
    pass(10 != 5);  // Returns 1 (true)
};

func:test_less_than = int32() {
    pass(5 < 10);  // Returns 1 (true)
};

func:test_less_equal = int32() {
    pass(5 <= 10);  // Returns 1 (true)
};

func:test_greater = int32() {
    pass(10 > 5);  // Returns 1 (true)
};

func:test_greater_equal = int32() {
    pass(10 >= 10);  // Returns 1 (true)
};

// Test logical operators
func:test_and_true = int32() {
    pass(1 && 1);  // Returns 1 (true)
};

func:test_and_false = int32() {
    pass(1 && 0);  // Returns 0 (false)
};

func:test_or_true = int32() {
    pass(0 || 1);  // Returns 1 (true)
};

func:test_or_false = int32() {
    pass(0 || 0);  // Returns 0 (false)
};

// Test bitwise operators
func:test_bitwise_and = int32() {
    pass(12 & 10);  // 1100 & 1010 = 1000 = 8
};

func:test_bitwise_or = int32() {
    pass(12 | 10);  // 1100 | 1010 = 1110 = 14
};

func:test_bitwise_xor = int32() {
    pass(12 ^ 10);  // 1100 ^ 1010 = 0110 = 6
};

func:test_shift_left = int32() {
    pass(3 << 2);  // 3 << 2 = 12
};

func:test_shift_right = int32() {
    pass(12 >> 2);  // 12 >> 2 = 3
};

// Test arithmetic
func:test_add = int32() {
    pass(10 + 5);  // Returns 15
};

func:test_subtract = int32() {
    pass(10 - 5);  // Returns 5
};

func:test_multiply = int32() {
    pass(3 * 4);  // Returns 12
};

func:test_divide = int32() {
    pass(20 / 4);  // Returns 5
};

func:test_modulo = int32() {
    pass(17 % 5);  // Returns 2
};

// Test unary operators
func:test_negate = int32() {
    pass(-5);  // Returns -5
};

func:test_double_negate = int32() {
    pass(-(-5));  // Returns 5
};

// Test combinations
func:test_complex = int32() {
    pass((10 + 5) * 2);  // Returns 30
};

// Main entry point
func:main = int32() {
    pass(42);
};
