// Test if parser supports defer statements

func:test_defer = int32() {
    int32:value = 10;
    
    defer {
        value = 99;
    }
    
    value += 5;
    
    pass(value);
};

func:main = int64() {
    int32:result = test_defer();
    pass(result);
};

