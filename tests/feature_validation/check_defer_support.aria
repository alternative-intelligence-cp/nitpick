// Test if parser supports defer statements

func:test_defer = int32() {
    int32:value = 10;
    
    defer {
        value = 99;
    }
    
    value += 5;
    
    pass value;
};

func:main = int32() {
    int32:result = raw test_defer();
    pass result;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
