// Simple when test
func:main = int32() {
    int64:i = 0;
    int64:result = 0;
    
    when(i < 3) {
        i = i + 1;
    } then {
        result = 1;  // Executed because loop completed
    } end {
        result = 2;  // Not executed
    }
    
    pass(result);  // Should be 1
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
