// Test control flow and operators
// Tests: if/else, comparisons, logical ops, arithmetic

// Test if statement - returns 1 if condition true
func:test_if_true = int32() {
    if (10 > 5) {
        pass(1);
    };
    pass(0);
};

// Test if statement - returns 0 if condition false
func:test_if_false = int32() {
    if (3 > 5) {
        pass(1);
    };
    pass(0);
};

// Test if/else - returns 2 from else branch
func:test_if_else = int32() {
    if (3 > 5) {
        pass(1);
    } else {
        pass(2);
    };
};

// Test comparison operators
func:test_equal = int32() {
    if (10 == 10) {
        pass(1);
    };
    pass(0);
};

func:test_not_equal = int32() {
    if (10 != 5) {
        pass(1);
    };
    pass(0);
};

func:test_less_than = int32() {
    if (5 < 10) {
        pass(1);
    };
    pass(0);
};

func:test_less_equal = int32() {
    if (5 <= 10) {
        pass(1);
    };
    pass(0);
};

func:test_greater = int32() {
    if (10 > 5) {
        pass(1);
    };
    pass(0);
};

func:test_greater_equal = int32() {
    if (10 >= 10) {
        pass(1);
    };
    pass(0);
};

// Test logical operators
func:test_and = int32() {
    if (1 && 1) {
        pass(1);
    };
    pass(0);
};

func:test_or = int32() {
    if (0 || 1) {
        pass(1);
    };
    pass(0);
};

// Test arithmetic in conditions
func:test_arithmetic = int32() {
    if ((10 + 5) == 15) {
        pass(1);
    };
    pass(0);
};

func:test_multiply = int32() {
    if ((3 * 4) == 12) {
        pass(1);
    };
    pass(0);
};

// Test bitwise operators
func:test_bitwise_and = int32() {
    pass(12 & 10);  // 1100 & 1010 = 1000 = 8
};

func:test_bitwise_or = int32() {
    pass(12 | 10);  // 1100 | 1010 = 1110 = 14
};

func:test_bitwise_xor = int32() {
    pass(12 ^ 10);  // 1100 ^ 1010 = 0110 = 6
};

// Test unary minus
func:test_negate = int32() {
    pass(-5);
};

// Main entry point - sums up all test results
func:main = int32() {
    pass(
        test_if_true() +
        test_if_false() +
        test_if_else() +
        test_equal() +
        test_not_equal() +
        test_less_than() +
        test_less_equal() +
        test_greater() +
        test_greater_equal() +
        test_and() +
        test_or() +
        test_arithmetic() +
        test_multiply() +
        test_bitwise_and() +
        test_bitwise_or() +
        test_bitwise_xor() +
        test_negate()
    );
};

