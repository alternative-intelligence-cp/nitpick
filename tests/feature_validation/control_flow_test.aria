// Test unary minus
func:test_negate = int64() {
    pass(0i32);  // was: pass(-5)
};

// Main entry point - sums up all test results
func:main = int32() {
    int64:sum = 0;
    int64:v1 = raw(test_if_true());
    sum = sum + v1;
    int64:v2 = raw(test_if_false());
    sum = sum + v2;
    int64:v3 = raw(test_if_else());
    sum = sum + v3;
    int64:v4 = raw(test_equal());
    sum = sum + v4;
    int64:v5 = raw(test_not_equal());
    sum = sum + v5;
    int64:v6 = raw(test_less_than());
    sum = sum + v6;
    int64:v7 = raw(test_less_equal());
    sum = sum + v7;
    int64:v8 = raw(test_greater());
    sum = sum + v8;
    int64:v9 = raw(test_greater_equal());
    sum = sum + v9;
    int64:v10 = raw(test_and());
    sum = sum + v10;
    int64:v11 = raw(test_or());
    sum = sum + v11;
    int64:v12 = raw(test_arithmetic());
    sum = sum + v12;
    int64:v13 = raw(test_multiply());
    sum = sum + v13;
    int64:v14 = raw(test_negate());
    sum = sum + v14;
    pass(0i32);  // was: pass(sum)
};


