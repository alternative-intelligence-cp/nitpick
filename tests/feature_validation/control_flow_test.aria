// Test unary minus
func:test_negate = int64() {
    pass(-5);
};

// Main entry point - sums up all test results
func:main = int64() {
    int64:sum = 0;
    sum = sum + test_if_true();
    sum = sum + test_if_false();
    sum = sum + test_if_else();
    sum = sum + test_equal();
    sum = sum + test_not_equal();
    sum = sum + test_less_than();
    sum = sum + test_less_equal();
    sum = sum + test_greater();
    sum = sum + test_greater_equal();
    sum = sum + test_and();
    sum = sum + test_or();
    sum = sum + test_arithmetic();
    sum = sum + test_multiply();
    sum = sum + test_negate();
    pass(sum);
};

