// Test control flow and operators
// Tests: if/else, comparisons, logical ops, arithmetic

// Test if statement - returns 1 if condition true
func:test_if_true = int64() {
    if (10 > 5) {
        pass(0i32);  // was: pass(1)
    }
    pass(0i32);  // was: pass(0)
};

// Test if statement - returns 0 if condition false
func:test_if_false = int64() {
    if (3 > 5) {
        pass(0i32);  // was: pass(1)
    }
    pass(0i32);  // was: pass(0)
};

// Test if/else - returns 2 from else branch
func:test_if_else = int64() {
    if (3 > 5) {
        pass(0i32);  // was: pass(1)
    } else {
        pass(0i32);  // was: pass(2)
    }
};

// Test comparison operators
func:test_equal = int64() {
    if (10 == 10) {
        pass(0i32);  // was: pass(1)
    }
    pass(0i32);  // was: pass(0)
};

func:test_not_equal = int64() {
    if (10 != 5) {
        pass(0i32);  // was: pass(1)
    }
    pass(0i32);  // was: pass(0)
};

func:test_less_than = int64() {
    if (5 < 10) {
        pass(0i32);  // was: pass(1)
    }
    pass(0i32);  // was: pass(0)
};

func:test_less_equal = int64() {
    if (5 <= 10) {
        pass(0i32);  // was: pass(1)
    }
    pass(0i32);  // was: pass(0)
};

func:test_greater = int64() {
    if (10 > 5) {
        pass(0i32);  // was: pass(1)
    }
    pass(0i32);  // was: pass(0)
};

func:test_greater_equal = int64() {
    if (10 >= 10) {
        pass(0i32);  // was: pass(1)
    }
    pass(0i32);  // was: pass(0)
};

// Test logical operators
func:test_and = int64() {
    if (true && true) {
        pass(0i32);  // was: pass(1)
    }
    pass(0i32);  // was: pass(0)
};

func:test_or = int64() {
    if (false || true) {
        pass(0i32);  // was: pass(1)
    }
    pass(0i32);  // was: pass(0)
};

// Test arithmetic in conditions
func:test_arithmetic = int64() {
    if ((10 + 5) == 15) {
        pass(0i32);  // was: pass(1)
    }
    pass(0i32);  // was: pass(0)
};

func:test_multiply = int64() {
    if ((3 * 4) == 12) {
        pass(0i32);  // was: pass(1)
    }
    pass(0i32);  // was: pass(0)
};

