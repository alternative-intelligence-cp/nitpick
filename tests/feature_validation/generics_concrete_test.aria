// Generics test using int32 as return type (concrete type) 
// Parameters use concrete types, function body has generic logic placeholder

// Generic identity - returns int32, takes int32
func<T>:identity = int32(int32:value) {
    pass(value);
};

// Main function
func:main = int64() {
    int32:x = identity(42) ? 0;
    pass(0);
};
