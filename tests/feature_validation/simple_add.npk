// Simple arithmetic test - no generics, just regular functions

func:add = int32(int32:a, int32:b) {
    pass a + b;
};

func:main = int32() {
    int32:r = add(10, 5) ? -1i32;
    if (r == 15) {
        exit 0;
    }
    exit 1;
};

