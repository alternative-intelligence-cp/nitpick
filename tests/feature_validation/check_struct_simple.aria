// Simple Struct Test - No Forward Declarations
// Tests basic struct functionality

struct:Point = {
    int32:x;
    int32:y;
};

func:main = int32() {
    // Create a Point struct
    Point:p = Point{ x: 42, y: 100 };
    
    // Access members
    int32:x_val = p.x;
    int32:y_val = p.y;
    
    // Verify values
    if (x_val != 42) {
        pass(1);  // ERROR: x should be 42
    }
    
    if (y_val != 100) {
        pass(2);  // ERROR: y should be 100
    }
    
    pass(0);  // Success!
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
