    atomic<int64>:a4;
    
    atomic<uint8>:u1;
    atomic<uint16>:u2;
    atomic<uint32>:u3;
    atomic<uint64>:u4;
    
    atomic<bool>:b1;
    
    atomic<tbb8>:t1;
