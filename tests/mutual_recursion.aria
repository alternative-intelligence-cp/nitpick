// Mutual recursion test
// is_even calls is_odd and vice versa — verifies that forward-declaration
// pre-pass allows functions to call each other in any declaration order.

// is_even(n): true when n mod 2 == 0
// Defined BEFORE is_odd so it can only call is_odd via forward declaration
func:is_even = bool(int32:n) {
    if (n == 0i32) { pass(true); }
    Result<bool>:r = is_odd(n - 1i32);
    bool:v = r ? false;
    pass(v);
};

// is_odd(n): true when n mod 2 == 1
func:is_odd = bool(int32:n) {
    if (n == 0i32) { pass(false); }
    Result<bool>:r = is_even(n - 1i32);
    bool:v = r ? false;
    pass(v);
};

func:main = int32() {
    // is_even tests
    Result<bool>:e0 = is_even(0i32);
    bool:b0 = e0 ? false;
    if (!b0) { pass(1i32); }      // 0 is even

    Result<bool>:e2 = is_even(2i32);
    bool:b2 = e2 ? false;
    if (!b2) { pass(2i32); }      // 2 is even

    Result<bool>:e4 = is_even(4i32);
    bool:b4 = e4 ? false;
    if (!b4) { pass(3i32); }      // 4 is even

    Result<bool>:e1 = is_even(1i32);
    bool:b1 = e1 ? false;
    if (b1) { pass(4i32); }       // 1 is NOT even

    Result<bool>:e3 = is_even(3i32);
    bool:b3e = e3 ? false;
    if (b3e) { pass(5i32); }      // 3 is NOT even

    // is_odd tests
    Result<bool>:o1 = is_odd(1i32);
    bool:b1o = o1 ? false;
    if (!b1o) { pass(6i32); }     // 1 is odd

    Result<bool>:o3 = is_odd(3i32);
    bool:b3o = o3 ? false;
    if (!b3o) { pass(7i32); }     // 3 is odd

    Result<bool>:o5 = is_odd(5i32);
    bool:b5o = o5 ? false;
    if (!b5o) { pass(8i32); }     // 5 is odd

    Result<bool>:o0 = is_odd(0i32);
    bool:b0o = o0 ? false;
    if (b0o) { pass(9i32); }      // 0 is NOT odd

    Result<bool>:o2 = is_odd(2i32);
    bool:b2o = o2 ? false;
    if (b2o) { pass(10i32); }     // 2 is NOT odd

    exit(0);
};

func:failsafe = int32(tbb32:err) {
    exit(1);
};
