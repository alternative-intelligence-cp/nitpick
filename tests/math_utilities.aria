// Aria Math Utilities - Integration Test
// Medium-complexity program exercising:
//   - Multiple cooperating functions
//   - Recursion (Fibonacci)
//   - While loops (GCD, prime sieve, ipow)
//   - Result<T> with ? unwrap
//   - Boolean results
//   - Integer arithmetic (+, -, *, /, %)
//   - Early return via pass()
//   - Multiple verification assertions in main()

// ============================================================================
// Fibonacci: iterative (Aria does not support self-recursion)
// fib(0)=0, fib(1)=1, fib(10)=55
// ============================================================================
func:fib = int32(int32:n) {
    if (n == 0i32) { pass 0i32; }
    if (n == 1i32) { pass 1i32; }
    int32:a = 0i32;
    int32:b = 1i32;
    int32:i = 2i32;
    while (i <= n) {
        int32:next = a + b;
        a = b;
        b = next;
        i = i + 1i32;
    }
    pass b;
};

// ============================================================================
// GCD: Euclidean algorithm
// Tests while loop, variable reassignment, modulo
// ============================================================================
func:gcd = int32(int32:a, int32:b) {
    int32:x = a;
    int32:y = b;
    while (y != 0i32) {
        int32:t = y;
        y = x % y;
        x = t;
    }
    pass x;
};

// ============================================================================
// LCM: via GCD
// Tests using Result<T> from one function as input to calculation
// ============================================================================
func:lcm = int32(int32:a, int32:b) {
    Result<int32>:g_r = gcd(a, b);
    int32:g = g_r ? 1i32;
    pass (a / g) * b;
};

// ============================================================================
// Primality test: trial division
// Tests: multiple early returns, i*i <= n termination, modulo
// ============================================================================
func:is_prime = bool(int32:n) {
    if (n < 2i32) { pass false; }
    if (n == 2i32) { pass true; }
    if (n % 2i32 == 0i32) { pass false; }
    int32:i = 3i32;
    while (i * i <= n) {
        if (n % i == 0i32) { pass false; }
        i = i + 2i32;
    }
    pass true;
};

// ============================================================================
// Count primes up to N (inclusive)
// Tests: calling bool-returning function in a loop
// ============================================================================
func:count_primes = int32(int32:lim) {
    int32:count = 0i32;
    int32:i = 2i32;
    while (i <= lim) {
        Result<bool>:r = is_prime(i);
        bool:p = r ? false;
        if (p) { count = count + 1i32; }
        i = i + 1i32;
    }
    pass count;
};

// ============================================================================
// Integer power: base^exp via fast exponentiation (binary method)
// Tests: bit-level arithmetic, multiple assignments in a loop
// ============================================================================
func:ipow = int32(int32:base, int32:exp) {
    if (exp == 0i32) { pass 1i32; }
    int32:result = 1i32;
    int32:b = base;
    int32:e = exp;
    while (e > 0i32) {
        if (e % 2i32 == 1i32) { result = result * b; }
        b = b * b;
        e = e / 2i32;
    }
    pass result;
};

// ============================================================================
// Absolute value
// ============================================================================
func:abs_val = int32(int32:n) {
    if (n < 0i32) { pass -n; }
    pass n;
};

// ============================================================================
// Integer min and max
// ============================================================================
func:imin = int32(int32:a, int32:b) {
    if (a < b) { pass a; }
    pass b;
};

func:imax = int32(int32:a, int32:b) {
    if (a > b) { pass a; }
    pass b;
};

// ============================================================================
// Integer division ceiling: ceil(a / b)
// ============================================================================
func:ceil_div = int32(int32:a, int32:b) {
    pass (a + b - 1i32) / b;
};

// ============================================================================
// Sum of digits of a non-negative integer
// ============================================================================
func:digit_sum = int32(int32:n) {
    int32:sum = 0i32;
    int32:remaining = n;
    while (remaining > 0i32) {
        sum = sum + (remaining % 10i32);
        remaining = remaining / 10i32;
    }
    pass sum;
};

// ============================================================================
// Check if N is a perfect square
// ============================================================================
func:is_perfect_square = bool(int32:n) {
    if (n < 0i32) { pass false; }
    if (n == 0i32) { pass true; }
    int32:i = 1i32;
    while (i * i <= n) {
        if (i * i == n) { pass true; }
        i = i + 1i32;
    }
    pass false;
};

// ============================================================================
// Main: verification suite
// Each test passes a unique non-zero exit code on failure for diagnosis
// Pass(0) at the end means all tests succeeded
// ============================================================================
func:main = int32() {

    // --- Fibonacci ---
    Result<int32>:f0_r = fib(0i32);
    int32:f0 = f0_r ? 99i32;
    if (f0 != 0i32) { pass 1i32; }   // fib(0) = 0

    Result<int32>:f1_r = fib(1i32);
    int32:f1 = f1_r ? 99i32;
    if (f1 != 1i32) { pass 2i32; }   // fib(1) = 1

    Result<int32>:f5_r = fib(5i32);
    int32:f5 = f5_r ? 99i32;
    if (f5 != 5i32) { pass 3i32; }   // fib(5) = 5

    Result<int32>:f10_r = fib(10i32);
    int32:f10 = f10_r ? 99i32;
    if (f10 != 55i32) { pass 4i32; }  // fib(10) = 55

    // --- GCD ---
    Result<int32>:g1_r = gcd(12i32, 8i32);
    int32:g1 = g1_r ? 99i32;
    if (g1 != 4i32) { pass 5i32; }

    Result<int32>:g2_r = gcd(48i32, 18i32);
    int32:g2 = g2_r ? 99i32;
    if (g2 != 6i32) { pass 6i32; }

    Result<int32>:g3_r = gcd(7i32, 13i32);
    int32:g3 = g3_r ? 99i32;
    if (g3 != 1i32) { pass 7i32; }   // coprime

    Result<int32>:g4_r = gcd(100i32, 75i32);
    int32:g4 = g4_r ? 99i32;
    if (g4 != 25i32) { pass 8i32; }

    // --- LCM ---
    Result<int32>:l1_r = lcm(4i32, 6i32);
    int32:l1 = l1_r ? 99i32;
    if (l1 != 12i32) { pass 9i32; }

    Result<int32>:l2_r = lcm(5i32, 3i32);
    int32:l2 = l2_r ? 99i32;
    if (l2 != 15i32) { pass 10i32; }

    Result<int32>:l3_r = lcm(7i32, 7i32);
    int32:l3 = l3_r ? 99i32;
    if (l3 != 7i32) { pass 11i32; }  // lcm(n, n) = n

    // --- Primality ---
    Result<bool>:p1_r = is_prime(1i32);
    bool:p1 = p1_r ? true;
    if (p1) { pass 12i32; }           // 1 is NOT prime

    Result<bool>:p2_r = is_prime(2i32);
    bool:p2 = p2_r ? false;
    if (!p2) { pass 13i32; }          // 2 IS prime

    Result<bool>:p3_r = is_prime(13i32);
    bool:p3 = p3_r ? false;
    if (!p3) { pass 14i32; }          // 13 IS prime

    Result<bool>:p4_r = is_prime(15i32);
    bool:p4 = p4_r ? false;
    if (p4) { pass 15i32; }           // 15 is NOT prime (3*5)

    Result<bool>:p5_r = is_prime(97i32);
    bool:p5 = p5_r ? false;
    if (!p5) { pass 16i32; }          // 97 IS prime

    // --- Count primes ---
    // Primes up to 20: 2,3,5,7,11,13,17,19 = 8
    Result<int32>:cp1_r = count_primes(20i32);
    int32:cp1 = cp1_r ? 99i32;
    if (cp1 != 8i32) { pass 17i32; }

    // Primes up to 10: 2,3,5,7 = 4
    Result<int32>:cp2_r = count_primes(10i32);
    int32:cp2 = cp2_r ? 99i32;
    if (cp2 != 4i32) { pass 18i32; }

    // --- Integer power ---
    Result<int32>:pw1_r = ipow(2i32, 10i32);
    int32:pw1 = pw1_r ? 99i32;
    if (pw1 != 1024i32) { pass 19i32; }  // 2^10 = 1024

    Result<int32>:pw2_r = ipow(3i32, 5i32);
    int32:pw2 = pw2_r ? 99i32;
    if (pw2 != 243i32) { pass 20i32; }   // 3^5 = 243

    Result<int32>:pw3_r = ipow(7i32, 0i32);
    int32:pw3 = pw3_r ? 99i32;
    if (pw3 != 1i32) { pass 21i32; }     // n^0 = 1

    Result<int32>:pw4_r = ipow(5i32, 3i32);
    int32:pw4 = pw4_r ? 99i32;
    if (pw4 != 125i32) { pass 22i32; }   // 5^3 = 125

    // --- Abs ---
    Result<int32>:ab1_r = abs_val(-42i32);
    int32:ab1 = ab1_r ? 99i32;
    if (ab1 != 42i32) { pass 23i32; }

    Result<int32>:ab2_r = abs_val(17i32);
    int32:ab2 = ab2_r ? 99i32;
    if (ab2 != 17i32) { pass 24i32; }

    Result<int32>:ab3_r = abs_val(0i32);
    int32:ab3 = ab3_r ? 99i32;
    if (ab3 != 0i32) { pass 25i32; }

    // --- Min / Max ---
    Result<int32>:mn1_r = imin(3i32, 7i32);
    int32:mn1 = mn1_r ? 99i32;
    if (mn1 != 3i32) { pass 26i32; }

    Result<int32>:mx1_r = imax(3i32, 7i32);
    int32:mx1 = mx1_r ? 99i32;
    if (mx1 != 7i32) { pass 27i32; }

    // --- Ceiling division ---
    Result<int32>:cd1_r = ceil_div(10i32, 3i32);
    int32:cd1 = cd1_r ? 99i32;
    if (cd1 != 4i32) { pass 28i32; }   // ceil(10/3) = 4

    Result<int32>:cd2_r = ceil_div(9i32, 3i32);
    int32:cd2 = cd2_r ? 99i32;
    if (cd2 != 3i32) { pass 29i32; }   // ceil(9/3) = 3 (exact)

    // --- Digit sum ---
    Result<int32>:ds1_r = digit_sum(12345i32);
    int32:ds1 = ds1_r ? 99i32;
    if (ds1 != 15i32) { pass 30i32; }  // 1+2+3+4+5 = 15

    Result<int32>:ds2_r = digit_sum(999i32);
    int32:ds2 = ds2_r ? 99i32;
    if (ds2 != 27i32) { pass 31i32; }  // 9+9+9 = 27

    // --- Perfect square ---
    Result<bool>:ps1_r = is_perfect_square(25i32);
    bool:ps1 = ps1_r ? false;
    if (!ps1) { pass 32i32; }          // 25 = 5^2

    Result<bool>:ps2_r = is_perfect_square(26i32);
    bool:ps2 = ps2_r ? false;
    if (ps2) { pass 33i32; }           // 26 is NOT a perfect square

    Result<bool>:ps3_r = is_perfect_square(0i32);
    bool:ps3 = ps3_r ? false;
    if (!ps3) { pass 34i32; }          // 0 = 0^2

    // --- Cross-function: verify fib primes ---
    // Both fib(5)=5 and fib(8)=21 should check:
    //   is_prime(fib(5)) = is_prime(5) = true
    //   is_prime(fib(8)) = is_prime(21) = false (3*7)
    Result<int32>:f8_r = fib(8i32);
    int32:f8 = f8_r ? 99i32;
    if (f8 != 21i32) { pass 35i32; }

    Result<bool>:fibp_r = is_prime(f5);
    bool:fibp = fibp_r ? false;
    if (!fibp) { pass 36i32; }         // fib(5)=5 is prime

    Result<bool>:fibp2_r = is_prime(f8);
    bool:fibp2 = fibp2_r ? false;
    if (fibp2) { pass 37i32; }         // fib(8)=21 is NOT prime

    exit 0;  // All 37 assertions passed!
};

func:failsafe = int32(tbb32:err) {
    // Error handling fallthrough
    exit 1;
};
