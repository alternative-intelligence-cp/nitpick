// tests/type_checker_test.aria
// Tests for stdlib/type_checker.aria — Aria self-hosted type checker
use "stdlib/lexer.aria".*;
use "stdlib/parser.aria".*;
use "stdlib/type_checker.aria".*;
use "stdlib/string_convert.aria".*;

extern func:ast_free = void(wild int8*:node);
extern func:tc_free = void(wild int8*:state);
extern func:tc_error_count = int64(wild int8*:state);
extern func:tc_get_error = string(wild int8*:state, int64:idx);

func:failsafe = int32(tbb32:err) { exit(1); };

func:check_pass = NIL(bool:cond, string:msg) {
    if (cond) {
        print("  [PASS] ");
        println(msg);
    }
    if (cond == false) {
        print("  [FAIL] ");
        println(msg);
    }
};


// ═══════════════════════════════════════════════════════════════════════
// Test Group 1: Basic Type Inference (T01-T08)
// ═══════════════════════════════════════════════════════════════════════

func:test_basic_inference = int32() {
    int32:passed = 0i32;
    int32:failed = 0i32;
    println("-- Basic Type Inference ----------------------------");

    // T01: Integer variable declaration — no errors
    wild int8->:a01 = parse(tokenize("int32:x = 42i32;"));
    wild int8->:tc01 = type_check(a01);
    ast_free(a01);
    int64:e01 = tc_error_count(tc01);
    if (e01 == 0i64) {
        drop(check_pass(true, "T01 int32 var decl")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T01 int32 var decl")); failed = failed + 1i32; }
    tc_free(tc01);

    // T02: String variable declaration
    wild int8->:a02 = parse(tokenize("string:s = \"hello\";"));
    wild int8->:tc02 = type_check(a02);
    ast_free(a02);
    int64:e02 = tc_error_count(tc02);
    if (e02 == 0i64) {
        drop(check_pass(true, "T02 string var decl")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T02 string var decl")); failed = failed + 1i32; }
    tc_free(tc02);

    // T03: Bool variable declaration
    wild int8->:a03 = parse(tokenize("bool:flag = true;"));
    wild int8->:tc03 = type_check(a03);
    ast_free(a03);
    int64:e03 = tc_error_count(tc03);
    if (e03 == 0i64) {
        drop(check_pass(true, "T03 bool var decl")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T03 bool var decl")); failed = failed + 1i32; }
    tc_free(tc03);

    // T04: Float variable declaration
    wild int8->:a04 = parse(tokenize("flt64:pi = 3.14;"));
    wild int8->:tc04 = type_check(a04);
    ast_free(a04);
    int64:e04 = tc_error_count(tc04);
    if (e04 == 0i64) {
        drop(check_pass(true, "T04 flt64 var decl")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T04 flt64 var decl")); failed = failed + 1i32; }
    tc_free(tc04);

    // T05: uint32 variable
    wild int8->:a05 = parse(tokenize("uint32:u = 100u32;"));
    wild int8->:tc05 = type_check(a05);
    ast_free(a05);
    int64:e05 = tc_error_count(tc05);
    if (e05 == 0i64) {
        drop(check_pass(true, "T05 uint32 var decl")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T05 uint32 var decl")); failed = failed + 1i32; }
    tc_free(tc05);

    // T06: Type mismatch — string assigned to int32
    wild int8->:a06 = parse(tokenize("int32:x = \"hello\";"));
    wild int8->:tc06 = type_check(a06);
    ast_free(a06);
    int64:e06 = tc_error_count(tc06);
    if (e06 > 0i64) {
        drop(check_pass(true, "T06 type mismatch detected")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T06 type mismatch detected")); failed = failed + 1i32; }
    tc_free(tc06);

    // T07: Undefined identifier
    wild int8->:a07 = parse(tokenize("int32:y = undefined_var;"));
    wild int8->:tc07 = type_check(a07);
    ast_free(a07);
    int64:e07 = tc_error_count(tc07);
    if (e07 > 0i64) {
        drop(check_pass(true, "T07 undefined identifier")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T07 undefined identifier")); failed = failed + 1i32; }
    tc_free(tc07);

    // T08: Multiple declarations, second uses first
    wild int8->:a08 = parse(tokenize("int32:a = 1i32; int32:b = a;"));
    wild int8->:tc08 = type_check(a08);
    ast_free(a08);
    int64:e08 = tc_error_count(tc08);
    if (e08 == 0i64) {
        drop(check_pass(true, "T08 var uses previous var")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T08 var uses previous var")); failed = failed + 1i32; }
    tc_free(tc08);

    println("");
    print("  Basic Inference: ");
    print(int32_toString(passed));
    print(" passed, ");
    print(int32_toString(failed));
    println(" failed");
    println("");

    int32:total = passed + failed;
    pass(total);
};


// ═══════════════════════════════════════════════════════════════════════
// Test Group 2: Binary Operations (T09-T12)
// ═══════════════════════════════════════════════════════════════════════

func:test_binary_ops = int32() {
    int32:passed = 0i32;
    int32:failed = 0i32;
    println("-- Binary Operations --------------------------------");

    // T09: int32 + int32 — no error
    wild int8->:a09 = parse(tokenize("int32:a = 1i32; int32:b = 2i32; int32:c = a + b;"));
    wild int8->:tc09 = type_check(a09);
    ast_free(a09);
    int64:e09 = tc_error_count(tc09);
    if (e09 == 0i64) {
        drop(check_pass(true, "T09 int32 addition")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T09 int32 addition")); failed = failed + 1i32; }
    tc_free(tc09);

    // T10: bool == bool — comparison
    wild int8->:a10 = parse(tokenize("bool:a = true; bool:b = false; bool:c = a == b;"));
    wild int8->:tc10 = type_check(a10);
    ast_free(a10);
    int64:e10 = tc_error_count(tc10);
    if (e10 == 0i64) {
        drop(check_pass(true, "T10 bool comparison")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T10 bool comparison")); failed = failed + 1i32; }
    tc_free(tc10);

    // T11: bool && bool — logical
    wild int8->:a11 = parse(tokenize("bool:a = true; bool:b = false; bool:c = a && b;"));
    wild int8->:tc11 = type_check(a11);
    ast_free(a11);
    int64:e11 = tc_error_count(tc11);
    if (e11 == 0i64) {
        drop(check_pass(true, "T11 logical AND")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T11 logical AND")); failed = failed + 1i32; }
    tc_free(tc11);

    // T12: string + string — concatenation
    wild int8->:a12 = parse(tokenize("string:a = \"foo\"; string:b = \"bar\"; string:c = a + b;"));
    wild int8->:tc12 = type_check(a12);
    ast_free(a12);
    int64:e12 = tc_error_count(tc12);
    if (e12 == 0i64) {
        drop(check_pass(true, "T12 string concatenation")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T12 string concatenation")); failed = failed + 1i32; }
    tc_free(tc12);

    println("");
    print("  Binary Ops: ");
    print(int32_toString(passed));
    print(" passed, ");
    print(int32_toString(failed));
    println(" failed");
    println("");

    int32:total = passed + failed;
    pass(total);
};


// ═══════════════════════════════════════════════════════════════════════
// Test Group 3: Function Declarations (T13-T16)
// ═══════════════════════════════════════════════════════════════════════

func:test_functions = int32() {
    int32:passed = 0i32;
    int32:failed = 0i32;
    println("-- Function Declarations ----------------------------");

    // T13: Simple function declaration
    wild int8->:a13 = parse(tokenize("func:add = int32(int32:a, int32:b) { pass(a + b); };"));
    wild int8->:tc13 = type_check(a13);
    ast_free(a13);
    int64:e13 = tc_error_count(tc13);
    if (e13 == 0i64) {
        drop(check_pass(true, "T13 simple function")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T13 simple function")); failed = failed + 1i32; }
    tc_free(tc13);

    // T14: Forward function call — caller uses callee defined later
    wild int8->:a14 = parse(tokenize("func:caller = int32() { int32:r = raw(callee()); pass(r); }; func:callee = int32() { pass(42i32); };"));
    wild int8->:tc14 = type_check(a14);
    ast_free(a14);
    int64:e14 = tc_error_count(tc14);
    if (e14 == 0i64) {
        drop(check_pass(true, "T14 forward function call")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T14 forward function call")); failed = failed + 1i32; }
    tc_free(tc14);

    // T15: Extern function — valid
    wild int8->:a15 = parse(tokenize("extern func:cfunc = int32(int32:x);"));
    wild int8->:tc15 = type_check(a15);
    ast_free(a15);
    int64:e15 = tc_error_count(tc15);
    if (e15 == 0i64) {
        drop(check_pass(true, "T15 extern function")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T15 extern function")); failed = failed + 1i32; }
    tc_free(tc15);

    // T16: Calling function with wrong number of args
    wild int8->:a16 = parse(tokenize("func:take_two = int32(int32:a, int32:b) { pass(a); }; func:caller = int32() { int32:r = raw(take_two(1i32)); pass(r); };"));
    wild int8->:tc16 = type_check(a16);
    ast_free(a16);
    int64:e16 = tc_error_count(tc16);
    if (e16 > 0i64) {
        drop(check_pass(true, "T16 wrong arg count")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T16 wrong arg count")); failed = failed + 1i32; }
    tc_free(tc16);

    println("");
    print("  Functions: ");
    print(int32_toString(passed));
    print(" passed, ");
    print(int32_toString(failed));
    println(" failed");
    println("");

    int32:total = passed + failed;
    pass(total);
};


// ═══════════════════════════════════════════════════════════════════════
// Test Group 4: Scope & Symbol Table (T17-T20)
// ═══════════════════════════════════════════════════════════════════════

func:test_scope = int32() {
    int32:passed = 0i32;
    int32:failed = 0i32;
    println("-- Scope & Symbol Table -----------------------------");

    // T17: Variable visible in inner block
    wild int8->:a17 = parse(tokenize("int32:x = 1i32; if (true) { int32:y = x; }"));
    wild int8->:tc17 = type_check(a17);
    ast_free(a17);
    int64:e17 = tc_error_count(tc17);
    if (e17 == 0i64) {
        drop(check_pass(true, "T17 var visible in block")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T17 var visible in block")); failed = failed + 1i32; }
    tc_free(tc17);

    // T18: Inner scope not visible outside
    wild int8->:a18 = parse(tokenize("func:f = NIL() { int32:inner = 5i32; }; int32:z = inner;"));
    wild int8->:tc18 = type_check(a18);
    ast_free(a18);
    int64:e18 = tc_error_count(tc18);
    if (e18 > 0i64) {
        drop(check_pass(true, "T18 scope isolation")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T18 scope isolation")); failed = failed + 1i32; }
    tc_free(tc18);

    // T19: Redefinition in same scope — error
    wild int8->:a19 = parse(tokenize("int32:dup = 1i32; int32:dup = 2i32;"));
    wild int8->:tc19 = type_check(a19);
    ast_free(a19);
    int64:e19 = tc_error_count(tc19);
    if (e19 > 0i64) {
        drop(check_pass(true, "T19 redefinition error")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T19 redefinition error")); failed = failed + 1i32; }
    tc_free(tc19);

    // T20: Parameters visible within function body
    wild int8->:a20 = parse(tokenize("func:use_param = int32(int32:val) { pass(val); };"));
    wild int8->:tc20 = type_check(a20);
    ast_free(a20);
    int64:e20 = tc_error_count(tc20);
    if (e20 == 0i64) {
        drop(check_pass(true, "T20 param in body")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T20 param in body")); failed = failed + 1i32; }
    tc_free(tc20);

    println("");
    print("  Scope: ");
    print(int32_toString(passed));
    print(" passed, ");
    print(int32_toString(failed));
    println(" failed");
    println("");

    int32:total = passed + failed;
    pass(total);
};


// ═══════════════════════════════════════════════════════════════════════
// Test Group 5: Control Flow (T21-T24)
