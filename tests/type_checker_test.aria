// ═══════════════════════════════════════════════════════════════════════
// Test Group 7: Type System Features (T27-T35)
// ═══════════════════════════════════════════════════════════════════════

func:test_type_features = int32() {
    int32:passed = 0i32;
    int32:failed = 0i32;
    println("-- Type System Features ----------------------------");

    // T27: Multiple int32 declarations
    wild int8->:a27 = parse(tokenize("int32:a = 1i32; int32:b = 2i32;"));
    wild int8->:tc27 = type_check(a27);
    ast_free(a27);
    int64:e27 = tc_error_count(tc27);
    if (e27 == 0i64) {
        drop(check_pass(true, "T27 multiple int32 decls")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T27 multiple int32 decls")); failed = failed + 1i32; }
    tc_free(tc27);

    // T28: Unary negation on signed type
    wild int8->:a28 = parse(tokenize("int32:x = 5i32; int32:y = -x;"));
    wild int8->:tc28 = type_check(a28);
    ast_free(a28);
    int64:e28 = tc_error_count(tc28);
    if (e28 == 0i64) {
        drop(check_pass(true, "T28 unary negation")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T28 unary negation")); failed = failed + 1i32; }
    tc_free(tc28);

    // T29: Logical NOT on bool
    wild int8->:a29 = parse(tokenize("bool:a = true; bool:b = !a;"));
    wild int8->:tc29 = type_check(a29);
    ast_free(a29);
    int64:e29 = tc_error_count(tc29);
    if (e29 == 0i64) {
        drop(check_pass(true, "T29 logical NOT")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T29 logical NOT")); failed = failed + 1i32; }
    tc_free(tc29);

    // T30: int64 widening from int32 — should coerce
    wild int8->:a30 = parse(tokenize("int32:x = 1i32; int64:y = x;"));
    wild int8->:tc30 = type_check(a30);
    ast_free(a30);
    int64:e30 = tc_error_count(tc30);
    if (e30 == 0i64) {
        drop(check_pass(true, "T30 int32->int64 coercion")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T30 int32->int64 coercion")); failed = failed + 1i32; }
    tc_free(tc30);

    // T31: flt64 cannot be assigned to int32
    wild int8->:a31 = parse(tokenize("int32:x = 3.14;"));
    wild int8->:tc31 = type_check(a31);
    ast_free(a31);
    int64:e31 = tc_error_count(tc31);
    if (e31 > 0i64) {
        drop(check_pass(true, "T31 flt64 to int32 rejected")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T31 flt64 to int32 rejected")); failed = failed + 1i32; }
    tc_free(tc31);

    // T32: Unknown type in declaration — error
    wild int8->:a32 = parse(tokenize("Nonexistent:x = 42i32;"));
    wild int8->:tc32 = type_check(a32);
    ast_free(a32);
    int64:e32 = tc_error_count(tc32);
    if (e32 > 0i64) {
        drop(check_pass(true, "T32 unknown type")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T32 unknown type")); failed = failed + 1i32; }
    tc_free(tc32);

    // T33: flt32 variable
    wild int8->:a33 = parse(tokenize("flt32:f = 1.0f32;"));
    wild int8->:tc33 = type_check(a33);
    ast_free(a33);
    int64:e33 = tc_error_count(tc33);
    if (e33 == 0i64) {
        drop(check_pass(true, "T33 flt32 var decl")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T33 flt32 var decl")); failed = failed + 1i32; }
    tc_free(tc33);

    // T34: int8 variable
    wild int8->:a34 = parse(tokenize("int8:b = 10i8;"));
    wild int8->:tc34 = type_check(a34);
    ast_free(a34);
    int64:e34 = tc_error_count(tc34);
    if (e34 == 0i64) {
        drop(check_pass(true, "T34 int8 var decl")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T34 int8 var decl")); failed = failed + 1i32; }
    tc_free(tc34);

    // T35: int64 variable
    wild int8->:a35 = parse(tokenize("int64:big = 999i64;"));
    wild int8->:tc35 = type_check(a35);
    ast_free(a35);
    int64:e35 = tc_error_count(tc35);
    if (e35 == 0i64) {
        drop(check_pass(true, "T35 int64 var decl")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T35 int64 var decl")); failed = failed + 1i32; }
    tc_free(tc35);

    println("");
    print("  Type Features: ");
    print(int32_toString(passed));
    print(" passed, ");
    print(int32_toString(failed));
    println(" failed");
    println("");

    int32:total = passed + failed;
    pass(total);
};


// ═══════════════════════════════════════════════════════════════════════
// Test Group 8: Error Reporting Quality (T36-T40)
// ═══════════════════════════════════════════════════════════════════════

func:test_error_reporting = int32() {
    int32:passed = 0i32;
    int32:failed = 0i32;
    println("-- Error Reporting ---------------------------------");

    // T36: Error count is accurate for multiple errors
    wild int8->:a36 = parse(tokenize("int32:a = undefined1; int32:b = undefined2;"));
    wild int8->:tc36 = type_check(a36);
    ast_free(a36);
    int64:e36 = tc_error_count(tc36);
    if (e36 >= 2i64) {
        drop(check_pass(true, "T36 multiple errors counted")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T36 multiple errors counted")); failed = failed + 1i32; }
    tc_free(tc36);

    // T37: Error for undefined reference
    wild int8->:a37 = parse(tokenize("int32:myvar = missing_name;"));
    wild int8->:tc37 = type_check(a37);
    ast_free(a37);
    int64:e37 = tc_error_count(tc37);
    if (e37 > 0i64) {
        drop(check_pass(true, "T37 error for undefined")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T37 error for undefined")); failed = failed + 1i32; }
    tc_free(tc37);

    // T38: No errors on valid program
    wild int8->:a38 = parse(tokenize("int32:x = 1i32; int32:y = 2i32; int32:z = x + y;"));
    wild int8->:tc38 = type_check(a38);
    ast_free(a38);
    int64:e38 = tc_error_count(tc38);
    if (e38 == 0i64) {
        drop(check_pass(true, "T38 valid program no errors")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T38 valid program no errors")); failed = failed + 1i32; }
    tc_free(tc38);

    // T39: Empty program — no errors
    wild int8->:a39 = parse(tokenize(""));
    wild int8->:tc39 = type_check(a39);
    ast_free(a39);
    int64:e39 = tc_error_count(tc39);
    if (e39 == 0i64) {
        drop(check_pass(true, "T39 empty program")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T39 empty program")); failed = failed + 1i32; }
    tc_free(tc39);

    // T40: Single valid statement
    wild int8->:a40 = parse(tokenize("bool:done = false;"));
    wild int8->:tc40 = type_check(a40);
    ast_free(a40);
    int64:e40 = tc_error_count(tc40);
    if (e40 == 0i64) {
        drop(check_pass(true, "T40 single valid stmt")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T40 single valid stmt")); failed = failed + 1i32; }
    tc_free(tc40);

    println("");
    print("  Error Reporting: ");
    print(int32_toString(passed));
    print(" passed, ");
    print(int32_toString(failed));
    println(" failed");
    println("");

    int32:total = passed + failed;
    pass(total);
};


