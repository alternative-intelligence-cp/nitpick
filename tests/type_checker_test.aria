    } else { drop(check_pass(false, "T21 if bool condition")); failed = failed + 1i32; }
    tc_free(tc21);

    // T22: While loop with bool condition — valid
    wild int8->:a22 = parse(tokenize("bool:running = true; while (running) { running = false; }"));
    wild int8->:tc22 = type_check(a22);
    ast_free(a22);
    int64:e22 = tc_error_count(tc22);
    if (e22 == 0i64) {
        drop(check_pass(true, "T22 while bool condition")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T22 while bool condition")); failed = failed + 1i32; }
    tc_free(tc22);

    // T23: If with non-bool condition — error
    wild int8->:a23 = parse(tokenize("int32:x = 1i32; if (x) { int32:y = 2i32; }"));
    wild int8->:tc23 = type_check(a23);
    ast_free(a23);
    int64:e23 = tc_error_count(tc23);
    if (e23 > 0i64) {
        drop(check_pass(true, "T23 non-bool if condition")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T23 non-bool if condition")); failed = failed + 1i32; }
    tc_free(tc23);

    // T24: If-else with both branches
    wild int8->:a24 = parse(tokenize("bool:c = true; if (c) { int32:a = 1i32; } else { int32:b = 2i32; }"));
    wild int8->:tc24 = type_check(a24);
    ast_free(a24);
    int64:e24 = tc_error_count(tc24);
    if (e24 == 0i64) {
        drop(check_pass(true, "T24 if-else branches")); passed = passed + 1i32;
    } else { drop(check_pass(false, "T24 if-else branches")); failed = failed + 1i32; }
    tc_free(tc24);

    println("");
    print("  Control Flow: ");
    print(int32_toString(passed));
    print(" passed, ");
    print(int32_toString(failed));
    println(" failed");
    println("");

    int32:total = passed + failed;
    pass(total);
};


