// Test 1: Basic move syntax
func:test_move = int32() {
    int32:x = 42;
    int32:y = move(x);  // move() should parse and type-check
    
    int32:zero = 0;
    pass(zero);
};

func:main = int32() {
    Result<int32>:r = test_move();
    pick(r.is_error) {
        (false) { pass(r.value); },
        (true) { pass(1i32); }
    }
};

func:failsafe = NIL(int32:err_code) {
