/**
 * Test with template literal FIRST
 */

func:failsafe = int32(tbb32:err) {
    exit 1;
};

func:main = int32() {
    int32:x = 42;
    
    // Template literal FIRST      
    drop println(`Test 1: x = &{x}`);
    
    // Plain text SECOND
    drop println("Test 2: Plain text");
    
    drop println("Test 3: After both");
    exit 0;
};
