    ASSERT_MSG(!unique_result.is_error, "Assertion should pass");
    
    AriaArray* unique = (AriaArray*)unique_result.value;
    ASSERT_EQ_MSG(unique->length, 5, "Values should match"); // 1, 2, 3, 4, 5
    
    // Verify unique values (preserves first occurrence order)
    int64_t expected[] = {1, 2, 3, 4, 5};
    for (int i = 0; i < 5; i++) {
        AriaResultPtr get_result = aria_array_get(unique, i);
        int64_t* elem = (int64_t*)get_result.value;
        ASSERT_EQ_MSG(*elem, expected[i], "Values should match");
    }
    
    shutdown_gc();
}

TEST_CASE(array_chain_operations) {
    init_gc();
    
    AriaResultPtr result = aria_array_new(sizeof(int64_t), 10, 0);
    AriaArray* array = (AriaArray*)result.value;
    
    // Push values 1-10
    for (int i = 1; i <= 10; i++) {
        int64_t value = i;
        aria_array_push(array, &value);
    }
    
    // Chain: filter even, transform *2, reduce sum
    // Even numbers: 2, 4, 6, 8, 10
    AriaResultPtr filtered_result = aria_array_filter(array, is_even, nullptr);
    ASSERT_MSG(!filtered_result.is_error, "Assertion should pass");
    AriaArray* filtered = (AriaArray*)filtered_result.value;
    
    // Transform: 4, 8, 12, 16, 20
    AriaResultPtr transformed_result = aria_array_transform(filtered, multiply_by_two,
                                                            sizeof(int64_t), 0, nullptr);
    ASSERT_MSG(!transformed_result.is_error, "Assertion should pass");
    AriaArray* transformed = (AriaArray*)transformed_result.value;
    
    // Sum: 4+8+12+16+20 = 60
    int64_t initial = 0;
    AriaResultPtr sum_result = aria_array_reduce(transformed, sum_reducer,
                                                  &initial, sizeof(int64_t), nullptr);
    ASSERT_MSG(!sum_result.is_error, "Assertion should pass");
    int64_t* sum = (int64_t*)sum_result.value;
    ASSERT_EQ_MSG(*sum, 60, "Values should match");
    
    shutdown_gc();
}
