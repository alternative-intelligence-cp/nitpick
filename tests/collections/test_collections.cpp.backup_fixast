TEST_CASE(array_push_grows_capacity) {
    init_gc();
    
    AriaResultPtr result = aria_array_new(sizeof(int64_t), 2, 0);
    AriaArray* array = (AriaArray*)result.value;
    
    size_t initial_capacity = array->capacity;
    
    // Push more than initial capacity
    for (int i = 0; i < 10; i++) {
        int64_t value = i;
        aria_array_push(array, &value);
    }
    
    ASSERT_EQ_MSG(array->length, 10, "Values should match");
    ASSERT_MSG(array->capacity > initial_capacity, "Assertion should pass");
    
    // Verify all values intact
    for (int i = 0; i < 10; i++) {
        AriaResultPtr get_result = aria_array_get(array, i);
        int64_t* elem = (int64_t*)get_result.value;
        ASSERT_EQ_MSG(*elem, i, "Values should match");
    }
    
    shutdown_gc();
}

