// Helper to initialize GC for tests that need it
static void init_gc() {
    aria_gc_init(1024 * 1024, 512 * 1024);
}

static void shutdown_gc() {
    aria_gc_shutdown();
}

// Helper predicates and functions for testing
static bool is_even(const void* element, size_t index, void* context) {
    (void)index; (void)context;
    int64_t value = *(const int64_t*)element;
    return value % 2 == 0;
}

static bool is_positive(const void* element, size_t index, void* context) {
    (void)index; (void)context;
    int64_t value = *(const int64_t*)element;
    return value > 0;
}

static void multiply_by_two(const void* element, size_t index, void* out_element, void* context) {
    (void)index; (void)context;
    int64_t value = *(const int64_t*)element;
    *(int64_t*)out_element = value * 2;
}

static void sum_reducer(void* accumulator, const void* element, size_t index, void* context) {
    (void)index; (void)context;
    *(int64_t*)accumulator += *(const int64_t*)element;
}

static int compare_i64(const void* a, const void* b, void* context) {
    (void)context;
    int64_t va = *(const int64_t*)a;
    int64_t vb = *(const int64_t*)b;
    if (va < vb) return -1;
    if (va > vb) return 1;
    return 0;
}

