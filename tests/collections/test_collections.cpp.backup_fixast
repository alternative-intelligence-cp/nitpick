TEST_CASE(array_filter) {
    init_gc();
    
    AriaResultPtr result = aria_array_new(sizeof(int64_t), 10, 0);
    AriaArray* array = (AriaArray*)result.value;
    
    // Push values 1-10
    for (int i = 1; i <= 10; i++) {
        int64_t value = i;
        aria_array_push(array, &value);
    }
    
    // Filter even numbers
    AriaResultPtr filter_result = aria_array_filter(array, is_even, nullptr);
    ASSERT_MSG(!filter_result.is_error, "Assertion should pass");
    
    AriaArray* filtered = (AriaArray*)filter_result.value;
    ASSERT_EQ_MSG(filtered->length, 5, "Values should match"); // 2, 4, 6, 8, 10
    
    // Verify filtered values
    int64_t expected[] = {2, 4, 6, 8, 10};
    for (int i = 0; i < 5; i++) {
        AriaResultPtr get_result = aria_array_get(filtered, i);
        int64_t* elem = (int64_t*)get_result.value;
        ASSERT_EQ_MSG(*elem, expected[i], "Values should match");
    }
    
    shutdown_gc();
}

