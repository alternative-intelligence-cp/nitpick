TEST_CASE(array_pop) {
    init_gc();
    
    AriaResultPtr result = aria_array_new(sizeof(int64_t), 10, 0);
    AriaArray* array = (AriaArray*)result.value;
    
    // Push values
    int64_t values[] = {10, 20, 30};
    for (int i = 0; i < 3; i++) {
        aria_array_push(array, &values[i]);
    }
    
    // Pop last value
    int64_t popped;
    AriaResultVoid pop_result = aria_array_pop(array, &popped);
    ASSERT_MSG(!pop_result.is_error, "Assertion should pass");
    ASSERT_EQ_MSG(popped, 30, "Values should match");
    ASSERT_EQ_MSG(array->length, 2, "Values should match");
    
    // Pop without storing value
    pop_result = aria_array_pop(array, nullptr);
    ASSERT_MSG(!pop_result.is_error, "Assertion should pass");
    ASSERT_EQ_MSG(array->length, 1, "Values should match");
    
    shutdown_gc();
}

