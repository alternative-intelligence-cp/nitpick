// Comprehensive range expression tests
// Testing actual range creation and usage

func:main = int32() {
    // Create some range expressions
    // Note: These create range structs but we need for loops to iterate
    
    int64:a = 1;
    int64:b = 10;
    
    // For now, just verify that range syntax parses
    // Range expressions will be fully useful when for loops support them
    
    print("Testing range syntax:");
    print("Creating inclusive range 1..10");
    print("Creating exclusive range 1...10");
    
    // Basic arithmetic with range bounds
    int64:inclusive_count = b - a + 1;  // 10 - 1 + 1 = 10 elements
    int64:exclusive_count = b - a;      // 10 - 1 = 9 elements
    
    print("Inclusive range would have:");
    print(inclusive_count);
    print("Exclusive range would have:");
    print(exclusive_count);
    
    pass(0);
};
