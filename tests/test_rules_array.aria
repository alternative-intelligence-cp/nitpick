// test_rules_array.aria — v0.2.44 Rules<T[]> Array Indexing & $.length
extern func:puts = int32(string:s);

// Rules that array's first element must be positive
Rules<int32[]>:arr_first_positive = {
    $[0] > 0
};

// Rules that array length must be >= 4
Rules<int32[]>:arr_min_length = {
    $.length >= 4
};

// Rules combining $[idx] and $.length
Rules<int32[]>:arr_valid = {
    $[0] > 0,
    $.length >= 2
};

func:failsafe = int32(tbb32:err) {
    drop puts("FAILSAFE: array rule violation!");
    exit 1;
};

func:main = int32() {
    int32:passed = 0i32;
    int32:failed = 0i32;

    // ----------------------------------------------------------
    // Test 1: Rules<int32[]> with $[0] > 0
    // ----------------------------------------------------------
    limit<arr_first_positive> int32[4]:arr1 = [5, 10, 15, 20];
    if (arr1[0] == 5) {
        drop puts("PASS: Test 1 — Rules<int32[]> $[0] > 0");
        passed += 1i32;
    } else {
        drop puts("FAIL: Test 1");
        failed += 1i32;
    }

    // ----------------------------------------------------------
    // Test 2: Rules<int32[]> with $.length >= 4
    // ----------------------------------------------------------
    limit<arr_min_length> int32[6]:arr2 = [1, 2, 3, 4, 5, 6];
    if (arr2[0] == 1) {
        drop puts("PASS: Test 2 — Rules<int32[]> $.length >= 4");
        passed += 1i32;
    } else {
        drop puts("FAIL: Test 2");
        failed += 1i32;
    }

    // ----------------------------------------------------------
    // Test 3: Rules<int32[]> with combined $[0] and $.length
    // ----------------------------------------------------------
    limit<arr_valid> int32[3]:arr3 = [42, 100, 200];
    if (arr3[0] == 42) {
        drop puts("PASS: Test 3 — Rules<int32[]> combined conditions");
        passed += 1i32;
    } else {
        drop puts("FAIL: Test 3");
        failed += 1i32;
    }

    // ----------------------------------------------------------
    // Results
    // ----------------------------------------------------------
    if (failed > 0i32) {
        drop puts("SOME TESTS FAILED");
        pass 1;
    }
    drop puts("All array rules tests passed!");
    exit 0;
};
