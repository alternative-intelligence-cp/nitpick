// Test string manipulation operations
// Phase 4.3 String Library Testing

func:main = int32() {
    // Test 1: String concatenation
    string:hello = "Hello";
    string:world = "World";
    string:combined = string_concat(hello, world);
    int64:combined_len = string_length(combined);
    print(combined_len);  // Should print 10 (HelloWorld)
    
    // Test 2: String substring
    string:original = "Hello World";
    string:sub = string_substring(original, 0, 5);  // "Hello"
    int64:sub_len = string_length(sub);
    print(sub_len);  // Should print 5
    
    // Test 3: String trim
    string:padded = "  trim me  ";
    string:trimmed = string_trim(padded);
    int64:trimmed_len = string_length(trimmed);
    print(trimmed_len);  // Should print 7 (without spaces)
    
    // Test 4: String to uppercase
    string:lower = "lowercase";
    string:upper = string_to_upper(lower);
    bool:contains_upper = string_contains(upper, "LOWER");
    if (contains_upper) {
        print(1);  // Should print 1
    }
    
    // Test 5: String to lowercase
    string:mixed = "MiXeD CaSe";
    string:all_lower = string_to_lower(mixed);
    bool:contains_mixed = string_contains(all_lower, "mixed");
    if (contains_mixed) {
        print(1);  // Should print 1
    }
    
    pass(0);
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
