// Test basic string operations
// Phase 4.3 String Library Testing

func:main = int64() {
    // Test 1: String creation and length
    string:msg = "Hello, Aria!";
    int64:len = string_length(msg);
    print(len);  // Should print 12
    
    // Test 2: String equality
    string:s1 = "test";
    string:s2 = "test";
    bool:equal = string_equals(s1, s2);
    if (equal) {
        print(1);  // Should print 1
    }
    
    // Test 3: String containment
    string:sentence = "The quick brown fox";
    bool:has_quick = string_contains(sentence, "quick");
    if (has_quick) {
        print(1);  // Should print 1
    }
    
    // Test 4: Starts with / ends with
    string:path = "/home/user/file.txt";
    bool:starts = string_starts_with(path, "/home");
    bool:ends = string_ends_with(path, ".txt");
    if (starts && ends) {
        print(1);  // Should print 1
    }
    
    // Test 5: Empty string check
    string:empty = "";
    bool:is_empty = string_is_empty(empty);
    if (is_empty) {
        print(1);  // Should print 1
    }
    
    pass(0);
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
