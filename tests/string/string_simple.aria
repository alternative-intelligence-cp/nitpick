// Simplified string test using C-string interop
// Phase 4.3 String Library Testing

func:main = int32() {
    // Test string_from_cstr - convert C string to Aria string
    string:msg = string_from_cstr("Hello, World!");
    
    // Test string_length
    int64:len = string_length(msg);
    
    // Test string creation with different text
    string:greeting = string_from_cstr("Hi");
    int64:greeting_len = string_length(greeting);
    
    // Test empty string
    string:empty = string_from_cstr("");
    bool:is_empty = string_is_empty(empty);
    if (is_empty) {
    }
    
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
