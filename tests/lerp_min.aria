use "stdlib/wave.aria".*;

func:failsafe = int32(tbb32:err) { exit(1); };

func:main = int32() {
    nit:n4 = 4;
    Wave9:wfull = wave_from_spatial(n4, n4, n4);
    println("wfull:");
    string:ws = wave9_toString(wfull);
    println(ws);

    Wave9:zero_w = wave_zero();
    Wave9:lerp_half = wave_lerp(zero_w, wfull, 50);
    println("lerp(zero, wfull, 50):");
    string:ls = wave9_toString(lerp_half);
    println(ls);
    exit(0);
};
