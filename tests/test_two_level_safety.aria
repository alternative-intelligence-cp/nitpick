// Expected: COMPILER ERROR
// Comprehensive test: ?! (local fallback) and !!! (global failsafe)
// Demonstrates the two-level safety system

// Mandatory failsafe function - global error handler
func:failsafe = int32(tbb32:err) {
    // In production: log error, cleanup resources, exit gracefully
    // For this test: just pass through the error code
    exit 1;
};

// Simulate loading configuration
func:loadConfig = int32() {
    // Simulate: config not found
    fail 404;
};

func:main = int32() {
    // Manual Result handling (workaround for ?! type mismatch)
    Result<int32>:res = loadConfig();
    int32:config = 42i32;
    if (!res.is_error) {
        config = res.value;
    }
    
    // If config loading completely fails, exit with error
    if (config == 42i32) {
        exit 1;
    }
    
    // Normal operation
    exit 0;
};
