// bug235: MEM-014 / ARIA-028 — positive case. A borrow that is read,
// dereferenced, and dropped inside the same function (never escaped)
// must NOT trigger ARIA-028.
func:internal_only = int32() {
    stack int32:host = 41i32;
    $$m int32:r = host;
    int32:val = r;
    pass val + 1i32;
};
func:failsafe = int32(tbb32:err) { exit 1; };
func:main = int32() { int32:got = raw internal_only(); exit got - 42i32; };
