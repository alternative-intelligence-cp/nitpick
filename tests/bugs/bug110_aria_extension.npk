// bug110: POLISH-002 — .aria file extension should be accepted by module resolver
// Imports a helper module named with .aria extension and calls a function from it.
use "./bug110_aria_ext_module.aria".*;

func:main = int32() {
    // greet_from_aria() returns Result<string>; use raw to assert no error
    raw greet_from_aria();
    println("aria module loaded ok");
    exit 0;
};
func:failsafe = int32(tbb32:err) { exit 1; };
