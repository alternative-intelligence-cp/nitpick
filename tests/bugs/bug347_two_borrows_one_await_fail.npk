// bug347: D-5 — TWO distinct borrows live at one await produce TWO ARIA-041
//                errors (one per offending loan), not one summarized error.
// Phase 1 / v0.31.0.4.

func:failsafe = int32(tbb32:err) { exit 1; };

async func:tick = int32() { pass 1i32; };

async func:bad = int32() {
    int32:x = 0i32;
    int32:y = 0i32;
    $$m int32:rx = x;
    $$m int32:ry = y;
    int32:_ = raw await tick();   // <-- both rx AND ry live → 2x ARIA-041
    rx = rx + 1i32;
    ry = ry + 1i32;
    pass rx + ry;
};

func:main = int32() {
    drop bad();
    exit 0;
};
