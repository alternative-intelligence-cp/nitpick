// BUG-011: Should be able to borrow from struct field
// Expected: $$i int32:ref = my_struct.field; should compile

struct:SensorData = {
    int32:temperature;
    int32:pressure;
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};

func:main = int32() {
    SensorData:data = SensorData { temperature: 36, pressure: 101 };
    $$i int32:temp_ref = data.temperature;
    println("borrowed temperature");
    exit 0;
};
