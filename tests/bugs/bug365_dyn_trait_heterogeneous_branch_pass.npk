// v0.31.1.3 (D-9 verification): heterogeneous dyn dispatch through an
// if/else — same trait, same concrete type via two different live
// values. Pins the vtable lookup path against branch optimization
// regressions.
trait:Tag = {
    func:tag = int32(int32:self);
};
impl:Tag:for:int32 = {
    func:tag = int32(int32:self) {
        pass self + 1i32;
    };
};
func:via_dyn = int32(dyn Tag:item) {
    pass item.tag();
};
func:failsafe = int32(tbb32:err) { exit 7; };
pub func:main = int32() {
    int32:a = 10i32;
    int32:b = 20i32;
    int32:flag = 1i32;
    int32:r1 = 0i32;
    if (flag == 1i32) {
        r1 = raw via_dyn(a);
    } else {
        r1 = raw via_dyn(b);
    }
    if (r1 == 11i32) {
        exit 65;
    }
    exit 1;
};
