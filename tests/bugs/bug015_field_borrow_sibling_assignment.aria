// BUG-015: Assignment to a disjoint sibling field should remain legal.
// Expected: pair.b assignment is disjoint from the active pair.a borrow.

struct:Pair = {
    int32:a;
    int32:b;
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};

func:main = int32() {
    Pair:pair = Pair { a: 10, b: 20 };
    $$m int32:ra = pair.a;
    pair.b = 22;
    exit pair.b;
};
