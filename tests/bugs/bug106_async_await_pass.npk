// bug106: A-010 — async func: and await basic compilation smoke test
// K semantics for async/await formalized in v0.21.6 (tests 137-139 in
// k-semantics/tests/core/). Synchronous model: await runs the coroutine
// to completion and extracts the Result value.
// Expected: compile and exit 0.

func:failsafe = int32(tbb32:err) { exit 1; };

async func:add_one = int32(int32:n) {
    pass n + 1;
};

async func:mul_two = int32(int32:n) {
    pass n + n;
};

func:main = int32() {
    // Basic declaration — async functions compile without error
    // (calling async from main via drop is the safe path)
    drop add_one(10);
    drop mul_two(5);

    exit 0;
};
