// v0.25.4 BORROW-008: borrow returned from a call conservatively roots at
// the entire source argument; taking a $$m sub-borrow on any path of the
// source while the returned borrow is live must be rejected (ARIA-023).
struct:Pair = { int32:a; int32:b; };
func:get_a = $$i int32($$i Pair:s) { pass s.a; };
func:failsafe = int32(tbb32:err) { exit 7; };
func:main = int32() {
    Pair:p;
    p.a = 1i32;
    p.b = 2i32;
    $$i int32:y = raw get_a(p);
    $$m int32:z = p.b;
    exit 0;
};
