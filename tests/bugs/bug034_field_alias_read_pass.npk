// BUG-034: Reading a mutable field alias loads through the field pointer.
// Expected: exits 10

struct:Pair = {
    int32:a;
    int32:b;
};

func:failsafe = int32(tbb32:err) {
    exit 7;
};

func:main = int32() {
    Pair:pair = Pair{a: 10, b: 20};
    $$m int32:alias = pair.a;
    exit alias;
};
