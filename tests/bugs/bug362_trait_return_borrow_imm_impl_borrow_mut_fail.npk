// bug362 (v0.31.1.2 / D-7 / ARIA-042): trait declares `$$i int32` return
// but the impl method declares `$$m int32`. Direction crossover is also
// an ARIA-042 mismatch.
struct:Pair = { int32:a; int32:b; };
trait:GetA = { func:get_a = $$i int32($$m Pair:self); };
impl:GetA:for:Pair = {
    func:get_a = $$m int32($$m Pair:self) {
        pass self.a;
    };
};
func:failsafe = int32(tbb32:err) { exit 7; };
func:main = int32() {
    exit 0;
};
