// v0.31.2.5 (D-18): the prefix `is (cond) : t : f` ternary form must
// still work alongside the new `<expr> is unknown` postfix test form.
// This guards against parser regression.
func:failsafe = int32(tbb32:err) { exit 99; };
func:main = int32() {
    int32:y = 7i32;
    int32:r = is (y == 7i32) : 0i32 : 1i32;
    exit r;
};
