// v0.31.2.4 (D-17 / ARIA-045): taint propagates through reassignment from
// a tainted source.
func:failsafe = int32(tbb32:err) { exit 99; };
func:takes_opt = int32(int32?:x) { pass 0; };
func:main = int32() {
    int32?:u = unknown;
    int32?:v = u;            // v inherits u's mayBeUnknown taint
    int32:r = raw takes_opt(v);  // ARIA-045 expected on 'v'
    exit r;
};
