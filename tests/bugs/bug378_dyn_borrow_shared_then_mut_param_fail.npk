// bug378 — v0.31.1.10 D-12 Probe D: $$i dyn live blocks $$m param pass
//
// While `bi` holds an immutable dyn borrow of `c`, passing `c`
// as the source of a `$$m dyn` parameter must be rejected with
// ARIA-023. Validates that the dyn-coercion call site (the v0.31.1.9
// path) participates in source-side borrow-conflict checking.

struct:Counter = { int32:n; };

trait:Bumpable = {
    func:bump = int32($$m Bumpable:self);
};

impl:Bumpable:for:Counter = {
    func:bump = int32($$m Counter:self) {
        self.n = self.n + 1i32;
        pass self.n;
    };
};

func:bump_it = int32($$m dyn Bumpable:b) {
    int32:r = b.bump();
    pass r;
};

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    Counter:c = { n: 5i32 };
    $$i dyn Bumpable:bi = c;
    int32:r = raw bump_it(c);
    exit c.n;
};
