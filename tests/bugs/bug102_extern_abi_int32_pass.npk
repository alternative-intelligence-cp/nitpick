// bug102: ABI — extern function with int32 param and int32 return works.
// Exercises the extern ABI path; regression test for ABI documentation changes
// in v0.21.4 (abi.md). The C stdlib abs() function serves as the fixture.
// Expected: compile and exit 0.

extern "libc" {
    func:abs = int32(int32:n);
}

func:failsafe = int32(tbb32:err) {
    exit 1;
};

func:main = int32() {
    int32:a = abs(-42i32);
    int32:b = abs(7i32);
    if (a == 42i32 && b == 7i32) {
        exit 0;
    }
    exit 1;
};
