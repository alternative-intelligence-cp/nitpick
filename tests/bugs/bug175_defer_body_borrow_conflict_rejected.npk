// BUG-175: defer body now borrow-checked (BORROW-002, v0.25.1).
// Two $$m borrows of the same host inside defer body must conflict.
// Expected: ARIA-023.

func:failsafe = int32(tbb32:err) { exit 7; };

func:main = int32() {
    int32:x = 10;
    defer {
        $$m int32:a = x;
        $$m int32:b = x;
        a = (a + 1);
        b = (b + 1);
    }
    exit 0;
};
