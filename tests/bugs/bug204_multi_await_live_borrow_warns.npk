// bug204: BORROW-012 — multi-await with $$m borrow live across both awaits → 2 ARIA-030 warnings.
async func:tick = int32() { pass 1i32; };
async func:run = int32() {
    int32:x = 0i32;
    $$m int32:y = x;
    int32:r1 = raw await tick();
    y = y + 1i32;
    int32:r2 = raw await tick();
    pass r1 + r2 + y;
};
func:failsafe = int32(tbb32:err) { exit 1; };
func:main = int32() { drop run(); exit 0; };
