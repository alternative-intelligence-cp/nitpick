// v0.24.1 — COMPTIME-002: assignment chain a=1, b=a+1, c=a+b → c==3

comptime func:chain = int32() {
    int32:a = 1;
    int32:b = 0;
    int32:c = 0;
    b = a + 1i32;
    c = a + b;
    pass c;
};

pub func:main = int32() {
    int32:result = comptime(chain());
    if (result != 3) {
        exit 1;
    }
    exit 0;
};

func:failsafe = int32(tbb32:err) { exit 1; };
