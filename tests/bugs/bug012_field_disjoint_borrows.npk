// BUG-012: Disjoint struct-field borrow paths should not conflict.
// Expected: $$m int32:ra = pair.a; and $$m int32:rb = pair.b; should compile.

struct:Pair = {
    int32:a;
    int32:b;
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};

func:main = int32() {
    Pair:pair = Pair { a: 10, b: 20 };
    $$m int32:ra = pair.a;
    $$m int32:rb = pair.b;
    exit pair.a + pair.b;
};
