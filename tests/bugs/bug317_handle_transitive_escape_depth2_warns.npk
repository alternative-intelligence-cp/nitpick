// BUG-317 (v0.30.2, ARIA-032 transitive arena escape — depth-2
// fixpoint): `wrap2` calls `wrap` and returns its result; `wrap`
// returns `HandleArena.alloc(<param>, ..)`. The fixpoint pass
// must lift `wrap`'s escape into `wrap2`'s
// `escapes_param_arena_indices`, so the caller's `pass wrap2(a)`
// with a local arena triggers the ARIA-032 warning.
//
// Expected: compiles cleanly with an ARIA-032 warning mentioning
// `wrap2`.

use "handle.npk".*;

func:failsafe = int32(tbb32:err) {
    exit 1;
};

func:wrap = int64(int64:a) {
    pass raw HandleArena.alloc(a, 4i64);
};

func:wrap2 = int64(int64:a) {
    pass raw wrap(a);
};

func:leak = int64() {
    int64:a = raw HandleArena.create();
    pass raw wrap2(a);
};

func:main = int32() {
    int64:h = raw leak();
    if (h == 0i64) { exit 0; }
    exit 0;
};
