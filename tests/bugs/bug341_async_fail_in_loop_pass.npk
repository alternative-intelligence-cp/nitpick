// bug341: D-7 — `fail` inside a loop in an async fn must exit the function
// Phase 1 / v0.31.0.3

func:failsafe = int32(tbb32:err) { exit 1; };

async func:loop_fail = int32() {
    int32:i = 0i32;
    while (i < 10i32) {
        if (i == 3i32) {
            fail 7i32;
        }
        i = i + 1i32;
    }
    println("DEAD-bug341");   // must not execute
    pass 0i32;
};

func:main = int32() {
    drop loop_fail();
    exit 0;
};
