// bug079: pick struct field pattern — mutating bound fields does not affect original
// Bound fields from a struct pattern are immutable copies; changing them
// must not change the original struct.
// Expected exit: 0  (original p unchanged — p.x still 10)

struct:Point = {
    int32:x;
    int32:y;
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};

func:main = int32() {
    Point:p = Point{ x: 10i32, y: 20i32 };

    pick(p) {
        (Point{ x, y }) {
            // x and y are local copies — writes here do NOT affect p
            // (they are not allowed anyway since struct pattern binds are immutable)
            int32:local_sum = x + y;   // 30
            if (local_sum != 30i32) { exit 2; }
        }
    }

    // p must be unchanged
    if (p.x != 10i32) { exit 1; }
    if (p.y != 20i32) { exit 1; }

    exit 0;
};
