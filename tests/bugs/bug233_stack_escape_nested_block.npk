// bug233: MEM-014 / ARIA-028 — taking a borrow inside a nested block,
// then returning it from the enclosing function, must be rejected
// (the host's stack frame is the inner block, not the function).
func:leaky = $$m int32() {
    stack int32:outer = 0i32;
    if (1i32 == 1i32) {
        stack int32:inner = 99i32;
        $$m int32:r = inner;
        pass r;
    }
    pass outer;
};
func:failsafe = int32(tbb32:err) { exit 1; };
func:main = int32() { exit 0; };
