// bug101: A-006/A-007 — complex loop+pick+struct program exercises many
// ir_generator codegen paths. Regression: the ICE message format change
// (adding nodeTypeToString) must not break normal codegen.
// Expected: compile and exit 0.

struct:Point = {
    int32:x;
    int32:y;
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};

func:main = int32() {
    Point:p = Point{ x: 3i32, y: 4i32 };
    int32:total = 0i32;
    int32:bonus = 0i32;
    pick(p.x) {
        (0i32..10i32) { bonus = 1i32; },
        (*) { bonus = 0i32; }
    }
    loop(0i32, 5i32, 1i32) {
        total = total + p.x + p.y + bonus;
    }
    // bonus=1 (3 is in 0..10), per iteration: 3+4+1=8, 5 times = 40
    if (total == 40i32) {
        exit 0;
    }
    exit 1;
};
