// BUG-178: early exit() with defer-paired free is OK (BORROW-003, v0.25.1).
// Defer obligation removes pending_wild_frees, so no ARIA-014.
// Expected: exit 0.

func:failsafe = int32(tbb32:err) { exit 7; };

func:main = int32() {
    wildx int8->:p = alloc(64);
    defer { free(p); }
    if (1 == 1) {
        exit 0;
    }
    exit 0;
};
