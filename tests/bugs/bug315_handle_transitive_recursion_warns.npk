// BUG-315 (v0.30.1, ARIA-032 transitive destroy — recursion
// fixpoint termination + transitive lift through indirect cycle):
//
// `ping(a, n)` and `pong(a, n)` form a mutual-recursion cycle.
// Neither destroys the arena directly. The actual destroy lives in
// `killer(a)`, which is called only from the n==0 base case in
// `ping`. The fixpoint pass in `propagateTransitiveDestroys` must:
//
//   1) lift `killer.destroys_param_indices = {0}` into
//      `ping.transitively_destroys_param_indices = {0}`,
//   2) then lift that into `pong.transitively_destroys_param_indices`
//      via the cycle edge,
//   3) terminate when no summary grows further (NOT infinite-loop
//      on the cycle).
//
// Calling `ping(a, 4)` from `main` then taking `HandleArena.free(h)`
// must produce an ARIA-032 transitive warning (warn-only,
// IPC-DEC-004).
//
// Expected: compiles cleanly with an ARIA-032 transitive warning at
// the `free(h)` site.

use "handle.npk".*;

func:failsafe = int32(tbb32:err) {
    exit 1;
};

func:killer = int32(int64:a) {
    raw HandleArena.destroy(a);
    pass 0i32;
};

func:ping = int32(int64:a, int32:n) {
    if (n == 0i32) {
        int32:rc = raw killer(a);
        pass rc;
    }
    int32:nn = n - 1i32;
    int32:rc = raw pong(a, nn);
    pass rc;
};

func:pong = int32(int64:a, int32:n) {
    int32:nn = n - 1i32;
    int32:rc = raw ping(a, nn);
    pass rc;
};

func:main = int32() {
    int64:a = raw HandleArena.create();
    Handle<int32>:h = raw HandleArena.alloc(a, 4i64);
    int32:rc = raw ping(a, 4i32);
    if (rc != 0i32) { exit 2; }
    raw HandleArena.free(h);
    exit 0;
};
