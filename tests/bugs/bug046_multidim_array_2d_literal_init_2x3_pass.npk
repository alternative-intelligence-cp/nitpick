// BUG-046: 2-D array literal initializer — 2×3 with all six elements correct.
// int32[2][3]:grid = [[1,2,3],[4,5,6]]
// Expected: exits 6  (grid[1][2])

func:failsafe = int32(tbb32:err) {
    exit 7;
};

func:main = int32() {
    int32[2][3]:grid = [[1, 2, 3], [4, 5, 6]];
    if (grid[0][0] != 1) { exit 10; }
    if (grid[0][1] != 2) { exit 11; }
    if (grid[0][2] != 3) { exit 12; }
    if (grid[1][0] != 4) { exit 13; }
    if (grid[1][1] != 5) { exit 14; }
    exit grid[1][2];
};
