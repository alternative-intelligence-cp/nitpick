// bug358 (v0.31.1.2 / D-7): trait method signature with `$$i T` return type
// parses, matches the impl method's return-borrow qualifier, and the
// resulting code compiles and runs.
struct:Pair = { int32:a; int32:b; };
trait:GetA = { func:get_a = $$i int32($$i Pair:self); };
impl:GetA:for:Pair = {
    func:get_a = $$i int32($$i Pair:self) {
        pass self.a;
    };
};
func:failsafe = int32(tbb32:err) { exit 7; };
func:main = int32() {
    Pair:p;
    p.a = 41i32;
    p.b = 99i32;
    int32:y = raw p.get_a();
    exit y;
};
