// v0.24.1 — COMPTIME-001: loop() iterations and triangle sum
// Loop from 0 to 5 → triangle number = 0+1+2+3+4 = 10 (using manual counter)

comptime func:triangle = int32(int32:n) {
    int32:acc = 0;
    int32:i = 0;
    loop(0i32, n, 1i32) {
        acc = acc + i;
        i = i + 1i32;
    }
    pass acc;
};

pub func:main = int32() {
    // 0+1+2+3+4 = 10 (5 iterations)
    int32:t5 = comptime(triangle(5i32));
    if (t5 != 10) {
        exit 1;
    }
    // 0+1+2+3+...+9 = 45 (10 iterations)
    int32:t10 = comptime(triangle(10i32));
    if (t10 != 45) {
        exit 1;
    }
    exit 0;
};

func:failsafe = int32(tbb32:err) { exit 1; };
