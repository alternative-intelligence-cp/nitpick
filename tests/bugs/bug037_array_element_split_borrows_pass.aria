// BUG-037: Distinct literal-index array element borrow paths are disjoint.
// Expected: exits 42

func:failsafe = int32(tbb32:err) {
    exit 7;
};

func:main = int32() {
    int32[2]:arr = [10, 20];
    $$m int32:left = arr[0];
    arr[1] = 12;
    $$m int32:right = arr[1];
    left = 30;
    right = right + 0;
    exit arr[0] + arr[1];
};
