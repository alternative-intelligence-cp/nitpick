// bug058: pick struct field destructuring — basic 2-field destructure
// Expected exit: 30 (x + y where x=10, y=20)

struct:Point = {
    int32:x;
    int32:y;
};

func:main = int32() {
    Point:p = Point{ x: 10i32, y: 20i32 };
    int32:result = 0i32;

    pick(p) {
        (Point{ x, y }) {
            result = x + y;
        }
    }

    exit result;
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};
