// v0.24.5 (COMPTIME-010): `type:T` parameters are only allowed in `comptime`
// functions. A non-comptime function declaring one must be rejected at
// compile time with a clear diagnostic.
pub func:bad = int32(type:T) {
    pass 0i32;
};

pub func:main = int32() { exit 0; };

func:failsafe = int32(tbb32:err) { exit 1; };
