// Test const with array sizes and complex expressions
// Tests compile-time evaluation capability

const int64:ARRAY_SIZE = 10;
const int64:BUFFER_COUNT = 5;
const int64:TOTAL_SLOTS = ARRAY_SIZE * BUFFER_COUNT;

// Test 1: Can we use const for array size?
func:test_array_size = int64() {
    int64[ARRAY_SIZE]:buffer;
    buffer[0] = 42;
    pass(buffer[0]);
};

// Test 2: Can we use const expressions?
func:test_const_expr = int64() {
    const int64:DOUBLED = ARRAY_SIZE * 2;
    const int64:HALVED = ARRAY_SIZE / 2;
    
    int64:result = DOUBLED + HALVED;
    pass(result);  // Should be 25 (20 + 5)
};

// Test 3: Can we use const in conditionals?
func:test_const_conditional = int64() {
    const bool:USE_LARGE_BUFFER = true;
    int64:size = 0;
    
    if (USE_LARGE_BUFFER) {
        size = TOTAL_SLOTS;
    } else {
        size = ARRAY_SIZE;
    }
    
    pass(size);  // Should be 50
};

func:main = int32() {
    int64:r1 = test_array_size();
    int64:r2 = test_const_expr();
    int64:r3 = test_const_conditional();
    
    int32:zero = 0;
    pass(zero);
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
