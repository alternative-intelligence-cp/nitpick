// ============================================================================
// LRU Eviction Tests
// ============================================================================

TEST_CASE(code_cache_evict_by_count) {
    AriaCodeCache* cache = aria_code_cache_create(3, 0); // Max 3 entries
    
    uint64_t hash1 = aria_code_cache_hash_string("func1");
    uint64_t hash2 = aria_code_cache_hash_string("func2");
    uint64_t hash3 = aria_code_cache_hash_string("func3");
    uint64_t hash4 = aria_code_cache_hash_string("func4");
    
    // Insert 3 entries (cache full)
    aria_code_cache_insert(cache, hash1, (void*)dummy_func_1, 100, 0, 0);
    aria_code_cache_insert(cache, hash2, (void*)dummy_func_2, 100, 0, 0);
    aria_code_cache_insert(cache, hash3, (void*)dummy_func_3, 100, 0, 0);
    
    AriaCodeCacheStats stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_entries == 3, "Cache should have 3 entries");
    
    // Insert 4th entry (should evict func1 - least recently used)
    aria_code_cache_insert(cache, hash4, (void*)dummy_func_4, 100, 0, 0);
    
    stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_entries == 3, "Cache should still have 3 entries");
    ASSERT(stats.total_evictions == 1, "One eviction should have occurred");
    
    // func1 should be evicted
    AriaCachedFunction* func1 = aria_code_cache_lookup(cache, hash1);
    ASSERT(func1 == nullptr, "func1 should be evicted");
    
    // Others should still exist
    AriaCachedFunction* func2 = aria_code_cache_lookup(cache, hash2);
    AriaCachedFunction* func3 = aria_code_cache_lookup(cache, hash3);
    AriaCachedFunction* func4 = aria_code_cache_lookup(cache, hash4);
    ASSERT(func2 != nullptr, "func2 should exist");
    ASSERT(func3 != nullptr, "func3 should exist");
    ASSERT(func4 != nullptr, "func4 should exist");
    
    aria_code_cache_destroy(cache);
}

TEST_CASE(code_cache_evict_by_memory) {
    AriaCodeCache* cache = aria_code_cache_create(0, 250); // Max 250 bytes
    
    uint64_t hash1 = aria_code_cache_hash_string("func1");
