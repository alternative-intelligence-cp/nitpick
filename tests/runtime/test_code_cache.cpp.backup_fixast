    stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_entries == 0, "Cache should be empty after clear");
    ASSERT(stats.total_memory_bytes == 0, "Memory should be zero");
    ASSERT(stats.total_hits == 0, "Hits should be reset");
    ASSERT(stats.total_misses == 0, "Misses should be reset");
    ASSERT(stats.total_inserts == 0, "Inserts should be reset");
    ASSERT(stats.total_evictions == 0, "Evictions should be reset");
    
    aria_code_cache_destroy(cache);
}

// ============================================================================
// Statistics Tests
// ============================================================================

TEST_CASE(code_cache_hit_rate) {
    AriaCodeCache* cache = aria_code_cache_create(0, 0);
    
    uint64_t hash1 = aria_code_cache_hash_string("func1");
    uint64_t hash2 = aria_code_cache_hash_string("func2");
    
    aria_code_cache_insert(cache, hash1, (void*)dummy_func_1, 100, 0, 0);
    
    // 3 hits, 2 misses = 60% hit rate
    aria_code_cache_lookup(cache, hash1); // Hit
    aria_code_cache_lookup(cache, hash1); // Hit
    aria_code_cache_lookup(cache, hash1); // Hit
    aria_code_cache_lookup(cache, hash2); // Miss
    aria_code_cache_lookup(cache, hash2); // Miss
    
    AriaCodeCacheStats stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_hits == 3, "Should have 3 hits");
    ASSERT(stats.total_misses == 2, "Should have 2 misses");
    
    double expected_rate = 3.0 / 5.0; // 0.6
    double diff = stats.hit_rate - expected_rate;
    if (diff < 0) diff = -diff;
    ASSERT(diff < 0.001, "Hit rate should be 60%");
    
    aria_code_cache_destroy(cache);
}

TEST_CASE(code_cache_access_count) {
    AriaCodeCache* cache = aria_code_cache_create(0, 0);
    
    uint64_t hash1 = aria_code_cache_hash_string("func1");
    
    aria_code_cache_insert(cache, hash1, (void*)dummy_func_1, 100, 0, 0);
    
    // Access 5 times
    for (int i = 0; i < 5; i++) {
        AriaCachedFunction* func = aria_code_cache_lookup(cache, hash1);
        ASSERT(func != nullptr, "Lookup should succeed");
    }
    
    AriaCachedFunction* func = aria_code_cache_lookup(cache, hash1);
    ASSERT(func->access_count == 6, "Access count should be 6 (5 lookups + 1 final)");
    
    aria_code_cache_destroy(cache);
}

// ============================================================================
// Configuration Tests
// ============================================================================

TEST_CASE(code_cache_config_limits) {
    AriaCodeCache* cache = aria_code_cache_create(0, 0);
    
    // Set limits
    aria_code_cache_set_max_entries(cache, 10);
    aria_code_cache_set_max_memory(cache, 1000);
    
    ASSERT(aria_code_cache_get_max_entries(cache) == 10, "Max entries should be 10");
    ASSERT(aria_code_cache_get_max_memory(cache) == 1000, "Max memory should be 1000");
    
    // Insert 5 entries
    for (int i = 0; i < 5; i++) {
        char name[32];
        snprintf(name, sizeof(name), "func%d", i);
        uint64_t hash = aria_code_cache_hash_string(name);
        aria_code_cache_insert(cache, hash, (void*)dummy_func_1, 100, 0, 0);
    }
    
    AriaCodeCacheStats stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_entries == 5, "Should have 5 entries");
    
    // Reduce limit to 3 (should trigger eviction)
    aria_code_cache_set_max_entries(cache, 3);
    
    stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_entries == 3, "Should have 3 entries after limit reduction");
    ASSERT(stats.total_evictions == 2, "Should have evicted 2 entries");
    
    aria_code_cache_destroy(cache);
}

TEST_CASE(code_cache_reset_stats) {
    AriaCodeCache* cache = aria_code_cache_create(0, 0);
    
    uint64_t hash1 = aria_code_cache_hash_string("func1");
    aria_code_cache_insert(cache, hash1, (void*)dummy_func_1, 100, 0, 0);
    aria_code_cache_lookup(cache, hash1);
    
    AriaCodeCacheStats stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_hits > 0, "Should have hits");
    ASSERT(stats.total_inserts > 0, "Should have inserts");
    
    aria_code_cache_reset_stats(cache);
    
    stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_hits == 0, "Hits should be reset");
    ASSERT(stats.total_misses == 0, "Misses should be reset");
    ASSERT(stats.total_inserts == 0, "Inserts should be reset");
    ASSERT(stats.total_evictions == 0, "Evictions should be reset");
    ASSERT(stats.total_entries == 1, "Entries should NOT be affected");
    
    aria_code_cache_destroy(cache);
}
