// ============================================================================
// Lifecycle Tests
// ============================================================================

TEST_CASE(code_cache_create_destroy) {
    // Create with limits
    AriaCodeCache* cache = aria_code_cache_create(100, 1024 * 1024);
    ASSERT(cache != nullptr, "Cache creation should succeed");
    ASSERT(aria_code_cache_get_max_entries(cache) == 100, "Max entries should be 100");
    ASSERT(aria_code_cache_get_max_memory(cache) == 1024 * 1024, "Max memory should be 1MB");
    
    AriaCodeCacheStats stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_entries == 0, "New cache should be empty");
    ASSERT(stats.total_memory_bytes == 0, "New cache should use no memory");
    
    aria_code_cache_destroy(cache);
    
    // Create with unlimited
    cache = aria_code_cache_create(0, 0);
    ASSERT(cache != nullptr, "Unlimited cache creation should succeed");
    ASSERT(aria_code_cache_get_max_entries(cache) == 0, "Max entries should be unlimited");
    ASSERT(aria_code_cache_get_max_memory(cache) == 0, "Max memory should be unlimited");
    
    aria_code_cache_destroy(cache);
}

// ============================================================================
// Hash Function Tests
// ============================================================================

TEST_CASE(code_cache_hash_bytes) {
    uint8_t data1[] = {1, 2, 3, 4, 5};
    uint8_t data2[] = {1, 2, 3, 4, 5};
    uint8_t data3[] = {5, 4, 3, 2, 1};
    
    uint64_t hash1 = aria_code_cache_hash_bytes(data1, 5);
    uint64_t hash2 = aria_code_cache_hash_bytes(data2, 5);
    uint64_t hash3 = aria_code_cache_hash_bytes(data3, 5);
    
    ASSERT(hash1 != 0, "Hash should not be zero");
    ASSERT(hash1 == hash2, "Identical data should produce identical hashes");
    ASSERT(hash1 != hash3, "Different data should produce different hashes");
    
    // Edge cases
    uint64_t empty_hash = aria_code_cache_hash_bytes(data1, 0);
    ASSERT(empty_hash == 0, "Empty data should produce zero hash");
    
    uint64_t null_hash = aria_code_cache_hash_bytes(nullptr, 5);
    ASSERT(null_hash == 0, "Null data should produce zero hash");
}

TEST_CASE(code_cache_hash_string) {
    const char* str1 = "hello world";
    const char* str2 = "hello world";
    const char* str3 = "goodbye world";
    
    uint64_t hash1 = aria_code_cache_hash_string(str1);
    uint64_t hash2 = aria_code_cache_hash_string(str2);
    uint64_t hash3 = aria_code_cache_hash_string(str3);
    
    ASSERT(hash1 != 0, "String hash should not be zero");
    ASSERT(hash1 == hash2, "Identical strings should produce identical hashes");
    ASSERT(hash1 != hash3, "Different strings should produce different hashes");
    
    // Edge cases
    uint64_t null_hash = aria_code_cache_hash_string(nullptr);
    ASSERT(null_hash == 0, "Null string should produce zero hash");
    
    uint64_t empty_hash = aria_code_cache_hash_string("");
    ASSERT(empty_hash != 0, "Empty string should produce non-zero hash");
}

TEST_CASE(code_cache_combine_hashes) {
    uint64_t hash1 = aria_code_cache_hash_string("signature");
    uint64_t hash2 = aria_code_cache_hash_string("body");
    
    uint64_t combined = aria_code_cache_combine_hashes(hash1, hash2);
    
    ASSERT(combined != 0, "Combined hash should not be zero");
    ASSERT(combined != hash1, "Combined hash should differ from hash1");
    ASSERT(combined != hash2, "Combined hash should differ from hash2");
    
    // Note: Our implementation using XOR is commutative, which is fine for cache keys
    // Just verify combination is different from inputs
    uint64_t self_combined = aria_code_cache_combine_hashes(hash1, hash1);
    ASSERT(self_combined != hash1, "Combining hash with itself should produce different result");
}

