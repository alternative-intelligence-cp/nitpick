    // func1 should be evicted
    AriaCachedFunction* func1 = aria_code_cache_lookup(cache, hash1);
    ASSERT(func1 == nullptr, "func1 should be evicted");
    
    aria_code_cache_destroy(cache);
}

TEST_CASE(code_cache_lru_ordering) {
    AriaCodeCache* cache = aria_code_cache_create(3, 0);
    
    uint64_t hash1 = aria_code_cache_hash_string("func1");
    uint64_t hash2 = aria_code_cache_hash_string("func2");
    uint64_t hash3 = aria_code_cache_hash_string("func3");
    uint64_t hash4 = aria_code_cache_hash_string("func4");
    
    // Insert 3 entries
    aria_code_cache_insert(cache, hash1, (void*)dummy_func_1, 100, 0, 0);
    aria_code_cache_insert(cache, hash2, (void*)dummy_func_2, 100, 0, 0);
    aria_code_cache_insert(cache, hash3, (void*)dummy_func_3, 100, 0, 0);
    
    // Access func1 (move to front of LRU)
    aria_code_cache_lookup(cache, hash1);
    
    // Insert func4 (should evict func2 - now least recently used)
    aria_code_cache_insert(cache, hash4, (void*)dummy_func_4, 100, 0, 0);
    
    // func2 should be evicted, not func1
    AriaCachedFunction* func1 = aria_code_cache_lookup(cache, hash1);
    AriaCachedFunction* func2 = aria_code_cache_lookup(cache, hash2);
    AriaCachedFunction* func3 = aria_code_cache_lookup(cache, hash3);
    AriaCachedFunction* func4 = aria_code_cache_lookup(cache, hash4);
    
    ASSERT(func1 != nullptr, "func1 should exist (accessed recently)");
    ASSERT(func2 == nullptr, "func2 should be evicted (LRU)");
    ASSERT(func3 != nullptr, "func3 should exist");
    ASSERT(func4 != nullptr, "func4 should exist");
    
    aria_code_cache_destroy(cache);
}

// ============================================================================
// Manual Eviction Tests
// ============================================================================

TEST_CASE(code_cache_manual_evict) {
    AriaCodeCache* cache = aria_code_cache_create(0, 0);
    
    uint64_t hash1 = aria_code_cache_hash_string("func1");
    uint64_t hash2 = aria_code_cache_hash_string("func2");
    
    aria_code_cache_insert(cache, hash1, (void*)dummy_func_1, 100, 0, 0);
    aria_code_cache_insert(cache, hash2, (void*)dummy_func_2, 100, 0, 0);
    
    AriaCodeCacheStats stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_entries == 2, "Cache should have 2 entries");
    
    int result = aria_code_cache_evict(cache, hash1);
    ASSERT(result == 0, "Eviction should succeed");
    
    stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_entries == 1, "Cache should have 1 entry after eviction");
    ASSERT(stats.total_memory_bytes == 100, "Memory should be 100 bytes");
    ASSERT(stats.total_evictions == 1, "Eviction count should be 1");
    
    AriaCachedFunction* func1 = aria_code_cache_lookup(cache, hash1);
    AriaCachedFunction* func2 = aria_code_cache_lookup(cache, hash2);
    ASSERT(func1 == nullptr, "func1 should be evicted");
    ASSERT(func2 != nullptr, "func2 should still exist");
    
    // Evict nonexistent
    result = aria_code_cache_evict(cache, hash1);
    ASSERT(result == -1, "Evicting nonexistent entry should fail");
    
    aria_code_cache_destroy(cache);
}

TEST_CASE(code_cache_clear) {
    AriaCodeCache* cache = aria_code_cache_create(0, 0);
    
    uint64_t hash1 = aria_code_cache_hash_string("func1");
    uint64_t hash2 = aria_code_cache_hash_string("func2");
    uint64_t hash3 = aria_code_cache_hash_string("func3");
    
    aria_code_cache_insert(cache, hash1, (void*)dummy_func_1, 100, 0, 0);
    aria_code_cache_insert(cache, hash2, (void*)dummy_func_2, 100, 0, 0);
    aria_code_cache_insert(cache, hash3, (void*)dummy_func_3, 100, 0, 0);
    
    aria_code_cache_lookup(cache, hash1);
    aria_code_cache_lookup(cache, hash2);
    
    AriaCodeCacheStats stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_entries == 3, "Cache should have 3 entries");
    ASSERT(stats.total_hits == 2, "Should have 2 hits");
    
