TEST_CASE(code_cache_insert_lookup) {
    AriaCodeCache* cache = aria_code_cache_create(0, 0);
    ASSERT(cache != nullptr, "Cache creation should succeed");
    
    uint64_t hash1 = aria_code_cache_hash_string("func1");
    void* ptr1 = (void*)dummy_func_1;
    
    int result = aria_code_cache_insert(cache, hash1, ptr1, 100, 0, 0);
    ASSERT(result == 0, "Insert should succeed");
    
    AriaCodeCacheStats stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_entries == 1, "Cache should have 1 entry");
    ASSERT(stats.total_memory_bytes == 100, "Cache should track memory");
    ASSERT(stats.total_inserts == 1, "Insert count should be 1");
    
    AriaCachedFunction* func = aria_code_cache_lookup(cache, hash1);
    ASSERT(func != nullptr, "Lookup should succeed");
    ASSERT(func->function_ptr == ptr1, "Function pointer should match");
    ASSERT(func->code_size == 100, "Code size should match");
    ASSERT(func->backend_type == 0, "Backend type should be ARA");
    ASSERT(func->access_count == 1, "Access count should be 1");
    
    stats = aria_code_cache_stats(cache);
    ASSERT(stats.total_hits == 1, "Hit count should be 1");
    ASSERT(stats.total_misses == 0, "Miss count should be 0");
    
    aria_code_cache_destroy(cache);
}

