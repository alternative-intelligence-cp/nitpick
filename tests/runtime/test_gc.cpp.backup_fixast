// Stress Tests
// =============================================================================

TEST_CASE(gc_stress_test_allocations) {
    aria_gc_init(256 * 1024, 2 * 1024 * 1024);
    
    aria_shadow_stack_push_frame();
    
    // Allocate many objects, keep some as roots
    std::vector<void*> roots;
    
    for (int round = 0; round < 10; ++round) {
        for (int i = 0; i < 100; ++i) {
            void* obj = aria_gc_alloc(128 + (i % 256), 1);
            
            // Keep every 10th object as root
            if (i % 10 == 0) {
                roots.push_back(obj);
                aria_shadow_stack_add_root(&roots.back());
                
                // Write pattern
                uint32_t* data = (uint32_t*)obj;
                data[0] = round * 100 + i;
            }
        }
        
        // Trigger collection occasionally
        if (round % 3 == 0) {
            aria_gc_collect(false);
        }
    }
    
    // Verify roots survived
    for (size_t i = 0; i < roots.size(); ++i) {
        ASSERT(roots[i] != nullptr, "roots[i] != nullptr");
        // Data integrity check would require tracking expected values
    }
    
    GCStats stats;
    aria_gc_get_stats(&stats);
    ASSERT(stats.num_minor_collections > 0, "stats.num_minor_collections > 0");
    
    aria_shadow_stack_pop_frame();
    aria_gc_shutdown();
}

TEST_CASE(gc_header_integrity) {
    aria_gc_init(1024 * 1024, 4 * 1024 * 1024);
    
    void* obj = aria_gc_alloc(256, 42);  // type_id = 42
    
    ObjHeader* header = aria_gc_get_header(obj);
    ASSERT(header != nullptr, "header != nullptr");
    ASSERT(header->type_id == 42, "header->type_id == 42");
    ASSERT(header->is_nursery == 1, "header->is_nursery == 1");
    ASSERT(header->mark_bit == 0, "header->mark_bit == 0");
    ASSERT(header->pinned_bit == 0, "header->pinned_bit == 0");
    ASSERT(header->forwarded_bit == 0, "header->forwarded_bit == 0");
    
    aria_gc_shutdown();
}

