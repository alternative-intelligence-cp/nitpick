// Test async I/O operations
#include "runtime/async/async_io_api.h"
#include "runtime/async/async_io.h"
#include <iostream>
#include <cassert>
#include <cstring>

using namespace aria::runtime;
using namespace aria::runtime::async_io;

int main() {
    std::cout << "=== Aria Async I/O Test ===\n\n";
    
    int tests_passed = 0;
    int tests_failed = 0;
    
    // Test 1: Write file
    std::cout << "Test 1: Write file async... ";
    const char* test_file = "/tmp/aria_async_test.txt";
    const char* test_content = "Hello, async I/O!";
    
    AriaFutureHandle write_fut = aria_write_file_async(test_file, test_content);
    if (write_fut && aria_future_is_ready(write_fut)) {
        bool* success = static_cast<bool*>(aria_future_get_value(write_fut));
        if (success && *success) {
            std::cout << "✓ PASS\n";
            tests_passed++;
        } else {
            std::cout << "✗ FAIL (write failed)\n";
            tests_failed++;
        }
        aria_future_destroy(write_fut);
    } else {
        std::cout << "✗ FAIL (future not ready)\n";
        tests_failed++;
    }
    
    // Test 2: File exists
    std::cout << "Test 2: Check file exists... ";
    AriaFutureHandle exists_fut = aria_file_exists_async(test_file);
    if (exists_fut && aria_future_is_ready(exists_fut)) {
        bool* exists = static_cast<bool*>(aria_future_get_value(exists_fut));
        if (exists && *exists) {
            std::cout << "✓ PASS\n";
            tests_passed++;
        } else {
            std::cout << "✗ FAIL (file doesn't exist)\n";
            tests_failed++;
        }
        aria_future_destroy(exists_fut);
    } else {
        std::cout << "✗ FAIL (future not ready)\n";
        tests_failed++;
    }
    
    // Test 3: Read file
    std::cout << "Test 3: Read file async... ";
    AriaFutureHandle read_fut = aria_read_file_async(test_file);
    if (read_fut && aria_future_is_ready(read_fut)) {
        const char* content = static_cast<const char*>(aria_future_get_value(read_fut));
        if (content && strcmp(content, test_content) == 0) {
            std::cout << "✓ PASS\n";
            tests_passed++;
        } else {
            std::cout << "✗ FAIL (content mismatch: '" 
                      << (content ? content : "null") << "')\n";
            tests_failed++;
        }
        aria_future_destroy(read_fut);
    } else {
        std::cout << "✗ FAIL (future not ready)\n";
        tests_failed++;
    }
    
    // Test 4: Append to file
    std::cout << "Test 4: Append to file... ";
    const char* append_content = "\nLine 2";
    AriaFutureHandle append_fut = aria_append_file_async(test_file, append_content);
    if (append_fut && aria_future_is_ready(append_fut)) {
        bool* success = static_cast<bool*>(aria_future_get_value(append_fut));
        if (success && *success) {
            std::cout << "✓ PASS\n";
            tests_passed++;
        } else {
            std::cout << "✗ FAIL\n";
            tests_failed++;
        }
        aria_future_destroy(append_fut);
    } else {
        std::cout << "✗ FAIL (future not ready)\n";
        tests_failed++;
    }
    
    // Test 5: Delete file
    std::cout << "Test 5: Delete file async... ";
    AriaFutureHandle delete_fut = aria_delete_file_async(test_file);
    if (delete_fut && aria_future_is_ready(delete_fut)) {
        bool* success = static_cast<bool*>(aria_future_get_value(delete_fut));
        if (success && *success) {
            std::cout << "✓ PASS\n";
            tests_passed++;
        } else {
            std::cout << "✗ FAIL\n";
            tests_failed++;
        }
        aria_future_destroy(delete_fut);
    } else {
        std::cout << "✗ FAIL (future not ready)\n";
        tests_failed++;
    }
    
    // Test 6: Sleep (just check it returns a future)
    std::cout << "Test 6: Sleep async... ";
    AriaFutureHandle sleep_fut = aria_sleep_async(100);
    if (sleep_fut) {
        std::cout << "✓ PASS\n";
        tests_passed++;
        aria_future_destroy(sleep_fut);
    } else {
        std::cout << "✗ FAIL\n";
        tests_failed++;
    }
    
    // Test 7: Combinators (basic check)
    std::cout << "Test 7: Join combinator... ";
    AriaFutureHandle fut1 = aria_future_create(sizeof(int));
    AriaFutureHandle fut2 = aria_future_create(sizeof(int));
    int val1 = 1, val2 = 2;
    aria_future_set_value(fut1, &val1, sizeof(val1));
    aria_future_set_value(fut2, &val2, sizeof(val2));
    
    AriaFutureHandle futs[2] = {fut1, fut2};
    AriaFutureHandle join_fut = aria_join_all(futs, 2);
    
    if (join_fut && aria_future_is_ready(join_fut)) {
        std::cout << "✓ PASS\n";
        tests_passed++;
        aria_future_destroy(join_fut);
    } else {
        std::cout << "✗ FAIL\n";
        tests_failed++;
    }
    
    aria_future_destroy(fut1);
    aria_future_destroy(fut2);
    
    // Summary
    std::cout << "\n=== Test Summary ===\n";
    std::cout << "Passed: " << tests_passed << "\n";
    std::cout << "Failed: " << tests_failed << "\n";
    std::cout << "Total:  " << (tests_passed + tests_failed) << "\n";
    
    if (tests_failed == 0) {
        std::cout << "\n🎉 All async I/O tests passed!\n";
        return 0;
    } else {
        std::cout << "\n❌ Some tests failed\n";
        return 1;
    }
}
