TEST_CASE(atomic_tbb8_overflow_to_err) {
    AriaAtomicTBB8* atomic = aria_atomic_tbb8_create(ARIA_TBB8_MAX);  // 127
    ASSERT(atomic != nullptr, "TBB8 atomic creation should succeed");
    
