 * Test: Memory Fences
 * ============================================================================ */

TEST_CASE(atomic_memory_fences) {
    // These are compile-time operations that prevent reordering
    // Hard to test directly, but we can verify they don't crash
    
    aria_atomic_thread_fence(ARIA_MEMORY_ORDER_ACQUIRE);
    aria_atomic_thread_fence(ARIA_MEMORY_ORDER_RELEASE);
    aria_atomic_thread_fence(ARIA_MEMORY_ORDER_ACQ_REL);
