}

TEST_CASE(atomic_tbb8_underflow_to_err) {
    AriaAtomicTBB8* atomic = aria_atomic_tbb8_create(ARIA_TBB8_MIN);  // -127
    ASSERT(atomic != nullptr, "TBB8 atomic creation should succeed");
    
    int8_t old = aria_atomic_tbb8_fetch_sub(atomic, 1, ARIA_MEMORY_ORDER_SEQ_CST);
