}

TEST_CASE(atomic_tbb8_sticky_error) {
    AriaAtomicTBB8* atomic = aria_atomic_tbb8_create(ARIA_TBB8_ERR);
    ASSERT(atomic != nullptr, "TBB8 atomic creation should succeed");
    
    // Adding to ERR should keep it as ERR
    int8_t old = aria_atomic_tbb8_fetch_add(atomic, 10, ARIA_MEMORY_ORDER_SEQ_CST);
    ASSERT(old == ARIA_TBB8_ERR, "Fetch_add from ERR should return ERR");
    
    int8_t value = aria_atomic_tbb8_load(atomic, ARIA_MEMORY_ORDER_SEQ_CST);
    ASSERT(value == ARIA_TBB8_ERR, "ERR should be sticky");
    
    // Subtracting from ERR should keep it as ERR
    old = aria_atomic_tbb8_fetch_sub(atomic, 5, ARIA_MEMORY_ORDER_SEQ_CST);
    ASSERT(old == ARIA_TBB8_ERR, "Fetch_sub from ERR should return ERR");
    
    value = aria_atomic_tbb8_load(atomic, ARIA_MEMORY_ORDER_SEQ_CST);
    ASSERT(value == ARIA_TBB8_ERR, "ERR should remain sticky");
    
    aria_atomic_tbb8_destroy(atomic);
}

