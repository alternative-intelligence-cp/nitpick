/* ============================================================================
 * Test: Lock-Free Properties
 * ============================================================================ */

TEST_CASE(atomic_lock_free_properties) {
    bool bool_lock_free = aria_atomic_is_lock_free_bool();
    bool int8_lock_free = aria_atomic_is_lock_free_int8();
    bool int32_lock_free = aria_atomic_is_lock_free_int32();
    bool int64_lock_free = aria_atomic_is_lock_free_int64();
    bool ptr_lock_free = aria_atomic_is_lock_free_ptr();
    
    printf("  Lock-free properties: bool=%d int8=%d int32=%d int64=%d ptr=%d\n",
           bool_lock_free, int8_lock_free, int32_lock_free, int64_lock_free, ptr_lock_free);
    
    // On modern architectures, these should all be lock-free
    ASSERT(bool_lock_free, "Bool atomics should be lock-free");
    ASSERT(int32_lock_free, "Int32 atomics should be lock-free");
}

/* ============================================================================
 * Test: Atomic Bool Operations
 * ============================================================================ */

TEST_CASE(atomic_bool_load_store) {
    AriaAtomicBool* atomic = aria_atomic_bool_create(false);
    ASSERT(atomic != nullptr, "Bool atomic creation should succeed");
    
    bool value = aria_atomic_bool_load(atomic, ARIA_MEMORY_ORDER_SEQ_CST);
    ASSERT(value == false, "Initial value should be false");
    
    aria_atomic_bool_store(atomic, true, ARIA_MEMORY_ORDER_SEQ_CST);
    value = aria_atomic_bool_load(atomic, ARIA_MEMORY_ORDER_SEQ_CST);
    ASSERT(value == true, "Stored value should be true");
    
    aria_atomic_bool_destroy(atomic);
}

TEST_CASE(atomic_bool_exchange) {
    AriaAtomicBool* atomic = aria_atomic_bool_create(false);
    ASSERT(atomic != nullptr, "Bool atomic creation should succeed");
    
    bool old = aria_atomic_bool_exchange(atomic, true, ARIA_MEMORY_ORDER_SEQ_CST);
    ASSERT(old == false, "Exchange should return old value");
    
    bool current = aria_atomic_bool_load(atomic, ARIA_MEMORY_ORDER_SEQ_CST);
    ASSERT(current == true, "Exchange should set new value");
    
    aria_atomic_bool_destroy(atomic);
}

TEST_CASE(atomic_bool_compare_exchange) {
    AriaAtomicBool* atomic = aria_atomic_bool_create(false);
    ASSERT(atomic != nullptr, "Bool atomic creation should succeed");
    
    bool expected = false;
    bool success = aria_atomic_bool_compare_exchange_strong(atomic, &expected, true,
                                                             ARIA_MEMORY_ORDER_SEQ_CST,
                                                             ARIA_MEMORY_ORDER_SEQ_CST);
    ASSERT(success, "CAS should succeed when expected matches");
    ASSERT(expected == false, "Expected should be unchanged on success");
    
    expected = false;
    success = aria_atomic_bool_compare_exchange_strong(atomic, &expected, false,
                                                        ARIA_MEMORY_ORDER_SEQ_CST,
                                                        ARIA_MEMORY_ORDER_SEQ_CST);
    ASSERT(!success, "CAS should fail when expected doesn't match");
    ASSERT(expected == true, "Expected should be updated on failure");
    
    aria_atomic_bool_destroy(atomic);
}

