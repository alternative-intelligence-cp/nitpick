    aria_atomic_signal_fence(ARIA_MEMORY_ORDER_ACQUIRE);
    aria_atomic_signal_fence(ARIA_MEMORY_ORDER_SEQ_CST);
    
    // If we got here without crashing, consider it a success
    ASSERT(true, "Memory fences should execute without error");
}

