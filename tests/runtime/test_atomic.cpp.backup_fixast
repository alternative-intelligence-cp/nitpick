/* ============================================================================
 * Test: Concurrent Counter (Multi-threaded)
 * ============================================================================ */

typedef struct {
    AriaAtomicInt32* counter;
    int iterations;
} CounterTestData;

static void* increment_counter_thread(void* arg) {
    CounterTestData* data = (CounterTestData*)arg;
    for (int i = 0; i < data->iterations; i++) {
        aria_atomic_int32_fetch_add(data->counter, 1, ARIA_MEMORY_ORDER_RELAXED);
    }
    return NULL;
}

TEST_CASE(atomic_concurrent_counter) {
    const int NUM_THREADS = 4;
    const int ITERATIONS = 10000;
    
    AriaAtomicInt32* counter = aria_atomic_int32_create(0);
    ASSERT(counter != nullptr, "Counter creation should succeed");
    
    CounterTestData data;
    data.counter = counter;
    data.iterations = ITERATIONS;
    
    AriaThread* threads[NUM_THREADS];
    
    // Create threads
    for (int i = 0; i < NUM_THREADS; i++) {
        AriaResult* result = aria_thread_create(increment_counter_thread, &data);
        ASSERT(result->err == nullptr, "Thread creation should succeed");
        threads[i] = (AriaThread*)result->val;
    }
    
    // Join threads
    for (int i = 0; i < NUM_THREADS; i++) {
        AriaResult* result = aria_thread_join(threads[i], NULL);
        ASSERT(result->err == nullptr, "Thread join should succeed");
    }
    
    int32_t final_value = aria_atomic_int32_load(counter, ARIA_MEMORY_ORDER_SEQ_CST);
    ASSERT(final_value == NUM_THREADS * ITERATIONS, "Counter should have exact value");
    
    aria_atomic_int32_destroy(counter);
}

/* ============================================================================
 * Test: Memory Ordering (Acquire-Release)
 * ============================================================================ */

typedef struct {
    AriaAtomicInt32* data;
    AriaAtomicBool* flag;
} AcqRelTestData;

static void* producer_thread(void* arg) {
    AcqRelTestData* test_data = (AcqRelTestData*)arg;
    
    // Write data
    aria_atomic_int32_store(test_data->data, 42, ARIA_MEMORY_ORDER_RELAXED);
    
    // Release: Publish data availability
    aria_atomic_bool_store(test_data->flag, true, ARIA_MEMORY_ORDER_RELEASE);
    
    return NULL;
}

static void* consumer_thread(void* arg) {
    AcqRelTestData* test_data = (AcqRelTestData*)arg;
    
    // Acquire: Wait for data availability
    while (!aria_atomic_bool_load(test_data->flag, ARIA_MEMORY_ORDER_ACQUIRE)) {
        // Spin (in real code, use proper synchronization)
    }
    
    // Read data (guaranteed to see 42 due to acquire-release ordering)
    int32_t value = aria_atomic_int32_load(test_data->data, ARIA_MEMORY_ORDER_RELAXED);
    
    return (void*)(intptr_t)value;
}

TEST_CASE(atomic_acquire_release_ordering) {
    AcqRelTestData test_data;
    test_data.data = aria_atomic_int32_create(0);
    test_data.flag = aria_atomic_bool_create(false);
    
    ASSERT(test_data.data != nullptr, "Data atomic creation should succeed");
    ASSERT(test_data.flag != nullptr, "Flag atomic creation should succeed");
    
    // Create producer and consumer
    AriaResult* result1 = aria_thread_create(producer_thread, &test_data);
    AriaResult* result2 = aria_thread_create(consumer_thread, &test_data);
    
    ASSERT(result1->err == nullptr, "Producer thread creation should succeed");
    ASSERT(result2->err == nullptr, "Consumer thread creation should succeed");
    
    AriaThread* producer = (AriaThread*)result1->val;
    AriaThread* consumer = (AriaThread*)result2->val;
    
    // Join threads
    aria_thread_join(producer, NULL);
    
    void* consumer_result = NULL;
    aria_thread_join(consumer, &consumer_result);
    
    // Consumer should have seen the value 42
    ASSERT((intptr_t)consumer_result == 42, "Consumer should see published data");
    
    aria_atomic_int32_destroy(test_data.data);
    aria_atomic_bool_destroy(test_data.flag);
}

/* ============================================================================
 * Test: Compare-Exchange in Lock Implementation
 * ============================================================================ */

typedef struct {
    AriaAtomicBool* lock;
    int* shared_counter;
    int iterations;
} SpinlockTestData;

static void* spinlock_increment_thread(void* arg) {
    SpinlockTestData* data = (SpinlockTestData*)arg;
    
    for (int i = 0; i < data->iterations; i++) {
        // Acquire spinlock using CAS
        bool expected = false;
        while (!aria_atomic_bool_compare_exchange_weak(data->lock, &expected, true,
                                                        ARIA_MEMORY_ORDER_ACQUIRE,
                                                        ARIA_MEMORY_ORDER_RELAXED)) {
            expected = false;  // Reset for next attempt
        }
        
        // Critical section
        (*data->shared_counter)++;
        
        // Release spinlock
        aria_atomic_bool_store(data->lock, false, ARIA_MEMORY_ORDER_RELEASE);
    }
    
    return NULL;
}

TEST_CASE(atomic_spinlock_implementation) {
    const int NUM_THREADS = 4;
    const int ITERATIONS = 1000;
    
    AriaAtomicBool* lock = aria_atomic_bool_create(false);
    ASSERT(lock != nullptr, "Lock creation should succeed");
    
    int shared_counter = 0;
    
    SpinlockTestData data;
    data.lock = lock;
    data.shared_counter = &shared_counter;
    data.iterations = ITERATIONS;
    
    AriaThread* threads[NUM_THREADS];
    
    // Create threads
    for (int i = 0; i < NUM_THREADS; i++) {
        AriaResult* result = aria_thread_create(spinlock_increment_thread, &data);
        ASSERT(result->err == nullptr, "Thread creation should succeed");
        threads[i] = (AriaThread*)result->val;
    }
    
    // Join threads
    for (int i = 0; i < NUM_THREADS; i++) {
        AriaResult* result = aria_thread_join(threads[i], NULL);
        ASSERT(result->err == nullptr, "Thread join should succeed");
    }
    
    ASSERT(shared_counter == NUM_THREADS * ITERATIONS, "Spinlock should protect counter");
    
    aria_atomic_bool_destroy(lock);
}

