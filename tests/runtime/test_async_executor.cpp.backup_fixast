TEST_CASE(task_states) {
    Executor executor;
    
    void* handle = (void*)0x1000;
    Task::TaskId id = executor.spawn(handle);
    
    Task* task = executor.getTask(id);
    
    // Task starts in READY state (added to ready queue)
    ASSERT(task->isReady(), "Should be ready initially");
    ASSERT(!task->isPending(), "Should not be pending");
    ASSERT(!task->isRunning(), "Should not be running");
    ASSERT(!task->isSuspended(), "Should not be suspended");
    ASSERT(!task->isCompleted(), "Should not be completed");
    ASSERT(!task->isFailed(), "Should not be failed");
}

TEST_CASE(task_state_after_execution) {
    Executor executor;
    
    void* handle = (void*)0x1000;
    Task::TaskId id = executor.spawn(handle);
    
    executor.step();
    
    Task* task = executor.getTask(id);
    
    // After execution, task should be completed
    ASSERT(task->isCompleted(), "Should be completed");
    ASSERT(!task->isReady(), "Should not be ready");
    ASSERT(!task->isRunning(), "Should not be running");
    ASSERT(!task->isSuspended(), "Should not be suspended");
    ASSERT(!task->isFailed(), "Should not be failed");
}

TEST_CASE(get_nonexistent_task) {
    Executor executor;
    
    Task* task = executor.getTask(999);
    
    ASSERT(task == nullptr, "Should return nullptr for nonexistent task");
}

TEST_CASE(task_result_storage) {
    Executor executor;
    
    void* handle = (void*)0x1000;
    Task::TaskId id = executor.spawn(handle);
    
    Task* task = executor.getTask(id);
    
    ASSERT(task->getResultStorage() == nullptr, "Initially no result storage");
    
    void* storage = (void*)0xABCD;
    task->setResultStorage(storage);
    
    ASSERT(task->getResultStorage() == storage, "Result storage should be set");
}

TEST_CASE(task_error_flag) {
    Executor executor;
    
    void* handle = (void*)0x1000;
    Task::TaskId id = executor.spawn(handle);
    
    Task* task = executor.getTask(id);
    
    ASSERT(!task->hasErrorFlag(), "Initially no error");
    
    task->setError(true);
    
    ASSERT(task->hasErrorFlag(), "Error flag should be set");
}

TEST_CASE(executor_statistics) {
    Executor executor;
    
    executor.spawn((void*)0x1000);
    executor.spawn((void*)0x2000);
    executor.spawn((void*)0x3000);
    executor.spawn((void*)0x4000);
    executor.spawn((void*)0x5000);
    
    ASSERT(executor.getTasksExecuted() == 0, "No tasks executed yet");
    ASSERT(executor.getTasksCompleted() == 0, "No tasks completed yet");
    ASSERT(executor.getPendingTasks() == 5, "5 pending tasks");
    
    executor.runToCompletion();
    
    ASSERT(executor.getTasksExecuted() == 5, "5 tasks executed");
    ASSERT(executor.getTasksCompleted() == 5, "5 tasks completed");
    ASSERT(executor.getTasksFailed() == 0, "No failed tasks");
    ASSERT(executor.getPendingTasks() == 0, "No pending tasks");
}

TEST_CASE(executor_empty_run) {
    Executor executor;
    
    // Run with no tasks
    executor.runToCompletion();
    
    ASSERT(executor.getStatus() == ExecutorStatus::COMPLETED, "Should complete successfully");
    ASSERT(executor.getTasksExecuted() == 0, "No tasks executed");
}

TEST_CASE(step_on_empty_executor) {
    Executor executor;
    
    bool result = executor.step();
    
    ASSERT(result == false, "Step should return false on empty executor");
}
