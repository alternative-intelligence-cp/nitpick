/* ============================================================================
 * Test: Thread-Local Storage
 * ============================================================================ */

static AriaThreadLocal* g_tls_key = NULL;

static void* tls_thread(void* arg) {
    int* value = (int*)malloc(sizeof(int));
    *value = (int)(intptr_t)arg;
    
    aria_thread_local_set(g_tls_key, value);
    
    int* retrieved = (int*)aria_thread_local_get(g_tls_key);
    ASSERT(retrieved == value, "TLS should return same pointer");
    ASSERT(*retrieved == (int)(intptr_t)arg, "TLS should preserve value");
    
    free(value);
    return NULL;
}

TEST_CASE(thread_local_storage) {
    AriaResult* result = aria_thread_local_create(NULL);
    ASSERT(result->err == NULL, "TLS creation should succeed");
    g_tls_key = (AriaThreadLocal*)result->val;
    
    const int NUM_THREADS = 4;
    AriaThread* threads[NUM_THREADS];
    
    // Create threads with different TLS values
    for (int i = 0; i < NUM_THREADS; i++) {
        result = aria_thread_create(tls_thread, (void*)(intptr_t)(i + 100));
        ASSERT(result->err == NULL, "Thread creation should succeed");
        threads[i] = (AriaThread*)result->val;
    }
    
    // Join all threads
    for (int i = 0; i < NUM_THREADS; i++) {
        result = aria_thread_join(threads[i], NULL);
        ASSERT(result->err == NULL, "Thread join should succeed");
    }
    
    aria_thread_local_destroy(g_tls_key);
}

