/* ============================================================================
 * Test: Detached Thread
 * ============================================================================ */

static volatile int detached_counter = 0;

static void* detached_thread_func(void* arg) {
    (void)arg;
    aria_thread_sleep_ns(50000000); // 50ms
    detached_counter = 99;
    return NULL;
}

TEST_CASE(thread_detach) {
    detached_counter = 0;
    
    AriaThreadOptions options = {0};
    options.detached = true;
    
    AriaResult* result = aria_thread_create_with_options(detached_thread_func, NULL, &options);
    ASSERT(result->err == NULL, "Detached thread creation should succeed");
    
    // Can't join a detached thread - just wait for it to finish
    aria_thread_sleep_ns(100000000); // 100ms
    
    ASSERT(detached_counter == 99, "Detached thread should execute");
}

/* ============================================================================
 * Test: Multiple Threads
 * ============================================================================ */

static void* increment_thread(void* arg) {
    int* counter = (int*)arg;
    for (int i = 0; i < 1000; i++) {
        (*counter)++;  // Intentionally racy for basic test
    }
    return NULL;
}

TEST_CASE(thread_multiple) {
    int counter = 0;
    const int NUM_THREADS = 4;
    AriaThread* threads[NUM_THREADS];
    
    // Create threads
    for (int i = 0; i < NUM_THREADS; i++) {
        AriaResult* result = aria_thread_create(increment_thread, &counter);
        ASSERT(result->err == NULL, "Thread creation should succeed");
        threads[i] = (AriaThread*)result->val;
    }
    
    // Join all threads
    for (int i = 0; i < NUM_THREADS; i++) {
        AriaResult* result = aria_thread_join(threads[i], NULL);
        ASSERT(result->err == NULL, "Thread join should succeed");
    }
    
    // Counter should be around NUM_THREADS * 1000, but may vary due to races
    ASSERT(counter > 0, "Counter should be incremented");
    ASSERT(counter <= NUM_THREADS * 1000, "Counter should not exceed maximum");
}

