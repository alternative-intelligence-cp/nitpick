/* ============================================================================
 * Test: Simple Thread Creation and Join
 * ============================================================================ */

static void* simple_thread_func(void* arg) {
    int* value = (int*)arg;
    *value = 42;
    return (void*)(intptr_t)123;
}

TEST_CASE(thread_create_and_join) {
    int shared_value = 0;
    AriaResult* result = aria_thread_create(simple_thread_func, &shared_value);
    
    ASSERT(result->err == NULL, "Thread creation should succeed");
    AriaThread* thread = (AriaThread*)result->val;
    
    void* ret_val = NULL;
    result = aria_thread_join(thread, &ret_val);
    
    ASSERT(result->err == NULL, "Thread join should succeed");
    ASSERT(shared_value == 42, "Thread should modify shared value");
    ASSERT((intptr_t)ret_val == 123, "Thread should return expected value");
}

