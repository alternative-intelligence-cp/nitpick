/* ============================================================================
 * Test: Mutex Protects Shared Data
 * ============================================================================ */

typedef struct {
    AriaMutex* mutex;
    int counter;
} MutexTestData;

static void* mutex_increment_thread(void* arg) {
    MutexTestData* data = (MutexTestData*)arg;
    
    for (int i = 0; i < 1000; i++) {
        aria_mutex_lock(data->mutex);
        data->counter++;
        aria_mutex_unlock(data->mutex);
    }
    
    return NULL;
}

TEST_CASE(mutex_protects_data) {
    AriaResult* result = aria_mutex_create(ARIA_MUTEX_NORMAL);
    ASSERT(result->err == NULL, "Mutex creation should succeed");
    
    MutexTestData data;
    data.mutex = (AriaMutex*)result->val;
    data.counter = 0;
    
    const int NUM_THREADS = 4;
    AriaThread* threads[NUM_THREADS];
    
    // Create threads
    for (int i = 0; i < NUM_THREADS; i++) {
        result = aria_thread_create(mutex_increment_thread, &data);
        ASSERT(result->err == NULL, "Thread creation should succeed");
        threads[i] = (AriaThread*)result->val;
    }
    
    // Join all threads
    for (int i = 0; i < NUM_THREADS; i++) {
        result = aria_thread_join(threads[i], NULL);
        ASSERT(result->err == NULL, "Thread join should succeed");
    }
    
    ASSERT(data.counter == NUM_THREADS * 1000, "Mutex should protect counter perfectly");
    
    aria_mutex_destroy(data.mutex);
}

