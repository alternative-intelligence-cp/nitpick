/* ============================================================================
 * Test: Condition Variable Signal
 * ============================================================================ */

typedef struct {
    AriaMutex* mutex;
    AriaCondVar* condvar;
    bool ready;
} CondVarTestData;

static void* condvar_wait_thread(void* arg) {
    CondVarTestData* data = (CondVarTestData*)arg;
    
    aria_mutex_lock(data->mutex);
    while (!data->ready) {
        aria_condvar_wait(data->condvar, data->mutex);
    }
    aria_mutex_unlock(data->mutex);
    
    return (void*)(intptr_t)777;
}

TEST_CASE(condvar_signal) {
    AriaResult* result = aria_mutex_create(ARIA_MUTEX_NORMAL);
    ASSERT(result->err == NULL, "Mutex creation should succeed");
    
    CondVarTestData data;
    data.mutex = (AriaMutex*)result->val;
    
    result = aria_condvar_create();
    ASSERT(result->err == NULL, "CondVar creation should succeed");
    data.condvar = (AriaCondVar*)result->val;
    data.ready = false;
    
    // Create waiting thread
    result = aria_thread_create(condvar_wait_thread, &data);
    ASSERT(result->err == NULL, "Thread creation should succeed");
    AriaThread* thread = (AriaThread*)result->val;
    
    // Give thread time to start waiting
    aria_thread_sleep_ns(50000000); // 50ms
    
    // Signal the thread
    aria_mutex_lock(data.mutex);
    data.ready = true;
    aria_condvar_signal(data.condvar);
    aria_mutex_unlock(data.mutex);
    
    // Join thread
    void* ret_val = NULL;
    result = aria_thread_join(thread, &ret_val);
    ASSERT(result->err == NULL, "Thread join should succeed");
    ASSERT((intptr_t)ret_val == 777, "Thread should have been woken");
    
    aria_condvar_destroy(data.condvar);
    aria_mutex_destroy(data.mutex);
}

