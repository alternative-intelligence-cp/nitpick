/* ============================================================================
 * Test: Barrier
 * ============================================================================ */

typedef struct {
    AriaBarrier* barrier;
    volatile int* counter;
} BarrierTestData;

static void* barrier_thread(void* arg) {
    BarrierTestData* data = (BarrierTestData*)arg;
    
    // Increment before barrier
    __sync_fetch_and_add(data->counter, 1);
    
    // Wait at barrier
    aria_barrier_wait(data->barrier);
    
    // All threads should see the full count now
    return (void*)(intptr_t)(*data->counter);
}

TEST_CASE(barrier_synchronize) {
    const int NUM_THREADS = 4;
    
    AriaResult* result = aria_barrier_create(NUM_THREADS);
    ASSERT(result->err == NULL, "Barrier creation should succeed");
    
    BarrierTestData data;
    data.barrier = (AriaBarrier*)result->val;
    volatile int counter = 0;
    data.counter = &counter;
    
    AriaThread* threads[NUM_THREADS];
    
    // Create threads
    for (int i = 0; i < NUM_THREADS; i++) {
        result = aria_thread_create(barrier_thread, &data);
        ASSERT(result->err == NULL, "Thread creation should succeed");
        threads[i] = (AriaThread*)result->val;
    }
    
    // Join all threads
    for (int i = 0; i < NUM_THREADS; i++) {
        void* ret_val = NULL;
        result = aria_thread_join(threads[i], &ret_val);
        ASSERT(result->err == NULL, "Thread join should succeed");
        ASSERT((intptr_t)ret_val == NUM_THREADS, "All threads should see full count");
    }
    
    aria_barrier_destroy(data.barrier);
}

