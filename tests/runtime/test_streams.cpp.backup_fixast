// ============================================================================
// Debug Session Tests
// ============================================================================

TEST_CASE(debug_session_create_close) {
    AriaDebugSession* session = aria_debug_session_create("test_session");
    ASSERT(session != nullptr, "Debug session should be created");
    
    aria_debug_session_close(session);
}

TEST_CASE(debug_session_log) {
    AriaDebugSession* session = aria_debug_session_create("test");
    ASSERT(session != nullptr, "Debug session should be created");
    
    // These should not crash
    aria_debug_session_log(session, ARIA_LOG_DEBUG, "Debug message");
    aria_debug_session_log(session, ARIA_LOG_INFO, "Info message");
    aria_debug_session_log(session, ARIA_LOG_WARN, "Warning message");
    aria_debug_session_log(session, ARIA_LOG_ERROR, "Error message");
    aria_debug_session_log(session, ARIA_LOG_FATAL, "Fatal message");
    
    aria_debug_session_close(session);
}

TEST_CASE(debug_session_logf) {
    AriaDebugSession* session = aria_debug_session_create("formatted");
    ASSERT(session != nullptr, "Debug session should be created");
    
    aria_debug_session_logf(session, ARIA_LOG_INFO, "User: %s, ID: %d", "alice", 42);
    aria_debug_session_logf(session, ARIA_LOG_WARN, "Low memory: %d MB", 128);
    
    aria_debug_session_close(session);
}

TEST_CASE(debug_session_min_level) {
    AriaDebugSession* session = aria_debug_session_create("filtered");
    ASSERT(session != nullptr, "Debug session should be created");
    
    // Set minimum level to WARN
    aria_debug_session_set_min_level(session, ARIA_LOG_WARN);
    
    // These should be filtered (DEBUG, INFO below WARN)
    aria_debug_session_log(session, ARIA_LOG_DEBUG, "Should not appear");
    aria_debug_session_log(session, ARIA_LOG_INFO, "Should not appear");
    
    // These should appear (WARN, ERROR, FATAL >= WARN)
    aria_debug_session_log(session, ARIA_LOG_WARN, "Should appear");
    aria_debug_session_log(session, ARIA_LOG_ERROR, "Should appear");
    
    aria_debug_session_close(session);
}

TEST_CASE(debug_session_timestamps) {
    AriaDebugSession* session = aria_debug_session_create("timestamps");
    ASSERT(session != nullptr, "Debug session should be created");
    
    // Enable timestamps (default)
    aria_debug_session_set_timestamps(session, true);
    aria_debug_session_log(session, ARIA_LOG_INFO, "With timestamp");
    
    // Disable timestamps
    aria_debug_session_set_timestamps(session, false);
    aria_debug_session_log(session, ARIA_LOG_INFO, "Without timestamp");
    
    aria_debug_session_close(session);
}

