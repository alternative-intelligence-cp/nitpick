    AriaSystemTime* now = aria_systemtime_now();
    ASSERT(now != nullptr, "Getting current system time should succeed");
    ASSERT(!aria_systemtime_is_err(now), "System time should not be ERR");
    
    int64_t unix_secs = aria_systemtime_to_unix_secs(now);
    // Current time should be after 2020-01-01 (1577836800)
    ASSERT(unix_secs > 1577836800, "Unix timestamp should be reasonable");
    
    aria_systemtime_destroy(now);
}

TEST_CASE(systemtime_from_unix) {
    // Create time from Unix timestamp: 2024-01-01 00:00:00 UTC = 1704067200
    int64_t unix_secs = 1704067200;
    AriaSystemTime* time = aria_systemtime_from_unix_secs(unix_secs);
    
    ASSERT(time != nullptr, "Creating system time from Unix should succeed");
    
    int64_t extracted = aria_systemtime_to_unix_secs(time);
    ASSERT(extracted == unix_secs, "Extracted timestamp should match");
    
    aria_systemtime_destroy(time);
}

TEST_CASE(systemtime_nanosecond_precision) {
    int64_t unix_nanos = 1704067200000000000LL; // 2024-01-01 with nanos
    AriaSystemTime* time = aria_systemtime_from_unix_nanos(unix_nanos);
    
    ASSERT(time != nullptr, "Creating system time from nanos should succeed");
    
    int64_t extracted = aria_systemtime_to_unix_nanos(time);
    ASSERT(extracted == unix_nanos, "Extracted nanos should match");
    
    aria_systemtime_destroy(time);
}

TEST_CASE(systemtime_duration_since_epoch) {
    AriaSystemTime* now = aria_systemtime_now();
    AriaDuration* since_epoch = aria_systemtime_duration_since_epoch(now);
    
    ASSERT(since_epoch != nullptr, "Duration since epoch should be valid");
    ASSERT(!aria_duration_is_err(since_epoch), "Duration should not be ERR");
    
    int64_t secs = aria_duration_as_secs(since_epoch);
    ASSERT(secs > 1577836800, "Should be many seconds since 1970");
    
    aria_systemtime_destroy(now);
    aria_duration_destroy(since_epoch);
}

/* ============================================================================
 * Test: Sleep Functions
 * ============================================================================ */

TEST_CASE(sleep_short_duration) {
    AriaInstant* start = aria_instant_now();
    
    AriaDuration* sleep_time = aria_duration_from_millis(10); // 10ms
    int result = aria_sleep(sleep_time);
    
    AriaInstant* end = aria_instant_now();
    
    ASSERT(result == 0, "Sleep should succeed");
    
    AriaDuration* elapsed = aria_instant_duration_since(end, start);
    int64_t elapsed_ms = aria_duration_as_millis(elapsed);
    
    // Allow 5ms tolerance for scheduler granularity
    ASSERT(elapsed_ms >= 8, "Should sleep at least ~10ms");
    ASSERT(elapsed_ms < 50, "Should not oversleep significantly");
    
    printf("  Sleep requested: 10ms, actual: %lldms\n", (long long)elapsed_ms);
    
    aria_instant_destroy(start);
    aria_instant_destroy(end);
    aria_duration_destroy(sleep_time);
    aria_duration_destroy(elapsed);
}

TEST_CASE(sleep_zero_duration) {
    AriaDuration* zero = aria_duration_from_nanos(0);
    int result = aria_sleep(zero);
    
    ASSERT(result == 0, "Zero sleep should succeed immediately");
    
    aria_duration_destroy(zero);
}

TEST_CASE(sleep_err_handling) {
    AriaDuration* err_dur = aria_duration_from_nanos(ARIA_TIME_ERR);
    int result = aria_sleep(err_dur);
    
    ASSERT(result == -1, "Sleep with ERR duration should fail");
    
    aria_duration_destroy(err_dur);
}

