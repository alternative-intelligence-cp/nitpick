/* ============================================================================
 * Test: TBB64 Symmetric Range Benefits
 * ============================================================================ */

TEST_CASE(tbb_symmetric_negation) {
    // Standard int64_t has asymmetry: abs(INT64_MIN) fails
    // TBB64 is symmetric: -MAX is valid
    
    AriaDuration* max_dur = aria_duration_from_nanos(ARIA_TIME_MAX);
    int64_t max_val = aria_duration_as_nanos(max_dur);
    
    // Create negative max (which would be problematic with standard integers)
    AriaDuration* neg_max = aria_duration_from_nanos(-max_val);
    ASSERT(neg_max != nullptr, "Negative max should be valid");
    ASSERT(!aria_duration_is_err(neg_max), "Negative max should not be ERR");
    
    int64_t neg_val = aria_duration_as_nanos(neg_max);
    ASSERT(neg_val == -max_val, "Negation should work symmetrically");
    
    aria_duration_destroy(max_dur);
    aria_duration_destroy(neg_max);
}

TEST_CASE(tbb_no_asymmetry_bugs) {
    // In standard int64: abs(-9223372036854775808) is undefined/overflow
    // In TBB64: the minimum value (-2^63) is reserved as ERR, so symmetric range works
    
    AriaDuration* near_min = aria_duration_from_nanos(ARIA_TIME_MIN);
    int64_t val = aria_duration_as_nanos(near_min);
    
    // Negating near-minimum should work (TBB prevents the asymmetry)
    AriaDuration* negated = aria_duration_from_nanos(-val);
    ASSERT(!aria_duration_is_err(negated), "Negation of MIN should work");
    
    int64_t neg_val = aria_duration_as_nanos(negated);
    ASSERT(neg_val == -val, "Double negation should restore value");
    ASSERT(neg_val == ARIA_TIME_MAX, "Negated MIN should equal MAX");
    
    aria_duration_destroy(near_min);
    aria_duration_destroy(negated);
}

