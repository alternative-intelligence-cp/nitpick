/* ============================================================================
 * Test: Duration Creation and Conversion
 * ============================================================================ */

TEST_CASE(duration_from_nanos) {
    AriaDuration* dur = aria_duration_from_nanos(1000000000);
    ASSERT(dur != nullptr, "Duration creation should succeed");
    
    int64_t nanos = aria_duration_as_nanos(dur);
    ASSERT(nanos == 1000000000, "Nanoseconds should match");
    
    int64_t secs = aria_duration_as_secs(dur);
    ASSERT(secs == 1, "Should be 1 second");
    
    aria_duration_destroy(dur);
}

TEST_CASE(duration_from_various_units) {
    // Microseconds
    AriaDuration* micros = aria_duration_from_micros(1000);
    ASSERT(micros != nullptr, "Microsecond duration creation should succeed");
    int64_t micros_ns = aria_duration_as_nanos(micros);
    ASSERT(micros_ns == 1000000, "1000 microseconds = 1 million nanoseconds");
    
    // Milliseconds
    AriaDuration* millis = aria_duration_from_millis(500);
    ASSERT(millis != nullptr, "Millisecond duration creation should succeed");
    int64_t millis_ns = aria_duration_as_nanos(millis);
    ASSERT(millis_ns == 500000000, "500 milliseconds = 500 million nanoseconds");
    
    // Seconds
    AriaDuration* secs = aria_duration_from_secs(5);
    ASSERT(secs != nullptr, "Second duration creation should succeed");
    int64_t secs_ns = aria_duration_as_nanos(secs);
    ASSERT(secs_ns == 5000000000, "5 seconds = 5 billion nanoseconds");
    
    aria_duration_destroy(micros);
    aria_duration_destroy(millis);
    aria_duration_destroy(secs);
}

TEST_CASE(duration_tbb_err_handling) {
    AriaDuration* err_dur = aria_duration_from_nanos(ARIA_TIME_ERR);
    ASSERT(err_dur != nullptr, "ERR duration creation should succeed");
    ASSERT(aria_duration_is_err(err_dur), "Duration should be ERR");
    
    int64_t extracted = aria_duration_as_nanos(err_dur);
    ASSERT(extracted == ARIA_TIME_ERR, "Extracted value should be ERR");
    
    aria_duration_destroy(err_dur);
}

/* ============================================================================
 * Test: Duration Arithmetic with TBB64
 * ============================================================================ */

TEST_CASE(duration_addition) {
    AriaDuration* a = aria_duration_from_millis(100);
    AriaDuration* b = aria_duration_from_millis(250);
    
    AriaDuration* sum = aria_duration_add(a, b);
    ASSERT(sum != nullptr, "Addition should succeed");
    
    int64_t result_ms = aria_duration_as_millis(sum);
    ASSERT(result_ms == 350, "100ms + 250ms = 350ms");
    
    aria_duration_destroy(a);
    aria_duration_destroy(b);
    aria_duration_destroy(sum);
}

TEST_CASE(duration_subtraction) {
    AriaDuration* a = aria_duration_from_secs(10);
    AriaDuration* b = aria_duration_from_secs(3);
    
    AriaDuration* diff = aria_duration_sub(a, b);
    ASSERT(diff != nullptr, "Subtraction should succeed");
    
    int64_t result_s = aria_duration_as_secs(diff);
    ASSERT(result_s == 7, "10s - 3s = 7s");
    
    aria_duration_destroy(a);
    aria_duration_destroy(b);
    aria_duration_destroy(diff);
}

TEST_CASE(duration_multiplication) {
    AriaDuration* dur = aria_duration_from_millis(50);
    
    AriaDuration* scaled = aria_duration_mul(dur, 10);
    ASSERT(scaled != nullptr, "Multiplication should succeed");
    
    int64_t result_ms = aria_duration_as_millis(scaled);
    ASSERT(result_ms == 500, "50ms * 10 = 500ms");
    
    aria_duration_destroy(dur);
    aria_duration_destroy(scaled);
}

TEST_CASE(duration_division) {
    AriaDuration* dur = aria_duration_from_secs(10);
    
    AriaDuration* divided = aria_duration_div(dur, 2);
    ASSERT(divided != nullptr, "Division should succeed");
    
    int64_t result_s = aria_duration_as_secs(divided);
    ASSERT(result_s == 5, "10s / 2 = 5s");
    
    aria_duration_destroy(dur);
    aria_duration_destroy(divided);
}

TEST_CASE(duration_tbb_overflow_propagation) {
    // Create duration near maximum
    AriaDuration* max_dur = aria_duration_from_nanos(ARIA_TIME_MAX);
    AriaDuration* one = aria_duration_from_nanos(1);
    
    // Adding 1 to MAX should overflow to ERR
    AriaDuration* overflow = aria_duration_add(max_dur, one);
    ASSERT(overflow != nullptr, "Overflow addition should return ERR duration");
    ASSERT(aria_duration_is_err(overflow), "Overflow should produce ERR");
    
    aria_duration_destroy(max_dur);
    aria_duration_destroy(one);
    aria_duration_destroy(overflow);
}

TEST_CASE(duration_tbb_sticky_error) {
    AriaDuration* err = aria_duration_from_nanos(ARIA_TIME_ERR);
    AriaDuration* normal = aria_duration_from_secs(5);
    
    // ERR + normal = ERR (sticky)
    AriaDuration* sum = aria_duration_add(err, normal);
    ASSERT(aria_duration_is_err(sum), "ERR + value should be ERR");
    
    // normal + ERR = ERR (commutative)
    AriaDuration* sum2 = aria_duration_add(normal, err);
    ASSERT(aria_duration_is_err(sum2), "value + ERR should be ERR");
    
    aria_duration_destroy(err);
    aria_duration_destroy(normal);
    aria_duration_destroy(sum);
    aria_duration_destroy(sum2);
}

/* ============================================================================
 * Test: Duration Comparison
 * ============================================================================ */

TEST_CASE(duration_comparison) {
    AriaDuration* short_dur = aria_duration_from_millis(100);
    AriaDuration* long_dur = aria_duration_from_millis(500);
    AriaDuration* equal_dur = aria_duration_from_millis(100);
    
    ASSERT(aria_duration_compare(short_dur, long_dur) < 0, "100ms < 500ms");
    ASSERT(aria_duration_compare(long_dur, short_dur) > 0, "500ms > 100ms");
    ASSERT(aria_duration_compare(short_dur, equal_dur) == 0, "100ms == 100ms");
    
    aria_duration_destroy(short_dur);
    aria_duration_destroy(long_dur);
    aria_duration_destroy(equal_dur);
}

TEST_CASE(duration_is_zero) {
    AriaDuration* zero = aria_duration_from_nanos(0);
    AriaDuration* nonzero = aria_duration_from_millis(1);
    
    ASSERT(aria_duration_is_zero(zero), "Zero duration should be detected");
    ASSERT(!aria_duration_is_zero(nonzero), "Non-zero duration should not be zero");
    
    aria_duration_destroy(zero);
    aria_duration_destroy(nonzero);
}

/* ============================================================================
 * Test: Monotonic Clock (Instant)
 * ============================================================================ */

TEST_CASE(instant_now) {
    AriaInstant* now = aria_instant_now();
    ASSERT(now != nullptr, "Getting current instant should succeed");
    ASSERT(!aria_instant_is_err(now), "Instant should not be ERR");
    
    aria_instant_destroy(now);
}

TEST_CASE(instant_elapsed) {
    AriaInstant* start = aria_instant_now();
    ASSERT(start != nullptr, "Start instant should be valid");
    
    // Small delay (platform-dependent busy wait)
    volatile int sum = 0;
    for (int i = 0; i < 100000; i++) {
        sum += i;
    }
    
    AriaDuration* elapsed = aria_instant_elapsed(start);
    ASSERT(elapsed != nullptr, "Elapsed duration should be valid");
    ASSERT(!aria_duration_is_err(elapsed), "Elapsed should not be ERR");
    
    int64_t elapsed_ns = aria_duration_as_nanos(elapsed);
    ASSERT(elapsed_ns > 0, "Some time should have elapsed");
    
    aria_instant_destroy(start);
    aria_duration_destroy(elapsed);
}

TEST_CASE(instant_duration_since) {
    AriaInstant* earlier = aria_instant_now();
    ASSERT(earlier != nullptr, "Earlier instant should be valid");
    
    // Small delay
    volatile int sum = 0;
    for (int i = 0; i < 100000; i++) {
        sum += i;
    }
    
    AriaInstant* later = aria_instant_now();
    ASSERT(later != nullptr, "Later instant should be valid");
    
    AriaDuration* diff = aria_instant_duration_since(later, earlier);
    ASSERT(diff != nullptr, "Duration difference should be valid");
    ASSERT(!aria_duration_is_err(diff), "Difference should not be ERR");
    
    int64_t diff_ns = aria_duration_as_nanos(diff);
    ASSERT(diff_ns > 0, "Later - earlier should be positive");
    
    aria_instant_destroy(earlier);
    aria_instant_destroy(later);
    aria_duration_destroy(diff);
}

TEST_CASE(instant_arithmetic) {
    AriaInstant* now = aria_instant_now();
    AriaDuration* offset = aria_duration_from_secs(10);
    
    // Add duration
    AriaInstant* future = aria_instant_add(now, offset);
    ASSERT(future != nullptr, "Adding duration should succeed");
    ASSERT(!aria_instant_is_err(future), "Future instant should be valid");
    
    // Subtract duration
    AriaInstant* past = aria_instant_sub(now, offset);
    ASSERT(past != nullptr, "Subtracting duration should succeed");
    ASSERT(!aria_instant_is_err(past), "Past instant should be valid");
    
    aria_instant_destroy(now);
    aria_instant_destroy(future);
    aria_instant_destroy(past);
    aria_duration_destroy(offset);
}

