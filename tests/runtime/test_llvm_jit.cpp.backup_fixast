// ============================================================================
// Utility Tests
// ============================================================================

TEST_CASE(llvm_jit_get_target_triple) {
    const char* triple = aria_llvm_get_target_triple();
    ASSERT(triple != nullptr, "Target triple should not be NULL");
    
    // Should contain architecture (x86_64, aarch64, etc.)
    bool has_arch = strstr(triple, "x86_64") || strstr(triple, "aarch64") || strstr(triple, "i686");
    ASSERT(has_arch, "Target triple should contain valid architecture");
}

TEST_CASE(llvm_jit_get_data_layout) {
    const char* layout = aria_llvm_get_data_layout();
    ASSERT(layout != nullptr, "Data layout should not be NULL");
    
    // Should start with endianness (e=little, E=big)
    ASSERT(layout[0] == 'e' || layout[0] == 'E', "Data layout should start with endianness marker");
}
