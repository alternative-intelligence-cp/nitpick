/**
 * Test Suite: LLVM ORC JIT Integration
 * 
 * Tests high-optimization JIT compilation using LLVM's ORC engine.
 * Validates optimization levels, function compilation, and execution.
 */

#include "../test_helpers.h"
#include "runtime/llvm_jit.h"

#include <cstdio>
#include <cstring>

// ============================================================================
// Test Helpers
// ============================================================================

/**
 * LLVM IR for simple return constant function
 * 
 * define i64 @return_42() {
 *   ret i64 42
 * }
 */
static const char* IR_RETURN_CONSTANT = R"(
define i64 @return_42() {
  ret i64 42
}
)";

/**
 * LLVM IR for identity function
 * 
 * define i64 @identity(i64 %x) {
 *   ret i64 %x
 * }
 */
static const char* IR_IDENTITY = R"(
define i64 @identity(i64 %x) {
  ret i64 %x
}
)";

/**
 * LLVM IR for addition function
 * 
 * define i64 @add(i64 %a, i64 %b) {
 *   %sum = add i64 %a, %b
 *   ret i64 %sum
 * }
 */
static const char* IR_ADD = R"(
define i64 @add(i64 %a, i64 %b) {
  %sum = add i64 %a, %b
  ret i64 %sum
}
)";

// ============================================================================
// JIT Lifecycle Tests
// ============================================================================

TEST_CASE(llvm_jit_create_destroy) {
    // Test JIT creation with different optimization levels
    AriaLLVMJIT* jit0 = aria_llvm_jit_create(0);
    ASSERT(jit0 != nullptr, "JIT O0 creation should succeed");
    ASSERT(jit0->optimization_level == 0, "Opt level should be O0");
    
    AriaLLVMJIT* jit2 = aria_llvm_jit_create(2);
    ASSERT(jit2 != nullptr, "JIT O2 creation should succeed");
    ASSERT(jit2->optimization_level == 2, "Opt level should be O2");
    
    AriaLLVMJIT* jit3 = aria_llvm_jit_create(3);
    ASSERT(jit3 != nullptr, "JIT O3 creation should succeed");
    ASSERT(jit3->optimization_level == 3, "Opt level should be O3");
    
    // Verify default optimization flags
    ASSERT(jit2->enable_inlining, "Inlining should be enabled by default");
    ASSERT(jit2->enable_vectorization, "Vectorization should be enabled by default");
    
    // Cleanup
    aria_llvm_jit_destroy(jit0);
    aria_llvm_jit_destroy(jit2);
    aria_llvm_jit_destroy(jit3);
}

TEST_CASE(llvm_jit_invalid_opt_level) {
    // Test invalid optimization levels (should clamp to valid range)
    AriaLLVMJIT* jit_neg = aria_llvm_jit_create(-1);
    ASSERT(jit_neg != nullptr, "JIT creation should succeed with invalid opt level");
    ASSERT(jit_neg->optimization_level == 2, "Should default to O2");
    
    AriaLLVMJIT* jit_high = aria_llvm_jit_create(10);
    ASSERT(jit_high != nullptr, "JIT creation should succeed with high opt level");
    ASSERT(jit_high->optimization_level == 2, "Should default to O2");
    
    aria_llvm_jit_destroy(jit_neg);
    aria_llvm_jit_destroy(jit_high);
}

// ============================================================================
// IR Compilation Tests
// ============================================================================

TEST_CASE(llvm_jit_compile_return_constant) {
    AriaLLVMJIT* jit = aria_llvm_jit_create(2);
    ASSERT(jit != nullptr, "JIT creation should succeed");
    
    // Compile IR
    int result = aria_llvm_jit_compile_ir(jit, IR_RETURN_CONSTANT, "test_module");
    ASSERT(result == 0, "IR compilation should succeed");
    
    // Lookup function
    AriaJITFunction* func = aria_llvm_jit_lookup(jit, "return_42");
    ASSERT(func != nullptr, "Function lookup should succeed");
    ASSERT(func->function_ptr != nullptr, "Function pointer should be valid");
    
    // Execute
    int64_t value = aria_jit_execute_i64(func, 0);
    ASSERT(value == 42, "Function should return 42");
    
    free(func);
    aria_llvm_jit_destroy(jit);
}

TEST_CASE(llvm_jit_compile_identity) {
    AriaLLVMJIT* jit = aria_llvm_jit_create(2);
    ASSERT(jit != nullptr, "JIT creation should succeed");
    
    // Compile IR
    int result = aria_llvm_jit_compile_ir(jit, IR_IDENTITY, "identity_module");
    ASSERT(result == 0, "IR compilation should succeed");
    
    // Lookup function
    AriaJITFunction* func = aria_llvm_jit_lookup(jit, "identity");
    ASSERT(func != nullptr, "Function lookup should succeed");
    
    // Execute with various inputs
    int64_t val1 = aria_jit_execute_i64(func, 0);
    ASSERT(val1 == 0, "identity(0) should be 0");
    
    int64_t val2 = aria_jit_execute_i64(func, 42);
    ASSERT(val2 == 42, "identity(42) should be 42");
    
    int64_t val3 = aria_jit_execute_i64(func, -100);
    ASSERT(val3 == -100, "identity(-100) should be -100");
    
    free(func);
    aria_llvm_jit_destroy(jit);
}

TEST_CASE(llvm_jit_compile_add) {
    AriaLLVMJIT* jit = aria_llvm_jit_create(2);
    ASSERT(jit != nullptr, "JIT creation should succeed");
    
    // Compile IR
    int result = aria_llvm_jit_compile_ir(jit, IR_ADD, "add_module");
    ASSERT(result == 0, "IR compilation should succeed");
    
    // Lookup function
    AriaJITFunction* func = aria_llvm_jit_lookup(jit, "add");
    ASSERT(func != nullptr, "Function lookup should succeed");
    
    // Execute with various inputs
    int64_t sum1 = aria_jit_execute_i64_i64(func, 10, 32);
    ASSERT(sum1 == 42, "add(10, 32) should be 42");
    
    int64_t sum2 = aria_jit_execute_i64_i64(func, 0, 0);
    ASSERT(sum2 == 0, "add(0, 0) should be 0");
    
    int64_t sum3 = aria_jit_execute_i64_i64(func, -5, 5);
    ASSERT(sum3 == 0, "add(-5, 5) should be 0");
    
    free(func);
    aria_llvm_jit_destroy(jit);
}

// ============================================================================
// Configuration Tests
// ============================================================================

TEST_CASE(llvm_jit_set_opt_level) {
    AriaLLVMJIT* jit = aria_llvm_jit_create(1);
    ASSERT(jit != nullptr, "JIT creation should succeed");
    ASSERT(jit->optimization_level == 1, "Initial opt level should be O1");
    
    // Change optimization level
    aria_llvm_jit_set_opt_level(jit, 3);
    ASSERT(jit->optimization_level == 3, "Opt level should be changed to O3");
    
    // Invalid opt level (should clamp to O2)
    aria_llvm_jit_set_opt_level(jit, 10);
    ASSERT(jit->optimization_level == 2, "Invalid opt level should clamp to O2");
    
    aria_llvm_jit_destroy(jit);
}

TEST_CASE(llvm_jit_set_inlining) {
    AriaLLVMJIT* jit = aria_llvm_jit_create(2);
    ASSERT(jit != nullptr, "JIT creation should succeed");
    ASSERT(jit->enable_inlining, "Inlining should be enabled by default");
    
    // Disable inlining
    aria_llvm_jit_set_inlining(jit, false);
    ASSERT(!jit->enable_inlining, "Inlining should be disabled");
    
    // Re-enable inlining
    aria_llvm_jit_set_inlining(jit, true);
    ASSERT(jit->enable_inlining, "Inlining should be re-enabled");
    
    aria_llvm_jit_destroy(jit);
}

TEST_CASE(llvm_jit_set_vectorization) {
    AriaLLVMJIT* jit = aria_llvm_jit_create(2);
    ASSERT(jit != nullptr, "JIT creation should succeed");
    ASSERT(jit->enable_vectorization, "Vectorization should be enabled by default");
    
    // Disable vectorization
    aria_llvm_jit_set_vectorization(jit, false);
    ASSERT(!jit->enable_vectorization, "Vectorization should be disabled");
    
    // Re-enable vectorization
    aria_llvm_jit_set_vectorization(jit, true);
    ASSERT(jit->enable_vectorization, "Vectorization should be re-enabled");
    
    aria_llvm_jit_destroy(jit);
}

// ============================================================================
// Error Handling Tests
// ============================================================================

TEST_CASE(llvm_jit_lookup_nonexistent) {
    AriaLLVMJIT* jit = aria_llvm_jit_create(2);
    ASSERT(jit != nullptr, "JIT creation should succeed");
    
    // Compile IR
    aria_llvm_jit_compile_ir(jit, IR_IDENTITY, "test_module");
    
    // Lookup nonexistent function (should return NULL)
    AriaJITFunction* func = aria_llvm_jit_lookup(jit, "nonexistent_function");
    ASSERT(func == nullptr, "Lookup of nonexistent function should return NULL");
    
    aria_llvm_jit_destroy(jit);
}

