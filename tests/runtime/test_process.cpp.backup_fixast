/**
 * Aria Runtime - Process Management Tests
 * 
 * Test suite for process spawning, forking, execution, and pipes.
 */

#include "runtime/process.h"
#include "test_helpers.h"
#include <cstring>
#include <cstdio>
#include <unistd.h>
#include <sys/wait.h>

// Test helper programs (we'll use standard Unix utilities)
static const char* TEST_ECHO = "/bin/echo";
static const char* TEST_TRUE = "/bin/true";
static const char* TEST_FALSE = "/bin/false";
static const char* TEST_SLEEP = "/bin/sleep";
static const char* TEST_CAT = "/bin/cat";

// ============================================================================
// Process Information Tests
// ============================================================================

TEST_CASE(process_get_current_pid) {
    int64_t pid = aria_get_current_pid();
    ASSERT(pid > 0, "Current PID should be positive");
}

TEST_CASE(process_get_parent_pid) {
    int64_t ppid = aria_get_parent_pid();
    ASSERT(ppid > 0, "Parent PID should be positive");
}

// ============================================================================
// Spawn Tests
// ============================================================================

TEST_CASE(spawn_simple_command) {
    const char* args[] = {"Hello", "World", NULL};
    AriaResult* r = aria_spawn(TEST_ECHO, args, NULL);
    
    ASSERT(r != nullptr, "Result should not be NULL");
    ASSERT(r->err == nullptr, "Spawn should succeed");
    
    AriaProcessInfo* info = (AriaProcessInfo*)r->val;
    ASSERT(info != nullptr, "Process info should not be NULL");
    ASSERT(info->pid > 0, "PID should be positive");
    ASSERT(info->handle != nullptr, "Handle should not be NULL");
    
    // Wait for process to complete
    int exit_code = aria_process_wait(info->handle);
    ASSERT(exit_code == 0, "Echo should exit with 0");
    
    aria_process_free(info->handle);
    aria_process_info_free(info);
    r->val = NULL;
    aria_result_free(r);
}

TEST_CASE(spawn_with_exit_code) {
    // /bin/true should exit with 0
    AriaResult* r_true = aria_spawn(TEST_TRUE, NULL, NULL);
    ASSERT(r_true->err == nullptr, "Spawn /bin/true should succeed");
    
    AriaProcessInfo* info_true = (AriaProcessInfo*)r_true->val;
    int exit_code_true = aria_process_wait(info_true->handle);
    ASSERT(exit_code_true == 0, "/bin/true should exit with 0");
    
    aria_process_free(info_true->handle);
    aria_process_info_free(info_true);
    r_true->val = NULL;
    aria_result_free(r_true);
    
    // /bin/false should exit with 1
    AriaResult* r_false = aria_spawn(TEST_FALSE, NULL, NULL);
    ASSERT(r_false->err == nullptr, "Spawn /bin/false should succeed");
    
    AriaProcessInfo* info_false = (AriaProcessInfo*)r_false->val;
    int exit_code_false = aria_process_wait(info_false->handle);
    ASSERT(exit_code_false == 1, "/bin/false should exit with 1");
    
    aria_process_free(info_false->handle);
    aria_process_info_free(info_false);
    r_false->val = NULL;
    aria_result_free(r_false);
}

TEST_CASE(spawn_get_pid) {
    AriaResult* r = aria_spawn(TEST_TRUE, NULL, NULL);
    ASSERT(r->err == nullptr, "Spawn should succeed");
    
    AriaProcessInfo* info = (AriaProcessInfo*)r->val;
    int64_t pid = aria_process_get_pid(info->handle);
    
    ASSERT(pid > 0, "PID should be positive");
    ASSERT(pid == info->pid, "PIDs should match");
    
    aria_process_wait(info->handle);
    aria_process_free(info->handle);
    aria_process_info_free(info);
    r->val = NULL;
    aria_result_free(r);
}

TEST_CASE(spawn_is_running) {
    const char* args[] = {"0.1", NULL};  // Sleep for 0.1 seconds
    AriaResult* r = aria_spawn(TEST_SLEEP, args, NULL);
    ASSERT(r->err == nullptr, "Spawn should succeed");
    
    AriaProcessInfo* info = (AriaProcessInfo*)r->val;
    
    // Should be running initially
    bool running = aria_process_is_running(info->handle);
    ASSERT(running, "Process should be running");
    
    // Wait for it to finish
    aria_process_wait(info->handle);
    
    // Should not be running after wait
    running = aria_process_is_running(info->handle);
    ASSERT(!running, "Process should not be running after wait");
    
    aria_process_free(info->handle);
    aria_process_info_free(info);
    r->val = NULL;
    aria_result_free(r);
}

TEST_CASE(spawn_get_exit_code) {
    AriaResult* r = aria_spawn(TEST_TRUE, NULL, NULL);
    ASSERT(r->err == nullptr, "Spawn should succeed");
    
    AriaProcessInfo* info = (AriaProcessInfo*)r->val;
    
    // Exit code not available before wait
    int exit_code;
    bool has_exit = aria_process_get_exit_code(info->handle, &exit_code);
    ASSERT(!has_exit, "Exit code should not be available before wait");
    
    // Wait for process
    aria_process_wait(info->handle);
    
    // Exit code should be available now
    has_exit = aria_process_get_exit_code(info->handle, &exit_code);
    ASSERT(has_exit, "Exit code should be available after wait");
    ASSERT(exit_code == 0, "Exit code should be 0");
    
    aria_process_free(info->handle);
    aria_process_info_free(info);
    r->val = NULL;
    aria_result_free(r);
}

// ============================================================================
// Fork Tests
// ============================================================================

TEST_CASE(fork_basic) {
    AriaResult* r = aria_fork();
    ASSERT(r != nullptr, "Fork result should not be NULL");
    ASSERT(r->err == nullptr, "Fork should succeed");
    
    AriaForkInfo* info = (AriaForkInfo*)r->val;
    ASSERT(info != nullptr, "Fork info should not be NULL");
    
    if (info->is_child) {
        // Child process - exit immediately with code 42
        aria_fork_info_free(info);
        r->val = NULL;
        aria_result_free(r);
        exit(42);
    } else {
        // Parent process
        ASSERT(info->pid > 0, "Child PID should be positive");
        
        // Wait for child
        int status;
        waitpid((pid_t)info->pid, &status, 0);
        
        int exit_code = WIFEXITED(status) ? WEXITSTATUS(status) : -1;
        ASSERT(exit_code == 42, "Child should exit with 42");
        
        aria_fork_info_free(info);
        r->val = NULL;
        aria_result_free(r);
    }
}

TEST_CASE(fork_parent_child_identification) {
    AriaResult* r = aria_fork();
    ASSERT(r->err == nullptr, "Fork should succeed");
    
    AriaForkInfo* info = (AriaForkInfo*)r->val;
    
    if (info->is_child) {
        // Child
        ASSERT(info->pid == 0, "Child should have pid 0 in fork info");
        ASSERT(info->parent_pid > 0, "Parent PID should be positive");
        
        aria_fork_info_free(info);
        r->val = NULL;
        aria_result_free(r);
        exit(0);
    } else {
        // Parent
        ASSERT(info->pid > 0, "Parent should have child PID > 0");
        
        // Wait for child
        waitpid((pid_t)info->pid, NULL, 0);
        
        aria_fork_info_free(info);
        r->val = NULL;
        aria_result_free(r);
    }
}

// ============================================================================
// Pipe Tests
// ============================================================================

TEST_CASE(pipe_create) {
    AriaResult* r = aria_pipe_create();
    
    ASSERT(r != nullptr, "Result should not be NULL");
    ASSERT(r->err == nullptr, "Pipe creation should succeed");
    
    AriaPipe* pipe = (AriaPipe*)r->val;
    ASSERT(pipe != nullptr, "Pipe should not be NULL");
    
    int read_fd = aria_pipe_get_read_fd(pipe);
    int write_fd = aria_pipe_get_write_fd(pipe);
    
    ASSERT(read_fd >= 0, "Read FD should be valid");
    ASSERT(write_fd >= 0, "Write FD should be valid");
    ASSERT(read_fd != write_fd, "Read and write FDs should be different");
    
    aria_pipe_free(pipe);
    r->val = NULL;
    aria_result_free(r);
}

TEST_CASE(pipe_write_read) {
    AriaResult* r = aria_pipe_create();
    ASSERT(r->err == nullptr, "Pipe creation should succeed");
    
    AriaPipe* pipe = (AriaPipe*)r->val;
    
    // Write data
    const char* message = "Hello through pipe!";
    int64_t written = aria_pipe_write(pipe, message, strlen(message));
    ASSERT(written == (int64_t)strlen(message), "Should write all bytes");
    
    // Read data
    char buffer[100] = {0};
    int64_t bytes_read = aria_pipe_read(pipe, buffer, sizeof(buffer) - 1);
    ASSERT(bytes_read == (int64_t)strlen(message), "Should read all bytes");
    ASSERT(strcmp(buffer, message) == 0, "Data should match");
    
    aria_pipe_free(pipe);
    r->val = NULL;
    aria_result_free(r);
}

TEST_CASE(pipe_close_write_eof) {
    AriaResult* r = aria_pipe_create();
    ASSERT(r->err == nullptr, "Pipe creation should succeed");
    
    AriaPipe* pipe = (AriaPipe*)r->val;
    
    // Write some data
    const char* message = "Test";
    aria_pipe_write(pipe, message, strlen(message));
    
    // Close write end
    int result = aria_pipe_close_write(pipe);
    ASSERT(result == 0, "Close write should succeed");
    
    // Read should get the data
    char buffer[100];
    int64_t bytes_read = aria_pipe_read(pipe, buffer, sizeof(buffer));
    ASSERT(bytes_read == (int64_t)strlen(message), "Should read data");
    
    // Next read should get EOF (0)
    bytes_read = aria_pipe_read(pipe, buffer, sizeof(buffer));
    ASSERT(bytes_read == 0, "Should get EOF after write end closed");
    
    aria_pipe_free(pipe);
    r->val = NULL;
    aria_result_free(r);
}

TEST_CASE(pipe_with_fork) {
    AriaResult* pipe_r = aria_pipe_create();
    ASSERT(pipe_r->err == nullptr, "Pipe creation should succeed");
    
    AriaPipe* pipe = (AriaPipe*)pipe_r->val;
    
    AriaResult* fork_r = aria_fork();
    ASSERT(fork_r->err == nullptr, "Fork should succeed");
    
    AriaForkInfo* info = (AriaForkInfo*)fork_r->val;
    
    if (info->is_child) {
        // Child writes to pipe
        const char* message = "Message from child";
        aria_pipe_close_read(pipe);  // Close unused read end
        aria_pipe_write(pipe, message, strlen(message));
        aria_pipe_close_write(pipe);
        
        aria_fork_info_free(info);
        fork_r->val = NULL;
        aria_result_free(fork_r);
        aria_pipe_free(pipe);
        pipe_r->val = NULL;
        aria_result_free(pipe_r);
        exit(0);
    } else {
        // Parent reads from pipe
        aria_pipe_close_write(pipe);  // Close unused write end
        
        char buffer[100] = {0};
        int64_t bytes_read = aria_pipe_read(pipe, buffer, sizeof(buffer) - 1);
        
        ASSERT(bytes_read > 0, "Should read data from child");
        ASSERT(strcmp(buffer, "Message from child") == 0, "Message should match");
        
        // Wait for child
        waitpid((pid_t)info->pid, NULL, 0);
        
        aria_fork_info_free(info);
        fork_r->val = NULL;
        aria_result_free(fork_r);
        aria_pipe_free(pipe);
        pipe_r->val = NULL;
        aria_result_free(pipe_r);
    }
}

// ============================================================================
// Spawn Options Tests
// ============================================================================

TEST_CASE(spawn_options_create_free) {
    AriaSpawnOptions* options = aria_spawn_options_create();
    ASSERT(options != nullptr, "Options should be created");
    
    aria_spawn_options_free(options);
}

TEST_CASE(spawn_with_pipe_redirect) {
    // Create pipe for stdout
    AriaResult* pipe_r = aria_pipe_create();
    ASSERT(pipe_r->err == nullptr, "Pipe creation should succeed");
    
    AriaPipe* pipe = (AriaPipe*)pipe_r->val;
    
    // Create spawn options
    AriaSpawnOptions* options = aria_spawn_options_create();
    options->redirect_stdout = true;
    options->stdout_pipe = pipe;
    
    // Spawn echo command
    const char* args[] = {"Hello", "Pipe", NULL};
    AriaResult* spawn_r = aria_spawn(TEST_ECHO, args, options);
    ASSERT(spawn_r->err == nullptr, "Spawn should succeed");
    
    AriaProcessInfo* info = (AriaProcessInfo*)spawn_r->val;
    
    // Close write end in parent
    aria_pipe_close_write(pipe);
    
    // Read output from pipe
    char buffer[100] = {0};
    int64_t bytes_read = aria_pipe_read(pipe, buffer, sizeof(buffer) - 1);
    
    ASSERT(bytes_read > 0, "Should read data from child");
    ASSERT(strstr(buffer, "Hello") != nullptr, "Output should contain 'Hello'");
    ASSERT(strstr(buffer, "Pipe") != nullptr, "Output should contain 'Pipe'");
    
    // Wait for process
    aria_process_wait(info->handle);
    
    // Cleanup
    aria_process_free(info->handle);
    aria_process_info_free(info);
    spawn_r->val = NULL;
    aria_result_free(spawn_r);
    
    aria_pipe_free(pipe);
    pipe_r->val = NULL;
    aria_result_free(pipe_r);
    
    aria_spawn_options_free(options);
}
