/// Minimal test of current pointer capabilities

/// Test 1: @ for address-of (Randy's design - works!)
func:test_address_syntax = int32() {
    int64:myInt = 345;
    int64->:myPtr = @myInt;  // @ = "at the address of"
    
    // Retrieve via array indexing (current workaround for dereference)
    int64:retrieved = myPtr[0];
    
    pass(0);
};

/// Test 2: What we discovered doesn't work yet
/// Standalone dereference syntax is TBD in compiler
/// These don't compile:
///   int64:val = ptr@;    // Not implemented
///   int64:val = @ptr;    // Wrong - this gets address OF the pointer
///   int64:val = *ptr;    // Wrong - * is only for extern blocks

func:main = int32() {
    int32:r = raw(test_address_syntax());
    exit(0);
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit(1);
};
