/**
 * Nikola Capability Test
 * 
 * Systematically validates Aria features required for Nikola implementation.
 * Tests: custom types, generics, pattern matching, error handling
 */

// ============================================================================
// TEST 1: Custom Numeric Type
// ============================================================================

struct:Nit = {
    int32:value;
};

func:nit_new = Nit(int32:v) {
    int32:clamped = v;
    if (v < -4i32) {
        clamped = -4i32;
    }
    if (v > 4i32) {
        clamped = 4i32;
    }
    Nit:result = {value: clamped};
    pass result;
};

func:nit_add = Nit(Nit:a, Nit:b) {
    int32:sum = a.value + b.value;
    Result<Nit>:res = nit_new(sum);
    if (res.is_error) { fail 1i32; }
    pass res.value;
};

func:nit_eq = bool(Nit:a, Nit:b) {
    pass a.value == b.value;
};

// ============================================================================
// TEST 2: Generic Complex Number Type
// ============================================================================

struct<T>:Complex = {
    T:real;
    T:imag;
};

func<T>:complex_add = Complex<T>(Complex<T>:a, Complex<T>:b) {
    Complex<T>:result;
    result.real = a.real + b.real;
    result.imag = a.imag + b.imag;
    pass result;
};

func<T>:complex_mul = Complex<T>(Complex<T>:a, Complex<T>:b) {
    T:ac = a.real * b.real;
    T:bd = a.imag * b.imag;
    T:ad = a.real * b.imag;
    T:bc = a.imag * b.real;
    
    Complex<T>:result = {real: ac - bd, imag: ad + bc};
    pass result;
};

// ============================================================================
// TEST 3: Pattern Matching
// ============================================================================

func:classify_nit = int32(Nit:n) {
    if (n.value < 0) {
        pass 1;  // Negative
    }
    if (n.value == 0) {
        pass 0;  // Zero
    }
    pass 2;  // Positive
};

// ============================================================================
// TEST 4: Error Handling with Result Types
// ============================================================================

func:safe_divide = int32(int32:a, int32:b) {
    if (b == 0) {
        fail 1;  // Error code
    }
    pass a / b;
};

// ============================================================================
// MAIN TEST RUNNER
// ============================================================================

func:failsafe = int32(tbb32:err) {
    exit 1;
};

func:main = int32() {
    println("=== Nikola Capability Test Suite ===");
    println("");
    
    // TEST 1: Custom Numeric Type (Nit)
    println("[TEST 1] Custom Numeric Type - Nit");
    
    Result<Nit>:n1_res = nit_new(3i32);
    if (n1_res.is_error) { println("  FAIL: nit_new(3) failed"); pass -10i32; }
    Nit:n1 = n1_res.value;
    
    Result<Nit>:n2_res = nit_new(-2i32);
    if (n2_res.is_error) { println("  FAIL: nit_new(-2) failed"); pass -11i32; }
    Nit:n2 = n2_res.value;
    
    // Test addition: 3 + (-2) = 1
    Result<Nit>:sum_res = nit_add(n1, n2);
    if (sum_res.is_error) { println("  FAIL: nit_add failed"); pass -12i32; }
    Nit:sum = sum_res.value;
    if (sum.value != 1i32) {
        println("  FAIL: Nit addition");
        pass -1i32;
    }
    println("  PASS: Addition works (3 + -2 = 1)");
    
    // Test saturation
    Result<Nit>:saturated_res = nit_new(10i32);
    if (saturated_res.is_error) { println("  FAIL: nit_new(10) failed"); pass -15i32; }
    Nit:saturated = saturated_res.value;
    if (saturated.value != 4i32) {
        println("  FAIL: Nit saturation (expected 4 from 10)");
        pass -2i32;
    }
    println("  PASS: Saturation works");
    
    // Test equality
    Result<Nit>:n3_res = nit_new(3i32);
    if (n3_res.is_error) { println("  FAIL: nit_new(3) for equality failed"); pass -14i32; }
    Nit:n3 = n3_res.value;
    Result<bool>:eq_result = nit_eq(n1, n3);
    if (eq_result.is_error){        println("  FAIL: Equality returned error");
        pass -3i32;
    }
    if (!eq_result.value) {
        println("  FAIL: Nit equality");
        pass -4i32;
    }
    println("  PASS: Equality works");
    
    println("");
    
    // TEST 2: Generic Complex Numbers
    println("[TEST 2] Generic Complex Numbers");
    
    // Test with int32 - using inline operations (Result<Complex<T>> not supported by parser)
    Complex<int32>:z1 = {real: 3, imag: 4};
    Complex<int32>:z2 = {real: 1, imag: 2};
    
    // Manual addition: (3+4i) + (1+2i) = (4+6i)
    Complex<int32>:z_sum = {real: z1.real + z2.real, imag: z1.imag + z2.imag};
    
    if (z_sum.real != 4 || z_sum.imag != 6) {
        println("  FAIL: Complex addition");
        pass -5;
    }
    println("  PASS: Complex addition works (3+4i + 1+2i = 4+6i)");
    
    // Manual multiplication: (3+4i) * (1+2i) = (3-8) + (6+4)i = -5+10i
    int32:ac = z1.real * z2.real;
    int32:bd = z1.imag * z2.imag;
    int32:ad = z1.real * z2.imag;
    int32:bc = z1.imag * z2.real;
    
    Complex<int32>:z_prod = {real: ac - bd, imag: ad + bc};
    
    if (z_prod.real != -5 || z_prod.imag != 10) {
        println("  FAIL: Complex multiplication");
        pass -6;
    }
    println("  PASS: Complex multiplication works (3+4i * 1+2i = -5+10i)");
    
    // Test with int64 (different type) - verifies generics work
    Complex<int64>:w1 = {real: 10, imag: 20};
    Complex<int64>:w2 = {real: 5, imag: 15};
    
    Complex<int64>:w_sum = {real: w1.real + w2.real, imag: w1.imag + w2.imag};
    
    if (w_sum.real != 15 || w_sum.imag != 35) {
        println("  FAIL: Complex<int64> addition");
        pass -7;
    }
    println("  PASS: Generic instantiation works (Complex<int32> and Complex<int64>)");
    
    println("");
    
    // TEST 3: Pattern Matching
    println("[TEST 3] Pattern Matching");
    
    Nit:neg = raw nit_new(-3);
    Nit:zero = raw nit_new(0);
    Nit:pos = raw nit_new(2);
    
    int32:class_neg = raw classify_nit(neg);
    int32:class_zero = raw classify_nit(zero);
    int32:class_pos = raw classify_nit(pos);
    
    if (class_neg != 1 || class_zero != 0 || class_pos != 2) {
        println("  FAIL: Pattern matching classification");
        pass -7;
    }
    println("  PASS: Pattern matching works");
    
    println("");
    
    // TEST 4: Error Handling
    println("[TEST 4] Error Handling with Result<T>");
    
    Result<int32>:good_div = safe_divide(10, 2);
    if (good_div.is_error) {
        println("  FAIL: Valid division returned error");
        pass -11;
    }
    if (good_div.value != 5) {
        println("  FAIL: Division result incorrect");
        pass -12;
    }
    println("  PASS: Successful Result works");
    
    Result<int32>:bad_div = safe_divide(10, 0);
    if (!bad_div.is_error) {
        println("  FAIL: Division by zero should return error");
        pass -13;
    }
    println("  PASS: Error Result works (division by zero detected)");
    
    println("");
    println("=== ALL TESTS PASSED ===");
    
    exit 0;
};
