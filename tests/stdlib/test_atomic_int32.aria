// Expected: COMPILER ERROR
/**
 * Test Suite: atomic_int32
 * 
 * Verifies lock-free atomic operations for 32-bit signed integers.
 * Tests all operations with various memory orderings.
 */

// Memory ordering constants
func:RELAXED = int32() { pass 0; };
func:ACQUIRE = int32() { pass 1; };
func:RELEASE = int32() { pass 2; };
func:ACQ_REL = int32() { pass 3; };
func:SEQ_CST = int32() { pass 4; };

// ============================================================================
// Extern Declarations (from stdlib/atomic/int32.aria)
// ============================================================================

extern func:aria_atomic_int32_create = wild int8*(int32);
extern func:aria_atomic_int32_destroy = void(wild int8*);
extern func:aria_atomic_int32_store = void(wild int8*, int32, int32);
extern func:aria_atomic_int32_load = int32(wild int8*, int32);
extern func:aria_atomic_int32_exchange = int32(wild int8*, int32, int32);
extern func:aria_atomic_int32_compare_exchange_strong = bool(wild int8*, wild int32*, int32, int32, int32);
extern func:aria_atomic_int32_fetch_add = int32(wild int8*, int32, int32);
extern func:aria_atomic_int32_fetch_sub = int32(wild int8*, int32, int32);

struct atomic_int32 {
    ptr: wild int8*;
};

pub func atomic_int32_new(int32:value) = atomic_int32 {
    atomic_int32:result;
    result.ptr = aria_atomic_int32_create(value);
    pass result;
};

pub func atomic_int32_destroy(atomic_int32:self) = void {
    aria_atomic_int32_destroy(self.ptr);
    pass;
};

pub func atomic_int32_store(atomic_int32:self, int32:value, int32:order) = void {
    aria_atomic_int32_store(self.ptr, value, order);
    pass;
};

pub func atomic_int32_load(atomic_int32:self, int32:order) = int32 {
    int32:result = aria_atomic_int32_load(self.ptr, order);
    pass result;
};

pub func atomic_int32_exchange(atomic_int32:self, int32:value, int32:order) = int32 {
    int32:result = aria_atomic_int32_exchange(self.ptr, value, order);
    pass result;
};

pub func atomic_int32_compare_exchange_strong(
    atomic_int32:self,
    @int32:expected,
    int32:desired,
    int32:success_order,
    int32:failure_order
) = bool {
    bool:result = aria_atomic_int32_compare_exchange_strong(
        self.ptr, expected, desired, success_order, failure_order
    );
    pass result;
};

pub func atomic_int32_fetch_add(atomic_int32:self, int32:value, int32:order) = int32 {
    int32:result = aria_atomic_int32_fetch_add(self.ptr, value, order);
    pass result;
};

pub func atomic_int32_fetch_sub(atomic_int32:self, int32:value, int32:order) = int32 {
    int32:result = aria_atomic_int32_fetch_sub(self.ptr, value, order);
    pass result;
};

// ============================================================================
// Tests
// ============================================================================

/**
 * Test: Basic store and load
 */
func:test_store_load = int32() {
    atomic_int32:counter = atomic_int32_new(0);
    
    # Store with release ordering
    atomic_int32_store(counter, 42, 2);  # 2 = RELEASE
    
    # Load with acquire ordering (synchronizes with release store)
    int32:value = atomic_int32_load(counter, 1);  # 1 = ACQUIRE
    
    atomic_int32_destroy(counter);
    
    # Should read the stored value
    if value == 42 {
        pass 0;  # SUCCESS
    } else {
        pass 1;  # FAILURE
    }
};

/**
 * Test: Atomic exchange
 */
func:test_exchange = int32() {
    atomic_int32:counter = atomic_int32_new(10);
    
    # Exchange 10 for 20
    int32:old = atomic_int32_exchange(counter, 20, 3);  # 3 = ACQ_REL
    
    # old should be 10
    int32:new_val = atomic_int32_load(counter, 4);  # 4 = SEQ_CST
    
    atomic_int32_destroy(counter);
    
    if old == 10 && new_val == 20 {
        pass 0;  # SUCCESS
    } else {
        pass 1;  # FAILURE
    }
};

/**
 * Test: Compare-and-swap (success case)
 */
func:test_cas_success = int32() {
    atomic_int32:counter = atomic_int32_new(10);
    
    int32:expected = 10;
    bool:swapped = atomic_int32_compare_exchange_strong(
        counter, @expected, 20, 3, 1  # 3=ACQ_REL, 1=ACQUIRE
    );
    
    int32:value = atomic_int32_load(counter, 4);  # 4=SEQ_CST
    
    atomic_int32_destroy(counter);
    
    # Should succeed: expected was 10, so store 20
    if swapped && value == 20 && expected == 10 {
        pass 0;  # SUCCESS
    } else {
        pass 1;  # FAILURE
    }
};

/**
 * Test: Compare-and-swap (failure case)
 */
func:test_cas_failure = int32() {
    atomic_int32:counter = atomic_int32_new(10);
    
    int32:expected = 99;  # WRONG value
    bool:swapped = atomic_int32_compare_exchange_strong(
        counter, @expected, 20, 3, 1  # 3=ACQ_REL, 1=ACQUIRE
    );
    
    int32:value = atomic_int32_load(counter, 4);  # 4=SEQ_CST
    
    atomic_int32_destroy(counter);
    
    # Should fail: expected was 99 but actual is 10
    # expected should be updated to 10
    # value should still be 10 (not changed)
    if !swapped && expected == 10 && value == 10 {
        pass 0;  # SUCCESS
    } else {
        pass 1;  # FAILURE
    }
};

/**
 * Test: Fetch-add operation
 */
func:test_fetch_add = int32() {
    atomic_int32:counter = atomic_int32_new(10);
    
    # Add 5, get old value
    int32:old1 = atomic_int32_fetch_add(counter, 5, 2);  # 2=RELEASE
    int32:current1 = atomic_int32_load(counter, 1);  # 1=ACQUIRE
    
    # Add 3 more
    int32:old2 = atomic_int32_fetch_add(counter, 3, 2);
    int32:current2 = atomic_int32_load(counter, 1);
    
    atomic_int32_destroy(counter);
    
    # old1 should be 10, current1 should be 15
    # old2 should be 15, current2 should be 18
    if old1 == 10 && current1 == 15 && old2 == 15 && current2 == 18 {
        pass 0;  # SUCCESS
    } else {
        pass 1;  # FAILURE
    }
};

/**
 * Test: Fetch-sub operation
 */
func:test_fetch_sub = int32() {
    atomic_int32:counter = atomic_int32_new(100);
    
    # Subtract 10
    int32:old1 = atomic_int32_fetch_sub(counter, 10, 2);  # 2=RELEASE
    int32:current1 = atomic_int32_load(counter, 1);  # 1=ACQUIRE
    
    # Subtract 5 more
    int32:old2 = atomic_int32_fetch_sub(counter, 5, 2);
    int32:current2 = atomic_int32_load(counter, 1);
    
    atomic_int32_destroy(counter);
    
    # old1 should be 100, current1 should be 90
    # old2 should be 90, current2 should be 85
    if old1 == 100 && current1 == 90 && old2 == 90 && current2 == 85 {
        pass 0;  # SUCCESS
    } else {
        pass 1;  # FAILURE
    }
};

/**
 * Test: Relaxed memory ordering
 */
func:test_relaxed_ordering = int32() {
    atomic_int32:counter = atomic_int32_new(0);
    
    # Use relaxed ordering - only atomicity, no synchronization
    atomic_int32_store(counter, 123, 0);  # 0=RELAXED
    int32:value = atomic_int32_load(counter, 0);  # 0=RELAXED
    
    atomic_int32_destroy(counter);
    
    # Should still work (same thread)
    if value == 123 {
        pass 0;  # SUCCESS
    } else {
        pass 1;  # FAILURE
    }
};

/**
 * Main test runner
 */
func:main = int32() {
    int32:failures = 0;
    
    # Run all tests
    failures = failures + test_store_load();
    failures = failures + test_exchange();
    failures = failures + test_cas_success();
    failures = failures + test_cas_failure();
    failures = failures + test_fetch_add();
    failures = failures + test_fetch_sub();
    failures = failures + test_relaxed_ordering();
    
    # Report results
    if failures == 0 {
        # All tests passed!
        exit 0;
    } else {
        # Some tests failed
        pass failures;
    }
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
