// ============================================================================
// Array Allocation Tests
// ============================================================================

TEST_CASE(arena_alloc_array_success) {
    AriaArenaResult arena_res = aria_arena_new(8192);
    aria_arena* arena = arena_res.arena;
    
    // Allocate array of 100 int64_t
    AriaAllocResult res = aria_arena_alloc_array(arena, sizeof(int64_t), 100, 8);
    
    ASSERT_MSG(aria_alloc_result_is_ok(res), "Array allocation should succeed");
    ASSERT_MSG(res.value != NULL, "Pointer should not be NULL");
    ASSERT_EQ_MSG(res.requested_size, sizeof(int64_t) * 100, "Size should be elem_size * count");
    
    // Initialize and verify
    int64_t* arr = (int64_t*)res.value;
    for (int i = 0; i < 100; i++) {
        arr[i] = i * 2;
    }
    
    ASSERT_EQ_MSG(arr[0], 0, "First element");
    ASSERT_EQ_MSG(arr[50], 100, "Middle element");
    ASSERT_EQ_MSG(arr[99], 198, "Last element");
    
    aria_arena_destroy(arena);
}

TEST_CASE(arena_alloc_array_overflow) {
    AriaArenaResult arena_res = aria_arena_new(4096);
    aria_arena* arena = arena_res.arena;
    
    // Try to overflow: SIZE_MAX elements of 2 bytes each
    AriaAllocResult res = aria_arena_alloc_array(arena, 2, SIZE_MAX, 8);
    
    ASSERT_MSG(aria_alloc_result_is_err(res), "Should fail with overflow");
    ASSERT_EQ_MSG(res.error_code, ARIA_ALLOC_ERR_SIZE_OVERFLOW, "Error should be SIZE_OVERFLOW");
    
    aria_arena_destroy(arena);
}

