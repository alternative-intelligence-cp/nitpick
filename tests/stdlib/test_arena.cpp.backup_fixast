/**
 * Arena Allocator Tests - Phase 4.2 Stage 3
 * 
 * Tests for Aria's arena allocator including:
 * - Creation and destruction
 * - Pointer bump allocation
 * - Block chaining
 * - Reset with retain capacity
 * - Large allocation optimization
 * - Error handling
 */

#include "test_helpers.h"
#include "runtime/arena.h"
#include <cstring>

// ============================================================================
// Arena Creation Tests
// ============================================================================

TEST_CASE(arena_new_success) {
    AriaArenaResult result = aria_arena_new(4096);
    
    ASSERT_MSG(aria_arena_result_is_ok(result), "Arena creation should succeed");
    ASSERT_MSG(result.arena != NULL, "Arena pointer should not be NULL");
    ASSERT_EQ_MSG(result.error_code, ARIA_ARENA_OK, "Error code should be ARIA_ARENA_OK");
    
    aria_arena_destroy(result.arena);
}

TEST_CASE(arena_new_with_block_size) {
    AriaArenaResult result = aria_arena_new_with_block_size(8192, 8192);
    
    ASSERT_MSG(aria_arena_result_is_ok(result), "Arena creation should succeed");
    ASSERT_MSG(result.arena != NULL, "Arena pointer should not be NULL");
    
    aria_arena_destroy(result.arena);
}

TEST_CASE(arena_new_invalid_block_size) {
    // Block size too small (< 256)
    AriaArenaResult result = aria_arena_new_with_block_size(1024, 128);
    
    ASSERT_MSG(aria_arena_result_is_err(result), "Should fail with small block size");
    ASSERT_EQ_MSG(result.error_code, ARIA_ARENA_ERR_INVALID_CAPACITY, "Error should be INVALID_CAPACITY");
    ASSERT_MSG(result.arena == NULL, "Arena pointer should be NULL on error");
}

TEST_CASE(arena_destroy_null_safe) {
    // Should not crash with NULL
    aria_arena_destroy(NULL);
}

// ============================================================================
// Basic Allocation Tests
// ============================================================================

TEST_CASE(arena_alloc_single) {
    AriaArenaResult arena_res = aria_arena_new(4096);
    ASSERT_MSG(aria_arena_result_is_ok(arena_res), "Arena creation should succeed");
    aria_arena* arena = arena_res.arena;
    
    // Allocate 64 bytes
    AriaAllocResult alloc_res = aria_arena_alloc(arena, 64, 8);
    
    ASSERT_MSG(aria_alloc_result_is_ok(alloc_res), "Allocation should succeed");
    ASSERT_MSG(alloc_res.value != NULL, "Pointer should not be NULL");
    ASSERT_EQ_MSG(alloc_res.requested_size, 64, "Size should be 64");
    
    // Use the memory
    memset(alloc_res.value, 42, 64);
    uint8_t* bytes = (uint8_t*)alloc_res.value;
    ASSERT_EQ_MSG(bytes[0], 42, "Memory should be writable");
    ASSERT_EQ_MSG(bytes[63], 42, "Memory should be writable");
    
    aria_arena_destroy(arena);
}

TEST_CASE(arena_alloc_multiple) {
    AriaArenaResult arena_res = aria_arena_new(4096);
    aria_arena* arena = arena_res.arena;
    
    // Allocate multiple objects
    AriaAllocResult res1 = aria_arena_alloc(arena, 32, 8);
    AriaAllocResult res2 = aria_arena_alloc(arena, 64, 8);
    AriaAllocResult res3 = aria_arena_alloc(arena, 128, 8);
    
    ASSERT_MSG(aria_alloc_result_is_ok(res1), "First allocation should succeed");
    ASSERT_MSG(aria_alloc_result_is_ok(res2), "Second allocation should succeed");
    ASSERT_MSG(aria_alloc_result_is_ok(res3), "Third allocation should succeed");
    
    // Pointers should be distinct
    ASSERT_MSG(res1.value != res2.value, "Pointers should be different");
    ASSERT_MSG(res2.value != res3.value, "Pointers should be different");
    
    aria_arena_destroy(arena);
}

TEST_CASE(arena_alloc_alignment) {
    AriaArenaResult arena_res = aria_arena_new(4096);
    aria_arena* arena = arena_res.arena;
    
    // Allocate with 16-byte alignment
    AriaAllocResult res = aria_arena_alloc(arena, 64, 16);
    
    ASSERT_MSG(aria_alloc_result_is_ok(res), "Allocation should succeed");
    ASSERT_MSG(((uintptr_t)res.value % 16) == 0, "Pointer should be 16-byte aligned");
    
    // Allocate with 32-byte alignment
    AriaAllocResult res2 = aria_arena_alloc(arena, 64, 32);
    ASSERT_MSG(((uintptr_t)res2.value % 32) == 0, "Pointer should be 32-byte aligned");
    
    aria_arena_destroy(arena);
}

