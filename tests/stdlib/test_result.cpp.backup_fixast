TEST_CASE(alloc_result_ok_basic) {
    void* ptr = (void*)0x1000;
    AriaAllocResult result = aria_alloc_result_ok(ptr, 64, 16);
    
    ASSERT_MSG(aria_alloc_result_is_ok(result), "Result should be Ok");
    ASSERT_MSG(!aria_alloc_result_is_err(result), "Result should not be Err");
    ASSERT_MSG(result.value == ptr, "Value should match");
    ASSERT_EQ_MSG(result.error_code, ARIA_ALLOC_OK, "Error code should be ARIA_ALLOC_OK");
    ASSERT_EQ_MSG(result.requested_size, 64, "Size should be 64");
    ASSERT_EQ_MSG(result.requested_align, 16, "Alignment should be 16");
}

TEST_CASE(alloc_result_err_out_of_memory) {
    AriaAllocResult result = aria_alloc_result_err(ARIA_ALLOC_ERR_OUT_OF_MEMORY, 1024, 0);
    
    ASSERT_MSG(aria_alloc_result_is_err(result), "Result should be Err");
    ASSERT_MSG(!aria_alloc_result_is_ok(result), "Result should not be Ok");
    ASSERT_MSG(result.value == NULL, "Value should be NULL");
    ASSERT_EQ_MSG(result.error_code, ARIA_ALLOC_ERR_OUT_OF_MEMORY, "Error code should be OUT_OF_MEMORY");
    ASSERT_EQ_MSG(result.requested_size, 1024, "Size should be 1024");
}

TEST_CASE(alloc_result_err_invalid_size) {
    AriaAllocResult result = aria_alloc_result_err(ARIA_ALLOC_ERR_INVALID_SIZE, 0, 0);
    
    ASSERT_MSG(aria_alloc_result_is_err(result), "Result should be Err");
    ASSERT_EQ_MSG(result.error_code, ARIA_ALLOC_ERR_INVALID_SIZE, "Error code should be INVALID_SIZE");
}

TEST_CASE(alloc_result_err_invalid_alignment) {
    AriaAllocResult result = aria_alloc_result_err(ARIA_ALLOC_ERR_INVALID_ALIGNMENT, 64, 15);
    
    ASSERT_MSG(aria_alloc_result_is_err(result), "Result should be Err");
    ASSERT_EQ_MSG(result.error_code, ARIA_ALLOC_ERR_INVALID_ALIGNMENT, "Error code should be INVALID_ALIGNMENT");
    ASSERT_EQ_MSG(result.requested_align, 15, "Alignment should be 15 (invalid)");
}

TEST_CASE(alloc_result_err_size_overflow) {
    AriaAllocResult result = aria_alloc_result_err(ARIA_ALLOC_ERR_SIZE_OVERFLOW, 0, 0);
    
    ASSERT_MSG(aria_alloc_result_is_err(result), "Result should be Err");
    ASSERT_EQ_MSG(result.error_code, ARIA_ALLOC_ERR_SIZE_OVERFLOW, "Error code should be SIZE_OVERFLOW");
}

TEST_CASE(alloc_error_messages) {
    const char* msg;
    
    msg = aria_alloc_error_message(ARIA_ALLOC_OK);
    ASSERT_MSG(strcmp(msg, "Success") == 0, "ARIA_ALLOC_OK message");
    
    msg = aria_alloc_error_message(ARIA_ALLOC_ERR_OUT_OF_MEMORY);
    ASSERT_MSG(strcmp(msg, "Out of memory") == 0, "OUT_OF_MEMORY message");
    
    msg = aria_alloc_error_message(ARIA_ALLOC_ERR_INVALID_SIZE);
    ASSERT_MSG(strcmp(msg, "Invalid size (must be > 0)") == 0, "INVALID_SIZE message");
    
    msg = aria_alloc_error_message(ARIA_ALLOC_ERR_INVALID_ALIGNMENT);
    ASSERT_MSG(strcmp(msg, "Invalid alignment (must be power of 2)") == 0, "INVALID_ALIGNMENT message");
    
    msg = aria_alloc_error_message(ARIA_ALLOC_ERR_SIZE_OVERFLOW);
    ASSERT_MSG(strcmp(msg, "Size overflow (size * count too large)") == 0, "SIZE_OVERFLOW message");
    
    msg = aria_alloc_error_message(ARIA_ALLOC_ERR_UNSUPPORTED);
    ASSERT_MSG(strcmp(msg, "Operation not supported") == 0, "UNSUPPORTED message");
}

// ============================================================================
