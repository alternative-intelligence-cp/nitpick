// ============================================================================
// Result Construction Tests
// ============================================================================

TEST_CASE(result_ok_ptr_basic) {
    char* value = (char*)"test";
    AriaResultPtr result = aria_result_ok_ptr(value);
    
    ASSERT_MSG(!result.is_error, "Ok result should not be error");
    ASSERT_MSG(result.value == value, "Ok result should contain value");
    ASSERT_MSG(result.error == NULL, "Ok result should have NULL error");
}

TEST_CASE(result_err_ptr_basic) {
    aria_gc_init(1024 * 1024, 256 * 1024);
    
    AriaError* error = aria_error_msg("test error");
    AriaResultPtr result = aria_result_err_ptr(error);
    
    ASSERT_MSG(result.is_error, "Err result should be error");
    ASSERT_MSG(result.value == NULL, "Err result should have NULL value");
    ASSERT_MSG(result.error == error, "Err result should contain error");
    
    aria_gc_shutdown();
}

