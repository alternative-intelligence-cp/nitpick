TEST_CASE(aria_alloc_result_success) {
    AriaAllocResult result = aria_alloc_result(64);
    
    ASSERT_MSG(aria_alloc_result_is_ok(result), "Allocation should succeed");
    ASSERT_MSG(result.value != NULL, "Pointer should not be NULL");
    ASSERT_EQ_MSG(result.requested_size, 64, "Size should be 64");
    
    // Clean up
    free(result.value);
}

TEST_CASE(aria_alloc_result_invalid_size) {
    AriaAllocResult result = aria_alloc_result(0);
    
    ASSERT_MSG(aria_alloc_result_is_err(result), "Should fail with invalid size");
    ASSERT_EQ_MSG(result.error_code, ARIA_ALLOC_ERR_INVALID_SIZE, "Error should be INVALID_SIZE");
    ASSERT_MSG(result.value == NULL, "Pointer should be NULL");
}

TEST_CASE(aria_alloc_array_result_success) {
    AriaAllocResult result = aria_alloc_array_result(sizeof(int64_t), 100);
    
    ASSERT_MSG(aria_alloc_result_is_ok(result), "Array allocation should succeed");
    ASSERT_MSG(result.value != NULL, "Pointer should not be NULL");
    ASSERT_EQ_MSG(result.requested_size, sizeof(int64_t) * 100, "Size should be elem_size * count");
    
    // Clean up
    free(result.value);
}

TEST_CASE(aria_alloc_array_result_invalid_size) {
    // Zero element size
    AriaAllocResult result1 = aria_alloc_array_result(0, 100);
    ASSERT_MSG(aria_alloc_result_is_err(result1), "Should fail with zero elem_size");
    ASSERT_EQ_MSG(result1.error_code, ARIA_ALLOC_ERR_INVALID_SIZE, "Error should be INVALID_SIZE");
    
    // Zero count
    AriaAllocResult result2 = aria_alloc_array_result(sizeof(int64_t), 0);
    ASSERT_MSG(aria_alloc_result_is_err(result2), "Should fail with zero count");
    ASSERT_EQ_MSG(result2.error_code, ARIA_ALLOC_ERR_INVALID_SIZE, "Error should be INVALID_SIZE");
}

TEST_CASE(aria_alloc_array_result_overflow) {
    // Try to allocate SIZE_MAX elements of 2 bytes each (will overflow)
    AriaAllocResult result = aria_alloc_array_result(2, SIZE_MAX);
    
    ASSERT_MSG(aria_alloc_result_is_err(result), "Should fail with overflow");
    ASSERT_EQ_MSG(result.error_code, ARIA_ALLOC_ERR_SIZE_OVERFLOW, "Error should be SIZE_OVERFLOW");
}

TEST_CASE(aria_alloc_aligned_result_success) {
    AriaAllocResult result = aria_alloc_aligned_result(64, 16);
    
    ASSERT_MSG(aria_alloc_result_is_ok(result), "Aligned allocation should succeed");
    ASSERT_MSG(result.value != NULL, "Pointer should not be NULL");
    
    // Verify alignment
    ASSERT_MSG(((uintptr_t)result.value % 16) == 0, "Pointer should be 16-byte aligned");
    
    // Clean up
    free(result.value);
}

TEST_CASE(aria_alloc_aligned_result_invalid_alignment) {
    // Non-power-of-2 alignment
    AriaAllocResult result = aria_alloc_aligned_result(64, 15);
    
    ASSERT_MSG(aria_alloc_result_is_err(result), "Should fail with invalid alignment");
    ASSERT_EQ_MSG(result.error_code, ARIA_ALLOC_ERR_INVALID_ALIGNMENT, "Error should be INVALID_ALIGNMENT");
}

TEST_CASE(aria_alloc_buffer_result_success) {
    AriaAllocResult result = aria_alloc_buffer_result(4096, 16, true);
    
    ASSERT_MSG(aria_alloc_result_is_ok(result), "Buffer allocation should succeed");
    ASSERT_MSG(result.value != NULL, "Pointer should not be NULL");
    
    // Verify alignment
    ASSERT_MSG(((uintptr_t)result.value % 16) == 0, "Pointer should be 16-byte aligned");
    
    // Verify zeroing
    uint8_t* bytes = (uint8_t*)result.value;
    bool all_zero = true;
    for (size_t i = 0; i < 4096; i++) {
        if (bytes[i] != 0) {
            all_zero = false;
            break;
        }
    }
    ASSERT_MSG(all_zero, "Buffer should be zero-initialized");
    
    // Clean up
    free(result.value);
}

TEST_CASE(alloc_result_error_propagation_pattern) {
    // Simulate error propagation pattern
    AriaAllocResult result1 = aria_alloc_result(1024);
    if (aria_alloc_result_is_err(result1)) {
        FAIL_MSG("First allocation should succeed");
    }
    
    // Use the allocation
    int64_t* ptr = (int64_t*)result1.value;
    *ptr = 42;
    ASSERT_EQ_MSG(*ptr, 42, "Value should be set");
    
    // Clean up
    free(result1.value);
    
    // Test error case
    AriaAllocResult result2 = aria_alloc_result(0);  // Invalid size
    if (aria_alloc_result_is_ok(result2)) {
        free(result2.value);
        FAIL_MSG("Zero-size allocation should fail");
    }
    
    // Error was detected correctly
    ASSERT_EQ_MSG(result2.error_code, ARIA_ALLOC_ERR_INVALID_SIZE, "Should be INVALID_SIZE error");
}
