TEST_CASE(result_multiple_types) {
    aria_gc_init(1024 * 1024, 256 * 1024);
    
    // Create different result types
    AriaResultPtr ptr_result = aria_result_ok_ptr((void*)0x1234);
    AriaResultI64 i64_result = aria_result_ok_i64(42);
    AriaResultF64 f64_result = aria_result_ok_f64(3.14);
    AriaResultBool bool_result = aria_result_ok_bool(true);
    AriaResultVoid void_result = aria_result_ok_void();
    
    // Verify all are Ok
    ASSERT_MSG(aria_result_is_ok_ptr(ptr_result), "Ptr result should be Ok");
    ASSERT_MSG(aria_result_is_ok_i64(i64_result), "I64 result should be Ok");
    ASSERT_MSG(aria_result_is_ok_f64(f64_result), "F64 result should be Ok");
    ASSERT_MSG(aria_result_is_ok_bool(bool_result), "Bool result should be Ok");
    ASSERT_MSG(aria_result_is_ok_void(void_result), "Void result should be Ok");
    
    aria_gc_shutdown();
}

