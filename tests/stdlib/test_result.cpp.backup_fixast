// ============================================================================
// Error Construction Tests
// ============================================================================

TEST_CASE(error_new_full) {
    aria_gc_init(1024 * 1024, 256 * 1024);
    
    AriaError* error = aria_error_new(ARIA_ERR_NOT_FOUND, "File not found", "test.aria", 42);
    
    ASSERT_MSG(error != NULL, "Error should be allocated");
    ASSERT_EQ_MSG(error->code, ARIA_ERR_NOT_FOUND, "Error code should match");
    ASSERT_EQ_MSG(strcmp(error->message, "File not found"), 0, "Error message should match");
    ASSERT_EQ_MSG(strcmp(error->file, "test.aria"), 0, "Error file should match");
    ASSERT_EQ_MSG(error->line, 42, "Error line should match");
    
    aria_gc_shutdown();
}

TEST_CASE(error_msg_simple) {
    aria_gc_init(1024 * 1024, 256 * 1024);
    
    AriaError* error = aria_error_msg("simple error");
    
    ASSERT_MSG(error != NULL, "Error should be allocated");
    ASSERT_EQ_MSG(error->code, ARIA_ERR_UNKNOWN, "Error code should be UNKNOWN");
    ASSERT_EQ_MSG(strcmp(error->message, "simple error"), 0, "Error message should match");
    ASSERT_MSG(error->file == NULL, "Error file should be NULL");
    ASSERT_EQ_MSG(error->line, 0, "Error line should be 0");
    
    aria_gc_shutdown();
}

// ============================================================================
// Result Query Tests
// ============================================================================

TEST_CASE(result_is_ok_ptr) {
    char* value = (char*)"test";
    AriaResultPtr ok_result = aria_result_ok_ptr(value);
    
    ASSERT_MSG(aria_result_is_ok_ptr(ok_result), "Ok result should return true for is_ok");
    ASSERT_MSG(!aria_result_is_err_ptr(ok_result), "Ok result should return false for is_err");
    
    aria_gc_init(1024 * 1024, 256 * 1024);
    AriaError* error = aria_error_msg("error");
    AriaResultPtr err_result = aria_result_err_ptr(error);
    
    ASSERT_MSG(!aria_result_is_ok_ptr(err_result), "Err result should return false for is_ok");
    ASSERT_MSG(aria_result_is_err_ptr(err_result), "Err result should return true for is_err");
    
    aria_gc_shutdown();
}

TEST_CASE(result_get_error) {
    aria_gc_init(1024 * 1024, 256 * 1024);
    
    // Ok result should return NULL error
    AriaResultI64 ok_result = aria_result_ok_i64(42);
    AriaError* ok_error = aria_result_get_error_i64(ok_result);
    ASSERT_MSG(ok_error == NULL, "Ok result should have NULL error");
    
    // Err result should return error
    AriaError* error = aria_error_msg("test error");
    AriaResultI64 err_result = aria_result_err_i64(error);
    AriaError* err_error = aria_result_get_error_i64(err_result);
    ASSERT_MSG(err_error == error, "Err result should return error");
    
    aria_gc_shutdown();
}

// ============================================================================
// Unwrap-or Tests
// ============================================================================

TEST_CASE(result_unwrap_or_i64_ok) {
    AriaResultI64 result = aria_result_ok_i64(42);
    int64_t value = aria_result_unwrap_or_i64(result, 99);
    ASSERT_EQ_MSG(value, 42, "Unwrap-or should return value for Ok result");
}

TEST_CASE(result_unwrap_or_i64_err) {
    aria_gc_init(1024 * 1024, 256 * 1024);
    
    AriaError* error = aria_error_msg("error");
    AriaResultI64 result = aria_result_err_i64(error);
    int64_t value = aria_result_unwrap_or_i64(result, 99);
    ASSERT_EQ_MSG(value, 99, "Unwrap-or should return default for Err result");
    
    aria_gc_shutdown();
}

TEST_CASE(result_unwrap_or_ptr_ok) {
    char* test_value = (char*)"test";
    AriaResultPtr result = aria_result_ok_ptr(test_value);
    void* value = aria_result_unwrap_or_ptr(result, NULL);
    ASSERT_MSG(value == test_value, "Unwrap-or should return value for Ok result");
}

TEST_CASE(result_unwrap_or_ptr_err) {
    aria_gc_init(1024 * 1024, 256 * 1024);
    
    char* default_value = (char*)"default";
    AriaError* error = aria_error_msg("error");
    AriaResultPtr result = aria_result_err_ptr(error);
    void* value = aria_result_unwrap_or_ptr(result, default_value);
    ASSERT_MSG(value == default_value, "Unwrap-or should return default for Err result");
    
    aria_gc_shutdown();
}

TEST_CASE(result_unwrap_or_f64_values) {
    // Ok case
    AriaResultF64 ok_result = aria_result_ok_f64(3.14);
    double ok_value = aria_result_unwrap_or_f64(ok_result, 2.71);
    ASSERT_NEAR_MSG(ok_value, 3.14, 0.0001, "Unwrap-or should return Ok value");
    
    // Err case
    aria_gc_init(1024 * 1024, 256 * 1024);
    AriaError* error = aria_error_msg("error");
    AriaResultF64 err_result = aria_result_err_f64(error);
    double err_value = aria_result_unwrap_or_f64(err_result, 2.71);
    ASSERT_NEAR_MSG(err_value, 2.71, 0.0001, "Unwrap-or should return default value");
    aria_gc_shutdown();
}

TEST_CASE(result_unwrap_or_bool_values) {
    // Ok case - true
    AriaResultBool ok_true = aria_result_ok_bool(true);
    bool value_true = aria_result_unwrap_or_bool(ok_true, false);
    ASSERT_MSG(value_true == true, "Unwrap-or should return true");
    
    // Ok case - false  
    AriaResultBool ok_false = aria_result_ok_bool(false);
    bool value_false = aria_result_unwrap_or_bool(ok_false, true);
    ASSERT_MSG(value_false == false, "Unwrap-or should return false");
    
    // Err case
    aria_gc_init(1024 * 1024, 256 * 1024);
    AriaError* error = aria_error_msg("error");
    AriaResultBool err_result = aria_result_err_bool(error);
    bool err_value = aria_result_unwrap_or_bool(err_result, true);
    ASSERT_MSG(err_value == true, "Unwrap-or should return default");
    aria_gc_shutdown();
}

