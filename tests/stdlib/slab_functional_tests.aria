// Expected: COMPILER ERROR - allocator ownership semantics or unimplemented syntax
func:test_slab_lifecycle = int32() {
    print("Test 1: Slab lifecycle\n");
    
    // Create slab (64-byte objects, 4096-byte slabs)
    int64:slab = slab_new(64, 4096);
    if (slab == 0) {
        print("ERROR: Slab creation failed\n");
        int32:err = 1;
        pass err;
    }
    
    // Destroy slab
    slab_destroy(slab);
    
    print("SUCCESS: Slab lifecycle test passed\n");
    int32:res_ok = 0;
    pass res_ok;
};

func:test_slab_stats = int32() {
    print("Test 2: Slab statistics\n");
    
    int64:slab = slab_new(128, 8192);
    if (slab == 0) {
        print("ERROR: Slab creation failed\n");
        int32:err = 3;
        pass err;
    }
    
    // TODO: Get stats when builtins available
