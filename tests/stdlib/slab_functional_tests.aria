    int32:res_ok = 0;
    pass res_ok;
};

func:test_slab_multiple = int32() {
    print("Test 3: Multiple slabs\n");
    
    // Create different sized slabs (object_size, slab_size_bytes)
    int64:slab1 = slab_new(32, 2048);
    int64:slab2 = slab_new(64, 4096);
    int64:slab3 = slab_new(256, 8192);
    
    if (slab1 == 0 || slab2 == 0 || slab3 == 0) {
        print("ERROR: Multi-slab creation failed\n");
        if (slab1 != 0) { slab_destroy(slab1); }
        if (slab2 != 0) { slab_destroy(slab2); }
        if (slab3 != 0) { slab_destroy(slab3); }
        int32:err = 4;
        pass err;
    }
    
    // Destroy in reverse order
    slab_destroy(slab3);
    slab_destroy(slab2);
    slab_destroy(slab1);
    
    print("SUCCESS: Multiple slabs test passed\n");
    int32:res_ok = 0;
    pass res_ok;
};

func:main = int32() {
    print("=== Slab Allocator Functional Tests ===\n\n");
    
    int32:result1 = raw test_slab_lifecycle();
    if (result1 != 0) { exit result1; }
    
    int32:result2 = raw test_slab_stats();
    if (result2 != 0) { exit result2; }
    
    int32:result3 = raw test_slab_multiple();
    if (result3 != 0) { exit result3; }
    
    print("\n=== All Slab Tests PASSED ===\n");
    int32:success = 0;
    exit success;
};

