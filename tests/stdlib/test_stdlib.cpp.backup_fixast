/**
 * Phase 6 Standard Library Tests
 * 
 * Tests for Aria standard library runtime support functions.
 * These tests verify that stdlib functions can be called and work correctly.
 */

#include "test_helpers.h"
#include "runtime/stdlib.h"
#include "runtime/gc.h"
#include <cstring>
#include <cmath>

// ============================================================================
// I/O Tests
// ============================================================================

TEST_CASE(stdlib_print_basic) {
    // Just verify it doesn't crash - can't easily test stdout
    aria_print("Hello", 5);
    aria_println("World", 5);
}

TEST_CASE(stdlib_eprint_basic) {
    // Just verify it doesn't crash - can't easily test stderr
    aria_eprint("Error", 5);
    aria_eprintln("Message", 7);
}

TEST_CASE(stdlib_debug_basic) {
    // Just verify it doesn't crash - can't easily test stddbg
    aria_debug("Debug", 5);
    aria_debugln("Info", 4);
}

TEST_CASE(stdlib_print_empty_string) {
    // Should handle empty strings gracefully
    aria_print("", 0);
    aria_println("", 0);
}

TEST_CASE(stdlib_print_null_pointer) {
    // Should handle NULL gracefully (no crash)
    aria_print(nullptr, 0);
    aria_println(nullptr, 0);
}

// ============================================================================
// String Tests
// ============================================================================

TEST_CASE(stdlib_string_length_basic) {
    const char* str = "Hello";
    int64_t len = aria_cstr_length(str);
    ASSERT_EQ_MSG(len, 5, "String length should be 5");
}

TEST_CASE(stdlib_string_length_empty) {
    const char* str = "";
    int64_t len = aria_cstr_length(str);
    ASSERT_EQ_MSG(len, 0, "Empty string length should be 0");
}

TEST_CASE(stdlib_string_length_null) {
    int64_t len = aria_cstr_length(nullptr);
    ASSERT_EQ_MSG(len, 0, "NULL string length should be 0");
}

TEST_CASE(stdlib_string_compare_equal) {
    const char* s1 = "test";
    const char* s2 = "test";
    int32_t result = aria_string_compare(s1, s2);
    ASSERT_EQ_MSG(result, 0, "Equal strings should return 0");
}

TEST_CASE(stdlib_string_compare_less) {
    const char* s1 = "abc";
    const char* s2 = "def";
    int32_t result = aria_string_compare(s1, s2);
    ASSERT_MSG(result < 0, "s1 < s2 should return negative");
}

TEST_CASE(stdlib_string_compare_greater) {
    const char* s1 = "xyz";
    const char* s2 = "abc";
    int32_t result = aria_string_compare(s1, s2);
    ASSERT_MSG(result > 0, "s1 > s2 should return positive");
}

TEST_CASE(stdlib_string_concat_basic) {
    // Initialize GC before using it (1MB nursery, 256KB threshold)
    aria_gc_init(1024 * 1024, 256 * 1024);
    
    const char* s1 = "Hello";
    const char* s2 = " World";
    char* result = aria_cstr_concat(s1, s2);
    ASSERT_MSG(result != nullptr, "Concat should return non-null");
    ASSERT_EQ_MSG(strcmp(result, "Hello World"), 0, "Concat result should match");
    
    aria_gc_shutdown();
}

TEST_CASE(stdlib_string_concat_empty) {
    aria_gc_init(1024 * 1024, 256 * 1024);
    
    const char* s1 = "";
    const char* s2 = "test";
    char* result = aria_cstr_concat(s1, s2);
    ASSERT_MSG(result != nullptr, "Concat should return non-null");
    ASSERT_EQ_MSG(strcmp(result, "test"), 0, "Concat result should match");
    
    aria_gc_shutdown();
}

// ============================================================================
// Math Tests
// ============================================================================

TEST_CASE(stdlib_math_abs_i64_positive) {
    int64_t result = aria_math_abs_i64(42);
    ASSERT_EQ_MSG(result, 42, "abs(42) should be 42");
}

TEST_CASE(stdlib_math_abs_i64_negative) {
    int64_t result = aria_math_abs_i64(-42);
    ASSERT_EQ_MSG(result, 42, "abs(-42) should be 42");
}

TEST_CASE(stdlib_math_abs_i64_zero) {
    int64_t result = aria_math_abs_i64(0);
    ASSERT_EQ_MSG(result, 0, "abs(0) should be 0");
}

TEST_CASE(stdlib_math_abs_f64_positive) {
    double result = aria_math_abs_f64(3.14);
    ASSERT_NEAR_MSG(result, 3.14, 0.0001, "abs(3.14) should be 3.14");
}

TEST_CASE(stdlib_math_abs_f64_negative) {
    double result = aria_math_abs_f64(-3.14);
    ASSERT_NEAR_MSG(result, 3.14, 0.0001, "abs(-3.14) should be 3.14");
}

TEST_CASE(stdlib_math_sqrt_basic) {
    double result = aria_math_sqrt(16.0);
    ASSERT_NEAR_MSG(result, 4.0, 0.0001, "sqrt(16) should be 4");
}

TEST_CASE(stdlib_math_sqrt_zero) {
    double result = aria_math_sqrt(0.0);
    ASSERT_NEAR_MSG(result, 0.0, 0.0001, "sqrt(0) should be 0");
}

TEST_CASE(stdlib_math_pow_basic) {
    double result = aria_math_pow(2.0, 3.0);
    ASSERT_NEAR_MSG(result, 8.0, 0.0001, "2^3 should be 8");
}

TEST_CASE(stdlib_math_pow_zero) {
    double result = aria_math_pow(5.0, 0.0);
    ASSERT_NEAR_MSG(result, 1.0, 0.0001, "5^0 should be 1");
}

TEST_CASE(stdlib_math_min_i64_basic) {
    int64_t result = aria_math_min_i64(10, 20);
    ASSERT_EQ_MSG(result, 10, "min(10, 20) should be 10");
}

TEST_CASE(stdlib_math_min_i64_equal) {
    int64_t result = aria_math_min_i64(15, 15);
    ASSERT_EQ_MSG(result, 15, "min(15, 15) should be 15");
}

TEST_CASE(stdlib_math_max_i64_basic) {
    int64_t result = aria_math_max_i64(10, 20);
    ASSERT_EQ_MSG(result, 20, "max(10, 20) should be 20");
}

TEST_CASE(stdlib_math_max_i64_equal) {
    int64_t result = aria_math_max_i64(15, 15);
    ASSERT_EQ_MSG(result, 15, "max(15, 15) should be 15");
}

TEST_CASE(stdlib_math_pi_constant) {
    double pi = aria_math_pi();
    ASSERT_NEAR_MSG(pi, 3.14159265358979, 0.0001, "PI constant should match");
}

TEST_CASE(stdlib_math_e_constant) {
    double e = aria_math_e();
    ASSERT_NEAR_MSG(e, 2.71828182845905, 0.0001, "E constant should match");
}
