// ═══════════════════════════════════════════════════════════════════════
// Test: Self-hosted Project Config — v0.15.2
// ═══════════════════════════════════════════════════════════════════════
// 12 test cases for the Aria project configuration parser:
// TOML parsing, package fields, build config, deps, features, validation.
// ═══════════════════════════════════════════════════════════════════════

// ─── Constants ────────────────────────────────────────────────────────
fixed int32:TARGET_EXECUTABLE = 0i32;
fixed int32:OPT_RELEASE       = 1i32;

// ─── C shim externs ───────────────────────────────────────────────────
extern func:projcfg_parse_file    = int64(string:path);
extern func:projcfg_free          = int32(int64:handle);
extern func:projcfg_pkg_name      = string(int64:handle);
extern func:projcfg_pkg_version   = string(int64:handle);
extern func:projcfg_pkg_edition   = string(int64:handle);
extern func:projcfg_pkg_license   = string(int64:handle);
extern func:projcfg_pkg_description = string(int64:handle);
extern func:projcfg_pkg_author_count = int32(int64:handle);
extern func:projcfg_pkg_author    = string(int64:handle, int32:idx);
extern func:projcfg_pkg_keyword_count = int32(int64:handle);
extern func:projcfg_build_target  = int32(int64:handle);
extern func:projcfg_build_optimization = int32(int64:handle);
extern func:projcfg_build_output  = string(int64:handle);
extern func:projcfg_build_main    = string(int64:handle);
extern func:projcfg_dep_count     = int32(int64:handle);
extern func:projcfg_dep_names_refresh = int32(int64:handle);
extern func:projcfg_dep_name      = string(int32:idx);
extern func:projcfg_dep_version_by_name = string(int64:handle, string:name);
extern func:projcfg_feature_count = int32(int64:handle);
extern func:projcfg_has_feature   = int32(int64:handle, string:name);
extern func:projcfg_validate_name    = int32(string:name);
extern func:projcfg_validate_version = int32(string:version);
extern func:projcfg_is_reserved_name = int32(string:name);
extern func:projcfg_create_test_fixture = int64(string:dir_path);
extern func:projcfg_cleanup_test  = int64(string:path);

// ─── Test path ────────────────────────────────────────────────────────
fixed string:TEST_DIR  = "/tmp/npk_projcfg_test";
fixed string:TEST_TOML = "/tmp/npk_projcfg_test/aria.toml";

// ═══ Test 1: Parse file returns valid handle ═════════════════════════
pub func:test_parse_file = int32() {
    _ = projcfg_cleanup_test(TEST_DIR);
    _ = projcfg_create_test_fixture(TEST_DIR);
    int64:h = projcfg_parse_file(TEST_TOML);
    int32:result = 1i32;
    if (h >= 0i64) {
        result = 0i32;
    }
    _ = projcfg_free(h);
    pass result;
};

// ═══ Test 2: Package name extracted ══════════════════════════════════
pub func:test_pkg_name = int32() {
    _ = projcfg_cleanup_test(TEST_DIR);
    _ = projcfg_create_test_fixture(TEST_DIR);
    int64:h = projcfg_parse_file(TEST_TOML);
    string:name = projcfg_pkg_name(h);
    int32:result = 1i32;
    if (name == "hello-world") {
        result = 0i32;
    }
    _ = projcfg_free(h);
    pass result;
};

// ═══ Test 3: Package version extracted ═══════════════════════════════
pub func:test_pkg_version = int32() {
    _ = projcfg_cleanup_test(TEST_DIR);
    _ = projcfg_create_test_fixture(TEST_DIR);
    int64:h = projcfg_parse_file(TEST_TOML);
    string:ver = projcfg_pkg_version(h);
    int32:result = 1i32;
    if (ver == "0.2.0") {
        result = 0i32;
    }
    _ = projcfg_free(h);
    pass result;
};

// ═══ Test 4: Author count ════════════════════════════════════════════
pub func:test_author_count = int32() {
    _ = projcfg_cleanup_test(TEST_DIR);
    _ = projcfg_create_test_fixture(TEST_DIR);
    int64:h = projcfg_parse_file(TEST_TOML);
    int32:count = projcfg_pkg_author_count(h);
    int32:result = 1i32;
    if (count == 2i32) {
        result = 0i32;
    }
    _ = projcfg_free(h);
    pass result;
};

// ═══ Test 5: Build target is executable ══════════════════════════════
pub func:test_build_target = int32() {
    _ = projcfg_cleanup_test(TEST_DIR);
    _ = projcfg_create_test_fixture(TEST_DIR);
    int64:h = projcfg_parse_file(TEST_TOML);
    int32:target = projcfg_build_target(h);
    int32:result = 1i32;
    if (target == TARGET_EXECUTABLE) {
        result = 0i32;
    }
    _ = projcfg_free(h);
    pass result;
};

// ═══ Test 6: Build optimization is release ═══════════════════════════
pub func:test_build_opt = int32() {
    _ = projcfg_cleanup_test(TEST_DIR);
    _ = projcfg_create_test_fixture(TEST_DIR);
    int64:h = projcfg_parse_file(TEST_TOML);
    int32:opt = projcfg_build_optimization(h);
    int32:result = 1i32;
    if (opt == OPT_RELEASE) {
        result = 0i32;
    }
    _ = projcfg_free(h);
    pass result;
};

// ═══ Test 7: Dependency count ════════════════════════════════════════
pub func:test_dep_count = int32() {
    _ = projcfg_cleanup_test(TEST_DIR);
    _ = projcfg_create_test_fixture(TEST_DIR);
    int64:h = projcfg_parse_file(TEST_TOML);
    int32:count = projcfg_dep_count(h);
    int32:result = 1i32;
    if (count == 2i32) {
        result = 0i32;
    }
    _ = projcfg_free(h);
    pass result;
};

// ═══ Test 8: Dependency version access ═══════════════════════════════
pub func:test_dep_version = int32() {
    _ = projcfg_cleanup_test(TEST_DIR);
    _ = projcfg_create_test_fixture(TEST_DIR);
    int64:h = projcfg_parse_file(TEST_TOML);
    string:ver = projcfg_dep_version_by_name(h, "aria-std");
    int32:result = 1i32;
    if (ver == "0.1.0") {
        result = 0i32;
    }
    _ = projcfg_free(h);
    pass result;
};

// ═══ Test 9: Feature count and has_feature ═══════════════════════════
pub func:test_features = int32() {
    _ = projcfg_cleanup_test(TEST_DIR);
    _ = projcfg_create_test_fixture(TEST_DIR);
    int64:h = projcfg_parse_file(TEST_TOML);
    int32:count = projcfg_feature_count(h);
    int32:has_default = projcfg_has_feature(h, "default");
    int32:has_logging = projcfg_has_feature(h, "logging");
    int32:result = 1i32;
    if (count == 3i32 && has_default == 1i32 && has_logging == 1i32) {
        result = 0i32;
    }
    _ = projcfg_free(h);
    pass result;
};

// ═══ Test 10: Valid name passes, invalid fails ═══════════════════════
pub func:test_validate_name = int32() {
    int32:ok1 = projcfg_validate_name("hello-world");
    int32:ok2 = projcfg_validate_name("my_project");
    int32:bad1 = projcfg_validate_name("");
    int32:bad2 = projcfg_validate_name("1bad");
    int32:result = 1i32;
    if (ok1 == 1i32 && ok2 == 1i32 && bad1 == 0i32 && bad2 == 0i32) {
        result = 0i32;
    }
    pass result;
};

// ═══ Test 11: Version validation ═════════════════════════════════════
pub func:test_validate_version = int32() {
    int32:ok1 = projcfg_validate_version("1.0.0");
    int32:ok2 = projcfg_validate_version("0.2.0-beta");
    int32:bad1 = projcfg_validate_version("notaversion");
    int32:bad2 = projcfg_validate_version("");
    int32:result = 1i32;
    if (ok1 == 1i32 && ok2 == 1i32 && bad1 == 0i32 && bad2 == 0i32) {
        result = 0i32;
    }
    pass result;
};

// ═══ Test 12: Reserved name detection ════════════════════════════════
pub func:test_reserved_names = int32() {
    int32:r1 = projcfg_is_reserved_name("std");
    int32:r2 = projcfg_is_reserved_name("core");
    int32:r3 = projcfg_is_reserved_name("aria");
    int32:r4 = projcfg_is_reserved_name("mypackage");
    int32:result = 1i32;
    if (r1 == 1i32 && r2 == 1i32 && r3 == 1i32 && r4 == 0i32) {
        result = 0i32;
    }
    pass result;
};

// ═══ main / failsafe ═════════════════════════════════════════════════

pub func:main = int32() {
    int32:r1 = raw test_parse_file();
    if (r1 != 0i32) { exit 1; }

    int32:r2 = raw test_pkg_name();
    if (r2 != 0i32) { exit 2; }

    int32:r3 = raw test_pkg_version();
    if (r3 != 0i32) { exit 3; }

    int32:r4 = raw test_author_count();
    if (r4 != 0i32) { exit 4; }

    int32:r5 = raw test_build_target();
    if (r5 != 0i32) { exit 5; }

    int32:r6 = raw test_build_opt();
    if (r6 != 0i32) { exit 6; }

    int32:r7 = raw test_dep_count();
    if (r7 != 0i32) { exit 7; }

    int32:r8 = raw test_dep_version();
    if (r8 != 0i32) { exit 8; }

    int32:r9 = raw test_features();
    if (r9 != 0i32) { exit 9; }

    int32:r10 = raw test_validate_name();
    if (r10 != 0i32) { exit 10; }

    int32:r11 = raw test_validate_version();
    if (r11 != 0i32) { exit 11; }

    int32:r12 = raw test_reserved_names();
    if (r12 != 0i32) { exit 12; }

    _ = projcfg_cleanup_test(TEST_DIR);
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    _ = projcfg_cleanup_test(TEST_DIR);
    exit 99;
};
