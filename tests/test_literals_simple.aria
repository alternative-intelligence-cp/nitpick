// Simple test of balanced literals without string operations

func:main = int32() {
    // Test ternary literals
    int64:t1 = 0t1T0;  // 1*9 + (-1)*3 + 0*1 = 6
    int64:t2 = 0t0;    // 0
    int64:t3 = 0t1;    // 1
    int64:t4 = 0tT;    // -1
    
    // Test nonary literals
    int64:n1 = 0n2A;   // 2*9 + (-1)*1 = 17
    int64:n2 = 0n0;    // 0
    int64:n3 = 0n1;    // 1
   int64:n4 = 0nA;    // -1
    
    // Just return success - literals compile correctly
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
