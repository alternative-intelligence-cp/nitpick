// Vec<T> Standard Library Implementation
// Phase 3: Method wrappers for ergonomic API
// NOTE: Starting with int8 to avoid FFI pointer casting issues

// Runtime function declarations
extern func:aria_array_new_simple = wild int8*(int64:element_size, int32:type_id);
extern func:aria_array_length = int64(wild int8*:arr);
extern func:aria_array_free = NIL(wild int8*:arr);
extern func:aria_array_push_simple = NIL(wild int8*:arr, wild int8*:val);
extern func:aria_array_pop_simple = NIL(wild int8*:arr, wild int8*:out_val);

// Vec<int8> constructor
// Returns: Vec<int8> struct initialized with empty array
func:Vec_int8_new = Vec<int8>() {
    Vec<int8>:vec;
    
    // Call runtime to create array and store directly (transfers ownership)
    // element_size = sizeof(int8) = 1 byte
    // type_id = 1 (primitive type for GC)
    vec.data = aria_array_new_simple(1i64, 1i32);
    vec.length = 0i64;
    vec.capacity = 16i64;  // Default capacity from runtime
    vec.element_size = 1i64;
    vec.type_id = 1i32;
    
    pass vec;
};

// Vec<int8> push method - simplified to take data pointer directly
// Parameters: data pointer, value to push  
func:Vec_int8_push = NIL(wild int8->:data, int8:value) {
    // Call runtime push directly with data pointer
    aria_array_push_simple(data, @value);
};

// Vec<int8> pop method - simplified to take data pointer directly
// Parameters: data pointer
// Returns: popped value
func:Vec_int8_pop = int8(wild int8->:data) {
    int8:result = 0i8;
    
    // Call runtime pop directly
    aria_array_pop_simple(data, @result);
    
    pass result;
};

// Vec<int8> update length helper -  takes data pointer directly
// Gets the actual length from runtime
func:Vec_int8_update_length = int64(wild int8->:data) {
    pass aria_array_length(data);
};
// Vec<T> Phase 3: Method Syntax Test  
// Goal: Clean, ergonomic Vec API for Nikola
// NOTE: Using static methods for now to avoid UFCS parameter handling issues

// Test Vec<int8> with static method syntax
func:main = int32() {
    // Create new Vec<int8>
    Vec<int8>:numbers = raw Vec_int8_new();
    
    // Check initial state
    if (numbers.length != 0i64) {
        exit 1i32;  // FAIL: Initial length should be 0
    }
    
    // Push some values (passing data pointer directly)
    _ = Vec_int8_push(numbers.data, 42i8);
    _ = Vec_int8_push(numbers.data, 99i8);
    _ = Vec_int8_push(numbers.data, 123i8);
    
    // Update length from runtime
    numbers.length = Vec_int8_update_length(numbers.data) ? 0i64;
    
    // Verify length
    if (numbers.length != 3i64) {
        exit 2i32;  // FAIL: Length should be 3 after pushes
    }
    
    // Pop values (passing data pointer directly)
    int8:val3 = raw Vec_int8_pop(numbers.data);
    if (val3 != 123i8) {
        exit 3i32;  // FAIL: Popped value should be 123
    }
    
    int8:val2 = raw Vec_int8_pop(numbers.data);
    if (val2 != 99i8) {
        exit 4i32;  // FAIL: Popped value should be 99
    }
    
    int8:val1 = raw Vec_int8_pop(numbers.data);
    if (val1 != 42i8) {
        exit 5i32;  // FAIL: Popped value should be 42
    }
    
    // Update and check final length
    numbers.length = Vec_int8_update_length(numbers.data) ? 0i64;
    if (numbers.length != 0i64) {
        exit 6i32;  // FAIL: Length should be 0 after popping all
    }
    
    exit 0;  // SUCCESS!
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};
