/**
 * Test: Generic Function Preserves TBB Type
 * Expected: Should PASS - TBB type preserved through generic
 * Why Important: Generics should not degrade TBB to regular int
 */

func<T>:identity = *T(*T:x) {
    pass(x);
};

func:main = int32() {
    tbb8:x = 50;
    tbb8:y = identity(x);  // Should preserve tbb8 type

    pass(0i32);
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
