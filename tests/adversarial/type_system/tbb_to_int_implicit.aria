/**
 * Test: TBB to int Implicit Conversion
 * Expected: COMPILER ERROR - No implicit conversion
 * Why Critical: Implicit conversion would bypass TBB error tracking
 */

func:main = int32() {
    tbb8:x = 100;  // Valid TBB value
    int8:y = x;    // ERROR: Implicit conversion from tbb8 to int8

    print("Should not compile!\n");
    return 0;
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
