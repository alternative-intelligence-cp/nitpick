/**
 * Test: Direct Sentinel Construction (TBB Type Safety)
 * Expected: COMPILER ERROR - Cannot construct TBB with sentinel value
 * Why Critical: Sentinel value (-128 for tbb8) would corrupt error propagation
 */

func:main = int32() {
    tbb8:x = -128;  // ERROR: Sentinel value directly assigned

    print("Should not compile!\n");
    return 0;
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
