/**
 * Test: int to TBB Implicit Conversion
 * Expected: COMPILER ERROR - No implicit conversion
 * Why Critical: Int value -128 would become sentinel, corrupting TBB semantics
 */

func:main = int32() {
    int8:x = -128;  // Has sentinel value in int form
    tbb8:y = x;     // ERROR: Implicit conversion could leak sentinel

    print("Should not compile!\n");
    return 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit(1);
};
