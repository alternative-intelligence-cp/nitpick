/**
 * Test: TBB Mixed Sizes
 * Expected: COMPILER ERROR - No implicit widening
 * Why Critical: Different TBB sizes have different sentinel values
 */

func:main = int32() {
    tbb8:small = 10;
    tbb16:large = small;  // ERROR: No implicit widening between TBB sizes

    print("Should not compile!\n");
    return 0;
};
