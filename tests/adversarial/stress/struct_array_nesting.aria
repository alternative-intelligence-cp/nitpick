// Stress test: Struct arrays — boundary access, overwrite, verify isolation

struct:Point = {
    flt64:x;
    flt64:y;
};

struct:Line = {
    flt64:x1;
    flt64:y1;
    flt64:x2;
    flt64:y2;
};

pub func:fill_points = int64(wild Point->:pts, int64:n) {
    int64:i = 0i64;
    while (i < n) {
        flt64:fi = i => flt64;
        Point:p = Point { x: fi * 1.5, y: fi * 2.5 };
        pts[i] = p;
        i = i + 1i64;
    }
    pass n;
};

func:main = int32() {
    // Test 1: Fill 10 Points and verify first/last
    wild Point[10]:points;
    int64:n = raw fill_points(points, 10i64);

    Point:p0 = points[0i64];
    if (p0.x < -0.01 || p0.x > 0.01) { pass 1i32; }
    if (p0.y < -0.01 || p0.y > 0.01) { pass 2i32; }

    Point:p9 = points[9i64];
    if (p9.x < 13.4 || p9.x > 13.6) { pass 3i32; }
    if (p9.y < 22.4 || p9.y > 22.6) { pass 4i32; }

    // Test 2: Overwrite element and verify it's stored
    Point:pm = Point { x: 999.0, y: 888.0 };
    points[5i64] = pm;

    Point:p5 = points[5i64];
    if (p5.x < 998.9 || p5.x > 999.1) { pass 5i32; }
    if (p5.y < 887.9 || p5.y > 888.1) { pass 6i32; }

    // Test 3: Line array — 4 elements
    wild Line[4]:lines;
    Line:l0 = Line { x1: 0.0, y1: 0.0, x2: 10.0, y2: 10.0 };
    Line:l3 = Line { x1: 100.0, y1: 200.0, x2: 300.0, y2: 400.0 };
    lines[0i64] = l0;
    lines[3i64] = l3;

    Line:last = lines[3i64];
    if (last.x1 < 99.9 || last.x1 > 100.1) { pass 7i32; }
    if (last.y2 < 399.9 || last.y2 > 400.1) { pass 8i32; }

    Line:first = lines[0i64];
    if (first.x2 < 9.9 || first.x2 > 10.1) { pass 9i32; }

    exit 0;
};

func:failsafe = int32(tbb32:err) { exit 1; };
