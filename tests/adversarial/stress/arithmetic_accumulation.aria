// Stress test: Arithmetic accumulation with mixed operations
// Verifies: int64 loops, uint64 bit ops, pub func call stability

pub func:add_i32 = int32(int32:a, int32:b) {
    pass a + b;
};

pub func:sum_range = int64(int64:start, int64:end_val) {
    int64:s = 0i64;
    int64:i = start;
    while (i <= end_val) {
        s = s + i;
        i = i + 1i64;
    }
    pass s;
};

func:main = int32() {
    // Test 1: Sum 1..100 = 5050
    int64:s100 = raw sum_range(1i64, 100i64);
    if (s100 != 5050i64) {
        exit 1i32;
    }

    // Test 2: Sum 1..1000 = 500500
    int64:s1000 = raw sum_range(1i64, 1000i64);
    if (s1000 != 500500i64) {
        exit 2i32;
    }

    // Test 3: 500 iterations of i32 add
    int32:acc = 0i32;
    int64:i = 0i64;
    while (i < 500i64) {
        acc = raw add_i32(acc, 1i32);
        i = i + 1i64;
    }
    if (acc != 500i32) {
        exit 3i32;
    }

    // Test 4: Build uint64 bitmask of all 64 bits
    uint64:mask = 0u64;
    int64:bit = 0i64;
    while (bit < 64i64) {
        uint64:one = 1u64;
        uint64:ubit = bit => uint64;
        uint64:shifted = one << ubit;
        mask = mask | shifted;
        bit = bit + 1i64;
    }
    uint64:max_val = 18446744073709551615u64;
    if (mask != max_val) {
        exit 4i32;
    }

    // Test 5: Alternating +3/-1 for 2000 iterations = 4000
    int64:val = 0i64;
    int64:k = 0i64;
    while (k < 2000i64) {
        val = val + 3i64;
        val = val - 1i64;
        k = k + 1i64;
    }
    if (val != 4000i64) {
        exit 5i32;
    }

    exit 0;
};

func:failsafe = int32(tbb32:err) { exit 1; };
