/**
 * Test: Basic Wild Memory Allocation
 * Expected: COMPILES SUCCESSFULLY
 * Why: This is the correct usage pattern for wild memory
 */

func:main = int32() {
    // Call alloc with just a size - returns int8@ (byte pointer)
    int64:size = 1024;
    wild int8@:ptr = alloc(size);

    // Free the memory
    free(ptr);

    // Return
    return 0;
};
