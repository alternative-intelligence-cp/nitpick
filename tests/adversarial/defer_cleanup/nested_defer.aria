/**
 * Test: Nested Scope Defers
 * Expected: COMPILES SUCCESSFULLY
 * Why: Defers in nested scopes must execute in correct order
 *
 * Pattern: Nested resource management
 */

func:main = int32() {
    wild int8->outer = alloc(100);
    defer { free(outer); }

    {
        wild int8->inner = alloc(50);
        defer { free(inner); }

        // Use both outer and inner here
        // inner's defer runs when this scope exits
    }

    // Only outer is valid here
    // outer's defer runs when function exits

    return 0;
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
