/**
 * Test: Defer Executes on Early Return
 * Expected: COMPILES SUCCESSFULLY
 * Why: defer block must execute even when function returns early
 *
 * From TODO: "Test defer executes on early return"
 */

func:test = int32(bool:cond) {
    wild int8->:p = alloc(1024);
    defer { free(p); }

    if (cond) {
        pass 1i32;  // Early return - defer must still run
    }

    pass 0i32;  // Normal return - defer runs here too
};

func:main = int32() {
    int32:r1 = raw test(true);
    int32:r2 = raw test(false);
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
