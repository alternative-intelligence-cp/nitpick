/**
 * Test: Borrow Through Mutable Reference
 * Expected: COMPILER ERROR - cannot borrow immutably while mutably borrowed
 * Why Critical: XOR rule violation
 */

func:main = int32() {
    int32:x = 10;
    $$m int32:m = x;  // Mutable borrow

    $$i int32:r = x;  // ERROR: Cannot immutably borrow while mutably borrowed

    print("Should not compile!\n");
    return 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
