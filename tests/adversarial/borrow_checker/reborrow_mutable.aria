/**
 * Test: Reborrow of Mutable Reference
 * Expected: COMPILER ERROR - cannot reborrow while original exists
 * Why Critical: Creates two mutable paths to same data
 */

func:use_ref = NIL(int32$:r) {
    print("using ref\n");
};

func:main = int32() {
    int32:x = 10;
    int32$:m1 = $x;  // First mutable borrow

    use_ref($x);  // ERROR: Reborrowing x while m1 exists

    print("m1 still active\n");
    return 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
