/**
 * Test: Mutable + Immutable Borrow Simultaneously
 * Expected: COMPILER ERROR - XOR rule violation
 */

func:main = int32() {
    int32:x = 10;

    int32$:r1 = !$x;     // Immutable borrow
    int32$:m = $x;       // ERROR: Mutable borrow while immutable exists

    print("Should not compile!\n");
    return 0;
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
