/**
 * Test: Borrow and Modify in Loop
 * Expected: COMPILER ERROR - borrow persists across iterations
 * Why Critical: Loop creates overlapping borrow lifetimes
 */

func:main = int32() {
    int32:x = 10;
    int32:i = 0;

    while (i < 3) {
        int32$:r = $x;  // Borrow at start of each iteration
        x = x + 1;      // ERROR: Cannot modify while borrowed
        i = i + 1;
    }

    return 0;
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
