/**
 * Test: Conditional Borrow Conflict
 * Expected: COMPILER ERROR - assignment while borrowed
 * Why Critical: Conditional control flow must still enforce active loans
 */

func:main = int32() {
    int32:x = 10;
    int32:y = 20;
    bool:cond = true;

    if (cond) {
        $$i int32:r = x;  // Borrow x in true branch
        x = 30;           // ERROR: x is borrowed by r
    } else {
        $$i int32:r = y;  // Borrow y in false branch
    }

    return 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
