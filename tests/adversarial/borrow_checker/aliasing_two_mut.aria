/**
 * Test: Two Mutable Borrows (Aliasing Violation)
 * Expected: COMPILER ERROR - XOR rule violation
 * Why Critical: Two mutable borrows to same variable violates memory safety
 */

func:main = int32() {
    int32:x = 10;

    int32$:m1 = $x;  // First mutable borrow
    int32$:m2 = $x;  // ERROR: Second mutable borrow while first exists

    // Both borrows are alive here - this should be rejected
    print("Should not compile!\n");

    return 0;
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
