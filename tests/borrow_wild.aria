// Wild Memory Tests - Manual memory management with safety

// Note: extern is not yet implemented, so these tests won't compile yet
// extern func malloc(size: int64) -> wild int8*;
// extern func free(ptr: wild int8*) -> void;

func:test_wild_alloc_free = int32() {
    // Test 1: Basic wild allocation and freeing
    // wild int8*:ptr = malloc(100);
    // free(ptr);
    int32:zero = 0;
    pass zero;
};

func:test_use_after_free = int32() {
    // Test 2: Use after free should FAIL at compile time
    // wild int8*:ptr = malloc(100);
    // free(ptr);
    // @ptr = 42;  // ERROR: Use after free
    
    int32:one = 1;
    pass one;
};

func:test_double_free = int32() {
    // Test 3: Double free should FAIL at compile time
    // wild int8*:ptr = malloc(100);
    // free(ptr);
    // free(ptr);  // ERROR: Double free
    
    int32:one = 1;
    pass one;
};

func:test_leak_detection = int32() {
    // Test 4: Memory leak should FAIL at compile time
    // wild int8*:ptr = malloc(100);
    // Forgot to free!
    int32:one = 1;
    pass one;
};

func:test_conditional_free = int32() {
    // Test 5: Must free in all branches
    // wild int8*:ptr = malloc(100);
    // 
    // if (true) {
    //     free(ptr);
    // }
    // ERROR: ptr not freed in else branch (implicit else)
    
    int32:one = 1;
    pass one;
};

func:test_conditional_free_both_branches = int32() {
    // Test 6: Freed in both branches - should be OK
    // wild int8*:ptr = malloc(100);
    // 
    // if (true) {
    //     free(ptr);
    // } else {
    //     free(ptr);
    // }
    
    int32:zero = 0;
    pass zero;
};

func:main = int32() {
    // Run tests that should succeed
    int32:result1 = raw test_wild_alloc_free();
    int32:result6 = raw test_conditional_free_both_branches();
    
    // Tests 2, 3, 4, 5 should fail at compile time
    // Uncomment one at a time to test error reporting:
    // int32:result2 = test_use_after_free();
    // int32:result3 = test_double_free();
    // int32:result4 = test_leak_detection();
    // int32:result5 = test_conditional_free();
    
    int32:zero = 0;
    pass zero;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
