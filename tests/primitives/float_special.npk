// Float special values, precision, and arithmetic test
// Verifies flt32/flt64 literals, arithmetic, comparisons, and large exponents

func:main = int32() {
    // flt64 arithmetic
    flt64:a = 1.5;
    flt64:b = 2.5;
    if (a + b != 4.0)   { exit 1i32; }  // 1.5 + 2.5 = 4.0
    if (b - a != 1.0)   { exit 2i32; }  // 2.5 - 1.5 = 1.0
    if (a * b != 3.75)  { exit 3i32; }  // 1.5 * 2.5 = 3.75
    flt64:d = 9.0;
    flt64:e = 3.0;
    if (d / e != 3.0)   { exit 4i32; }  // 9.0 / 3.0 = 3.0

    // flt64 comparisons
    flt64:x = 3.0;
    flt64:y = 5.0;
    if (x >= y)   { exit 5i32; }
    if (y <= x)   { exit 6i32; }
    if (x > y)    { exit 7i32; }
    if (y < x)    { exit 8i32; }
    if (x == y)   { exit 9i32; }
    if (x != 3.0) { exit 10i32; }

    // flt64 negation
    flt64:neg = -x;
    if (neg >= 0.0) { exit 11i32; }

    // large exponents
    flt64:big = 1.0e6;
    flt64:small = 1.0e-3;
    if (big != 1000000.0)  { exit 12i32; }
    if (small != 0.001) { exit 13i32; }

    // flt32 arithmetic
    flt32:p = 4.0f32;
    flt32:q = 2.0f32;
    if (p + q != 6.0f32)  { exit 14i32; }
    if (p - q != 2.0f32)  { exit 15i32; }
    if (p * q != 8.0f32)  { exit 16i32; }
    if (p / q != 2.0f32)  { exit 17i32; }

    exit 0;
};
func:failsafe = int32(tbb32:err) { exit 1; };
