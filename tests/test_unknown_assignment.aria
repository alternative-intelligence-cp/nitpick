// Test: unknown literal assignment and comparison
// Phase 5.1: Core unknown literal

func:test_unknown_assignment = int32() {
    // Assign unknown to a variable
    int32:x = unknown;
    
    // Test comparison with unknown
    if (x == unknown) {
        pass(42i32);
    } else {
        pass(99i32);
    }
};

func:test_unknown_vs_regular = int32() {
    // Regular value should NOT equal unknown
    int32:y = 5i32;
    
    if (y == unknown) {
        pass(1i32);
    } else {
        pass(2i32);
    }
};

func:main = int32() {
    int32:a = raw(test_unknown_assignment());  // Should be 42
    int32:b = raw(test_unknown_vs_regular());  // Should be 2
    
    // Return 42 + 2 = 44
    pass(a + b);
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
