// Test that functions return raw types (not Result<T>)
// This validates the type system raw return behavior
// Note: using regular functions (not extern) to avoid linker dependency;
// the underlying type-system behavior is identical.

func:test_extern_int = int32(int32:x) {
    pass x;
};

func:main = int32() {
    // Before fix: calls would fail with "Cannot initialize... with value of type 'result<int32>'"
    // After fix: functions return raw types - compiles successfully!
    
    int32:val = raw test_extern_int(42);  // Returns int32, not Result<int32>
    
    // Success if it compiles!
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
