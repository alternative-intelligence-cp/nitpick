// test_race_unprotected.aria — v0.14.2 Unprotected Access Detection
// Compile with: ariac --verify-concurrency --verify-report -v test_race_unprotected.aria
//
// Tests that genuinely unprotected shared accesses still trigger race warnings.
// This is a negative test — race detection must NOT be suppressed.

extern func:puts = int32(string:s);
extern func:npk_libc_thread_spawn = int64(wild ?*:func, int64:arg);
extern func:npk_libc_thread_join = int32(int64:handle);

// Shared state — NO synchronization
int32:shared_data = 0i32;
int32:shared_flag = 0i32;

// Worker: writes shared_data without any lock
func:unprotected_writer = int64(int64:arg) {
    shared_data = 99i32;
    shared_flag = 1i32;
    pass 0i64;
};

// Spawner: reads shared_data without any lock
// Expected: DISPROVEN — data races on shared_data and shared_flag
func:test_unprotected_access = NIL() {
    int64:t1 = npk_libc_thread_spawn(@unprotected_writer, 0i64);
    int32:val = shared_data + shared_flag;
    drop npk_libc_thread_join(t1);
};

func:failsafe = int32(tbb32:err) {
    drop puts("FAILSAFE");
    exit 1;
};

func:main = int32() {
    drop puts("=== Unprotected Access Test ===");
    drop test_unprotected_access();
    drop puts("=== Done ===");
    exit 0;
};
