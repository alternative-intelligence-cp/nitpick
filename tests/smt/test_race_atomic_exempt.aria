// test_race_atomic_exempt.aria — v0.14.2 Atomic Type Exemption
// Compile with: ariac --verify-concurrency --verify-report -v test_race_atomic_exempt.aria
//
// Tests that atomic operations are recognized as inherently race-free.
// AtomicInt32 accesses via load/store/fetch_add should not trigger race warnings.

extern func:puts = int32(string:s);
extern func:aria_libc_thread_spawn = int64(wild ?*:func, int64:arg);
extern func:aria_libc_thread_join = int32(int64:handle);
extern func:aria_shim_atomic_int32_create = int64(int32:val, int32:order);
extern func:aria_shim_atomic_int32_load = int32(int64:handle, int32:order);
extern func:aria_shim_atomic_int32_store = NIL(int64:handle, int32:val, int32:order);
extern func:aria_shim_atomic_int32_fetch_add = int32(int64:handle, int32:val, int32:order);
extern func:aria_shim_atomic_int32_destroy = NIL(int64:handle);

// Shared atomic counter
int64:atomic_counter = 0i64;

// Worker: uses atomic operations on shared counter
func:atomic_worker = int64(int64:arg) {
    drop aria_shim_atomic_int32_fetch_add(atomic_counter, 1i32, 5i32);
    pass 0i64;
};

// Spawner: also uses atomic operations
// Expected: PROVEN race-free (all accesses are atomic)
func:test_atomic_exempt = NIL() {
    atomic_counter = aria_shim_atomic_int32_create(0i32, 5i32);
    int64:t1 = aria_libc_thread_spawn(@atomic_worker, 0i64);
    drop aria_shim_atomic_int32_fetch_add(atomic_counter, 1i32, 5i32);
    drop aria_libc_thread_join(t1);
    int32:final_val = aria_shim_atomic_int32_load(atomic_counter, 5i32);
    drop aria_shim_atomic_int32_destroy(atomic_counter);
};

func:failsafe = int32(tbb32:err) {
    drop puts("FAILSAFE");
    exit 1;
};

func:main = int32() {
    drop puts("=== Atomic Exemption Test ===");
    drop test_atomic_exempt();
    drop puts("=== Done ===");
    exit 0;
};
