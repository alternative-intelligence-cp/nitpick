// test_race_mutex_protected.aria — v0.14.2 Data Race Analysis
// Compile with: ariac --verify-concurrency --verify-report -v test_race_mutex_protected.aria
//
// Tests that shared variables under consistent mutex protection produce NO race warnings.

extern func:puts = int32(string:s);
extern func:npk_libc_thread_spawn = int64(wild ?*:func, int64:arg);
extern func:npk_libc_thread_join = int32(int64:handle);
extern func:npk_libc_mutex_create = int64(int32:mutex_type);
extern func:npk_libc_mutex_lock = int32(int64:handle);
extern func:npk_libc_mutex_unlock = int32(int64:handle);
extern func:npk_libc_mutex_destroy = int32(int64:handle);

// Shared state
int32:counter = 0i32;
int64:mtx = 0i64;

// Worker: always accesses counter under mutex
func:safe_worker = int64(int64:arg) {
    drop npk_libc_mutex_lock(mtx);
    counter = counter + 1i32;
    drop npk_libc_mutex_unlock(mtx);
    pass 0i64;
};

// Spawner: also accesses counter under mutex
// Expected: PROVEN race-free (both sides protected)
func:test_mutex_protected = NIL() {
    mtx = npk_libc_mutex_create(0i32);
    int64:t1 = npk_libc_thread_spawn(@safe_worker, 0i64);
    drop npk_libc_mutex_lock(mtx);
    counter = counter + 1i32;
    drop npk_libc_mutex_unlock(mtx);
    drop npk_libc_thread_join(t1);
    drop npk_libc_mutex_destroy(mtx);
};

func:failsafe = int32(tbb32:err) {
    drop puts("FAILSAFE");
    exit 1;
};

func:main = int32() {
    drop puts("=== Mutex Protected Test ===");
    drop test_mutex_protected();
    drop puts("=== Done ===");
    exit 0;
};
