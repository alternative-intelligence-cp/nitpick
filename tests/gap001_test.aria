// Simple test to verify int2048 and int4096 tokens are recognized
func:main = int32() {
    int8:a = 1i8;
    int16:b = 2i16;
    int32:c = 3i32;
    int64:d = 4i64;
    int128:e = 5i128;
    int1024:f = 6i1024;
    
    // Test new LBIM types (GAP-001 fix)
    int2048:g = 7i2048;
    int4096:h = 8i4096;
    
    return 0;
};

func:failsafe = NIL(int32:err_code) {
