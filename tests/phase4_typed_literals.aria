// PHASE 4: Test explicit type suffixes in IR generation

func:main = int32() {
    // Unsigned integers
    uint8:a = 255u8;
    uint16:b = 65535u16;
    uint32:c = 42u32;
    uint64:d = 1000u64;
    
    // Signed integers
    int8:e = 127i8;
    int16:f = 32767i16;
    int32:g = 42i32;
    int64:h = 1000i64;
    
    // Floats
    flt32:x = 3.14f32;
    flt64:y = 2.71828f64;
    
    pass(0);
};
