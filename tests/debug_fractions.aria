// Test fraction literals
func:test_fractions = int32() {
    frac8:half = {0, 1, 2};     // 0 + 1/2
    frac16:third = {0, 1, 3};   // 0 + 1/3
    frac32:quarter = {0, 1, 4}; // 0 + 1/4
    
    tfp32:pi = {1, 14159};      // TFP: exponent, mantissa
    tfp64:e = {1, 71828};       // TFP: exponent, mantissa
    
    pass(0i32);
};

func:main = int32() {
    Result<int32>:r = test_fractions();
    pick(r.is_error) {
        (false) { pass(r.value); },
        (true) { pass(1i32); }
    }
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
