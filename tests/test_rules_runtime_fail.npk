// test_rules_runtime_fail.aria — runtime limit violation via assignment
extern func:puts = int32(string:s);

Rules:r_lt_100 = {
    $ < 100
};

func:failsafe = int32(tbb32:err) {
    drop puts("FAILSAFE: limit violation caught at runtime!");
    exit 1;
};

func:main = int32() {
    limit<r_lt_100> int32:a = 50;
    drop puts("Before violation");
    a = 200;
    drop puts("This should NOT print");
    exit 0;
};
