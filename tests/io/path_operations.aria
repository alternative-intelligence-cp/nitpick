func:main = int64() {
    string:rel_path = "./test.txt";
    string:abs_path = pathAbsolute(rel_path);
    print(rel_path);
    print(abs_path);
    print("");
    
    string:full_path = "/home/user/documents/file.txt";
    string:dir = pathDirname(full_path);
    print(full_path);
    print(dir);
    print("");
    
    string:base = pathBasename(full_path);
    print(full_path);
    print(base);
    print("");
    
    string:dir_path = "/home/user";
    string:file_name = "test.txt";
    string:joined = pathJoin(dir_path, file_name);
    print(dir_path);
    print(file_name);
    print(joined);
    print("");
    
    string:abs_test = "/usr/bin/test";
    string:rel_test = "relative/path";
    
    if (pathIsAbsolute(abs_test)) {
        print(abs_test);
    } else {
        print(abs_test);
    }
    
    if (pathIsAbsolute(rel_test)) {
        print(rel_test);
    } else {
        print(rel_test);
    }
    
    return 0;
};
