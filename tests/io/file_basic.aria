// Test basic file I/O functionality
// Phase 4.2: File I/O Builtins

func:main = int32() {
    // Test 1: Write a file
    string:content = "Hello from Aria file I/O!";
    int64:write_result = raw(writeFile("/tmp/aria_test.txt", content)); //this should fail, assigning raw result to int64, no unwrap,  result object == {err:errCode OR NIL, val:returnVal OR NIL}
    
    if (write_result != 0) {
        print("Failed to write file");
        pass(1);
    }
    print("File written successfully");
    
    // Test 2: Read the file back
    string:read_content = raw(readFile("/tmp/aria_test.txt")); //this should fail, assigning raw result to string, no unwrap,  result object == {err:errCode OR NIL, val:returnVal OR NIL}
    print(read_content);
    
    // Test 3: Check if file exists
    bool:exists = raw(fileExists("/tmp/aria_test.txt"));//this should fail, assigning raw result to bool, no unwrap,  result object == {err:errCode OR NIL, val:returnVal OR NIL}
    if (!exists) {
        print("File exists check: FAIL");
        pass(1);
    }
    print("File exists check: PASS");
    
    // Test 4: Get file size
    int64:size = raw(fileSize("/tmp/aria_test.txt")); //this should fail, assigning raw result to int64, no unwrap,  result object == {err:errCode OR NIL, val:returnVal OR NIL}
    if (size < 0) {
        print("Failed to get file size");
        pass(1);
    }
    print("File size retrieved successfully");
    
    // Test 5: Delete the file
    int64:delete_result = raw(deleteFile("/tmp/aria_test.txt"));//this should fail, assigning raw result to int64, no unwrap,  result object == {err:errCode OR NIL, val:returnVal OR NIL}
    if (delete_result != 0) {
        print("Failed to delete file");
        pass(1);
    }
    print("File deleted successfully");
    
    // Test 6: Verify file no longer exists
    bool:still_exists = raw(fileExists("/tmp/aria_test.txt"));//this should fail, assigning raw result to bool, no unwrap, result object == {err:errCode OR NIL, val:returnVal OR NIL}
    if (still_exists) {
        print("ERROR: File still exists after deletion");
        pass(1);
    }
    print("File deletion verified");
    
    print("All file I/O tests passed!");
    exit(0);
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit(1);
};
