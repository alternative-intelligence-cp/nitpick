// Test balanced ternary literal notation
// Format: 0t[01T]+  where T represents -1

// Inline int64_toString until module system is implemented
func:int64_toString = string(int64:value) {
    if (value == 0) { pass("0"); }
    bool:is_negative = false;
    int64:work_value = value;
    if (value < 0) { is_negative = true; work_value = -value; }
    string:result = "";
    int64:remaining = work_value;
    while (remaining > 0) {
        int64:digit = remaining % 10;
        remaining = remaining / 10;
        string:digit_char = "";
        if (digit == 0) { digit_char = "0"; }
        if (digit == 1) { digit_char = "1"; }
        if (digit == 2) { digit_char = "2"; }
        if (digit == 3) { digit_char = "3"; }
        if (digit == 4) { digit_char = "4"; }
        if (digit == 5) { digit_char = "5"; }
        if (digit == 6) { digit_char = "6"; }
        if (digit == 7) { digit_char = "7"; }
        if (digit == 8) { digit_char = "8"; }
        if (digit == 9) { digit_char = "9"; }
        result = string_concat(digit_char, result);
    }
    if (is_negative) { result = string_concat("-", result); }
    pass(result);
};

func:main = int32() {
    // Basic ternary literals
    int64:zero = 0t0;        // 0
    int64:one = 0t1;         // 1
    int64:neg_one = 0tT;     // -1 (T = -1)
    
    // Multi-digit ternary
    int64:two = 0t1T;        // 1*3 + (-1)*1 = 2
    int64:three = 0t10;      // 1*3 + 0*1 = 3
    int64:four = 0t11;       // 1*3 + 1*1 = 4
    int64:five = 0t1TT;      // 1*9 + (-1)*3 + (-1)*1 = 5
    
    // Test with explicit string conversion for all prints
    drop(println("Testing balanced ternary literals:"));
    
    drop(print("0t0 = "));
    string:zero_str = int64_toString(zero);
    drop(println(zero_str));
    
    drop(print("0t1 = "));
    string:one_str = int64_toString(one);
    drop(println(one_str));
    
    drop(print("0tT = "));
    string:neg_one_str = int64_toString(neg_one);
    drop(println(neg_one_str));
    
    drop(print("0t1T = "));
    string:two_str = int64_toString(two);
    drop(println(two_str));
    
    drop(print("0t10 = "));
    string:three_str = int64_toString(three);
    drop(println(three_str));
    
    drop(print("0t11 = "));
    string:four_str = int64_toString(four);
    drop(println(four_str));
    
    drop(print("0t1TT = "));
    string:five_str = int64_toString(five);
    drop(println(five_str));
    
    pass(42);
};

func:failsafe = NIL(int32:err_code) {
