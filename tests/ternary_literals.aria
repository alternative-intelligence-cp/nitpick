// Test balanced ternary literal notation
// Format: 0t[01T]+  where T represents -1

func:main = int32() {
    // Basic ternary literals
    int64:zero = 0t0;        // 0
    int64:one = 0t1;         // 1
    int64:neg_one = 0tT;     // -1 (T = -1)
    
    // Multi-digit ternary
    int64:two = 0t1T;        // 1*3 + (-1)*1 = 2
    int64:three = 0t10;      // 1*3 + 0*1 = 3
    int64:four = 0t11;       // 1*3 + 1*1 = 4
    int64:five = 0t1TT;      // 1*9 + (-1)*3 + (-1)*1 = 5
    
    // Test with print
    print("Testing balanced ternary literals:");
    print("0t0 = ");
    print(zero);
    print("0t1 = ");
    print(one);
    print("0tT = ");
    print(neg_one);
    print("0t1T = ");
    print(two);
    print("0t10 = ");
    print(three);
    print("0t11 = ");
    print(four);
    print("0t1TT = ");
    print(five);
    
    pass(42);
};
