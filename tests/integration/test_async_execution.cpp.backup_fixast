// Integration tests for async/await execution
// Phase 4.5.3 Task #7: End-to-end async execution validation
// These tests verify all async/await components work together
#include "../test_helpers.h"
#include "frontend/sema/type.h"
#include "runtime/async/executor.h"

using namespace aria::sema;
using namespace aria::runtime;

TEST_CASE(async_await_type_integration) {
    // Verify type system integration: async func -> Future<T>, await -> T
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    std::vector<Type*> paramTypes;
    
    // async func:compute = int32() { ... }
    FunctionType* asyncFunc = typeSystem.getFunctionType(paramTypes, int32Type, true, false);
    
    // Function returns future<int32>
    Type* returnType = asyncFunc->getReturnType();
    ASSERT(returnType->getKind() == TypeKind::FUTURE, "Async function returns Future");
    
    // await future<int32> → int32
    Type* awaitType = typeSystem.unwrapFutureType(returnType);
    ASSERT(awaitType == int32Type, "Await extracts int32");
    
    // Full chain validation
    ASSERT(asyncFunc->isAsyncFunction(), "Function is async");
    FutureType* futureType = static_cast<FutureType*>(returnType);
    ASSERT(futureType->getOutputType() == int32Type, "Future contains int32");
}

TEST_CASE(executor_task_lifecycle) {
    // Verify executor can manage task lifecycle
    Executor executor;
    
    void* handle = (void*)0x1000;
    Task::TaskId id = executor.spawn(handle);
    
    // Task lifecycle: READY -> RUNNING -> COMPLETED
    Task* task = executor.getTask(id);
    ASSERT(task->isReady(), "Task starts ready");
    
    executor.step();
    ASSERT(task->isCompleted(), "Task completes after step");
    ASSERT(executor.getTasksCompleted() == 1, "1 task completed");
}

TEST_CASE(multiple_async_tasks_execution) {
    // Verify executor handles multiple tasks correctly
    Executor executor;
    
    Task::TaskId id1 = executor.spawn((void*)0x1000);
    Task::TaskId id2 = executor.spawn((void*)0x2000);
    Task::TaskId id3 = executor.spawn((void*)0x3000);
    
    ASSERT(executor.getPendingTasks() == 3, "3 tasks pending");
    
    executor.runToCompletion();
    
    ASSERT(executor.getStatus() == ExecutorStatus::COMPLETED, "All tasks completed");
    ASSERT(executor.getTasksCompleted() == 3, "3 tasks completed");
    
    Task* task1 = executor.getTask(id1);
    Task* task2 = executor.getTask(id2);
    Task* task3 = executor.getTask(id3);
    
    ASSERT(task1->isCompleted(), "Task 1 completed");
    ASSERT(task2->isCompleted(), "Task 2 completed");
    ASSERT(task3->isCompleted(), "Task 3 completed");
}

