TEST_CASE(nested_future_unwrapping) {
    // Verify nested futures unwrap correctly
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    FutureType* inner = typeSystem.getFutureType(int32Type);
    FutureType* outer = typeSystem.getFutureType(inner);
    
    // future<future<int32>> → future<int32>
    Type* firstUnwrap = typeSystem.unwrapFutureType(outer);
    ASSERT(firstUnwrap == inner, "First unwrap extracts inner future");
    ASSERT(firstUnwrap->getKind() == TypeKind::FUTURE, "Still a Future");
    
    // future<int32> → int32
    Type* secondUnwrap = typeSystem.unwrapFutureType(firstUnwrap);
    ASSERT(secondUnwrap == int32Type, "Second unwrap extracts int32");
}

TEST_CASE(async_function_with_params) {
    // Verify async functions with parameters maintain correct types
    TypeSystem typeSystem;
    
    Type* int32Type = typeSystem.getPrimitiveType("int32");
    Type* stringType = typeSystem.getPrimitiveType("string");
    
    // async func:compute = int32(string, int32) { ... }
    std::vector<Type*> params = {stringType, int32Type};
    FunctionType* asyncFunc = typeSystem.getFunctionType(params, int32Type, true, false);
    
    ASSERT(asyncFunc->isAsyncFunction(), "Is async");
    ASSERT(asyncFunc->getParamCount() == 2, "Has 2 parameters");
    ASSERT(asyncFunc->getParamTypes()[0] == stringType, "First param is string");
    ASSERT(asyncFunc->getParamTypes()[1] == int32Type, "Second param is int32");
    
    Type* returnType = asyncFunc->getReturnType();
    ASSERT(returnType->getKind() == TypeKind::FUTURE, "Returns Future");
    
    FutureType* futureType = static_cast<FutureType*>(returnType);
    ASSERT(futureType->getOutputType() == int32Type, "Future contains int32");
}

TEST_CASE(executor_statistics_accuracy) {
    // Verify executor statistics are accurate
    Executor executor;
    
    ASSERT(executor.getTasksExecuted() == 0, "No tasks initially");
    ASSERT(executor.getTasksCompleted() == 0, "No completions initially");
    ASSERT(executor.getTasksFailed() == 0, "No failures initially");
    
    executor.spawn((void*)0x1000);
    executor.spawn((void*)0x2000);
    
    ASSERT(executor.getPendingTasks() == 2, "2 pending tasks");
    
    executor.step();
    ASSERT(executor.getTasksExecuted() == 1, "1 executed after step");
    ASSERT(executor.getTasksCompleted() == 1, "1 completed after step");
    ASSERT(executor.getPendingTasks() == 1, "1 still pending");
    
    executor.runToCompletion();
    ASSERT(executor.getTasksExecuted() == 2, "2 total executed");
    ASSERT(executor.getTasksCompleted() == 2, "2 total completed");
    ASSERT(executor.getPendingTasks() == 0, "0 pending");
}

TEST_CASE(complex_type_async_integration) {
    // Verify complex types work through full async pipeline
    TypeSystem typeSystem;
    
    Type* tbb32Type = typeSystem.getPrimitiveType("tbb32");
    ArrayType* arrayTbb = typeSystem.getArrayType(tbb32Type, 100);
    PointerType* ptrArray = typeSystem.getPointerType(arrayTbb);
    ResultType* resultPtr = typeSystem.getResultType(ptrArray);
    
    std::vector<Type*> params;
    
    // async func:process = result<tbb32[100]@>() { ... }
    // Returns: future<result<tbb32[100]@>>
    FunctionType* asyncFunc = typeSystem.getFunctionType(params, resultPtr, true, false);
    
    Type* returnType = asyncFunc->getReturnType();
    ASSERT(returnType->getKind() == TypeKind::FUTURE, "Returns Future");
    ASSERT(returnType->toString() == "future<result<tbb32[100]@>>", "Correct nested type");
    
    // await future<result<tbb32[100]@>> → result<tbb32[100]@>
    Type* awaitType = typeSystem.unwrapFutureType(returnType);
    ASSERT(awaitType == resultPtr, "Unwraps to result<tbb32[100]@>");
}

