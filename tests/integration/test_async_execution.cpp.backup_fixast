TEST_CASE(chained_async_await_types) {
    // Verify type propagation through chained async calls
    TypeSystem typeSystem;
    
    Type* stringType = typeSystem.getPrimitiveType("string");
    std::vector<Type*> params;
    
    // async func:fetch = string() { ... } → future<string>
    FunctionType* fetchFunc = typeSystem.getFunctionType(params, stringType, true, false);
    Type* fetchReturn = fetchFunc->getReturnType();
    
    // data = await fetch() → string
    Type* dataType = typeSystem.unwrapFutureType(fetchReturn);
    ASSERT(dataType == stringType, "First await extracts string");
    
    // async func:process = string(string) { ... } → future<string>
    std::vector<Type*> processParams = {stringType};
    FunctionType* processFunc = typeSystem.getFunctionType(processParams, stringType, true, false);
    Type* processReturn = processFunc->getReturnType();
    
    // result = await process(data) → string
    Type* resultType = typeSystem.unwrapFutureType(processReturn);
    ASSERT(resultType == stringType, "Second await extracts string");
}

