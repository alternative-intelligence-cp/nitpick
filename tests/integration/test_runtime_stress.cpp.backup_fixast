// Test 1: Concurrent GC + Threading + Atomics
TEST_CASE(stress_concurrent_gc_threading) {
    aria_gc_init(1024 * 1024, 4 * 1024 * 1024); // 1MB nursery, 4MB old gen
    
    const int NUM_ITERATIONS = 100;
    
    // Allocate many objects to stress GC
    for (int i = 0; i < NUM_ITERATIONS; i++) {
        void* ptr = aria_gc_alloc(1024, 1); // size, type_id
        ASSERT(ptr != nullptr, "GC allocation should succeed under load");
    }
    
    // Force collection
    aria_gc_collect(false);
    
    // Allocate more after collection
    for (int i = 0; i < NUM_ITERATIONS; i++) {
        void* ptr = aria_gc_alloc(2048, 1); // size, type_id
        ASSERT(ptr != nullptr, "GC allocation should succeed after collection");
    }
    
    aria_gc_shutdown();
}

// Test 2: Heavy File I/O
TEST_CASE(stress_io_heavy) {
    const int NUM_FILES = 20;
    const char* TEST_DIR = "/tmp/aria_stress_test";
    
    // Create test directory
    system("mkdir -p /tmp/aria_stress_test");
    
    // Write multiple files
    for (int i = 0; i < NUM_FILES; i++) {
        char filename[256];
        snprintf(filename, sizeof(filename), "%s/test_%d.txt", TEST_DIR, i);
        
        // Create test content
        char content[100];
        snprintf(content, sizeof(content), "Test file %d content", i);
        
        // Write file
        AriaResult* result = aria_write_file(filename, content);
        ASSERT(result->err == nullptr, "File write should succeed");
        aria_result_free(result);
    }
    
    // Read files back and verify
    for (int i = 0; i < NUM_FILES; i++) {
        char filename[256];
        snprintf(filename, sizeof(filename), "%s/test_%d.txt", TEST_DIR, i);
        
        AriaResult* result = aria_read_file(filename);
        ASSERT(result->err == nullptr, "File read should succeed");
        ASSERT(result->val != nullptr, "File content should exist");
        aria_result_free(result);
    }
    
    // Clean up
    system("rm -rf /tmp/aria_stress_test");
}

// Test 3: Wild/GC Allocator Pressure
TEST_CASE(stress_allocator_pressure) {
    aria_gc_init(1024 * 1024, 4 * 1024 * 1024);
    
    const int NUM_ALLOCS = 100;
    std::vector<void*> wild_ptrs;
    
    for (int i = 0; i < NUM_ALLOCS; i++) {
        // Mix of GC and wild allocations
        void* gc_ptr = aria_gc_alloc(512, 1);
        ASSERT(gc_ptr != nullptr, "GC alloc should succeed");
        
        void* wild_ptr = aria_alloc(512);
        ASSERT(wild_ptr != nullptr, "Wild alloc should succeed");
        wild_ptrs.push_back(wild_ptr);
    }
    
    // Free wild allocations
    for (void* ptr : wild_ptrs) {
        aria_free(ptr);
    }
    
    aria_gc_shutdown();
}

// Test 4: Timer Operations Under Load
TEST_CASE(stress_timer_operations) {
    AriaInstant* start = aria_instant_now();
    
    const int NUM_SLEEPS = 20;
    for (int i = 0; i < NUM_SLEEPS; i++) {
        AriaDuration* delay = aria_duration_from_millis(1);
        aria_sleep(delay);
        aria_duration_destroy(delay);
    }
    
    AriaDuration* elapsed = aria_instant_elapsed(start);
    int64_t elapsed_ms = aria_duration_as_millis(elapsed);
    
    ASSERT(elapsed_ms >= NUM_SLEEPS - 5, "Should take at least expected time");
    
    aria_instant_destroy(start);
    aria_duration_destroy(elapsed);
}

// Test 5: Atomic Operations Under Contention
TEST_CASE(stress_atomic_operations) {
    AriaAtomicInt32* counter = aria_atomic_int32_create(0);
    
    const int NUM_ITERATIONS = 1000;
    
    for (int i = 0; i < NUM_ITERATIONS; i++) {
        aria_atomic_int32_fetch_add(counter, 1, ARIA_MEMORY_ORDER_SEQ_CST);
    }
    
    int32_t final_value = aria_atomic_int32_load(counter, ARIA_MEMORY_ORDER_SEQ_CST);
    ASSERT(final_value == NUM_ITERATIONS, "Counter should match iterations");
    
    aria_atomic_int32_destroy(counter);
}

// Test 6: GC Memory Pressure
TEST_CASE(stress_gc_pressure) {
    aria_gc_init(1024 * 1024, 4 * 1024 * 1024);
    
    const int NUM_ALLOCS = 500;
    
    for (int i = 0; i < NUM_ALLOCS; i++) {
        void* ptr = aria_gc_alloc(5120, 1); // 5KB, type_id=1
        ASSERT(ptr != nullptr, "GC should handle continuous allocation");
    }
    
    // Force collection
    aria_gc_collect(false);
    
    // More allocations after collection
    for (int i = 0; i < NUM_ALLOCS; i++) {
        void* ptr = aria_gc_alloc(5120, 1); // 5KB, type_id=1
        ASSERT(ptr != nullptr, "GC should work after collection");
    }
    
    aria_gc_shutdown();
}
