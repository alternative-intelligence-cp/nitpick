// ============================================================================
// Integration Tests - Generics System (Phase 3.4)
// ============================================================================
// These tests verify that all components of the generics system work together:
// - Lexer tokenizes generic syntax
// - Parser builds correct AST
// - Generic resolver performs type inference
// - Monomorphizer creates specializations

TEST_CASE(integration_complete_generics_workflow) {
    // Full workflow test: Create generic function, infer types, monomorphize
    
    // Create a generic function AST manually
    std::vector<ASTNodePtr> params;
    auto param = std::make_unique<ParameterNode>("*T", "value");
    params.push_back(std::move(param));
    
    auto body = std::make_unique<ReturnStmt>(
        std::make_unique<IdentifierExpr>("value", 2, 5), 2, 1);
    
    auto funcDecl = std::make_unique<FuncDeclStmt>(
        "identity", "*T", params, std::move(body));
    funcDecl->genericParams.emplace_back("T");
    
    ASSERT_EQ(funcDecl->genericParams.size(), 1, "Should have 1 generic parameter");
    ASSERT_EQ(funcDecl->genericParams[0].name, "T", "Parameter should be named T");
    
    // Test type inference
    GenericResolver resolver;
    TypeSystem typeSystem;
    
    std::vector<Type*> argTypes;
    argTypes.push_back(typeSystem.getPrimitiveType("int32"));
    
    TypeSubstitution sub = resolver.inferTypeArgs(funcDecl.get(), nullptr, argTypes);
    
    ASSERT_EQ(sub.size(), 1, "Should infer 1 type parameter");
    ASSERT(sub.find("T") != sub.end(), "Should infer T");
    ASSERT_EQ(sub["T"]->toString(), "int32", "Should infer int32");
    
    // Test monomorphization
    Monomorphizer mono(&resolver);
    Specialization* spec = mono.requestSpecialization(funcDecl.get(), sub);
    
    ASSERT(spec != nullptr, "Should create specialization");
    ASSERT(spec->mangledName.find("identity") != std::string::npos,
           "Mangled name should contain function name");
    ASSERT_EQ(spec->funcDecl->genericParams.size(), 0,
              "Specialized function should have no generic params");
}

TEST_CASE(integration_type_inference_with_multiple_args) {
    // Test inference with multiple arguments of same type
    
    std::vector<ASTNodePtr> params;
    auto param1 = std::make_unique<ParameterNode>("*T", "a");
    auto param2 = std::make_unique<ParameterNode>("*T", "b");
    params.push_back(std::move(param1));
    params.push_back(std::move(param2));
    
    auto funcDecl = std::make_unique<FuncDeclStmt>(
        "max", "*T", params, nullptr);
    funcDecl->genericParams.emplace_back("T");
    
    GenericResolver resolver;
    TypeSystem typeSystem;
    
    // Both arguments are int32
    std::vector<Type*> argTypes;
    argTypes.push_back(typeSystem.getPrimitiveType("int32"));
    argTypes.push_back(typeSystem.getPrimitiveType("int32"));
    
    TypeSubstitution sub = resolver.inferTypeArgs(funcDecl.get(), nullptr, argTypes);
    
    ASSERT(!resolver.hasErrors(), "Should infer successfully");
    ASSERT_EQ(sub.size(), 1, "Should infer 1 type parameter");
    ASSERT_EQ(sub["T"]->toString(), "int32", "Should infer int32");
    
    // Create specialization
    Monomorphizer mono(&resolver);
    Specialization* spec = mono.requestSpecialization(funcDecl.get(), sub);
    
    ASSERT(spec != nullptr, "Should monomorphize successfully");
    ASSERT(spec->mangledName.find("max") != std::string::npos,
           "Mangled name should contain function name");
}

