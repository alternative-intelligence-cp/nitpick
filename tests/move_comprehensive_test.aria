// Comprehensive Move Semantics Test Suite
// Tests all aspects of the move() operator

// Test 1: Basic move (should compile)
func:test_basic_move = int32() {
    int32:x = 42;
    int32:y = move(x);  // Transfer ownership from x to y
    
    int32:zero = 0;
    pass(zero);
};

// Test 2: Use-after-move (should FAIL)
func:test_use_after_move = int32() {
    int32:x = 100;
    int32:y = move(x);  // x is moved
    int32:z = x;         // ERROR: Use of moved variable
    
    int32:zero = 0;
    pass(zero);
};

// Test 3: Double move (should FAIL)
func:test_double_move = int32() {
    int32:x = 200;
    int32:y = move(x);  // First move
    int32:z = move(x);  // ERROR: Cannot move already-moved variable
    
    int32:zero = 0;
    pass(zero);
};

// Test 4: Move type preservation
func:test_move_type_preservation = int32() {
    int64:a = 12345;
    int64:b = move(a);  // Type should be preserved
    
    int32:zero = 0;
    pass(zero);
};

// Entry point
func:main = int32() {
    // Only test_basic_move and test_move_type_preservation should compile
    // Others should fail at compile time
    
    int32:zero = 0;
    pass(zero);
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
