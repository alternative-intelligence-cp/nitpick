/**
 * Comprehensive string interpolation test
 * Tests various combinations to ensure fix is complete
 */

func:failsafe = NIL(int32:err_code) {};

func:main = int32() {
    int32:x = 42;
    int32:y = 100;
    
    // Test 1: Plain text followed by template literal
    drop(println("Test 1: Plain text"));
    drop(println(`Test 2: x = &{x}`));
    
    // Test 3: Multiple interpolations
    drop(println(`Test 3: x = &{x}, y = &{y}`));
    
    // Test 4: Template literal followed by plain text
    drop(println(`Test 4: x = &{x}`));
    drop(println("Test 5: Plain text again"));
    
    // Test 6: Multiple template literals in a row
    drop(println(`Test 6: x = &{x}`));
    drop(println(`Test 7: y = &{y}`));
    
    // Test 8: Empty template literal (edge case)
    drop(println(``));
    
    // Test 9: Template literal with only text
    drop(println(`Test 9: No interpolation`));
    
    // Test 10: Complex expression in interpolation
    drop(println(`Test 10: x + y = &{x + y}`));
    
    pass(0);
};
