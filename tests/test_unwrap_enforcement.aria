// Test: Does unwrap operator (?) count as checking the result?

func:get_number = int32(int32:x) {
    pass(x);
};

func:main = int32() {
    // Use ? to unwrap - should this count as "checked"?
    int32:value = get_number(42i32) ? 0i32;
    
    pass(value);
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
