// Test with conditional string assignment like int64_toString

func:main = int32() {
    int64:digit = 5;
    string:digit_char = "";
    
    // Conditional assignment like in int64_toString
    if (digit == 0) { digit_char = "0"; }
    if (digit == 1) { digit_char = "1"; }
    if (digit == 2) { digit_char = "2"; }
    if (digit == 3) { digit_char = "3"; }
    if (digit == 4) { digit_char = "4"; }
    if (digit == 5) { digit_char = "5"; }
    if (digit == 6) { digit_char = "6"; }
    if (digit == 7) { digit_char = "7"; }
    if (digit == 8) { digit_char = "8"; }
    if (digit == 9) { digit_char = "9"; }
    
    // Now use it in concat
    string:result = string_concat(digit_char, "test");
    
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
