// Minimal atomic<T> syntax test

func:failsafe = NIL(int32:code) { pass(NIL); };

func:main = int32() {
    // Test 1: Can we declare atomic<T> types?
    atomic<int32>:counter = atomic_new(0i32);
    
    // Test 2: Can we call .load()?
    int32:val = counter.load();
    
    println("Test passed");
    pass(0i32);
};
