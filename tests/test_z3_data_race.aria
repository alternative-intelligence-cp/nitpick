// Expected: data race detection (negative test, requires --verify-concurrency)
// test_z3_data_race.aria — v0.5.4 Data Race Detection Tests
// Compile with: ariac test_z3_data_race.aria --verify-concurrency --verify-report
//
// Tests Z3 detection of unsafe shared variable accesses between threads.

extern func:puts = int32(string:s);
extern func:aria_shim_thread_spawn = int64(wild ?*:func, int64:arg);
extern func:aria_shim_thread_join = int32(int64:handle);
extern func:aria_shim_mutex_create = int64(int32:mutex_type);
extern func:aria_shim_mutex_lock = int32(int64:handle);
extern func:aria_shim_mutex_unlock = int32(int64:handle);
extern func:aria_shim_mutex_destroy = int32(int64:handle);

// Global shared variable
int32:shared_counter = 0i32;
int64:global_mtx = 0i64;

// ============================================================
// Test 1: UNSAFE — Thread writes shared_counter without mutex
// Should trigger data race warning
// ============================================================
func:unsafe_worker = int64(int64:arg) {
    shared_counter = shared_counter + 1i32;
    pass 0i64;
};

func:test_data_race_detected = NIL() {
    int64:t1 = aria_shim_thread_spawn(unsafe_worker, 0i64);
    // Main thread also accesses shared_counter
    shared_counter = shared_counter + 1i32;
    drop aria_shim_thread_join(t1);
};

// ============================================================
// Test 2: SAFE — Thread writes shared_counter WITH mutex
// Should prove race-free
// ============================================================
func:safe_worker = int64(int64:arg) {
    drop aria_shim_mutex_lock(global_mtx);
    shared_counter = shared_counter + 1i32;
    drop aria_shim_mutex_unlock(global_mtx);
    pass 0i64;
};

func:test_no_race_with_mutex = NIL() {
    global_mtx = aria_shim_mutex_create(0i32);
    drop aria_shim_mutex_lock(global_mtx);
    shared_counter = 0i32;
    drop aria_shim_mutex_unlock(global_mtx);
    int64:t1 = aria_shim_thread_spawn(safe_worker, 0i64);
    drop aria_shim_mutex_lock(global_mtx);
    shared_counter = shared_counter + 1i32;
    drop aria_shim_mutex_unlock(global_mtx);
    drop aria_shim_thread_join(t1);
    drop aria_shim_mutex_destroy(global_mtx);
};

func:failsafe = int32(tbb32:err) {
    drop puts("FAILSAFE");
    exit 1;
};

func:main = int32() {
    drop puts("=== Data Race Detection Tests ===");
    drop test_data_race_detected();
    drop test_no_race_with_mutex();
    drop puts("=== Done ===");
    exit 0;
};
