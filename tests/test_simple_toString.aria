// Simplified int64_toString to isolate the crash

func:simple_toString = string(int64:value) {
    // Skip zero check for now
    
    string:result = "";
    int64:remaining = value;
    
    // Just one iteration
    int64:digit = remaining % 10;
    
    // Convert digit to char
    string:digit_char = "";
    if (digit == 0) { digit_char = "0"; }
    if (digit == 1) { digit_char = "1"; }
    if (digit == 2) { digit_char = "2"; }
    
    // This is where it might crash
    result = string_concat(digit_char, result);
    
    pass(result);
};

func:main = int32() {
    int64:val = 42;
    string:str = raw(simple_toString(val));
    
    pass(0);
};

func:failsafe = NIL(int32:err_code) {
    // Error handling
};
