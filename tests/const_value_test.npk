// Simplified test - just check const value directly

fixed int64:VALUE = 30;

func:main = int32() {
    int64:x = VALUE;
    
    // Test: if VALUE is truly 30, x should equal 30
    int64:thirty = 30;
    
    // Simple check: just exit the value
    // If it's 30, exit code will be 30
    int32:zero = 0;
    exit zero;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
