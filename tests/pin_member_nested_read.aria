/// Regression test: nested pointer member read through a pin path is allowed.
/// Expected process exit: 10

struct:Leaf = {
    int32:x;
};

struct:Box = {
    Leaf->:leaf;
    int32:tag;
};

func:main = int32() {
    stack Leaf:leaf = Leaf{x: 10};
    stack Box:box = Box{leaf: @leaf, tag: 1};
    stack Box->:pin = #box;
    int32:got = pin->leaf->x;
    exit got;
};

func:failsafe = int32(tbb32:err) {
    exit 99;
};