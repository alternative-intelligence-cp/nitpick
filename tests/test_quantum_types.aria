/**
 * Clean Q9<T> and Q21<T> comprehensive test
 */

use stdlib.quantum;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    println("=== Quantum Types Q9 and Q21 Test ===");
    
    // Q9<T> Tests
    println("Q9 Test 1: Creation");
    nit:c0_9 = 0;
    Q9<int32>:q9 = {a: 10, b: 20, c: c0_9};
    if (q9.a != 10 || q9.b != 20) {
        println("  FAIL");
        pass 1;
    }
    println("  PASS");
    
    println("Q9 Test 2: Arithmetic");
    Q9<int32>:q9_after = {a: q9.a + 5, b: q9.b + 5, c: q9.c};
    if (q9_after.a != 15 || q9_after.b != 25) {
        println("  FAIL");
        pass 2;
    }
    println("  PASS");
    
    // Q21<T> Tests
    println("Q21 Test 1: Creation");
    tbb8:c0_21 = 0;
    Q21<int32>:q21 = {a: 100, b: 200, c: c0_21};
    if (q21.a != 100 || q21.b != 200) {
        println("  FAIL");
        pass 3;
    }
    println("  PASS");
    
    println("Q21 Test 2: Arithmetic");
    Q21<int32>:q21_after = {a: q21.a + 50, b: q21.b + 50, c: q21.c};
    if (q21_after.a != 150 || q21_after.b != 250) {
        println("  FAIL");
        pass 4;
    }
    println("  PASS");
    
    println("Q21 Test 3: Crystallization threshold");
    tbb8:c_high = 8;
    Q21<int32>:q21_conf = {a: 1000, b: 2000, c: c_high};
    int32:result = 0;
    tbb8:threshold = 8;
    if (q21_conf.c >= threshold) {
        result = q21_conf.b;
    }
    if (result != 2000) {
        println("  FAIL");
        pass 5;
    }
    println("  PASS");
    
    println("=== All Quantum Type Tests Complete ===");
    println("Q3, Q9, Q21 are production-ready!");
    exit 0;
};
