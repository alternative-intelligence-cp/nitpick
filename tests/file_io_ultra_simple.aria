// Ultra-simple File I/O Test
// Just tests that the functions can be called and linked

func:main = int32() {
    print("Testing file I/O functions...\n");
    
    // Call the functions directly without storing results
    // This tests that the builtins are registered and callable
    
    string:path = "/tmp/aria_test_simple.txt";
    string:content = "Test\n";
    
    // Call functions and discard results by not using them
    // Functions will still execute but we ignore return values
    int64:_1 = writeFile(path, content);
    string:_2 = readFile(path);
    bool:_3 = fileExists(path);
    int64:_4 = fileSize(path);
    int64:_5 = deleteFile(path);
    
    print("All file I/O functions called successfully!\n");
    
    int32:ok = 0;
    pass(ok);
};

func:failsafe = void(int32:err_code) {
    // Error handling
};
