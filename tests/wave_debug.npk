use "stdlib/wave.aria".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    println("step1");
    nit:n0 = 0;
    nit:n1 = 1;
    nit:n2 = 2;

    // Test wave_from_state
    Wave9:state = raw wave_from_state(n1, n0);
    string:sstate = raw wave9_toString(state);
    println(sstate);

    // Test wave_from_spatial
    Wave9:spat = raw wave_from_spatial(n1, n2, n0);
    string:sspat = raw wave9_toString(spat);
    println(sspat);

    // Test wave_from_full
    Wave9:full = raw wave_from_full(n1, n0, n2, n0, n0, n0, n0, n0, n0);
    string:sfull = raw wave9_toString(full);
    println(sfull);

    println("done");
    exit 0;
};


