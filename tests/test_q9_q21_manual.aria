// Expected: COMPILER ERROR
/**
 * Comprehensive test for Q9<T> and Q21<T> quantum types
 * 
 * Tests manual operations (struct literal approach) for both types.
 * Validates struct import, field access, arithmetic, crystallization,
 * and confidence manipulation.
 */

use stdlib.quantum;

func:failsafe = int32(tbb32:err) { exit(1); };

func:main = int32() {
    println("=== Q9<T> and Q21<T> Manual Operations Test ===");
    
    // =========================================================================
    // Q9<T> Tests (nit confidence: -4 to +4)
    // =========================================================================
    
    // Test 1: Q9 creation with different confidence levels
    println("Test 1: Q9 creation with different confidence levels");
    nit:c0 = 0;
    nit:c_neg4 = -4;
    nit:c4 = 4;
    
    Q9<int32>:q9_unknown = {a: 10, b: 20, c: c0};
    Q9<int32>:q9_strong_a = {a: 100, b: 200, c: c_neg4};
    Q9<int32>:q9_strong_b = {a: 50, b: 75, c: c4};
    
    if (q9_unknown.c != 0 || q9_strong_a.c != -4 || q9_strong_b.c != 4) {
        println("  FAIL: Confidence values incorrect");
        pass(1);
    }
    println("  PASS");
    
    // Test 2: Q9 arithmetic - adding to both hypotheses
    println("Test 2: Q9 arithmetic - adding to both hypotheses");
    Q9<int32>:q9_base = {a: 10, b: 20, c: c0};
    int32:add_val = 5;
    Q9<int32>:q9_added = {a: q9_base.a + add_val, b: q9_base.b + add_val, c: q9_base.c};
    
    if (q9_added.a != 15 || q9_added.b != 25) {
        println("  FAIL: Addition incorrect");
        pass(2);
    }
    println("  PASS");
    
    // Test 3: Q9 multiplication
    println("Test 3: Q9 multiplication");
    Q9<int32>:q9_mul_base = {a: 10, b: 20, c: c0};
    int32:mul_val = 2;
    Q9<int32>:q9_mulled = {a: q9_mul_base.a * mul_val, b: q9_mul_base.b * mul_val, c: q9_mul_base.c};
    
    if (q9_mulled.a != 20 || q9_mulled.b != 40) {
        println("  FAIL: Multiplication incorrect");
        pass(3);
    }
    println("  PASS");
    
    // Test 4: Q9 crystallization (threshold: abs(c) >= 3)
    println("Test 4: Q9 crystallization logic");
    nit:c_neg3 = -3;
    nit:c3 = 3;
    
    Q9<int32>:q9_conf_a = {a: 100, b: 200, c: c_neg3};
    Q9<int32>:q9_conf_b = {a: 50, b: 75, c: c3};
    
    int32:result_a = 0;
    int32:result_b = 0;
    
    if (q9_conf_a.c <= c_neg3) { result_a = q9_conf_a.a; }  // Should select A (100)
    if (q9_conf_b.c >= c3) { result_b = q9_conf_b.b; }      // Should select B (75)
    
    if (result_a != 100 || result_b != 75) {
        println("  FAIL: Crystallization logic error");
        pass(4);
    }
    println("  PASS");
    
    // Test 5: Q9 confidence manipulation - shift toward B
    println("Test 5: Q9 confidence shift");
    Q9<int32>:q9_shift = {a: 10, b: 20, c: c0};
    nit:one = 1;
    nit:shifted = q9_shift.c + one;  // Shift toward B: 0 + 1 = 1
    
    if (shifted != 1) {
        println("  FAIL: Confidence shift incorrect");
        pass(5);
    }
    println("  PASS");
    
    // =========================================================================
    // Q21<T> Tests (tbb8 confidence: -10 to +10)
    // =========================================================================
    
    // Test 6: Q21 creation
    println("Test 6: Q21 creation with different confidence levels");
    tbb8:c21_0 = 0;
    tbb8:c21_neg10 = -10;
    tbb8:c21_10 = 10;
    
    Q21<int32>:q21_unknown = {a: 10, b: 20, c: c21_0};
    Q21<int32>:q21_certain_a = {a: 100, b: 200, c: c21_neg10};
    Q21<int32>:q21_certain_b = {a: 50, b: 75, c: c21_10};
    
    if (q21_unknown.c != 0 || q21_certain_a.c != -10 || q21_certain_b.c != 10) {
        println("  FAIL: Q21 confidence values incorrect");
        pass(6);
    }
    println("  PASS");
    
    // Test 7: Q21 arithmetic
    println("Test 7: Q21 arithmetic operations");
    Q21<int32>:q21_base = {a: 100, b: 200, c: c21_0};
    int32:q21_add = 50;
    Q21<int32>:q21_result = {a: q21_base.a + q21_add, b: q21_base.b + q21_add, c: q21_base.c};
    
    if (q21_result.a != 150 || q21_result.b != 250) {
        println("  FAIL: Q21 addition incorrect");
        pass(7);
    }
    println("  PASS");
    
    // Test 8: Q21 crystallization (threshold: abs(c) >= 8)
    println("Test 8: Q21 crystallization logic");
    tbb8:c21_neg8 = -8;
    tbb8:c21_8 = 8;
    
    Q21<int32>:q21_conf_a = {a: 1000, b: 2000, c: c21_neg8};
    Q21<int32>:q21_conf_b = {a: 500, b: 750, c: c21_8};
    
    int32:q21_res_a = 0;
    int32:q21_res_b = 0;
    
    if (q21_conf_a.c <= c21_neg8) { q21_res_a = q21_conf_a.a; }  // Select A
    if (q21_conf_b.c >= c21_8) { q21_res_b = q21_conf_b.b; }     // Select B
    
    if (q21_res_a != 1000 || q21_res_b != 750) {
        println("  FAIL: Q21 crystallization error");
        pass(8);
    }
    println("  PASS");
    
    // Test 9: Q21 saturation barrier modeling
    println("Test 9: Q21 saturation barrier concept");
    tbb8:c21_neg6 = -6;
    tbb8:c21_6 = 6;
    
    Q21<int32>:q21_barrier_a = {a: 100, b: 200, c: c21_neg6};
    Q21<int32>:q21_barrier_b = {a: 100, b: 200, c: c21_6};
    
    // At barriers (±6), should NOT crystallize (threshold is ±8)
    bool:can_cryst_a = false;
    bool:can_cryst_b = false;
    
    if (q21_barrier_a.c <= c21_neg8 || q21_barrier_a.c >= c21_8) {
        can_cryst_a = true;
    }
    
    if (q21_barrier_b.c <= c21_neg8 || q21_barrier_b.c >= c21_8) {
        can_cryst_b = true;
    }
    
    if (can_cryst_a || can_cryst_b) {
        println("  FAIL: Should not crystallize at barriers (±6)");
        pass(9);
    }
    println("  PASS");
    
    println("=== All Q9<T> and Q21<T> Tests Complete ===");
    println("NOTE: All quantum types (Q3, Q9, Q21) are production-ready");
    println("      Use manual operations until turbofish backend support added");
    exit(0);
};
