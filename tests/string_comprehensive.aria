// Comprehensive string library test
// Tests all 11 string builtins with various string operations

func:main = int32() {
    // Test 1: string_length - Get length of string literals
    int64:len1 = string_length("Hello");
    int64:len2 = string_length("World!");
    int64:len3 = string_length("");
    
    // Test 2: string_is_empty - Check if strings are empty
    // Note: These return bool but we'll see how the IR handles it
    string_is_empty("");
    string_is_empty("NotEmpty");
    
    // Test 3: string_equals - Compare strings for equality
    string_equals("Hello", "Hello");
    string_equals("Hello", "World");
    
    // Test 4: string_concat - Concatenate two strings
    string_concat("Hello", " ");
    string_concat("World", "!");
    
    // Test 5: string_substring - Extract substring
    string_substring("Hello World", 0, 5);
    string_substring("Hello World", 6, 5);
    
    // Test 6: string_contains - Check if string contains substring
    string_contains("Hello World", "World");
    string_contains("Hello World", "xyz");
    
    // Test 7: string_starts_with - Check if string starts with prefix
    string_starts_with("Hello World", "Hello");
    string_starts_with("Hello World", "World");
    
    // Test 8: string_ends_with - Check if string ends with suffix
    string_ends_with("Hello World", "World");
    string_ends_with("Hello World", "Hello");
    
    // Test 9: string_trim - Remove leading/trailing whitespace
    string_trim("  Hello  ");
    string_trim("NoSpaces");
    
    // Test 10: string_to_upper - Convert to uppercase
    string_to_upper("hello");
    string_to_upper("Mixed Case 123");
    
    // Test 11: string_to_lower - Convert to lowercase
    string_to_lower("HELLO");
    string_to_lower("Mixed Case 123");
    
    // Combined operations - chaining (if supported)
    int64:result_len = string_length("Hello World");
    
    // Return success
    exit 0;
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
