// ============================================================================
// Aria Standard Library - Extended Mathematics Module
// ============================================================================
// Transcendental functions, interpolation, rounding, modular arithmetic
// Part of stdlib expansion phase (252+ functions across 22+ modules)

// =============================================================================
// External C Math Library Functions
// =============================================================================

extern "libm" {
    func:sqrt = flt64(flt64:x);
    func:pow = flt64(flt64:base, flt64:exp);
    func:sin = flt64(flt64:x);
    func:cos = flt64(flt64:x);
    func:tan = flt64(flt64:x);
    func:asin = flt64(flt64:x);
    func:acos = flt64(flt64:x);
    func:atan = flt64(flt64:x);
    func:atan2 = flt64(flt64:y, flt64:x);
    func:log = flt64(flt64:x);
    func:log10 = flt64(flt64:x);
    func:exp = flt64(flt64:x);
    func:floor = flt64(flt64:x);
    func:ceil = flt64(flt64:x);
    func:fabs = flt64(flt64:x);
    func:fmod = flt64(flt64:x, flt64:y);
    func:round = flt64(flt64:x);
}

