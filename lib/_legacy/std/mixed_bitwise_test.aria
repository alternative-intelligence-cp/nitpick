/// Test int32 and uint32 with bitwise in same file

func:test_int_arith = int32(int32:n) {
    int32:result = (n + 1);
    pass(result);
};

func:test_uint_bitwise = uint32(uint32:n, uint32:pos) {
    uint32:mask = 1i32;
    uint32:i = 0i32;
    uint32:two = 2i32;
    uint32:one = 1i32;
    
    while (i < pos) {
        mask = (mask * two);
        i = (i + one);
    }
    
    uint32:result = (n | mask);
    pass(result);
};
