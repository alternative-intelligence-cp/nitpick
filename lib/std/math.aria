/// @return The angle in radians whose cosine is x
/// @throws Panics if x is outside [-1.0, 1.0]
/// @example
/// ```aria
/// let result = acos(1.0);   // returns 0.0
/// let result2 = acos(-1.0); // returns π
/// ```
pub fn acos(x: flt64) -> flt64 {
