/// Core mathematical functions and constants
//!
//! This module provides essential mathematical operations including
//! trigonometric functions, power/exponential operations, and mathematical constants.

/// The mathematical constant π (pi)
/// Ratio of a circle's circumference to its diameter
pub const PI: flt64 = 3.141592653589793;

/// The mathematical constant e (Euler's number)
/// Base of natural logarithms
pub const E: flt64 = 2.718281828459045;

/// The mathematical constant τ (tau)
/// Equal to 2π, represents one full turn in radians
pub const TAU: flt64 = 6.283185307179586;

