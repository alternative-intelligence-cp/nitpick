/// Test module with uint32 bitwise functions

func:bit_set_test = uint32(uint32:n, uint32:pos) {
    uint32:mask = 1i32;
    uint32:i = 0i32;
    uint32:two = 2i32;
    uint32:one = 1i32;
    
    while (i < pos) {
        mask = (mask * two);
        i = (i + one);
    }
    
    uint32:result = (n | mask);
    pass(result);
};
