// Minimal std.io module for testing
// Full version backed up as io.aria.backup

extern "libc" {
    func:putchar = int32(int64:c);
}

// Simple print function that wraps putchar
pub func:print_char = NIL(int64:ch) {
    putchar(ch);
    pass(NIL);
};

// Simple error print
pub func:eprint_char = NIL(int64:ch) {
    putchar(ch);
    pass(NIL);
};
