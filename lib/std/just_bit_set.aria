/// Just bit_set to test

func:bit_set = uint32(uint32:n, uint32:pos) {
    uint32:mask = 1i32;
    uint32:i = 0i32;
    uint32:two = 2i32;
    uint32:one = 1i32;
    
    // Calculate 2^pos
    while (i < pos) {
        mask = (mask * two);
        i = (i + one);
    }
    
    uint32:result = (n | mask);  // Bitwise OR
    pass(result);
};
