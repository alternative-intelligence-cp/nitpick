#!/bin/sh
set -e

# Create aria-ref symlink for quick reference access
if [ -d /usr/lib/aria/stdlib ]; then
    echo "Aria compiler v0.2.2 installed successfully."
    echo "  Compiler:  ariac"
    echo "  LSP:       aria-ls"
    echo "  Audit:     aria-safety"
    echo "  Stdlib:    /usr/lib/aria/stdlib/"
    echo "  Packages:  /usr/lib/aria/packages/"
fi

#DEBHELPER#
