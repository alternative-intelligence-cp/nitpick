// Test: Fixed struct - should fail compilation on field modification

struct:Point = {
    int32:x;
    int32:y;
};

func:main = int32() {
    // Create a fixed struct
    fixed Point:p = Point{x: 10i32, y: 20i32};
    
    // Try to modify field - should fail
    p.x = 42i32;  // ERROR: Cannot modify field of fixed variable 'p'
    
    // This line should never execute
    pass p.x;
};
