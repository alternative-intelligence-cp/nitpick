// =============================================================================
// Q9<T> - Nonary Quantum Type (9 confidence states)
// =============================================================================

/**
 * Q9<T>: Quantum type with 9-level confidence (-4 to +4)
 * 
 * Tracks two hypotheses (A and B) with fine-grained confidence:
 * - c = -4: Strongly favor hypothesis A
 * - c = -3: Moderately favor A
 * - c = -2: Slightly favor A
 * - c = -1: Weakly favor A
 * - c =  0: Unknown / Equal confidence
 * - c = +1: Weakly favor B
 * - c = +2: Slightly favor B
 * - c = +3: Moderately favor B
 * - c = +4: Strongly favor B
 * 
 * Memory: Uses nit (i8) for confidence.
 * Best for: Decisions requiring gradual confidence accumulation.
 * 
 * Crystallization threshold: abs(c) >= 3 (moderate or strong confidence)
 * 
 * Example:
 *   Q9<int32>:temp = q9_create(20, 25, 0);  // Unknown
 *   temp.c = 3;                              // Moderate confidence in B
 *   int32 | unknown:final = q9_crystallize(temp);  // Returns 25 (B)
 */
struct<T>:Q9 = {
    T:a;        // Hypothesis A
    T:b;        // Hypothesis B
    nit:c;      // Confidence: -4 to +4
};

/**
 * Create Q9<T> with initial hypotheses and confidence.
 * 
 * Args:
 *   a: Hypothesis A value
 *   b: Hypothesis B value
 *   c: Initial confidence (-4 to +4)
 * 
 * Returns:
 *   Q9<T> instance
 */
pub func<T>:q9_create = Q9<T>(T:a, T:b, nit:c) {
    Q9<T>:q;
    q.a = a;
    q.b = b;
    q.c = c;
    pass q;
};

/**
 * Create Q9<T> in UNKNOWN state (c = 0).
 */
pub func<T>:q9_unknown = Q9<T>(T:a, T:b) {
    Q9<T>:q;
    q.a = a;
    q.b = b;
    q.c = 0;
    pass q;
};

/**
 * Create Q9<T> strongly favoring hypothesis A (c = -4).
 */
pub func<T>:q9_strong_a = Q9<T>(T:a, T:b) {
    Q9<T>:q;
    q.a = a;
    q.b = b;
    q.c = -4;
    pass q;
};

/**
 * Create Q9<T> strongly favoring hypothesis B (c = +4).
 */
pub func<T>:q9_strong_b = Q9<T>(T:a, T:b) {
    Q9<T>:q;
    q.a = a;
    q.b = b;
    q.c = 4;
    pass q;
};

// =============================================================================
// Q9<T> Arithmetic Operations (preserve superposition)
// =============================================================================

/**
 * Add value to both hypotheses in Q9<T>.
 * Confidence remains unchanged.
 */
pub func<T>:q9_add = Q9<T>(Q9<T>:q, T:value) {
    q.a = q.a + value;
    q.b = q.b + value;
    pass q;
};

/**
 * Subtract value from both hypotheses in Q9<T>.
 */
pub func<T>:q9_sub = Q9<T>(Q9<T>:q, T:value) {
    q.a = q.a - value;
    q.b = q.b - value;
    pass q;
};

/**
 * Multiply both hypotheses in Q9<T> by value.
 */
pub func<T>:q9_mul = Q9<T>(Q9<T>:q, T:value) {
    q.a = q.a * value;
    q.b = q.b * value;
    pass q;
};

/**
 * Divide both hypotheses in Q9<T> by value.
 */
pub func<T>:q9_div = Q9<T>(Q9<T>:q, T:value) {
    q.a = q.a / value;
    q.b = q.b / value;
    pass q;
};

// =============================================================================
// Q9<T> Crystallization
// =============================================================================

/**
 * Crystallize Q9<T> to definite value if confidence sufficient.
 * 
 * Q9 threshold: abs(c) >= 3 (moderate or strong confidence)
 * 
 * Returns:
 *   - Hypothesis A if c <= -3
 *   - Hypothesis B if c >= +3
 *   - unknown if -2 <= c <= +2
 */
pub func<T>:q9_crystallize = T(Q9<T>:q) {
    if (q.c <= -3) {
        pass q.a;
    }
    if (q.c >= 3) {
        pass q.b;
    }
    // Insufficient confidence
    pass unknown;
};

/**
 * Check if Q9<T> can crystallize (has sufficient confidence).
 */
pub func<T>:q9_can_crystallize = bool(Q9<T>:q) {
    pass q.c <= -3 || q.c >= 3;
};

/**
 * Get the most likely value without crystallizing.
 */
pub func<T>:q9_peek = T(Q9<T>:q) {
    if (q.c <= 0) {
        pass q.a;
    }
    pass q.b;
};

// =============================================================================
// Q9<T> Confidence Manipulation
// =============================================================================

/**
 * Shift confidence toward hypothesis A by one step.
 */
pub func<T>:q9_shift_to_a = Q9<T>(Q9<T>:q) {
    if (q.c > -4) {
        q.c = q.c - 1;
    }
    pass q;
};

/**
 * Shift confidence toward hypothesis B by one step.
 */
pub func<T>:q9_shift_to_b = Q9<T>(Q9<T>:q) {
    if (q.c < 4) {
        q.c = q.c + 1;
    }
    pass q;
};

/**
 * Reset confidence to unknown (c = 0).
 */
pub func<T>:q9_reset_confidence = Q9<T>(Q9<T>:q) {
    q.c = 0;
    pass q;
};

/**
 * Flip confidence (A ↔ B).
 */
pub func<T>:q9_flip_confidence = Q9<T>(Q9<T>:q) {
    q.c = 0 - q.c;
    pass q;
};

// =============================================================================
// Q21<T> - 21-State Quantum Type (with saturation barriers)
// =============================================================================

/**
 * Q21<T>: Quantum type with 21-level confidence and saturation barriers
 * 
 * Tracks two hypotheses with high-resolution confidence:
 * - Range: -10 to +10  
 * - Saturation barriers at ±6 (require strong evidence to cross)
 * - Crystallization threshold: abs(c) >= 8
 * 
 * The tbb8 (ternary-balanced byte) type naturally models saturation:
 * ±6 represent phase transitions requiring sustained evidence to overcome.
 * 
 * Memory: Uses tbb8 (i8) for confidence.
 * Best for: Complex decisions with multiple evidence phases.
 * 
 * Example:
 *   Q21<int32>:q = q21_create(100, 200, 0);
 *   q.c = 8;  // High confidence in B, past the barrier
 *   int32 | unknown:final = q21_crystallize(q);  // Returns 200
 */
struct<T>:Q21 = {
    T:a;        // Hypothesis A
    T:b;        // Hypothesis B
    tbb8:c;     // Confidence: -10 to +10, barriers at ±6
};

/**
 * Create Q21<T> with initial hypotheses and confidence.
 * 
 * Args:
 *   a: Hypothesis A value
 *   b: Hypothesis B value
 *   c: Initial confidence (-10 to +10)
 * 
 * Returns:
 *   Q21<T> instance
 */
pub func<T>:q21_create = Q21<T>(T:a, T:b, tbb8:c) {
    Q21<T>:q;
    q.a = a;
    q.b = b;
    q.c = c;
    pass q;
};

/**
 * Create Q21<T> in UNKNOWN state (c = 0).
 */
pub func<T>:q21_unknown = Q21<T>(T:a, T:b) {
    tbb8:c0 = 0;
    Q21<T>:q;
    q.a = a;
    q.b = b;
    q.c = c0;
    pass q;
};

/**
 * Create Q21<T> with maximum confidence in A (c = -10).
 */
pub func<T>:q21_certain_a = Q21<T>(T:a, T:b) {
    tbb8:c_neg10 = -10;
    Q21<T>:q;
    q.a = a;
    q.b = b;
    q.c = c_neg10;
    pass q;
};

/**
 * Create Q21<T> with maximum confidence in B (c = +10).
 */
pub func<T>:q21_certain_b = Q21<T>(T:a, T:b) {
    tbb8:c10 = 10;
    Q21<T>:q;
    q.a = a;
    q.b = b;
    q.c = c10;
    pass q;
};

// =============================================================================
// Q21<T> Arithmetic Operations
// =============================================================================

/**
 * Add value to both hypotheses in Q21<T>.
 */
pub func<T>:q21_add = Q21<T>(Q21<T>:q, T:value) {
    q.a = q.a + value;
    q.b = q.b + value;
    pass q;
};

/**
 * Subtract value from both hypotheses in Q21<T>.
 */
pub func<T>:q21_sub = Q21<T>(Q21<T>:q, T:value) {
    q.a = q.a - value;
    q.b = q.b - value;
    pass q;
};

/**
 * Multiply both hypotheses in Q21<T> by value.
 */
pub func<T>:q21_mul = Q21<T>(Q21<T>:q, T:value) {
    q.a = q.a * value;
    q.b = q.b * value;
    pass q;
};

/**
 * Divide both hypotheses in Q21<T> by value.
 */
pub func<T>:q21_div = Q21<T>(Q21<T>:q, T:value) {
    q.a = q.a / value;
    q.b = q.b / value;
    pass q;
};

// =============================================================================
// Q21<T> Crystallization
// =============================================================================

/**
 * Crystallize Q21<T> to definite value if confidence sufficient.
 * 
 * Q21 threshold: abs(c) >= 8 (must be past the saturation barrier at ±6)
 * 
 * Returns:
 *   - Hypothesis A if c <= -8
 *   - Hypothesis B if c >= +8
 *   - unknown if -7 <= c <= +7
 */
pub func<T>:q21_crystallize = T(Q21<T>:q) {
    tbb8:neg8 = -8;
    tbb8:pos8 = 8;
    
    if (q.c <= neg8) {
        pass q.a;
    }
    if (q.c >= pos8) {
        pass q.b;
    }
    pass unknown;
};

/**
 * Check if Q21<T> can crystallize.
 */
pub func<T>:q21_can_crystallize = bool(Q21<T>:q) {
    tbb8:neg8 = -8;
    tbb8:pos8 = 8;
    pass q.c <= neg8 || q.c >= pos8;
};

/**
 * Get the most likely value without crystallizing.
 */
pub func<T>:q21_peek = T(Q21<T>:q) {
    tbb8:c0 = 0;
    if (q.c <= c0) {
        pass q.a;
    }
    pass q.b;
};

// =============================================================================
// Q21<T> Confidence Manipulation
// =============================================================================

/**
 * Shift confidence toward hypothesis A by one step.
 */
pub func<T>:q21_shift_to_a = Q21<T>(Q21<T>:q) {
    tbb8:neg10 = -10;
    tbb8:one = 1;
    if (q.c > neg10) {
        q.c = q.c - one;
    }
    pass q;
};

/**
 * Shift confidence toward hypothesis B by one step.
 */
pub func<T>:q21_shift_to_b = Q21<T>(Q21<T>:q) {
    tbb8:pos10 = 10;
    tbb8:one = 1;
    if (q.c < pos10) {
        q.c = q.c + one;
    }
    pass q;
};

/**
 * Reset confidence to unknown (c = 0).
 */
pub func<T>:q21_reset_confidence = Q21<T>(Q21<T>:q) {
    tbb8:c0 = 0;
    q.c = c0;
    pass q;
};

/**
 * Flip confidence (A ↔ B).
 */
pub func<T>:q21_flip_confidence = Q21<T>(Q21<T>:q) {
    tbb8:c0 = 0;
    q.c = c0 - q.c;
    pass q;
};
