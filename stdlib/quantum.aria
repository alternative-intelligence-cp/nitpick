/**
 * Aria Standard Library - Quantum Types
 * 
 * Quantum types enable superposition-based reasoning: tracking multiple
 * hypotheses simultaneously with confidence levels, then crystallizing to
 * a definite value when evidence accumulates sufficiently.
 * 
 * Three variants:
 * - Q3<T>:  3-state confidence (trit: -1, 0, +1)
 * - Q9<T>:  9-state confidence (nit: -4 to +4)
 * - Q21<T>: 21-state confidence (tbb8: -10 to +10 with saturation barriers)
 * 
 * Core concept: "You don't know the answer, so you operate on BOTH values
 * as if each is true, accumulating evidence, and only 'crystallize' from
 * Q<T> to T when confidence reaches threshold."
 * 
 * References:
 * - Design: /home/randy/Workspace/TMP/ideas/aria-lang/quantum_type.idea
 * - POC: /home/randy/Workspace/REPOS/educational/quantum-types-poc
 */

// =============================================================================
// Q3<T> - Ternary Quantum Type (3 confidence states)
// =============================================================================

/**
 * Q3<T>: Quantum type with ternary confidence (-1, 0, +1)
 * 
 * Tracks two hypotheses (A and B) with simple confidence:
 * - c = -1: Lean toward hypothesis A
 * - c =  0: Unknown / Equal confidence
 * - c = +1: Lean toward hypothesis B
 * 
 * Memory efficient: Uses trit (fits in i8) for confidence.
 * Best for: Simple binary decisions that don't need fine-grained confidence.
 * 
 * Example:
 *   Q3<int32>:temp = q3_create(20, 25, 0);  // Could be either
 *   temp = q3_add(temp, 5);                  // Both hypotheses evolve
 *   temp.c = 1;                               // Evidence favors B
 *   int32 | unknown:final = q3_crystallize(temp);  // Returns 30 (25+5)
 */
struct<T>:Q3 = {
    T:a;        // Hypothesis A
    T:b;        // Hypothesis B
    trit:c;     // Confidence: -1 (lean A), 0 (unknown), +1 (lean B)
};

/**
 * Create Q3<T> with initial hypotheses and confidence.
 * 
 * Args:
 *   a: Hypothesis A value
 *   b: Hypothesis B value
 *   c: Initial confidence (-1, 0, or +1)
 * 
 * Returns:
 *   Q3<T> instance
 */
pub func<T>:q3_create = Q3<T>(T:a, T:b, trit:c) {
    Q3<T>:q;
    q.a = a;
    q.b = b;
    q.c = c;
    pass q;
};

/**
 * Create Q3<T> in UNKNOWN state (c = 0).
 * 
 * Convenience constructor for starting with zero confidence.
 */
pub func<T>:q3_unknown = Q3<T>(T:a, T:b) {
    pass q3_create(a, b, 0);
};

/**
 * Create Q3<T> leaning toward hypothesis A (c = -1).
 */
pub func<T>:q3_lean_a = Q3<T>(T:a, T:b) {
    pass q3_create(a, b, -1);
};

/**
 * Create Q3<T> leaning toward hypothesis B (c = +1).
 */
pub func<T>:q3_lean_b = Q3<T>(T:a, T:b) {
    pass q3_create(a, b, 1);
};

// =============================================================================
// Q3<T> Arithmetic Operations (preserve superposition)
// =============================================================================

/**
 * Add value to both hypotheses in Q3<T>.
 * 
 * Confidence remains unchanged - we're just evolving both possibilities.
 * 
 * Example:
 *   Q3<int32>:q = q3_unknown(10, 20);
 *   q = q3_add(q, 5);  // Now {a:15, b:25, c:0}
 */
pub func<T>:q3_add = Q3<T>(Q3<T>:q, T:value) {
    q.a = q.a + value;
    q.b = q.b + value;
    pass q;
};

/**
 * Subtract value from both hypotheses in Q3<T>.
 */
pub func<T>:q3_sub = Q3<T>(Q3<T>:q, T:value) {
    q.a = q.a - value;
    q.b = q.b - value;
    pass q;
};

/**
 * Multiply both hypotheses in Q3<T> by value.
 */
pub func<T>:q3_mul = Q3<T>(Q3<T>:q, T:value) {
    q.a = q.a * value;
    q.b = q.b * value;
    pass q;
};

/**
 * Divide both hypotheses in Q3<T> by value.
 * 
 * Note: For integer types, performs integer division.
 * Consider using floating point types if precision matters.
 */
pub func<T>:q3_div = Q3<T>(Q3<T>:q, T:value) {
    q.a = q.a / value;
    q.b = q.b / value;
    pass q;
};

// =============================================================================
// Q3<T> Crystallization (collapse superposition to single value)
// =============================================================================

/**
 * Crystallize Q3<T> to definite value if confidence sufficient.
 * 
 * Q3 threshold: abs(c) >= 1 (any non-zero confidence)
 * 
 * Returns:
 *   - Hypothesis A if c = -1
 *   - Hypothesis B if c = +1
 *   - unknown if c = 0 (insufficient confidence)
 * 
 * Example:
 *   Q3<int32>:q = {a:100, b:200, c:1};
 *   T:val = q3_crystallize(q);  // Returns 200 (or unknown if c=0)
 */
pub func<T>:q3_crystallize = T(Q3<T>:q) {
    if (q.c < 0) {
        pass q.a;
    }
    if (q.c > 0) {
        pass q.b;
    }
    // c == 0: unknown
    pass unknown;
};

/**
 * Check if Q3<T> can crystallize (has non-zero confidence).
 */
pub func<T>:q3_can_crystallize = bool(Q3<T>:q) {
    pass q.c != 0;
};

/**
 * Get the most likely value without crystallizing (peek).
 * 
 * Returns hypothesis with highest confidence, or A if tied (c=0).
 * Non-destructive: Q3<T> remains in superposition.
 */
pub func<T>:q3_peek = T(Q3<T>:q) {
    if (q.c <= 0) {
        pass q.a;
    }
    pass q.b;
};

// =============================================================================
// Q3<T> Confidence Manipulation
// =============================================================================

/**
 * Adjust confidence toward hypothesis A.
 * 
 * Example:
 *   Q3<int32>:q = q3_unknown(10, 20);
 *   q = q3_shift_to_a(q);  // Now c = -1 (lean A)
 */
pub func<T>:q3_shift_to_a = Q3<T>(Q3<T>:q) {
    if (q.c > -1) {
        q.c = q.c - 1;
    }
    pass q;
};

/**
 * Adjust confidence toward hypothesis B.
 */
pub func<T>:q3_shift_to_b = Q3<T>(Q3<T>:q) {
    if (q.c < 1) {
        q.c = q.c + 1;
    }
    pass q;
};

/**
 * Reset confidence to unknown (c = 0).
 */
pub func<T>:q3_reset_confidence = Q3<T>(Q3<T>:q) {
    q.c = 0;
    pass q;
};

/**
 * Flip confidence (A becomes B, B becomes A, unknown stays unknown).
 */
pub func<T>:q3_flip_confidence = Q3<T>(Q3<T>:q) {
    q.c = 0 - q.c;
    pass q;
};

// =============================================================================
// Q3<T> Conditional Operations (Q-Functions)
// =============================================================================

/**
 * Apply operation to Q3<T> if EITHER hypothesis meets condition.
 * 
 * Example:
 *   Q3<int32>:q = q3_unknown(5, 15);
 *   func<int32>:is_positive = bool(int32:v) { pass(v > 0); };
 *   func<Q3<int32>>:increase_conf = Q3<int32>(Q3<int32>:x) { 
 *       pass(q3_shift_to_b(x)); 
