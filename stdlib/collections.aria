// stdlib/collections.aria
// Collections Module — Pure Aria Implementation (v0.2.0)
//
// Dynamic collections backed by the Aria runtime.
// Provides Vec (dynamic array), Map (hash map), Set (hash set),
// and Graph (directed graph) for int64 values.
//
// Vec operations: new, push, pop, get, set, length, free, contains, sum, is_empty
// Map operations: new, insert, get, has, remove, length, clear, free, is_empty
// Set operations: new, add, has, remove, length, clear, free, is_empty
// Graph operations: new, add_node, add_edge, has_node, has_edge, degree,
//                   neighbor_at, node_count, edge_count, remove_edge, free
//
// Self-hosting: Vec/Map backed by typed C helpers (irreducible &val/memcpy).
//               Set is pure Aria over Map. Graph is pure Aria over Vec+Map.

// ═══════════════════════════════════════════════════════════════════════
// Extern: libc memory
// ═══════════════════════════════════════════════════════════════════════
extern func:malloc = wild int64*(int64:size);
extern func:free = void(wild int64*:ptr);

// ═══════════════════════════════════════════════════════════════════════
// Extern: Pointer↔int64 conversion (for Graph self-hosting)
// ═══════════════════════════════════════════════════════════════════════
extern func:ch_ptr_to_int = int64(wild int8*:ptr);
extern func:ch_int_to_ptr = wild int8*(int64:val);

// ═══════════════════════════════════════════════════════════════════════
// Extern: Vec<int64> typed helpers
// ═══════════════════════════════════════════════════════════════════════
extern func:vec_i64_new = wild int8*();
extern func:vec_i64_push = void(wild int8*:arr, int64:val);
extern func:vec_i64_pop = int64(wild int8*:arr);
extern func:vec_i64_get = int64(wild int8*:arr, int64:index);
extern func:vec_i64_set = void(wild int8*:arr, int64:index, int64:val);
extern func:vec_i64_length = int64(wild int8*:arr);
extern func:vec_i64_free = void(wild int8*:arr);

// ═══════════════════════════════════════════════════════════════════════
// Extern: Vec<int32> typed helpers
// ═══════════════════════════════════════════════════════════════════════
extern func:vec_i32_new = wild int8*();
extern func:vec_i32_push = void(wild int8*:arr, int32:val);
extern func:vec_i32_pop = int32(wild int8*:arr);
extern func:vec_i32_get = int32(wild int8*:arr, int64:index);
extern func:vec_i32_set = void(wild int8*:arr, int64:index, int32:val);
extern func:vec_i32_length = int64(wild int8*:arr);
extern func:vec_i32_free = void(wild int8*:arr);

// ═══════════════════════════════════════════════════════════════════════
// Extern: Vec<flt64> typed helpers
// ═══════════════════════════════════════════════════════════════════════
extern func:vec_f64_new = wild int8*();
extern func:vec_f64_push = void(wild int8*:arr, flt64:val);
extern func:vec_f64_pop = flt64(wild int8*:arr);
extern func:vec_f64_get = flt64(wild int8*:arr, int64:index);
extern func:vec_f64_set = void(wild int8*:arr, int64:index, flt64:val);
extern func:vec_f64_length = int64(wild int8*:arr);
extern func:vec_f64_free = void(wild int8*:arr);

// ═══════════════════════════════════════════════════════════════════════
// Extern: Map<int64, int64> typed helpers
// ═══════════════════════════════════════════════════════════════════════
extern func:map_i64_new = wild int8*();
extern func:map_i64_insert = void(wild int8*:map, int64:key, int64:val);
extern func:map_i64_get = int64(wild int8*:map, int64:key);
extern func:map_i64_has = int32(wild int8*:map, int64:key);
extern func:map_i64_remove = void(wild int8*:map, int64:key);
extern func:map_i64_length = int64(wild int8*:map);
extern func:map_i64_clear = void(wild int8*:map);
extern func:map_i64_free = void(wild int8*:map);

// ═══════════════════════════════════════════════════════════════════════
// Type:Vec — Dynamic array of int64 values
// ═══════════════════════════════════════════════════════════════════════
Type:Vec = {

    func:new = wild int8->() {
        wild int8->:handle = vec_i64_new();
        pass handle;
    };

    func:push = NIL(wild int8->:v, int64:val) {
        vec_i64_push(v, val);
    };

    func:pop = int64(wild int8->:v) {
        pass vec_i64_pop(v);
    };

    func:get = int64(wild int8->:v, int64:i) {
        pass vec_i64_get(v, i);
    };

    func:set = NIL(wild int8->:v, int64:i, int64:val) {
        vec_i64_set(v, i, val);
    };

    func:len = int64(wild int8->:v) {
        pass vec_i64_length(v);
    };

    func:free = NIL(wild int8->:v) {
        vec_i64_free(v);
    };

    func:contains = bool(wild int8->:v, int64:target) {
        int64:n = vec_i64_length(v);
        int64:idx = 0i64;
        while (idx < n) {
            int64:elem = vec_i64_get(v, idx);
            if (elem == target) { pass true; }
            idx = idx + 1i64;
        }
        pass false;
    };

    func:sum = int64(wild int8->:v) {
        int64:n = vec_i64_length(v);
        int64:total = 0i64;
        int64:idx = 0i64;
        while (idx < n) {
            total = total + vec_i64_get(v, idx);
            idx = idx + 1i64;
        }
        pass total;
    };

    func:is_empty = bool(wild int8->:v) {
        int64:n = vec_i64_length(v);
        if (n == 0i64) { pass true; }
        pass false;
    };
};

// ═══════════════════════════════════════════════════════════════════════
// Type:VecI32 — Dynamic array of int32 values
// ═══════════════════════════════════════════════════════════════════════
Type:VecI32 = {

    func:new = wild int8->() {
        wild int8->:handle = vec_i32_new();
        pass handle;
    };

    func:push = NIL(wild int8->:v, int32:val) {
        vec_i32_push(v, val);
    };

    func:pop = int32(wild int8->:v) {
        pass vec_i32_pop(v);
    };

    func:get = int32(wild int8->:v, int64:i) {
        pass vec_i32_get(v, i);
    };

    func:set = NIL(wild int8->:v, int64:i, int32:val) {
        vec_i32_set(v, i, val);
    };

    func:len = int64(wild int8->:v) {
        pass vec_i32_length(v);
    };

    func:free = NIL(wild int8->:v) {
        vec_i32_free(v);
    };
};

// ═══════════════════════════════════════════════════════════════════════
// Type:VecF64 — Dynamic array of flt64 values
// ═══════════════════════════════════════════════════════════════════════
Type:VecF64 = {

    func:new = wild int8->() {
        wild int8->:handle = vec_f64_new();
        pass handle;
    };

    func:push = NIL(wild int8->:v, flt64:val) {
        vec_f64_push(v, val);
    };

    func:pop = flt64(wild int8->:v) {
        pass vec_f64_pop(v);
    };

    func:get = flt64(wild int8->:v, int64:i) {
        pass vec_f64_get(v, i);
    };

    func:set = NIL(wild int8->:v, int64:i, flt64:val) {
        vec_f64_set(v, i, val);
    };

    func:len = int64(wild int8->:v) {
        pass vec_f64_length(v);
    };

    func:free = NIL(wild int8->:v) {
