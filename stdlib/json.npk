// DEPRECATED: This module uses direct extern FFI calls.
// Future versions will migrate to aria-libc shims for ABI safety.
// See: docs/STDLIB.md for migration status.

// stdlib/json.aria
// JSON Serialization / Deserialization Module — Pure Aria (v0.2.0)
//
// Full JSON encoding and decoding for Aria programs.
// Import with: use "stdlib/json.aria".*;
//
// Type codes (returned by json_type / json_arr_get_type):
//   0 = null,  1 = bool,  2 = int,  3 = float,  4 = string,
//   5 = array, 6 = object
//
// Self-hosting: All public API, encoder, and parser in pure Aria.
//               Thin C helpers (jh_*) for irreducible value tree ops.
//
// ── Building JSON ────────────────────────────────────────────────────
//   json_new_object()                        → handle
//   json_new_array()                         → handle
//   json_obj_set_str(h, key, val)            → NIL
//   json_obj_set_int(h, key, val)            → NIL
//   json_obj_set_flt(h, key, val)            → NIL
//   json_obj_set_bool(h, key, val)           → NIL
//   json_obj_set_null(h, key)                → NIL
//   json_obj_set_obj(h, key, child)          → NIL
//   json_obj_set_arr(h, key, child)          → NIL
//   json_arr_push_str(h, val)                → NIL
//   json_arr_push_int(h, val)                → NIL
//   json_arr_push_flt(h, val)                → NIL
//   json_arr_push_bool(h, val)               → NIL
//   json_arr_push_null(h)                    → NIL
//   json_arr_push_obj(h, child)              → NIL
//   json_arr_push_arr(h, child)              → NIL
//   json_encode(h)                           → string
//   json_free(h)                             → NIL
//
// ── Parsing JSON ─────────────────────────────────────────────────────
//   json_parse(json_string)                  → handle
//   json_type(h)                             → int32
//   json_obj_has(h, key)                     → int32    1 if exists
//   json_obj_count(h)                        → int64
//   json_obj_get_str(h, key)                 → string
//   json_obj_get_int(h, key)                 → int64
//   json_obj_get_flt(h, key)                 → flt64
//   json_obj_get_bool(h, key)                → int32
//   json_obj_get_obj(h, key)                 → handle
//   json_obj_get_arr(h, key)                 → handle
//   json_arr_len(h)                          → int64
//   json_arr_get_str(h, idx)                 → string
//   json_arr_get_int(h, idx)                 → int64
//   json_arr_get_flt(h, idx)                 → flt64
//   json_arr_get_bool(h, idx)                → int32
//   json_arr_get_obj(h, idx)                 → handle
//   json_arr_get_arr(h, idx)                 → handle
//   json_arr_get_type(h, idx)                → int32

// ═══════════════════════════════════════════════════════════════════════
// Extern: C helpers — node management (json_helpers.cpp)
// ═══════════════════════════════════════════════════════════════════════
