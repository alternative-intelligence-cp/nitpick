extern func:jh_arr_get_type = int32(wild int8*:h, int64:idx);

// ═══════════════════════════════════════════════════════════════════════
// Internal: Encoder — escape a JSON string value into buffer
// ═══════════════════════════════════════════════════════════════════════
func:json_encode_string = NIL(wild int8->:buf, string:s) {
    jh_buf_char(buf, 34i32);
    int64:slen = jh_strlen(s);
    int64:i = 0i64;
    while (i < slen) {
        int32:c = jh_byte_at(s, i);
        if (c == 34i32) { jh_buf_str(buf, "\\\""); }
        else if (c == 92i32) { jh_buf_str(buf, "\\\\"); }
        else if (c == 8i32) { jh_buf_str(buf, "\\b"); }
        else if (c == 12i32) { jh_buf_str(buf, "\\f"); }
        else if (c == 10i32) { jh_buf_str(buf, "\\n"); }
        else if (c == 13i32) { jh_buf_str(buf, "\\r"); }
        else if (c == 9i32) { jh_buf_str(buf, "\\t"); }
        else if (c < 32i32) {
            jh_buf_str(buf, "\\u00");
            int32:hi = c / 16i32;
            int32:lo = c - (hi * 16i32);
            if (hi < 10i32) { jh_buf_char(buf, hi + 48i32); }
            else { jh_buf_char(buf, hi - 10i32 + 97i32); }
            if (lo < 10i32) { jh_buf_char(buf, lo + 48i32); }
            else { jh_buf_char(buf, lo - 10i32 + 97i32); }
        }
        else { jh_buf_char(buf, c); }
        i = i + 1i64;
    }
    jh_buf_char(buf, 34i32);
};

// ═══════════════════════════════════════════════════════════════════════
// Internal: Encoder — recursive value encoding
// ═══════════════════════════════════════════════════════════════════════
func:json_encode_value = NIL(wild int8->:buf, wild int8->:v) {
    int32:t = jh_type(v);

    if (t == 0i32) { jh_buf_str(buf, "null"); }
    else if (t == 1i32) {
        int32:bv = jh_get_bool(v);
        if (bv == 1i32) { jh_buf_str(buf, "true"); }
        else { jh_buf_str(buf, "false"); }
    }
    else if (t == 2i32) {
        string:ns = jh_int_to_cstr(jh_get_int(v));
        jh_buf_str(buf, ns);
    }
    else if (t == 3i32) {
        string:fs = jh_float_to_cstr(jh_get_float(v));
        jh_buf_str(buf, fs);
    }
    else if (t == 4i32) {
        string:sv = jh_get_string(v);
        drop json_encode_string(buf, sv);
    }
    else if (t == 5i32) {
        jh_buf_char(buf, 91i32);
        int64:alen = jh_arr_len(v);
        int64:ai = 0i64;
        while (ai < alen) {
            if (ai > 0i64) { jh_buf_char(buf, 44i32); }
            wild int8->:aitem = jh_arr_get(v, ai);
            drop json_encode_value(buf, aitem);
            ai = ai + 1i64;
        }
        jh_buf_char(buf, 93i32);
    }
    else if (t == 6i32) {
        jh_buf_char(buf, 123i32);
        int64:olen = jh_obj_count(v);
        int64:oi = 0i64;
        while (oi < olen) {
            if (oi > 0i64) { jh_buf_char(buf, 44i32); }
            string:okey = jh_obj_key_at(v, oi);
            drop json_encode_string(buf, okey);
            jh_buf_char(buf, 58i32);
            wild int8->:oval = jh_obj_val_at(v, oi);
            drop json_encode_value(buf, oval);
            oi = oi + 1i64;
        }
        jh_buf_char(buf, 125i32);
    }
    else { jh_buf_str(buf, "null"); }
};

// ═══════════════════════════════════════════════════════════════════════
// Public API: Encoder (Aria)
// ═══════════════════════════════════════════════════════════════════════

func:json_encode = string(wild int8->:h) {
    wild int8->:buf = jh_buf_new();
    drop json_encode_value(buf, h);
    string:result = jh_buf_to_string(buf);
    pass result;
};

