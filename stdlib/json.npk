extern func:jh_get_float = flt64(wild int8*:h);
extern func:jh_get_string = string(wild int8*:h);

extern func:jh_obj_set = void(wild int8*:h, string:key, wild int8*:child);
extern func:jh_obj_find = wild int8*(wild int8*:h, string:key);
extern func:jh_obj_count = int64(wild int8*:h);
extern func:jh_obj_key_at = string(wild int8*:h, int64:idx);
extern func:jh_obj_val_at = wild int8*(wild int8*:h, int64:idx);

extern func:jh_arr_push = void(wild int8*:h, wild int8*:child);
extern func:jh_arr_get = wild int8*(wild int8*:h, int64:idx);
extern func:jh_arr_len = int64(wild int8*:h);

extern func:jh_clone = wild int8*(wild int8*:h);
extern func:jh_free = void(wild int8*:h);

