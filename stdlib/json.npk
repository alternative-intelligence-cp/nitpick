extern func:jh_new_float = wild int8*(flt64:val);
extern func:jh_new_string = wild int8*(string:val);
extern func:jh_new_object = wild int8*();
extern func:jh_new_array = wild int8*();

extern func:jh_type = int32(wild int8*:h);
extern func:jh_get_bool = int32(wild int8*:h);
