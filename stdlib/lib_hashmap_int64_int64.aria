// ============================================================================
// Runtime Typed Wrapper Declarations (map_i64_* already in runtime)
// ============================================================================

extern func:map_i64_new = wild int8*();
extern func:map_i64_insert = void(wild int8*:map, int64:key, int64:value);
extern func:map_i64_get = int64(wild int8*:map, int64:key);
extern func:map_i64_has = int32(wild int8*:map, int64:key);
extern func:map_i64_remove = void(wild int8*:map, int64:key);
extern func:map_i64_length = int64(wild int8*:map);
