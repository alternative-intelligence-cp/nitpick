// ── generic ──────────────────────────────────────────────────────────────────

/**
 * Print a labeled string value: "label: value\n"
 * Use when you've already converted your value to a string.
 */
pub func:printLabeled = NIL(string:label, string:value) {
    drop print(label);
    drop print(": ");
    drop println(value);
    pass NIL;
};

// ── string (direct) ──────────────────────────────────────────────────────────

pub func:printString = NIL(string:value) {
    drop print(value);
    pass NIL;
};

pub func:printlnString = NIL(string:value) {
    drop println(value);
    pass NIL;
};

pub func:printStringLabeled = NIL(string:label, string:value) {
    drop print(label);
    drop print(": ");
    drop println(value);
    pass NIL;
};

// ── formatting helpers ────────────────────────────────────────────────────────

/** Print a blank line. */
pub func:printNewline = NIL() {
    drop println("");
    pass NIL;
};

/** Print `width` dashes followed by a newline. */
pub func:printSeparator = NIL(int32:width) {
    int64:w = @cast<int64>(width);
    drop println(string_repeat("-", w));
    pass NIL;
};

/** Print `width` repetitions of `ch` followed by a newline (e.g. ch="="). */
pub func:printSeparatorChar = NIL(int32:width, string:ch) {
    int64:w = @cast<int64>(width);
    drop println(string_repeat(ch, w));
    pass NIL;
};

// ── float with explicit precision ─────────────────────────────────────────────

pub func:printlnFloatPrecision = NIL(float64:value, int32:precision) {
    drop println(float_toString(value, precision));
    pass NIL;
};

pub func:printFloatPrecisionLabeled = NIL(string:label, float64:value, int32:precision) {
    drop print(label);
    drop print(": ");
    drop println(float_toString(value, precision));
    pass NIL;
};

