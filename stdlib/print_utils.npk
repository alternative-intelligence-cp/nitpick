/**
 * @file print_utils.aria
 * @brief Print Utility Functions
 *
 * Convenience wrappers around print()/println() for common types.
 * Imports string_convert.aria and wave.aria so callers get one-stop access
 * to Wave9/nyte printing alongside the scalar helpers.
 *
 * Naming convention:
 *   print<Type>(value)            – print without newline
 *   println<Type>(value)          – print with newline
 *   print<Type>Labeled(lbl, val)  – print "label: value\n"
 *
 * Available functions:
 *   printBool / printlnBool / printBoolLabeled
 *   printNit  / printlnNit  / printNitLabeled
 *   printInt32 / printlnInt32 / printInt32Labeled
 *   printInt64 / printlnInt64 / printInt64Labeled
 *   printFloat / printlnFloat / printFloatLabeled
 *   printlnFloatPrecision / printFloatPrecisionLabeled
 *   printNyte  / printlnNyte  / printNyteLabeled
 *   printWave9 / printlnWave9 / printWave9Labeled
 *   printString / printlnString / printStringLabeled
 *   printLabeled(label, string)   – generic label + pre-converted string
 *   printNewline()                – blank line
 *   printSeparator(width)         – "----..." of given width
 *   printSeparatorChar(width, ch) – repeat any character
 *   printInt32Hex / printlnInt32Hex / printInt32HexLabeled
 *   printInt64Hex / printlnInt64Hex / printInt64HexLabeled
 */

use "stdlib/string_convert.aria".*;
use "stdlib/wave.aria".*;

// ── bool ────────────────────────────────────────────────────────────────────

pub func:printBool = NIL(bool:value) {
    drop print(bool_toString(value));
    pass NIL;
};

pub func:printlnBool = NIL(bool:value) {
    drop println(bool_toString(value));
    pass NIL;
};

pub func:printBoolLabeled = NIL(string:label, bool:value) {
    drop print(label);
    drop print(": ");
    drop println(bool_toString(value));
    pass NIL;
};

