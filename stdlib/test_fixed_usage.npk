// Test: Fixed variables can be read and used, just not modified

func:main = int32() {
    // Test: Fixed variables can be read and used, just not modified
    fixed int32:x = 42i32;
    fixed int32:y = 100i32;
    
    // Can read fixed values and use them in expressions
    int32:sum = x + y;
    
    // Test passes if we can use fixed values correctly
    // Should return 142 (42 + 100)
    pass sum;
};
