const int32:NT_POINTER_MEMBER    = 7i32;
const int32:NT_LAMBDA            = 8i32;
const int32:NT_TEMPLATE_LITERAL  = 9i32;
const int32:NT_RANGE             = 10i32;
const int32:NT_TERNARY           = 11i32;
const int32:NT_SAFE_NAV          = 12i32;
const int32:NT_NULL_COALESCE     = 13i32;
const int32:NT_PIPELINE          = 14i32;
const int32:NT_UNWRAP            = 15i32;
const int32:NT_ARRAY_LITERAL     = 16i32;
const int32:NT_OBJECT_LITERAL    = 17i32;
const int32:NT_AWAIT             = 18i32;
