// DEPRECATED: This module uses direct extern FFI calls.
// Future versions will migrate to aria-libc shims for ABI safety.
// See: docs/STDLIB.md for migration status.

// ═══════════════════════════════════════════════════════════════════════
// Aria Self-Hosted Type Checker — Phase 5.3
// ═══════════════════════════════════════════════════════════════════════
// Walks the AST produced by parser.aria and performs:
//   - Symbol table management (define, lookup, resolve)
//   - Type resolution from type annotations
//   - Expression type inference (literals, identifiers, binary/unary ops)
//   - Statement type checking (var decl, func decl, struct decl, etc.)
//   - Error collection
//
// State management via opaque C handle (sema_helpers.cpp).
// Uses the same AST opaque handles from ast_helpers.cpp.


// ═══════════════════════════════════════════════════════════════════════
// TypeKind Constants (match sema_helpers.cpp TK enum)
// ═══════════════════════════════════════════════════════════════════════

const int32:TYPE_PRIMITIVE = 0i32;
const int32:TYPE_POINTER   = 1i32;
const int32:TYPE_ARRAY     = 2i32;
const int32:TYPE_FUNCTION  = 3i32;
const int32:TYPE_STRUCT    = 4i32;
const int32:TYPE_OPTIONAL  = 5i32;
const int32:TYPE_RESULT    = 6i32;
const int32:TYPE_VECTOR    = 7i32;
const int32:TYPE_GENERIC   = 8i32;
const int32:TYPE_UNKNOWN   = 9i32;
const int32:TYPE_ERROR     = 10i32;

// ═══════════════════════════════════════════════════════════════════════
// SymbolKind Constants (match sema_helpers.cpp SK enum)
// ═══════════════════════════════════════════════════════════════════════

const int32:SYM_VARIABLE  = 0i32;
const int32:SYM_FUNCTION  = 1i32;
const int32:SYM_PARAMETER = 2i32;
const int32:SYM_TYPE      = 3i32;
const int32:SYM_TRAIT     = 4i32;
const int32:SYM_MODULE    = 5i32;
const int32:SYM_CONSTANT  = 6i32;

// ═══════════════════════════════════════════════════════════════════════
// ScopeKind Constants (match sema_helpers.cpp ScopeK enum)
// ═══════════════════════════════════════════════════════════════════════

const int32:SCOPE_GLOBAL   = 0i32;
const int32:SCOPE_FUNCTION = 1i32;
const int32:SCOPE_BLOCK    = 2i32;
const int32:SCOPE_STRUCT   = 3i32;
