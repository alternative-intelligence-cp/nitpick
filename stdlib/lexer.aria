// ═══════════════════════════════════════════════════════════════════════
// Whitespace and comment skipping
// ═══════════════════════════════════════════════════════════════════════

func:skip_line_comment = void(wild int8->:st) {
    lex_advance(st);
    lex_advance(st);
    while (lex_at_end(st) == 0i32 && lex_peek(st) != 10i32) {
        lex_advance(st);
    }
};

func:skip_block_comment = void(wild int8->:st) {
    lex_advance(st);
    lex_advance(st);
    while (lex_at_end(st) == 0i32) {
        if (lex_peek(st) == 42i32 && lex_peek_next(st) == 47i32) {
            lex_advance(st);
            lex_advance(st);
            return;
        }
        lex_advance(st);
    }
    lex_error(st, "Unterminated block comment");
};

func:skip_whitespace = void(wild int8->:st) {
    while (lex_at_end(st) == 0i32) {
        int32:c = lex_peek(st);
        if (c == 32i32 || c == 13i32 || c == 9i32 || c == 10i32) {
            lex_advance(st);
        } else if (c == 47i32) {
            int32:nx = lex_peek_next(st);
            if (nx == 47i32) {
                skip_line_comment(st);
            } else if (nx == 42i32) {
                skip_block_comment(st);
            } else {
                return;
            }
        } else {
            return;
        }
    }
};

// ═══════════════════════════════════════════════════════════════════════
// Identifier and keyword scanning
// ═══════════════════════════════════════════════════════════════════════

func:scan_identifier = void(wild int8->:st) {
    while (lex_is_alnum(lex_peek(st)) == 1i32) {
        lex_advance(st);
    }
    int32:kw = lex_scan_keyword(st);
    if (kw >= 0i32) {
        lex_add_token(st, kw);
    } else {
        lex_add_token(st, TK_IDENTIFIER);
    }
};

// ═══════════════════════════════════════════════════════════════════════
// String literal scanning
// ═══════════════════════════════════════════════════════════════════════

func:scan_string = void(wild int8->:st) {
    // Just scan the token span — skip building string value to avoid codegen bugs
    while (lex_at_end(st) == 0i32 && lex_peek(st) != 34i32) {
        if (lex_peek(st) == 92i32) {
            lex_advance(st);
            if (lex_at_end(st) == 0i32) {
                lex_advance(st);
            }
        } else {
            lex_advance(st);
        }
    }
    if (lex_at_end(st) == 1i32) {
        lex_error(st, "Unterminated string literal");
        return;
    }
    lex_advance(st);
    lex_add_token(st, TK_LIT_STRING);
};

// ═══════════════════════════════════════════════════════════════════════
// Character literal scanning
// ═══════════════════════════════════════════════════════════════════════

func:scan_char = void(wild int8->:st) {
    if (lex_at_end(st) == 1i32 || lex_peek(st) == 39i32) {
        lex_error(st, "Empty character literal");
        return;
    }
    // Scan the character span (handle escape sequences)
    if (lex_peek(st) == 92i32) {
        lex_advance(st);
        if (lex_at_end(st) == 0i32) {
            lex_advance(st);
        }
    } else {
        lex_advance(st);
    }
    if (lex_at_end(st) == 1i32 || lex_peek(st) != 39i32) {
        lex_error(st, "Unterminated character literal");
        return;
    }
    lex_advance(st);
    lex_add_token(st, TK_CHAR);
};

// ═══════════════════════════════════════════════════════════════════════
// Type suffix scanning (for numeric literals)
// ═══════════════════════════════════════════════════════════════════════

func:scan_type_suffix = string(wild int8->:st) {
    if (lex_is_alpha(lex_peek(st)) == 0i32) {
        pass "";
    }
    int64:suf_start = lex_get_current(st);
    while (lex_is_alnum(lex_peek(st)) == 1i32) {
        lex_advance(st);
    }
    int64:suf_end = lex_get_current(st);
    int64:suf_len = suf_end - suf_start;
    string:suf_text = lex_get_substr(st, suf_start, suf_len);
    pass suf_text;
};

// ═══════════════════════════════════════════════════════════════════════
// Numeric literal scanning
// ═══════════════════════════════════════════════════════════════════════

func:scan_hex = void(wild int8->:st) {
    lex_advance(st);
    if (lex_is_hex(lex_peek(st)) == 0i32) {
        lex_error(st, "Expected hexadecimal digits after '0x'");
        return;
    }
    while (lex_is_hex(lex_peek(st)) == 1i32 || lex_peek(st) == 95i32) {
        lex_advance(st);
    }
    string:text = lex_get_lexeme(st);
    // Remove 0x prefix — get substr after first 2 chars
    int64:start_pos = lex_get_start(st);
    int64:cur_pos = lex_get_current(st);
    int64:digit_len = cur_pos - start_pos - 2i64;
    string:digits = lex_get_substr(st, start_pos + 2i64, digit_len);
    string:cleaned = lex_strip_underscores(digits);
    string:suffix = scan_type_suffix(st);
    if (suffix == "") {
        int64:val = lex_parse_int(cleaned, 16i32);
        lex_add_token_int(st, TK_INTEGER, val);
    } else {
        int32:tt = suffix_to_int_type(suffix);
        if (tt < 0i32) {
            lex_error(st, "Invalid type suffix for hex literal");
            lex_add_token(st, TK_ERROR);
        } else {
            // Check if unsigned type for proper parsing
            if (tt >= TK_INTEGER_U8 && tt <= TK_INTEGER_U4096) {
                int64:val = lex_parse_uint(cleaned, 16i32);
                lex_add_token_int(st, tt, val);
            } else {
                int64:val = lex_parse_int(cleaned, 16i32);
                lex_add_token_int(st, tt, val);
            }
        }
    }
};

func:scan_binary = void(wild int8->:st) {
    lex_advance(st);
    if (lex_is_bin(lex_peek(st)) == 0i32) {
        lex_error(st, "Expected binary digits after '0b'");
        return;
    }
    while (lex_is_bin(lex_peek(st)) == 1i32 || lex_peek(st) == 95i32) {
        lex_advance(st);
    }
    int64:start_pos = lex_get_start(st);
    int64:cur_pos = lex_get_current(st);
    int64:digit_len = cur_pos - start_pos - 2i64;
    string:digits = lex_get_substr(st, start_pos + 2i64, digit_len);
    string:cleaned = lex_strip_underscores(digits);
    string:suffix = scan_type_suffix(st);
    if (suffix == "") {
        int64:val = lex_parse_int(cleaned, 2i32);
        lex_add_token_int(st, TK_INTEGER, val);
    } else {
        int32:tt = suffix_to_int_type(suffix);
        if (tt < 0i32) {
            lex_error(st, "Invalid type suffix for binary literal");
            lex_add_token(st, TK_ERROR);
        } else {
            int64:val = lex_parse_int(cleaned, 2i32);
            lex_add_token_int(st, tt, val);
        }
    }
};

func:scan_octal = void(wild int8->:st) {
    lex_advance(st);
    if (lex_is_oct(lex_peek(st)) == 0i32) {
        lex_error(st, "Expected octal digits after '0o'");
        return;
    }
    while (lex_is_oct(lex_peek(st)) == 1i32 || lex_peek(st) == 95i32) {
        lex_advance(st);
    }
    int64:start_pos = lex_get_start(st);
    int64:cur_pos = lex_get_current(st);
    int64:digit_len = cur_pos - start_pos - 2i64;
    string:digits = lex_get_substr(st, start_pos + 2i64, digit_len);
    string:cleaned = lex_strip_underscores(digits);
    string:suffix = scan_type_suffix(st);
    if (suffix == "") {
        int64:val = lex_parse_int(cleaned, 8i32);
        lex_add_token_int(st, TK_INTEGER, val);
    } else {
        int32:tt = suffix_to_int_type(suffix);
        if (tt < 0i32) {
            lex_error(st, "Invalid type suffix for octal literal");
            lex_add_token(st, TK_ERROR);
        } else {
            int64:val = lex_parse_int(cleaned, 8i32);
            lex_add_token_int(st, tt, val);
        }
    }
};

func:scan_ternary_lit = void(wild int8->:st) {
    lex_advance(st);
    int32:fc = lex_peek(st);
    if (fc != 48i32 && fc != 49i32 && fc != 84i32 && fc != 116i32) {
        lex_error(st, "Expected ternary digits (0, 1, T) after '0t'");
        return;
    }
    while (lex_at_end(st) == 0i32) {
        int32:c = lex_peek(st);
        if (c == 48i32 || c == 49i32 || c == 84i32 || c == 116i32 || c == 95i32) {
            lex_advance(st);
        } else {
            break;
        }
    }
    int64:start_pos = lex_get_start(st);
    int64:cur_pos = lex_get_current(st);
    int64:digit_len = cur_pos - start_pos - 2i64;
    string:digits = lex_get_substr(st, start_pos + 2i64, digit_len);
    string:cleaned = lex_strip_underscores(digits);
    // Convert balanced ternary to int64
    int64:value = 0i64;
    int64:power = 1i64;
    int64:i = @cast<int64>(string_length(cleaned)) - 1i64;
    while (i >= 0i64) {
        int32:d = @cast<int32>(cleaned[i]);
        int64:tv = 0i64;
        if (d == 48i32) {
            tv = 0i64;
        } else if (d == 49i32) {
            tv = 1i64;
        } else if (d == 84i32 || d == 116i32) {
            tv = -1i64;
        }
        value = value + tv * power;
        power = power * 3i64;
        i = i - 1i64;
    }
    lex_add_token_int(st, TK_TERNARY, value);
};

func:scan_nonary_lit = void(wild int8->:st) {
    lex_advance(st);
    int32:fc = lex_peek(st);
    int32:valid = 0i32;
    if (fc >= 48i32 && fc <= 52i32) { valid = 1i32; }
    if (fc >= 65i32 && fc <= 68i32) { valid = 1i32; }
    if (fc >= 97i32 && fc <= 100i32) { valid = 1i32; }
    if (valid == 0i32) {
        lex_error(st, "Expected nonary digits (0-4, A-D) after '0n'");
        return;
    }
    while (lex_at_end(st) == 0i32) {
        int32:c = lex_peek(st);
        int32:bk2 = 0i32;
        if (c >= 48i32 && c <= 52i32) { bk2 = 1i32; }
        if (c >= 65i32 && c <= 68i32) { bk2 = 1i32; }
        if (c >= 97i32 && c <= 100i32) { bk2 = 1i32; }
        if (c == 95i32) { bk2 = 1i32; }
        if (bk2 == 1i32) {
            lex_advance(st);
        } else {
            break;
        }
    }
    int64:start_pos = lex_get_start(st);
    int64:cur_pos = lex_get_current(st);
    int64:digit_len = cur_pos - start_pos - 2i64;
    string:digits = lex_get_substr(st, start_pos + 2i64, digit_len);
    string:cleaned = lex_strip_underscores(digits);
    // Convert balanced nonary to int64
    int64:value = 0i64;
    int64:power = 1i64;
    int64:i = @cast<int64>(string_length(cleaned)) - 1i64;
    while (i >= 0i64) {
        int32:d = @cast<int32>(cleaned[i]);
        int64:nit_val = 0i64;
        if (d >= 48i32 && d <= 52i32) {
            nit_val = @cast<int64>(d) - 48i64;
        } else if (d == 65i32 || d == 97i32) {
            nit_val = -1i64;
        } else if (d == 66i32 || d == 98i32) {
            nit_val = -2i64;
        } else if (d == 67i32 || d == 99i32) {
            nit_val = -3i64;
        } else if (d == 68i32 || d == 100i32) {
            nit_val = -4i64;
        }
        value = value + nit_val * power;
        power = power * 9i64;
        i = i - 1i64;
    }
    lex_add_token_int(st, TK_NONARY, value);
};

// Dispatch special number bases (0x, 0b, 0o, 0t, 0n). Returns 1 if handled.
func:dispatch_number_base = int32(wild int8->:st, int32:first) {
    if (first != 48i32 || lex_at_end(st) == 1i32) { pass 0i32; }
    int32:nx = lex_peek(st);
    if (nx == 120i32 || nx == 88i32) { scan_hex(st); }
    else if (nx == 98i32 || nx == 66i32) { scan_binary(st); }
    else if (nx == 111i32 || nx == 79i32) { scan_octal(st); }
    else if (nx == 116i32 || nx == 84i32) { scan_ternary_lit(st); }
    else if (nx == 110i32 || nx == 78i32) { scan_nonary_lit(st); }
    else { pass 0i32; }
    pass 1i32;
};

func:scan_number = void(wild int8->:st) {
    // Check for special bases (first digit already consumed = source[start])
    int32:first = lex_source_char(st, lex_get_start(st));
    int32:base_r = dispatch_number_base(st, first);
    if (base_r == 1i32) { return; }

    // Decimal number
    while (lex_is_digit(lex_peek(st)) == 1i32 || lex_peek(st) == 95i32) {
        lex_advance(st);
    }

    int32:is_flt = 0i32;
    // Check for decimal point
    if (lex_peek(st) == 46i32 && lex_is_digit(lex_peek_next(st)) == 1i32) {
        is_flt = 1i32;
        lex_advance(st);
        while (lex_is_digit(lex_peek(st)) == 1i32 || lex_peek(st) == 95i32) {
            lex_advance(st);
        }
    }

    // Check for scientific notation
    int32:ep = lex_peek(st);
    if (ep == 101i32 || ep == 69i32) {
        is_flt = 1i32;
        lex_advance(st);
        int32:sign = lex_peek(st);
        if (sign == 43i32 || sign == 45i32) {
            lex_advance(st);
        }
        if (lex_is_digit(lex_peek(st)) == 0i32) {
            lex_error(st, "Expected digits in exponent");
            return;
        }
        while (lex_is_digit(lex_peek(st)) == 1i32 || lex_peek(st) == 95i32) {
            lex_advance(st);
        }
    }

    // Get cleaned text
    int64:start_pos = lex_get_start(st);
    int64:cur_pos = lex_get_current(st);
    int64:num_len = cur_pos - start_pos;
    string:raw_text = lex_get_substr(st, start_pos, num_len);
    string:cleaned = lex_strip_underscores(raw_text);

    // Scan type suffix
    string:suffix = scan_type_suffix(st);

    if (suffix == "") {
        if (is_flt == 1i32) {
            flt64:fval = lex_parse_float(cleaned);
            lex_add_token_float(st, TK_FLOAT, fval);
        } else {
            int64:ival = lex_parse_int(cleaned, 10i32);
            lex_add_token_int(st, TK_INTEGER, ival);
        }
        return;
    }

    // Typed literal
    if (is_flt == 1i32) {
        int32:tt = suffix_to_float_type(suffix);
        if (tt < 0i32) {
            lex_error(st, "Invalid type suffix for float literal");
            lex_add_token(st, TK_ERROR);
        } else {
            flt64:fval = lex_parse_float(cleaned);
            lex_add_token_float_raw(st, tt, fval, cleaned);
        }
    } else {
        int32:tt = suffix_to_int_type(suffix);
        if (tt < 0i32) {
            lex_error(st, "Invalid type suffix for integer literal");
            lex_add_token(st, TK_ERROR);
        } else {
            if (tt >= TK_INTEGER_U8 && tt <= TK_INTEGER_U4096) {
                int64:uval = lex_parse_uint(cleaned, 10i32);
                lex_add_token_int(st, tt, uval);
            } else {
                int64:ival = lex_parse_int(cleaned, 10i32);
                lex_add_token_int(st, tt, ival);
            }
        }
    }
};

// ═══════════════════════════════════════════════════════════════════════
// Template literal scanning
// ═══════════════════════════════════════════════════════════════════════

// Forward declaration needed for recursive call from template scanning
func:scan_one_token = void(wild int8->:st);

func:scan_template_literal = void(wild int8->:st) {
    int32:start_ln = lex_get_start_line(st);
    int32:start_cl = lex_get_start_col(st);
    lex_push_token(st, TK_TEMPLATE_START, "`", start_ln, start_cl);

    int64:part_start = lex_get_current(st);
    int32:part_ln = lex_get_line(st);
    int32:part_cl = lex_get_col(st);

    while (lex_at_end(st) == 0i32) {
        // Check for interpolation: &{
        if (lex_peek(st) == 38i32 && lex_peek_next(st) == 123i32) {
            int64:part_end = lex_get_current(st);
            int64:part_len = part_end - part_start;
            string:part_text = lex_get_substr(st, part_start, part_len);
            lex_push_token_str(st, TK_TEMPLATE_PART, part_text, part_ln, part_cl, part_text);
            int32:interp_ln = lex_get_line(st);
            int32:interp_cl = lex_get_col(st);
            lex_advance(st);
            lex_advance(st);
            lex_push_token(st, TK_INTERP_START, "&{", interp_ln, interp_cl);

            // Tokenize interpolation expression until matching }
            int32:depth = 1i32;
            while (lex_at_end(st) == 0i32 && depth > 0i32) {
                // Skip whitespace inside interpolation
                while (lex_at_end(st) == 0i32) {
                    int32:wc = lex_peek(st);
                    if (wc == 32i32 || wc == 9i32 || wc == 13i32) {
                        lex_advance(st);
                    } else if (wc == 10i32) {
                        lex_advance(st);
                    } else {
                        break;
                    }
                }
                if (lex_at_end(st) == 1i32) { break; }
                int32:ic = lex_peek(st);
                if (ic == 123i32) {
                    depth = depth + 1i32;
                    scan_one_token(st);
                } else if (ic == 125i32) {
                    depth = depth - 1i32;
                    if (depth == 0i32) {
                        break;
                    } else {
                        scan_one_token(st);
                    }
                } else {
                    scan_one_token(st);
                }
            }

            if (depth > 0i32) {
                lex_error(st, "Unterminated interpolation in template literal");
                return;
            }

            int32:end_ln = lex_get_line(st);
            int32:end_cl = lex_get_col(st);
            lex_advance(st);
            lex_push_token(st, TK_INTERP_END, "}", end_ln, end_cl);

            part_start = lex_get_current(st);
            part_ln = lex_get_line(st);
            part_cl = lex_get_col(st);
            continue;
        }

        // Check for template end: `
        if (lex_peek(st) == 96i32) {
            int64:part_end = lex_get_current(st);
            int64:part_len = part_end - part_start;
            string:part_text = lex_get_substr(st, part_start, part_len);
            lex_push_token_str(st, TK_TEMPLATE_PART, part_text, part_ln, part_cl, part_text);
            int32:end_ln = lex_get_line(st);
            int32:end_cl = lex_get_col(st);
            lex_advance(st);
            lex_push_token(st, TK_TEMPLATE_END, "`", end_ln, end_cl);
            return;
        }

        // Escape sequences — just skip past (raw text preserved in lexeme)
        if (lex_peek(st) == 92i32) {
            lex_advance(st);
            if (lex_at_end(st) == 1i32) {
                lex_error(st, "Unterminated template literal");
                return;
            }
            lex_advance(st);
            continue;
        }

        // Regular character
        lex_advance(st);
    }

    lex_error(st, "Unterminated template literal");
};

// ═══════════════════════════════════════════════════════════════════════
// @cast keyword scanning
// ═══════════════════════════════════════════════════════════════════════

func:is_at_cast = int32(wild int8->:st) {
    // Check if we're looking at "cast" or "cast_unchecked" after @
    if (lex_peek(st) != 99i32 || lex_peek_n(st, 1i32) != 97i32 || lex_peek_n(st, 2i32) != 115i32 || lex_peek_n(st, 3i32) != 116i32) {
        pass 0i32;
    }
    // Got "cast" — check if rest is _unchecked or end of identifier
    int32:after = lex_peek_n(st, 4i32);
    int32:result = 0i32;
    if (after == 95i32 && lex_peek_n(st, 5i32) == 117i32 && lex_peek_n(st, 6i32) == 110i32) {
        int32:after14 = lex_peek_n(st, 14i32);
        if (lex_is_alnum(after14) == 0i32) {
            result = 2i32;
        }
    }
    else if (lex_is_alnum(after) == 0i32 || after == 0i32) {
        result = 1i32;
    }
    pass result;
};

func:scan_cast_keyword = void(wild int8->:st) {
    // @ already consumed. Consume "cast"
    lex_advance(st);
    lex_advance(st);
    lex_advance(st);
    lex_advance(st);
    // Check for _unchecked
    if (lex_peek(st) == 95i32 && lex_peek_n(st, 1i32) == 117i32) {
        // Consume "_unchecked" (10 chars)
        int32:j = 0i32;
        while (j < 10i32) {
            lex_advance(st);
            j = j + 1i32;
        }
        lex_add_token(st, TK_KW_CAST_UNCHECKED);
    } else {
        lex_add_token(st, TK_KW_CAST);
    }
};

// ═══════════════════════════════════════════════════════════════════════
// Operator scanning helpers (split to avoid too many pass() exits)
// ═══════════════════════════════════════════════════════════════════════

func:scan_plus = void(wild int8->:st) {
    if (lex_match(st, 43i32) == 1i32) {
        lex_add_token(st, TK_PLUS_PLUS);
    } else if (lex_match(st, 61i32) == 1i32) {
        lex_add_token(st, TK_PLUS_EQUAL);
    } else {
        lex_add_token(st, TK_PLUS);
    }
};

func:scan_minus = void(wild int8->:st) {
    if (lex_match(st, 45i32) == 1i32) {
        lex_add_token(st, TK_MINUS_MINUS);
    } else if (lex_match(st, 61i32) == 1i32) {
        lex_add_token(st, TK_MINUS_EQUAL);
    } else if (lex_match(st, 62i32) == 1i32) {
        lex_add_token(st, TK_ARROW);
    } else {
        lex_add_token(st, TK_MINUS);
    }
};

func:scan_star = void(wild int8->:st) {
    if (lex_match(st, 61i32) == 1i32) {
        lex_add_token(st, TK_STAR_EQUAL);
    } else {
        lex_add_token(st, TK_STAR);
    }
};

func:scan_fslash = void(wild int8->:st) {
    if (lex_match(st, 61i32) == 1i32) {
        lex_add_token(st, TK_SLASH_EQUAL);
    } else {
        lex_add_token(st, TK_SLASH);
    }
};

func:scan_pct = void(wild int8->:st) {
    if (lex_match(st, 61i32) == 1i32) {
        lex_add_token(st, TK_PERCENT_EQUAL);
    } else {
        lex_add_token(st, TK_PERCENT);
    }
};

func:scan_eq = void(wild int8->:st) {
    if (lex_match(st, 61i32) == 1i32) {
        lex_add_token(st, TK_EQUAL_EQUAL);
    } else if (lex_match(st, 62i32) == 1i32) {
        lex_add_token(st, TK_FAT_ARROW);
    } else {
        lex_add_token(st, TK_EQUAL);
    }
};

func:scan_bang = void(wild int8->:st) {
    if (lex_match(st, 33i32) == 1i32) {
        if (lex_match(st, 33i32) == 1i32) {
            lex_add_token(st, TK_BANG_BANG_BANG);
        } else {
            lex_error(st, "Unexpected '!!' - did you mean '!!!' for failsafe call?");
            lex_add_token(st, TK_BANG);
            lex_add_token(st, TK_BANG);
        }
    } else if (lex_match(st, 61i32) == 1i32) {
        lex_add_token(st, TK_BANG_EQUAL);
    } else {
        lex_add_token(st, TK_BANG);
    }
};

func:scan_less = void(wild int8->:st) {
    if (lex_match(st, 61i32) == 1i32) {
        if (lex_match(st, 62i32) == 1i32) {
            lex_add_token(st, TK_SPACESHIP);
        } else {
            lex_add_token(st, TK_LESS_EQUAL);
        }
    } else if (lex_match(st, 60i32) == 1i32) {
        lex_add_token(st, TK_SHIFT_LEFT);
    } else if (lex_match(st, 45i32) == 1i32) {
        lex_add_token(st, TK_LEFT_ARROW);
    } else if (lex_match(st, 124i32) == 1i32) {
        lex_add_token(st, TK_PIPE_LEFT);
    } else {
        lex_add_token(st, TK_LESS);
    }
};

func:scan_greater = void(wild int8->:st) {
    if (lex_match(st, 61i32) == 1i32) {
        lex_add_token(st, TK_GREATER_EQUAL);
    } else if (lex_match(st, 62i32) == 1i32) {
        lex_add_token(st, TK_SHIFT_RIGHT);
    } else {
        lex_add_token(st, TK_GREATER);
    }
};

func:scan_amp = void(wild int8->:st) {
    if (lex_match(st, 38i32) == 1i32) {
        lex_add_token(st, TK_AND_AND);
    } else {
        lex_add_token(st, TK_AMPERSAND);
    }
};

func:scan_bar = void(wild int8->:st) {
    if (lex_match(st, 124i32) == 1i32) {
        lex_add_token(st, TK_OR_OR);
    } else if (lex_match(st, 62i32) == 1i32) {
        lex_add_token(st, TK_PIPE_RIGHT);
    } else {
        lex_add_token(st, TK_PIPE);
    }
};

func:scan_question = void(wild int8->:st) {
    if (lex_match(st, 46i32) == 1i32) {
        lex_add_token(st, TK_SAFE_NAV);
    } else if (lex_match(st, 63i32) == 1i32) {
        lex_add_token(st, TK_NULL_COALESCE);
    } else if (lex_match(st, 33i32) == 1i32) {
        lex_add_token(st, TK_QUESTION_BANG);
    } else {
        lex_add_token(st, TK_QUESTION);
    }
};

func:scan_dot = void(wild int8->:st) {
    if (lex_match(st, 46i32) == 1i32) {
        if (lex_match(st, 46i32) == 1i32) {
            lex_add_token(st, TK_DOT_DOT_DOT);
        } else {
            lex_add_token(st, TK_DOT_DOT);
        }
    } else {
        lex_add_token(st, TK_DOT);
    }
};

// ═══════════════════════════════════════════════════════════════════════
// Main token scanning dispatch (split to avoid ISel crash)
// ═══════════════════════════════════════════════════════════════════════

// Dispatch: single-char punctuation tokens
func:dispatch_punct = int32(wild int8->:st, int32:c) {
    if (c == 40i32) { lex_add_token(st, TK_LEFT_PAREN); }
    else if (c == 41i32) { lex_add_token(st, TK_RIGHT_PAREN); }
    else if (c == 123i32) { lex_add_token(st, TK_LEFT_BRACE); }
    else if (c == 125i32) { lex_add_token(st, TK_RIGHT_BRACE); }
    else if (c == 91i32) { lex_add_token(st, TK_LEFT_BRACKET); }
    else if (c == 93i32) { lex_add_token(st, TK_RIGHT_BRACKET); }
    else if (c == 59i32) { lex_add_token(st, TK_SEMICOLON); }
    else if (c == 44i32) { lex_add_token(st, TK_COMMA); }
    else if (c == 126i32) { lex_add_token(st, TK_TILDE); }
    else if (c == 94i32) { lex_add_token(st, TK_CARET); }
    else if (c == 58i32) { lex_add_token(st, TK_COLON); }
    else { pass 0i32; }
    pass 1i32;
};

// Dispatch: special starters (@cast, $, #, backtick, string, char)
func:dispatch_special = int32(wild int8->:st, int32:c) {
    if (c == 64i32) {
        int32:cast_r = is_at_cast(st);
        if (cast_r > 0i32) {
            scan_cast_keyword(st);
        } else {
            lex_add_token(st, TK_AT);
        }
    }
    else if (c == 36i32) { lex_add_token(st, TK_DOLLAR); }
    else if (c == 35i32) { lex_add_token(st, TK_HASH); }
    else if (c == 96i32) { scan_template_literal(st); }
    else if (c == 34i32) { scan_string(st); }
    else if (c == 39i32) { scan_char(st); }
    else { pass 0i32; }
    pass 1i32;
};

// Dispatch: multi-char operators
func:dispatch_ops = int32(wild int8->:st, int32:c) {
    if (c == 43i32) { scan_plus(st); }
    else if (c == 45i32) { scan_minus(st); }
    else if (c == 42i32) { scan_star(st); }
    else if (c == 47i32) { scan_fslash(st); }
    else if (c == 37i32) { scan_pct(st); }
    else if (c == 61i32) { scan_eq(st); }
    else if (c == 33i32) { scan_bang(st); }
    else if (c == 60i32) { scan_less(st); }
    else if (c == 62i32) { scan_greater(st); }
    else if (c == 38i32) { scan_amp(st); }
    else if (c == 124i32) { scan_bar(st); }
    else if (c == 63i32) { scan_question(st); }
    else if (c == 46i32) { scan_dot(st); }
    else { pass 0i32; }
    pass 1i32;
};

func:scan_one_token = void(wild int8->:st) {
    skip_whitespace(st);
    if (lex_at_end(st) == 1i32) { return; }

    lex_start_token(st);
    int32:c = lex_advance(st);

    int32:r1 = dispatch_punct(st, c);
    if (r1 == 1i32) { return; }
    int32:r2 = dispatch_special(st, c);
    if (r2 == 1i32) { return; }
    int32:r3 = dispatch_ops(st, c);
    if (r3 == 1i32) { return; }

    // Identifiers and keywords
    if (lex_is_alpha(c) == 1i32) { scan_identifier(st); return; }

    // Numbers
    if (lex_is_digit(c) == 1i32) { scan_number(st); return; }

    // Unknown character
    lex_error(st, "Unexpected character");
};

// ═══════════════════════════════════════════════════════════════════════
// Main tokenize function
// ═══════════════════════════════════════════════════════════════════════

pub func:tokenize = wild int8->(string:source) {
    wild int8->:st = lex_new(source);
    while (lex_at_end(st) == 0i32) {
        scan_one_token(st);
    }
    // Add EOF token
    lex_start_token(st);
    lex_add_token(st, TK_EOF);
    pass st;
};
