// ═══════════════════════════════════════════════════════════════════════
// Character classification helpers (extern C — avoids struct-return ABI issue)
// ═══════════════════════════════════════════════════════════════════════

extern func:lex_is_alpha = int32(int32:c);
extern func:lex_is_digit = int32(int32:c);
extern func:lex_is_alnum = int32(int32:c);
extern func:lex_is_hex = int32(int32:c);
extern func:lex_is_bin = int32(int32:c);
