// Test Vec<T> Phase 3 - Using library functions
// This tests the critical struct field mutation capability

// Import library (inline for now)
extern func:npk_array_new_simple = wild int8*(int64:element_size, int32:type_id);
extern func:npk_array_push_simple = void(wild int8*:arr, wild int8*:val);
extern func:npk_array_length = int64(wild int8*:arr);
extern func:npk_array_free = void(wild int8*:arr);

func:main = int32() {
    // Create Vec directly using runtime
    wild int8->:data = npk_array_new_simple(1i64, 0i32);
    int64:length = 0i64;
    
    // Push 3 values
    int8:v1 = 42i8;
    npk_array_push_simple(data, @v1);
    
    int8:v2 = 99i8;
    npk_array_push_simple(data, @v2);
    
    int8:v3 = 7i8;
    npk_array_push_simple(data, @v3);
    
    // THIS IS THE CRITICAL TEST: Can we update a variable from a function call?
    length = npk_array_length(data);
    
    if (length != 3i64) {
        exit 1i32;  // FAIL
    }
    
    npk_array_free(data);
    exit 0;  // SUCCESS
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};
