// Trait + impl + UFCS method dispatch test

trait:Describable = {
    func:describe = int32(int32:self);
};

impl:Describable:for:int32 = {
    func:describe = int32(int32:self) {
        pass self + 100;
    };
};

pub func:main = int32() {
    int32:x = 5;
    // UFCS: x.describe() should resolve to int32_describe(x)
    int32:result = raw x.describe();
    if (result == 105) {
        exit 0;
    }
    exit 1;
};

func:failsafe = int32(tbb32:err) { exit 1; };
