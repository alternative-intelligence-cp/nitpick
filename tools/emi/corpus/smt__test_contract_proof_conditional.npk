// Test: v0.14.0 — Contract proof with conditional branches
// Verifies that if/else branches are analyzed separately.

func:failsafe = int32(tbb32:err) {
    exit 1;
};

// Absolute value — both branches satisfy ensures $ >= 0
func:abs_val = int32(int32:x)
    requires x > -1000i32, x < 1000i32
    ensures $ >= 0i32
{
    if (x >= 0i32) {
        pass(x);
    } else {
        pass(0i32 - x);
    }
};

// Max of two values — ensures $ >= a, $ >= b
func:max2 = int32(int32:a, int32:b)
    requires a > -1000i32, a < 1000i32, b > -1000i32, b < 1000i32
    ensures $ >= a, $ >= b
{
    if (a >= b) {
        pass(a);
    } else {
        pass(b);
    }
};

// Clamp to non-negative — ensures $ >= 0
func:clamp_pos = int32(int32:x)
    requires x > -1000i32, x < 1000i32
    ensures $ >= 0i32
{
    if (x < 0i32) {
        pass(0i32);
    } else {
        pass(x);
    }
};

func:main = int32() {
    exit 0;
};
