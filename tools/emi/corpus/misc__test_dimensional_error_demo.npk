// P1-5 Phase 4: Error Detection Demo
// This file demonstrates dimensional analysis ERROR DETECTION
// It should FAIL to compile with a clear error message

func:main = int32() {
    // Attempting to add incompatible dimensions
    // Energy (Joules) + Distance (Meters) should ERROR!
    
    // Uncomment the following lines to see error:
    fix256<Joules>:energy;
    fix256<Meters>:distance;
    
    // This should produce: "Cannot add values with different dimensions"
    // fix256:invalid = energy + distance;
    
    return 0;
};

func:failsafe = int32(tbb32:err) {
    exit 1;
};
