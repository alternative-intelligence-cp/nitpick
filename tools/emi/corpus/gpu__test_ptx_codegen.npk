// GPU PTX Codegen Validation Test
// This test compiles to PTX and is validated by ptxas
// Self-contained: no runtime dependencies that would cause unresolved externs

func:main = int32() {
    int32:a = 10;
    int32:b = 20;
    int32:sum = a + b;
    exit 0;
};

func:failsafe = int32(tbb32:err) { exit 1; };
