// Minimal pick test with Result

func:get_value = int32(bool:should_succeed) {
    if (should_succeed) {
        pass 0i32;
    }
    fail 1i32;
};

func:main = int32() {
    Result<int32>:r = get_value(true);
    
    pick(r.is_error) {
        (false) {
            exit r.value;
        },
        (true) {
            exit 0;
        }
    }
};

func:failsafe = int32(tbb32:err) {
    // Error handling
    exit 1;
};
