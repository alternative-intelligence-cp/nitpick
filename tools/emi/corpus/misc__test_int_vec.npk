// Type:IntVec - Dynamic array of int32 values
// Demonstrates Type system with stateful operations and memory management

// External memory functions (would be in runtime)
func:failsafe = int32(tbb32:err) { exit 1; };

extern func:malloc = wild int8*(int64:size);
extern func:free = NIL(wild int8*:ptr);

// Pointer conversion helpers (needed for pointer field workaround)
extern func:ptr_to_int64 = int64(wild int8*:ptr);
extern func:int64_to_ptr = wild int8*(int64:val);

// Array element access helpers
extern func:int_array_get = int32(wild int8*:buf, int32:idx);
extern func:int_array_set = NIL(wild int8*:buf, int32:idx, int32:val);

Type:IntVec = {
    // Constructor: Create vector with initial capacity

    func:create = IntVec(int32:initial_capacity) {
        // Allocate memory for capacity int32s
        // Calculate bytes: initial_capacity * 4 (sizeof int32)
        int64:cap64 = 0i64;
        // TODO: Need actual cast or conversion from int32 to int64
        // For now using literal calculation
        int64:bytes = 64i64;  // Placeholder: should be cap * 4
        wild int8->:buffer = malloc(bytes);
        
        IntVec:vec = IntVec{
            dataptr: ptr_to_int64(buffer),
            length: 0i32,
            capacity: initial_capacity
        };
        pass vec;
    };
    
    // Destructor: Free vector memory
    func:destroy = NIL(IntVec:self) {
        _ = free(int64_to_ptr(self.dataptr));
        pass NIL;
    };
    
    // Accessor methods
    func:len = int32(IntVec:self) {
        pass self.length;
    };
    
    func:capacity = int32(IntVec:self) {
        pass self.capacity;
    };
    
    func:isEmpty = bool(IntVec:self) {
        bool:empty = (self.length == 0i32);
        pass empty;
    };
    
    // Get element at index (unsafe - no bounds checking yet)
    func:get = int32(IntVec:self, int32:index) {
        // Convert int64 back to pointer and use helper to get element
        wild int8->:buffer = int64_to_ptr(self.dataptr);
        int32:element = int_array_get(buffer, index);
        pass element;
    };
    
    // Set element at index (unsafe - no bounds checking yet)
    func:set = NIL(IntVec:self, int32:index, int32:value) {
        wild int8->:buffer = int64_to_ptr(self.dataptr);
        _ = int_array_set(buffer, index, value);
        pass NIL;
    };
    
    // Push element to end (simplified - no resize yet)
    func:push = NIL(IntVec:self, int32:value) {
        // Note: This modifies a copy of self, not the original
        // In real usage, would need mutable reference
        wild int8->:buffer = int64_to_ptr(self.dataptr);
        _ = int_array_set(buffer, self.length, value);
        // TODO: Need mutable self to update length
        pass NIL;
    };
    
    // Static factory methods
    func:new = IntVec() {
        IntVec:vec = raw instance<IntVec>(16i32);  // Default capacity 16
        pass vec;
    };
    
    func:withCapacity = IntVec(int32:cap) {
        IntVec:vec = raw instance<IntVec>(cap);
        pass vec;
    };
    
    // Public interface - store pointer as int64 (workaround for pointer field limitation)
    struct:interface = {
        int64:dataptr;         // Raw byte buffer (stored as int64)
        int32:length;          // Current number of elements
        int32:capacity;        // Total allocated capacity
    };
};

// Example usage and testing
func:main = int32() {
    // Create vector with capacity 10
    IntVec:vec = raw instance<IntVec>(10i32);
    
    // Check initial state using UFCS
    int32:len = raw vec.len();          // → IntVec_len(vec)
    int32:cap = raw vec.capacity();     // → IntVec_capacity(vec)
    bool:empty = raw vec.isEmpty();     // → IntVec_isEmpty(vec)
    
    // Test array access methods
    _ = vec.set(0i32, 42i32);       // vec[0] = 42
    _ = vec.set(1i32, 100i32);      // vec[1] = 100
    _ = vec.set(2i32, 255i32);      // vec[2] = 255
    
    int32:first = raw vec.get(0i32);    // Get vec[0] → should be 42
    int32:second = raw vec.get(1i32);   // Get vec[1] → should be 100
    int32:third = raw vec.get(2i32);    // Get vec[2] → should be 255
    
    // Static factory methods
    IntVec:vecDefault = raw IntVec.new();              // → IntVec_new()
    IntVec:vecLarge = raw IntVec.withCapacity(100i32);  // → IntVec_withCapacity(100)
    
    // Clean up
    _ = vec.destroy();
    _ = vecDefault.destroy();
    _ = vecLarge.destroy();
    
    exit 0;  // Success!
};
