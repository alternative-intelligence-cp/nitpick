// Test comptime blocks and expressions (v0.8.3)
// Verifies comptime still works with the new macro infrastructure

pub func:main = int32() {
    // Comptime expression with i32 type
    int32:val = comptime(3i32 + 4i32);
    
    // Should be 7
    if (val == 7) {
        exit 0;
    }
    exit 1;
};

func:failsafe = int32(tbb32:err) { exit 1; };
