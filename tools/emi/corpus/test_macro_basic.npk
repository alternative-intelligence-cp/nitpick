// Test basic macro declaration and invocation (v0.8.3)

// Simple expression macro
macro:double_it = (x) {
    x + x;
};

pub func:main = int32() {
    int32:a = 5i32;
    int32:result = double_it!(a);
    // 5 + 5 = 10
    if (result == 10) {
        exit 0;
    }
    exit 1;
};

func:failsafe = int32(tbb32:err) { exit 1; };
