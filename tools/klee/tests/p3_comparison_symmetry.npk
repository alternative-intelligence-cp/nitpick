// Phase 3: Comparison symmetry — verifies that comparison operators
// are consistent (if a > b then NOT b > a, etc.)

extern func:klee_make_symbolic = void(wild ?*:addr, int64:nbytes, int64:name_ptr);

func:main = int32() {
    int32:a = 0;
    int32:b = 0;
    drop klee_make_symbolic(@a, 4, 0);
    drop klee_make_symbolic(@b, 4, 0);

    // Antisymmetry: if a > b then b < a
    if (a > b) {
        if (b >= a) { exit 1; }
    }

    // Totality: exactly one of {a < b, a == b, a > b} holds
    int32:lt = 0;
    int32:eq = 0;
    int32:gt = 0;
    if (a < b) { lt = 1; }
    if (a == b) { eq = 1; }
    if (a > b) { gt = 1; }

    int32:sum = lt + eq + gt;
    int32:one = 1;
    if (sum != one) { exit 2; }

    // Transitivity: if a <= b and b <= a, then a == b
    if (a <= b) {
        if (b <= a) {
            if (a != b) { exit 3; }
        }
    }

    exit 0;
};

func:failsafe = int32(tbb32:err) {
    exit 99;
};
