// Phase 3: TBB overflow propagation — verify that overflow tagging
// is consistent and that tbb32 error values propagate correctly.
//
// Aria's TBB (Tagged Binary Box) system uses i8 tag on all values.
// When integer overflow occurs, tbb is set to ERR. We verify that
// the downstream use of an overflowed value correctly tags further ops.

extern func:klee_make_symbolic = void(wild ?*:addr, int64:nbytes, int64:name_ptr);

func:main = int32() {
    int32:a = 0;
    int32:b = 0;
    drop klee_make_symbolic(@a, 4, 0);
    drop klee_make_symbolic(@b, 4, 0);

    // Constrain to values near i32 max to trigger overflow
    // 0x7FFFFF00 = 2147483392
    int32:near_max = 2147483392;
    int32:threshold = 128;

    // If both a and b are large positive, addition might overflow
    // KLEE will explore both overflow and non-overflow paths

    int32:sum = a + b;

    // Non-overflow safety: if neither operand is near max, sum >= a and sum >= b
    int32:half_max = 1073741823;
    if (a < half_max) {
        if (b < half_max) {
            if (sum < a) { exit 1; }  // Unexpected: should not underflow
        }
    }

    exit 0;
};

func:failsafe = int32(tbb32:err) {
    exit 99;
};
